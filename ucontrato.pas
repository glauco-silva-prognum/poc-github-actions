procedure TSerieFinanciamentoDinamico.ObtemPendCalcValorCorrMoraUPF(    DtIni,
                                                                        DtFim       : Tdata;
                                                                        Com200      : Boolean;
                                                                    var ValorT,
                                                                        MoraT       : Real;
                                                                    var UltDtPg     : TData;
                                                                        DtCorr      : TData;
                                                                        SemLiminar  : boolean;
                                                                        DataEmi     : TData;
                                                                        Dados       : TDadosAcertoEvo;
                                                                        Grava       : boolean;
                                                                        CarregaPagamentosSemDiferenca : boolean;
                                                                        IgnoraTipoDePagamento : boolean);
var
  RegParcAcPaga  : TpRegParcAcPaga;
  RegPrst        : TpArqPrst;
  ValIof,
  ValIOFComplem,
  IndCorr,
  ValIofAmaisj,
  ValPrstParcial,
  CorrAmaisJParcial,
  MoraAmaisJParcial,
  MultaAmaisjParcial,
  ValPrest,
  VMoeda,
  VMoedaVenc,
  ValPg,
  DifRPA,
  PendEmi,  Corr,
  Mora,Pend,Multa,
  MoraP, MultaP  : real;
  TipoPg         : byte;
  DtCalculo,
  DataPg         : TData;
  i,j,MaProc     : SmallInt;
  DtPrest        : TData;
  PercDescHonorarios,
  PercHonorarios,
  ValorHonorarios,
  ValPrst        : real;
{$IFDEF XE}
  MsgErro        : string;
{$ELSE}
  MsgErro        : shortstring;
{$ENDIF}
  MacIni,
  MacFim         : smallint;
  MacUltPag      : integer;
  Reg            : TValoresPorMac;
  RPendEmi       : TpPendEmi;
  Item : TItemAcertoEvo;
  UF : str3;
  CodMun : smallint;
  TpMora,
  TMoraAux : byte;
  JC : real;
  DataValidadeTit : TData;
begin
  RegParcAcPaga.ValPg := 0;
  fillchar( RegParcAcPaga,sizeof( RegParcAcPaga),0);
  RegPrst.AmaisJ := 0;
  fillchar(RegPrst,sizeof(RegPrst),0);
  ValPG := 0;
  MaProc := 0;
  JC := 0;
  Mora := 0;
  Multa := 0;
  DifRPA := 0;
  MsgErro := '';
  ValorHonorarios := 0;
  PercDescHonorarios := 0; 
  PercHonorarios := 0;
  ValIOFComplem  := 0;
  TipoPg := 0;
  DataValidadeTit.dia := 0; DataValidadeTit.mes := 0; DataValidadeTit.ano := 0;
  DataPG.dia := 0;  DataPG.mes := 0;  DataPG.ano := 0;
  UF := '';
  CodMun := 0;
  Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
  MacIni := Mes_int(DtIni.MesAno);
  MacFim := Mes_int(DtFim.MesAno);
  fillchar(UltDtPg,sizeof(TData),0);
  ValorT := 0; MoraT := 0; Corr := 0;
  if MacIni < Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1 then
    MacIni := Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1;
  if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);

  MacUltPag := 0;
  for i:= MacFim downto MacIni do
    if PrstPagaPend(DataH,i,IgnoraTipoDePagamento) then begin
      MacUltPag := i;
      Break;
    end;

  i := mes_int(Contrato.MutDsk.Financ.DtAssin.MesAno);
  while (i <= MACFim) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if Reg.CtrAtivo or ((MacUltPag > 0) and (i <= MacUltpag)) then begin
        if (i >= MACIni) and (i <= MACFim) then begin
          if PrstPagaPend(DataH,i,IgnoraTipoDePagamento) then begin
            MutPgValorDataN(i,ValPg,DataPg,TipoPg,MaProc,ValorHonorarios,
                            PercDescHonorarios,PercHonorarios,DataValidadeTit,
                            ValIOFComplem);
            DtPrest.Dia := Dia_Venc(i,Contrato.MutDsk.Financ.DtInFin.Dia);
            Int_mes(i,DtPrest.MesAno);
            if TipoPg in [200,253] then DataPg := DtPrest; { Nao Foi Paga, so Emitida }

            if ( (Com200 and 
                ((DataValidadeTit.Dia = 0) or 
                  DataEMenorOuIgual(DataH,DataValidadeTit))) or //se o titulo ainda   v lido
                 (not (TipoPg in [200,253]))) and
               (DataPg.Dia <> 99) and
               (Juliano(DataPg) >= Juliano(Contrato.MutDsk.Financ.DtAssin)) and
                DataValida(DataPg) and
               (Juliano(DataPg) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
               (not (TipoPg in NotGerPend) or
                (IgnoraTipoDePagamento and not (TipoPg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253])) or
                CarregaPagamentosSemDiferenca) then begin { Se Considera 200 ou nao (nao foi paga,so emitida) }
              UltDtPg := DataPg;
              if Scciconf.IncluiParcAcPagaNoAcertoFin then
                RetornaCtrParcAcPaga(Contrato.MutDsk.Cad.Ctr,i,RegParcAcPaga,MsgErro)
              else
                fillchar(RegParcAcPaga,sizeof(TpRegParcAcPaga),0);
              ValPg   := ValPg + RegParcAcPaga.ValPg;
              if assigned(Contrato) then
                PendEmi := Contrato.Pendencias.ValorPendEmi(Mes_Int(DtPrest.MesAno),0)
              else
                PendEmi := 0;
              ValIofAmaisj:= 0;
              ValPrstParcial := 0;
              CorrAmaisJParcial  := 0;
              MoraAmaisJParcial  := 0;
              MultaAmaisJParcial := 0;
              ValIof      := 0;
              if assigned(Contrato.SerieF.PagamentosParciais) and 
                (Contrato.SerieF.PagamentosParciais.Count > 0) then begin
                for j := 0 to Contrato.SerieF.PagamentosParciais.Count-1 do
                  if (Contrato.SerieF.PagamentosParciais[j].MAC = i) and
                     (Contrato.SerieF.PagamentosParciais[j].TipoPgParcial in PgtoParcial) and
                     (Juliano(Contrato.SerieF.PagamentosParciais[j].DtPg) < 
                      Juliano(DataPg)) then begin
                    if (Contrato.SerieF.PagamentosParciais[j].DataRefCalc.Dia > 0) and
                       (juliano(Contrato.SerieF.PagamentosParciais[j].DataRefCalc) < juliano(DataPg)) and
                       (Juliano(Contrato.SerieF.PagamentosParciais[j].DtPg) < juliano(Contrato.SerieF.PagamentosParciais[j].DataRefCalc)) then 
                      DtCalculo := Contrato.SerieF.PagamentosParciais[j].DataRefCalc
                    else
                      DtCalculo := Contrato.SerieF.PagamentosParciais[j].DtPg;

                    ValPrstParcial := ValPrstParcial + Contrato.ValDevDtPg0(DtPrest,DtCalculo,
                                                                  {Contrato.SerieF.PagamentosParciais[j].DtPg,}
                                                                  Contrato.SerieF.PagamentosParciais[j].TipoPgParcial,
                                                                  RegPrst,
                                                                  RegParcAcPaga,0{PendEmi},Corr,Mora,Multa,DifRPA,ValIof,
                                                                  SemLiminar,Reg.CodTabGCorr,
                                                                  Reg.CodTabGPreChvCorr,
                                                                  Contrato.RegCarteira.NaoCobraJurosContr,
                                                                  Reg.TipoDesc,{Estava zero fixo }
                                                                  false{ComDesc},0{PercDescMora},
                                                                  0{PercDescCorr},0{PercDescMulta},
                                                                  0{PercDescJRem},0{Desconto},
                                                                  nil{Contrato.SerieF.PagamentosParciais},
                                                                  Contrato.SerieF.PagamentosParciais[j]);
                    CorrAmaisJParcial     := CorrAmaisJParcial + Corr;
                    MoraAmaisJParcial     := MoraAmaisJParcial + Mora;
                    MultaAmaisJParcial    := MultaAmaisJParcial + Multa;
                    ValIofAmaisj   := ValIofAmaisj+ValIof;
                  end;
              end;
              if (Abs(ValIOFComplem-ValIofAmaisJ) > zero) and
                 (ValIofAmaisJ > zero) and 
                 (ValIOFComplem-ValIofAmaisJ < zero) then
                ValIOFAmaisJ := 0;

              Corr := 0;
              Mora := 0;
              Multa:= 0;
              ValIof:= 0;
              ValPrst := Contrato.ValDevDtPg0(DtPrest,DataPg,TipoPg,RegPrst,
                                              RegParcAcPaga,PendEmi,Corr,Mora,Multa,
                                              DifRPA,ValIof,
                                              SemLiminar,Reg.CodTabGCorr,
                                              Reg.CodTabGPreChvCorr,
                                              Contrato.RegCarteira.NaoCobraJurosContr,
                                              Reg.TipoDesc, {estava zero fixo }
                                              false{ComDesc},0{PercDescMora},
                                              0{PercDescCorr},0{PercDescMulta},
                                              0{PercDescJRem},0{Desconto},
                                              Contrato.SerieF.PagamentosParciais);

              if (Abs(ValorHonorarios) > Zero) and (PercHonorarios > Zero) then begin
                ValorHonorarios := arredonda(ValPrst *(PercHonorarios/100));
                if PercDescHonorarios > Zero then
                  ValorHonorarios := Arredonda(ValorHonorarios - (ValorHonorarios * PercDescHonorarios/100));
              end;
              ValPrst := ValPrst + ValPrstParcial + ValorHonorarios + (ValIOFComplem-ValIofAmaisj);
              if (Juliano(DtPrest) >= Juliano(DtIni)) and
                 (Juliano(DtPrest) <= Juliano(DtFim)) then begin
                Pend    := ValPrst - ValPg;
{ sol. 46012
                VMoeda  := LE_UPFD(DataPg);
                if VMoeda <= Zero then VMoeda := LE_VRF(mes_int(DataPg.Mesano));
}
                VMoeda  := LE_UPFD(DtPrest);
                if VMoeda <= Zero then VMoeda := LE_VRF(mes_int(DtPrest.Mesano));            
                AjMoedaComPrecisao(Mes_Int(DtPrest.MesAno),Mes_Int(DataPg.MesAno),VMoeda);
                if VMoeda <= Zero then VMoeda := 1.0;
                VMoedaVenc := VMoeda;
                ValPrest := ValPrst - Corr - Mora - Multa - ValorHonorarios;
                if ValPrest > Zero then 
                  IndCorr := 1 + Corr/ValPrest
                else
                  IndCorr := 1.0;
                VMoeda := VMoeda * IndCorr;
                Pend    := Pend/VMoeda;
                if Scciconf.CobraMoraDif then
                  MoraP := MoraRef(DataPg,DtCorr,UF,CodMun,0,Pend,Contrato.RegCarteira.NaoCobraJurosContr)
                else
                  MoraP := 0;
                if (MoraP <= Zero) and (not ScciConf.CobraMoraDifADev) then
                  MoraP := 0;
                if Scciconf.MultaContrEmEncRemuneratoriosNoAcFin and (Abs(MoraP) > Zero) then begin
                  if (Reg.TMora in [38..40]) then
                    MultaP := ValorMulta(DataPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
                  else
                    MultaP := ValorMulta(DataPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta);
                end
                else
                  MultaP := 0;
                ValorT := ValorT + Pend;
                MoraT  := MoraT  + MoraP + MultaP;
                if Abs(ValorT*VMoeda) < 0.01 then begin
                  ValorT := 0;
                  MoraT  := 0;
                end;
                if (abs(ValPrst - ValPg) > zero) or CarregaPagamentosSemDiferenca then begin
                  if assigned(Dados) then begin
                    Item := TItemAcertoEvo.create;
                    Item.DtVenc := DtPrest;
                    Item.DtPag := DataPg;
                    Item.DifAtu := Pend;
                    Item.Mora := MoraP+MultaP;
                    Item.CodSerie := 0;
                    Item.VMoeda := VMoeda;
                    Item.VMoedaVenc := VMoedaVenc;
                    Item.CorrPrest := Corr + CorrAmaisJParcial;
                    Item.MoraPrest := Mora + MoraAmaisJParcial;
                    Item.Multa     := Multa+ MultaAmaisJParcial;
                    Item.Prstatu := ValPrst;
                    Item.PrstAnt := Valpg;
                    Item.Honorarios := ValorHonorarios;
                    Item.ValIOFComplem := ValIOFComplem-ValIofAmaisJ;
                    
                    // Detalhes do rel2821c
                    Item.ValPrest := RegPrst.AmaisJ + RegPrst.Seguro + RegPrst.Fcvs +
                                     RegPrst.ValTxAdm - RegPrst.FGTS - RegPrst.Desc +
                                     RegParcAcPaga.ValEmi;
                    Item.FGTS := RegPrst.FGTS;
                    if (valint(ScciConf.NSerie) in [NsLetra,NsSulbras]) and
                       ((TipoPg = 200) or (DiasDeAtrasoEntreDatas(DtPrest,DataPg) > 0)) then
                      Item.ValPrest := Item.ValPrest + RegPrst.Desc;
                    if (TipoPg > 100) and (TipoPg < 199) then
                      TpMora := TipoPg - 100
                    else if TipoPg < 100 then
                      TpMora := Reg.TMora
                    else
                      TpMora := TipoPg;
                    Item.ValPrest := Item.ValPrest + PendEmi + DifRPA; { Incorpora-se as Pend.Emit. na Prest. }
                    if (TpMora <> 0) and (Item.ValPrest > Zero) and
                       (not PendCobraTMoraVigenteNoPeriodo) then
                      Item.PercMPrest:=int(Mora/Item.ValPrest*100+0.5)
                    else if (TpMora <> 100) and (TpMora <> 199) then begin
                      if PendCobraTMoraVigenteNoPeriodo then
                        TMoraAux := RetornaTMoraPorPeriodo(DataPg,TpMora)
                      else
                        TMoraAux := TpMora;
                      Item.PercMPrest := PerMora(DtPrest, DataPg, Reg.IndJuros,
                                                 TMoraAux,Contrato.MutDsk.Financ.DtAssin,
                                                 JC,Contrato.RegCarteira.NaoCobraJurosContr);
                    end;
                    AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DataPg.MesAno),Item.ValPrest);
                    AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DataPg.MesAno),Item.FGTS);
                    if MoraP > zero then
                      Item.PercM := PerMora(DataPg, DtCorr, 0,Reg.TMora,
                                            Contrato.MutDsk.Financ.DtAssin,JC,
                                            Contrato.RegCarteira.NaoCobraJurosContr);
                    Item.AmortNegMes := Reg.AmortNegMes;
                    Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                    Item.CorrSaldoAmortNeg := Reg.CorrSaldoAmortNeg;
                    Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                    Dados.add(Item);
                  end;
                  if Grava then begin
                    RPendEmi.Ctr := '';
                    fillchar(RPendEmi,sizeof(TpPendEmi),0);
                    with RPendEmi do begin
                      Ctr            := Contrato.MutDsk.Cad.Ctr;
                      if Com200 then TpEmissao := 1
                      else TpEmissao := 2;
                      DtEmi          := DataEmi;
                      MAC            := Mes_int(DtPrest.MesAno);
                      ValDevido      := ValPrst;
                      ValPago        := ValPg;
                      DifAtual       := Pend;
                      Atualizacao    := MoraP + MultaP;
                      DtVenc         := DtPrest;
                      DtPag          := DataPg;
                      Moeda          := 1;
                      Parcela        := Mes_int(DtPrest.MesAno) - Mes_Int(Contrato.MutDsk.Financ.DtInfin.MesAno);
                    end;
                    GravaPendEmi(RPendEmi);
                  end;
                end;
              end;
            end;
          end;
        end;
      end
      else
        break;
    end;
    inc(i);
  end;
end;

procedure TSerieFinanciamentoDinamico.ObtemPendCalcValorCorrMora(    DtIni,
                                                                     DtFim       : Tdata;
                                                                     DtCorr      : TData;
                                                                     Com200      : Boolean;
                                                                 var ValorT,
                                                                     CorrT,
                                                                     MoraT       : Real;
                                                                     SemLiminar  : boolean;
                                                                     DataEmi     : TData;
                                                                     Dados       : TDadosAcertoEvo;
                                                                     Grava       : boolean;
                                                                     UtilizaJMora,
                                                                     UtilizaJCont : boolean;
                                                                     TipoJur : integer;
                                                                     CarregaPagamentosSemDiferenca : boolean);
var
  RegParcAcPaga  : TpRegParcAcPaga;
  RegPrst        : TpArqPrst;
  ValPg,
  DifRPA,
  PendEmi,Corr,
  Mora,Pend,Multa,
  ValIof,
  ValIofAmaisj,
  CorrAmaisJParcial,
  MoraAmaisJParcial,
  MultaAmaisJParcial,
  CorrP,MoraP    : real;
  TipoPg         : byte;
  DataPg         : TData;
  i,j, MaProc    : SmallInt;
  DtCalculo,
  DtPrest        : TData;
  ValIOFComplem,
  ValorHonorarios,
  PercDescHonorarios,
  PercHonorarios,
  ValPrstParcial,
  ValPrst        : real;
{$IFDEF XE}
  MsgErro        : string;
{$ELSE}
  MsgErro        : shortstring;
{$ENDIF}
  CodTabelaGenerica : longint;
  MacIni,
  MacFim         : smallint;
  MacUltPag      : integer;
  Reg : TValoresPorMac;
  Item : TItemAcertoEvo;
  DtIsenMora : Tdata;
  UF : str3;
  CodMun : smallint;
  Defasagem : byte;
  DataValidadeTit : TData;
  SalvaNaoCorrigeAts : boolean;
begin
  SalvaNaoCorrigeAts := ScciConf.NaoCorrigeAts;
  RegParcAcPaga.ValPg := 0;
  fillchar( RegParcAcPaga,sizeof( RegParcAcPaga),0);
  RegPrst.AmaisJ := 0;
  fillchar(RegPrst,sizeof(RegPrst),0);
  Mora := 0;
  Corr := 0;
  Multa := 0;
  DifRPA := 0;
  Defasagem := 0;
  ValPg := 0;
  MsgErro := '';
  TipoPg := 0;
  MaProc := 0;
  ValIOFComplem   := 0;
  ValorHonorarios := 0;
  PercDescHonorarios := 0;
  PercHonorarios := 0;
  DataValidadeTit.dia := 0; DataValidadeTit.mes := 0; DataValidadeTit.ano := 0;
  DataPG.dia := 0;  DataPG.mes := 0;  DataPG.ano := 0;
  UF := '';
  CodMun := 0;
  DtIsenMora.Dia := 0; DtIsenMora.Mes := 0; DtIsenMora.ano := 0;
  Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
  MacIni := Mes_int(DtIni.MesAno);
  MacFim := Mes_int(DtFim.MesAno);
  ValorT := 0; CorrT := 0; MoraT := 0; MoraP := 0;

  if MacIni < Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1 then
    MacIni := Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1;
  if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);

  MacUltPag := 0;
  for i:= MacFim downto MacIni do
    if PrstPagaPend(DataH,i) then begin
      MacUltPag := i;
      Break;
    end;

  i := mes_int(Contrato.MutDsk.Financ.DtAssin.MesAno);
  while (i <= MACFim) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if Reg.CtrAtivo or ((MacUltPag > 0) and (i <= MacUltpag)) then begin
        if (i >= MACIni) and (i <= MACFim) then begin
          if PrstPagaPend(DataH,i) then begin
            MutPgValorDataN(i,ValPg,DataPg,TipoPg,MaProc,ValorHonorarios,
                            PercDescHonorarios,PercHonorarios,DataValidadeTit,
                            ValIOFComplem);
            if ((Com200 and
               ((DataValidadeTit.Dia = 0) or 
                 DataEMenorOuIgual(DataH,DataValidadeTit))) or //se o titulo ainda   v lido
               (not (TipoPg in [200,253]))) and
               (DataPg.Dia <> 99) and
               (Juliano(DataPg) >= Juliano(Contrato.MutDsk.Financ.DtAssin)) and
               DataValida(DataPg) and
               (Juliano(DataPg) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
               (not (TipoPg in NotGerPend) or CarregaPagamentosSemDiferenca) then begin { Se Considera 200 ou nao (nao foi paga,so emitida) }
              DtPrest.Dia := Dia_Venc(i,Contrato.MutDsk.Financ.DiaVenc);
              Int_mes(i,DtPrest.MesAno);
              if TipoPg in [200,253] then DataPg := DtPrest; { Nao Foi Paga, so Emitida }
              if Scciconf.IncluiParcAcPagaNoAcertoFin then
                RetornaCtrParcAcPaga(Contrato.MutDsk.Cad.Ctr,i,RegParcAcPaga,MsgErro)
              else
                fillchar(RegParcAcPaga,sizeof(TpRegParcAcPaga),0);
              ValPg   := ValPg + RegParcAcPaga.ValPg;
              if assigned(Contrato) then
                PendEmi := Contrato.Pendencias.ValorPendEmi(Mes_Int(DtPrest.MesAno),0)
              else
                PendEmi := 0;
              ValIof      := 0;
              ValIofAmaisj:= 0;
              ValPrstParcial   := 0;
              CorrAmaisJParcial  := 0;
              MoraAmaisJParcial  := 0;
              MultaAmaisJParcial := 0;
              if assigned(Contrato.SerieF.PagamentosParciais) and 
                (Contrato.SerieF.PagamentosParciais.Count > 0) then begin
                for j := 0 to Contrato.SerieF.PagamentosParciais.Count-1 do
                  if (Contrato.SerieF.PagamentosParciais[j].MAC = i) and
                     (Contrato.SerieF.PagamentosParciais[j].TipoPgParcial in PgtoParcial) and
                     (Juliano(Contrato.SerieF.PagamentosParciais[j].DtPg) < 
                      Juliano(DataPg)) then begin
                    if (Contrato.SerieF.PagamentosParciais[j].DataRefCalc.Dia > 0) and
                       (juliano(Contrato.SerieF.PagamentosParciais[j].DataRefCalc) < juliano(DataPg)) and
                       (Juliano(Contrato.SerieF.PagamentosParciais[j].DtPg) < juliano(Contrato.SerieF.PagamentosParciais[j].DataRefCalc)) then 
                      DtCalculo := Contrato.SerieF.PagamentosParciais[j].DataRefCalc
                    else
                      DtCalculo := Contrato.SerieF.PagamentosParciais[j].DtPg;
                    ValPrstParcial := ValPrstParcial + Contrato.ValDevDtPg0(DtPrest,DtCalculo,
                                                                  {Contrato.SerieF.PagamentosParciais[j].DtPg,}
                                                                  Contrato.SerieF.PagamentosParciais[j].TipoPgParcial,
                                                                  RegPrst,
                                                                  RegParcAcPaga,0{PendEmi},
                                                                  Corr,Mora,Multa,DifRPA,ValIof,
                                                                  SemLiminar,Reg.CodTabGCorr,
                                                                  Reg.CodTabGPreChvCorr,
                                                                  Contrato.RegCarteira.NaoCobraJurosContr,
                                                                  Reg.TipoDesc, {TipoDesc estava indo zerado }
                                                                  false{ComDesc},0{PercDescMora},
                                                                  0{PercDescCorr},0{PercDescMulta},
                                                                  0{PercDescJRem},0{Desconto},
                                                                  nil{Contrato.SerieF.PagamentosParciais},
                                                                  Contrato.SerieF.PagamentosParciais[j]);

                                                                                           
                    CorrAmaisJParcial     := CorrAmaisJParcial + Corr;
                    MoraAmaisJParcial     := MoraAmaisJParcial + Mora;
                    MultaAmaisJParcial    := MultaAmaisJParcial+ Multa;
                    ValIofAmaisJ   := ValIofAmaisJ + ValIof;
                  end;
              end;
              Corr := 0;
              Mora := 0;
              Multa:= 0;
              ValIof:= 0;
              if (Abs(ValIOFComplem-ValIofAmaisJ) > zero) and
                 (ValIofAmaisJ > zero) and 
                 (ValIOFComplem-ValIofAmaisJ < zero) then
                ValIofAmaisJ := 0;

              ValPrst := Contrato.ValDevDtPg0(DtPrest,DataPg,TipoPg,RegPrst,
                                              RegParcAcPaga,PendEmi,Corr,Mora,Multa,
                                              DifRPA,ValIof,
                                              SemLiminar,Reg.CodTabGCorr,
                                              Reg.CodTabGPreChvCorr,
                                              Contrato.RegCarteira.NaoCobraJurosContr,
                                              Reg.TipoDesc,
                                              false{ComDesc},0{PercDescMora},
                                              0{PercDescCorr},0{PercDescMulta},
                                              0{PercDescJRem},0{Desconto},
                                              Contrato.SerieF.PagamentosParciais);

              if (Abs(ValorHonorarios) > Zero) and (PercHonorarios > Zero) then begin
                ValorHonorarios := arredonda(ValPrst *(PercHonorarios/100));
                if PercDescHonorarios > Zero then
                  ValorHonorarios := Arredonda(ValorHonorarios - (ValorHonorarios * PercDescHonorarios/100));
              end;
              ValPrst := ValPrst + ValPrstParcial + ValorHonorarios + (ValIOFComplem-ValIofAmaisJ);
              if (Juliano(DtPrest) >= Juliano(DtIni)) and
                 (Juliano(DtPrest) <= Juliano(DtFim)) then begin
                Pend := ValPrst - ValPg;
                CodTabelaGenerica := DefineCodTabelaGenericaPorChaves( Contrato.MutDsk.Cad.DtEntregaChaves,
                                                                       Reg.CodTabGPreChvCorr,
                                                                       Reg.CodTabGCorr,
                                                                       Reg.DefReajPreChvCorr,
                                                                       Reg.DefReajCorr,
                                                                       DataPg,
                                                                       Defasagem);
               if ScciConf.NaoCorrigeAts then begin
                CorrP := 0;
                if juliano(DataPg) >= juliano(DtPrest) then
                  AjustaMoeda2(Mes_Int(DataPg.MesAno),Mes_Int(DtCorr.MesAno),Pend)
                else
                  AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DtCorr.MesAno),Pend);
               end
               else begin
                if juliano(DataPg) >= juliano(DtPrest) then begin
                  CorrP := CorrPendComDefasagem(Contrato.MutDsk,UF,CodMun,
                                                DataPg,DtCorr,Pend,MoraP,
                                                CodTabelaGenerica,Defasagem);
                  AjustaMoeda2(Mes_Int(DataPg.MesAno),Mes_Int(DtCorr.MesAno),Pend);
                end
                else begin
                  AjustaMoeda2(Mes_Int(DataPg.MesAno),Mes_Int(DtPrest.MesAno),Pend);
                  CorrP := CorrPendComDefasagem(Contrato.MutDsk,UF,CodMun,
                                                DtPrest,DtCorr,Pend,MoraP,
                                                CodTabelaGenerica,Defasagem);
                  AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DtCorr.MesAno),Pend);
                end;
               end;

                if SCCIConf.CobraMoraDif then begin
                  if ((ValPrst - ValPg) > ZERO) or ScciConf.CobraMoraDifADev then begin
                    if not UtilizaJMora  then MoraP := 0.0;
                    if UtilizaJCont then begin
                      if Not SCCICONF.PedeTipoJurAcertoFin then
                        MoraP := MoraP + CalcJurosContratuais(Contrato.MutDSK.Financ.TxJuros,DataPg,DtCorr,(Pend + CorrP) )
                      else MoraP := MoraP + CalcJurosEspeciais(TipoJur,Contrato.MutDSK.Financ.TxJuros,DataPg,DtCorr,(Pend + CorrP) );
                    end;
                  end;
                end;

                if (abs(ValPrst - ValPg) > zero) or CarregaPagamentosSemDiferenca then begin
                  if assigned(Dados) then begin
                    Item := TItemAcertoEvo.create;
                    Item.DtVenc := DtPrest;
                    Item.DtPag := DataPg;
                    Item.PrstAnt := ValPg;
                    Item.PrstAtu := ValPrst;
                    Item.Multa     := Multa+MultaAmaisJParcial;
                    Item.Honorarios:= ValorHonorarios;
                    Item.ValIOFComplem := ValIOFComplem-ValIofAmaisJ;
                    Item.CorrPrest := Corr +CorrAmaisJParcial;
                    Item.MoraPrest := Mora +MoraAmaisJParcial;
                    Item.ValPrest := RegPrst.AmaisJ + RegPrst.Seguro + RegPrst.Fcvs +
                                     RegPrst.ValTxAdm - RegPrst.FGTS - RegPrst.Desc +
                                     RegParcAcPaga.ValEmi;
                    if (valint(ScciConf.NSerie) in [NsLetra,NsSulbras]) and
                       ((TipoPg = 200) or (Contrato.DiasDeAtrasoEntreDatas(DtPrest,DataPg) > 0)) then
                      Item.ValPrest := Item.ValPrest + RegPrst.Desc;
                    Item.ValPrest := Item.ValPrest + PendEmi + DifRPA; { Incorpora-se as Pend.Emit. na Prest. }
                    Item.ValPrestOri := Item.ValPrest;
                    AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DataPg.MesAno),Item.ValPrest);
                    DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,Item.DtVenc,DtIsenMora,Contrato.Mutdsk.Cad.DiaIsencao);
                    Item.Dif := Item.PrstAtu - Item.PrstAnt;
                    Item.DifAtu := Pend;
                    Item.Mora := MoraP;
                    Item.Corr := CorrP;
                    Item.CodSerie := 0;
                    Item.AmortNegMes := Reg.AmortNegMes;
                    Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                    Item.CorrSaldoAmortNeg := Reg.CorrSaldoAMortNeg;
                    Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                    Dados.add(Item);
                  end;
                  if Grava then begin
                    fillchar(RPendEmi,sizeof(TpPendEmi),0);
                    with RPendEmi do begin
                      Ctr            := Contrato.MutDsk.Cad.Ctr;
                      if Com200 then TpEmissao := 1
                      else TpEmissao := 2;
                      DtEmi          := DataEmi;
                      MAC            := Mes_int(DtPrest.MesAno);
                      ValDevido      := ValPrst;
                      ValPago        := ValPg;
                      DifAtual       := Pend;
                      Atualizacao    := CorrP + MoraP;
                      DtVenc         := DtPrest;
                      DtPag          := DataPg;
                      Parcela        := Mes_int(DtPrest.MesAno) - Mes_Int(Contrato.MutDsk.Financ.DtInfin.MesAno);
                    end;
                    GravaPendEmi(RPendEmi);
                  end;
                end;
              end
              else begin
                Pend := 0; CorrP := 0; MoraP := 0;
              end;
            end
            else begin
              Pend := 0; CorrP := 0; MoraP := 0;
            end;
            ValorT := ValorT + Pend;
            CorrT  := CorrT + CorrP;
            MoraT  := MoraT + MoraP;
          end;
          ScciConf.NaoCorrigeAts := SalvaNaoCorrigeAts;
        end;
      end
      else
        break;
    end;
    inc(i);
  end;
  if Abs(ValorT) > Zero then begin
    if ValorT > Zero then
      ValorT :=  int(    ValorT * 100.0+0.5) / 100.0
    else
      ValorT := -int(Abs(ValorT)* 100.0+0.5) / 100.0;
  end;
  if Abs(CorrT) > Zero then begin
    if CorrT > Zero then
      CorrT  :=  int(    CorrT * 100.0+0.5) / 100.0
    else
      CorrT  := -int(Abs(CorrT)* 100.0+0.5) / 100.0;
  end;
  if Abs(MoraT) > Zero then begin
    if MoraT > Zero then
      MoraT  :=  int(    MoraT * 100.0+0.5) / 100.0
    else
      MoraT  := -int(Abs(MoraT)* 100.0+0.5) / 100.0;
  end;
end;

function  TSerieFinanciamentoDinamico.CalculaAcertoFin(    DataRef : Tdata;
                                                           DtIniPend, DtFimPend,
                                                           DataEmi : Tdata;
                                                           Dados : TDadosAcertoEvo;
                                                           Com200 : boolean;
                                                           SemLiminar : boolean;
                                                           Grava : boolean;
                                                           UtilizaJMora,
                                                           UtilizaJCont : boolean;
                                                           TipoJur : integer;
                                                           CarregaPagamentosSemDiferenca : boolean;
                                                           IgnoraTipoDePagamento : boolean) : real;
var
  Valor,
  Corr,
  Mora,
  VMoeda : real;
  UltDtPg : TData;
begin
  Valor := 0;
  Corr := 0;
  Mora := 0;
  UltDtPg.dia := 0; UltDtPg.mes := 0; UltDtPg.ano := 0;
  if Scciconf.CalcPendAutoPorUPF then begin
    ObtemPendCalcValorCorrMoraUPF(DtIniPend,DtFimPend,
                                  Com200,Valor,Mora,UltDtPg,DataRef,
                                  SemLiminar,DataEmi,Dados,Grava,
                                  CarregaPagamentosSemDiferenca,
                                  IgnoraTipoDePagamento);
    if (Abs(Valor) > Zero) or (Abs(Mora) > Zero) then begin
      VMoeda := LE_UPFD(DataRef);
      if VMoeda <= Zero then VMoeda := LE_VRF(mes_int(DataRef.Mesano));
      if VMoeda <= Zero then VMoeda := 1.0;
      if Abs(Valor) > Zero then begin
        Valor := Valor*VMoeda;
        if Valor > Zero then
          Valor :=  int(    Valor * 100.0+0.5) / 100.0
        else
          Valor := -int(Abs(Valor)* 100.0+0.5) / 100.0;
      end;
      if Abs(Mora) > Zero then begin
        Mora := Mora * VMoeda;
        if Mora > Zero then
          Mora  :=  int(    Mora  * 100.0+0.5) / 100.0
        else
          Mora  := -int(Abs(Mora) * 100.0+0.5) / 100.0;
      end;
    end;
  end
  else
    ObtemPendCalcValorCorrMora(DtIniPend,DtFimPend,DataRef,
                               Com200,Valor,Corr,Mora,SemLiminar,DataEmi,
                               Dados,Grava,UtilizaJMora,UtilizaJCont,TipoJur,
                               CarregaPagamentosSemDiferenca);
  result := Valor + Corr + Mora;
end;

function TSerieFinanciamentoDinamico.CalculaValAntecipacao(Mac : integer; DataRef : TData) : real;
var
  Reg : TValoresPorMac;
  DtVenc : TData;
  DtComCarencia : TData;
  IndJuros : real;
  CmTabErrTemp : integer;
  CmTabErrDataTemp : TData;
  EstaPagoAux : boolean;
begin
  result := 0;
  CmTabErrTemp := CmTabErr;
  CmTabErrDataTemp := CmTabErrData;
  try
    Reg := ObtemValoresPorMac(Mac);

    // IMPORTANTE: as parcelas de financiamento din mico s o criadas apenas
    //             quando a parcela est  paga
    EstaPagoAux := assigned(Reg.ParcelaDoMes) and
                   not Reg.ParcelaDoMes.EstaPagaReal;

    if assigned(Reg) and
       not EstaPagoAux and
       Reg.CtrAtivo then begin

      Int_Mes(Reg.Mac,DtVenc.MesAno);
      DtVenc.dia := Reg.diavenc;

      // S  considera parcela se n o estiver vencida
      if (Juliano(DtVenc) > Juliano(DataRef)) and
         (juliano(Reg.DtAssin) <= juliano(DataRef)) then begin

        IndJuros := Reg.IndJuros;

        DtComCarencia := DataRef;
        result := CalculaEncargoAtualizado(reg.amaisj,DtVenc,
                                           DtComCarencia,IndJuros,
                                           Contrato.Mutdsk.Financ3.JurProRata or
                                           ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                           false{Fin.IncluiFracaoDoMes},
                                           Contrato.Mutdsk.Cad3.JurosSimples);
      end;
    end;
  finally
    CmTabErr := CmTabErrTemp;
    CmTabErrData := CmTabErrDataTemp;
  end;
end;

{ TParcelasFinanciamentoConsolidado }

procedure TParcelasFinanciamentoConsolidado.Le(pContrato:TContrato);
var
  i,
  j : Integer;
  DescAntecip,
  ValorPago : Double;
  DtZero,
  DtProc,
  DtPg : TData;
  TipoPg : byte;
  Mac : Integer;
  wParcela : TParcela;
  TipoDesc : integer;
begin
  // Soma os pagamentos de todas as s ries e de financiamento din mico
  if TemFinancDinamico(pContrato.MutDsk) then
  begin
    for j := 0 to pContrato.SerieF.Parcelas.Count-1 do
    begin
      Mac := pContrato.SerieF.Parcelas[j].Mac;
      if ((pContrato.SerieF.Parcelas[j].DtPg.Dia <= 0) or
          (pContrato.SerieF.Parcelas[j].TipoPg in [8..9,66,74,95,108,110,114,117,121,200,253])) and
          pContrato.SerieF.Parcelas[j].temPgParcial then begin
          DtZero.Dia := 0; fillchar(DtZero,sizeof(DtZero),0);
          DtProc.Dia := 0; fillchar(DtProc,sizeof(DtProc),0);
          DtPg.Dia   := 0; fillchar(DtPg,sizeof(DtPg),0);
          TipoPg     := 0;
          DescAntecip:= 0;
          ValorPago  := 0;
          TipoDesc := 0;
          ValorTotalPagoAntecipado(1, { TipoParc }
                                   pContrato.MutDsk.Cad.Ctr,
                                   TpParc_Series,
                                   0{CodParc},
                                   MAC,
                                   DtPg,
                                   DtProc,
                                   DtZero,
                                   ValorPago,
                                   DescAntecip,
                                   TipoPg);
      end 
      else begin
        ValorPago := pContrato.SerieF.Parcelas[j].ValorPago;
        DtPg := pContrato.SerieF.Parcelas[j].DtPg;
        TipoPg := pContrato.SerieF.Parcelas[j].TipoPg;
        TipoDesc := pContrato.SerieF.Parcelas[j].TipoDesc;
      end;
      wParcela := ObtemParcelaPorMac(Mac);
      if not assigned(wParcela) then
         wParcela := self.add as TParcela;
      wParcela.Mac := Mac;
      wParcela.ValorPago := wParcela.ValorPago + ValorPago;
      wParcela.MoraPgto := wParcela.MoraPgto + pContrato.SerieF.Parcelas[j].MoraPgto;
      wParcela.MultaPgto := wParcela.MultaPgto + pContrato.SerieF.Parcelas[j].MultaPgto;
      wParcela.ResiduoCobrado := wParcela.ResiduoCobrado + pContrato.SerieF.Parcelas[j].ResiduoCobrado;
      wParcela.DescSeg := wParcela.DescSeg + pContrato.SerieF.Parcelas[j].DescSeg;
      wParcela.DescPagamento := wparcela.DescPagamento + pContrato.SerieF.Parcelas[j].DescPagamento;
      wParcela.CorrecaoPgto := wParcela.CorrecaoPgto + pContrato.SerieF.Parcelas[j].CorrecaoPgto;
      wParcela.JRemuneratoriosPgto := wParcela.jRemuneratoriosPgto + pContrato.SerieF.Parcelas[j].JRemuneratoriosPgto;
      wParcela.TipoPg    := TipoPg;
      wParcela.DtPg      := DtPg;
      wParcela.TipoDesc  := TipoDesc;
    end;
  end;
  for i := 0 to pContrato.Series.Count-1 do
  begin
    for j := 0 to pContrato.Series[i].Parcelas.Count-1 do
    begin
      Mac := pContrato.Series[i].Parcelas[j].Mac;
      ValorPago := pContrato.Series[i].Parcelas[j].ValorPago;
      DtPg := pContrato.Series[i].Parcelas[j].DtPg;
      TipoPg := pContrato.Series[i].Parcelas[j].TipoPg;
      TipoDesc := pContrato.Series[i].Parcelas[j].TipoDesc;
      if not TipoDeEstorno(TipoPg) and (TipoPg <> 200) then begin // n o consolidar emitidos ou estornados
        wParcela := ObtemParcelaPorMac(Mac);
        if not assigned(wParcela) then
           wParcela := self.add as TParcela;
        wParcela.Mac := Mac;
        wParcela.ValorPago := wParcela.ValorPago + ValorPago;
        wParcela.MoraPgto := wParcela.MoraPgto + pContrato.Series[i].Parcelas[j].MoraPgto;
        wParcela.MultaPgto := wParcela.MultaPgto + pContrato.Series[i].Parcelas[j].MultaPgto;
        wParcela.ResiduoCobrado := wParcela.ResiduoCobrado + pContrato.Series[i].Parcelas[j].ResiduoCobrado;
        wParcela.DescSeg := wParcela.DescSeg + pContrato.Series[i].Parcelas[j].DescSeg;
        wParcela.DescPagamento := wparcela.DescPagamento + pContrato.Series[i].Parcelas[j].DescPagamento;
        wParcela.CorrecaoPgto := wParcela.CorrecaoPgto + pContrato.Series[i].Parcelas[j].CorrecaoPgto;
        wParcela.JRemuneratoriosPgto := wParcela.JRemuneratoriosPgto + pContrato.Series[i].Parcelas[j].JRemuneratoriosPgto;
        if (wParcela.TipoPg = 0) or
           (pContrato.Series[i].Parcelas[j].TipoParc = TpParc_Series) then begin // dar a prefer ncia a pagamentos de parcela e n o a seguro
          wParcela.TipoPg := TipoPg;
          wParcela.DtPg := DtPg;
          wParcela.TipoDesc  := TipoDesc;
        end;
      end;
    end;
  end;
end;

