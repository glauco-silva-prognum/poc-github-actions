procedure TContrato.AjustaCodTabGenericaParaCorrecao(SerieMaiorPrazo : integer);
var
  i : integer;
begin
  for i := 0 to Series.Count -1 do begin
    if Series[i].Fin.codreaj > 0 then begin
      Series[i].RPAS.Temp10.CodTabGPreChvCorr := Series[i].Fin.CodReajPreChaves;
      Series[i].RPAS.Temp12.DefReajPreChvCorr := Series[i].Fin.DefReajPreChv + Mutdsk.Cad6.DefCorrAtraso;
      Series[i].RPAS.Temp10.CodTabGCorr       := Series[i].Fin.CodReaj;
      Series[i].RPAS.Temp12.DefReajCorr       := Series[i].Fin.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
    end;
    if SerieMaiorPrazo > -1 then begin
      if Series[i].RPAS.Temp10.CodTabGPreChvCorr = 0 then begin
        Series[i].RPAS.Temp10.CodTabGPreChvCorr := Series[SerieMaiorPrazo].Fin.CodReajPreChaves;
        Series[i].RPAS.Temp12.DefReajPreChvCorr := Series[SerieMaiorPrazo].Fin.DefReajPreChv + Mutdsk.Cad6.DefCorrAtraso;
      end;
      if Series[i].RPAS.Temp10.CodTabGCorr = 0 then begin
        Series[i].RPAS.Temp10.CodTabGCorr := Series[SerieMaiorPrazo].Fin.CodReaj;
        Series[i].RPAS.Temp12.DefReajCorr := Series[SerieMaiorPrazo].Fin.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
      end;
    end
    else if SerieMaiorPrazo = -1 then begin
      if Series[i].RPAS.Temp10.CodTabGPreChvCorr = 0 then begin
        Series[i].RPAS.Temp10.CodTabGPreChvCorr := MutDsk.Financ3.CodTabGPreChaves;
        Series[i].RPAS.Temp12.DefReajPreChvCorr := MutDsk.Cad6.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
      end;
      if Series[i].RPAS.Temp10.CodTabGCorr = 0 then begin
        Series[i].RPAS.Temp10.CodTabGCorr := MutDsk.Financ3.CodTabelaGenerica;
        Series[i].RPAS.Temp12.DefReajCorr := MutDsk.Cad6.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
      end;
    end;
  end;
  if SerieMaiorPrazo > -1 then begin
    RPA.Temp10.CodTabGPreChvCorr := Series[SerieMaiorPrazo].RPAS.Temp10.CodTabGPreChvCorr;
    RPA.Temp12.DefReajPreChvCorr := Series[SerieMaiorPrazo].RPAS.Temp12.DefReajPreChvCorr;
    RPA.Temp10.CodTabGCorr := Series[SerieMaiorPrazo].RPAS.Temp10.CodTabGCorr;
    RPA.Temp12.DefReajCorr := Series[SerieMaiorPrazo].RPAS.Temp12.DefReajCorr;
  end
  else if SerieMaiorPrazo = -1 then begin
    RPA.Temp10.CodTabGPreChvCorr := MutDsk.Financ3.CodTabGPreChaves;
    RPA.Temp12.DefReajPreChvCorr := MutDsk.Cad6.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
    RPA.Temp10.CodTabGCorr := MutDsk.Financ3.CodTabelaGenerica;
    RPA.Temp12.DefReajCorr := MutDsk.Cad6.DefReaj + Mutdsk.Cad6.DefCorrAtraso;
  end;
end;

procedure AtualizaDescSeg(Var RPA : TpRPA);
begin
  with RPA do begin
    ValRPA.Desc := ValRPA.Desc - Temp7.DescSeg;
    Temp7.DescSeg := 0;
    if TemdescMip(RPA) then
      Temp7.DescSeg := ValRPA.SegFin;
    if TemDescDfi(RPA) then
      Temp7.DescSeg := Temp7.DescSeg + ValRPA.SegImv;
    ValRPA.Desc := ValRPA.Desc + Temp7.DescSeg;
  end;
end;

function TContrato.SaldoParaCalculoDeSeguroDeApolice(LegLinkItem : TLegLinkItem = nil) : real;
var
  i : integer;
  TemSerieRenegociada : boolean;
  MACReneg : integer;
  SaldoSerie : real;
begin
  // Para compatibilizar o c lculo do seguro aqui com o individual por s ries,
  // considerar que o valbaseseg j  foi calculado corretamente - sol. 68315
  
  // Sol. 83312 - na RecalculaSegComAtraso eu adicionei o atraso ao valorbase do financ. din mico
  //              n o precisando somar mais aqui
  
  result := 0;
  if RPAF.FinRPA.IndSegFin > Zero then begin
    result := RPAF.Temp11.SaldoCalcSeg{RPAF.ValRPA.SaldoDev + RPAF.ValRPA.Amaisj - RPAF.ValRPA.Juro + RPAF.Temp11.TotPrestEmAtsAteVenc};
    if assigned(LegLinkItem) then
      if result > zero then begin
        LegLinkItem.valores['Tipo de valor base para MIP Financ. Din mico'] := cTipoCampoVBaseMip[RPAF.Temp11.CampoVBaseMip]+'('+intstr(RPAF.Temp11.CampoVBaseMip)+')<br>';
        LegLinkItem.valores['Saldo base MIP Financ. Din mico'] := strgrana(result);
      end;
  end;  
  // seguindo a mesma l gica da consolidarpa (sol. 75895)
  // eu n o considero no saldo consolidado as s ries que estejam com NPC=0, no m s em que outra s rie foi
  // renegociada
  TemSerieRenegociada := false; MACReneg := 0;
  for i := 0 to Series.Count -1 do begin
    TemSerieRenegociada := TemSerieRenegociada or (Series[i].RPAS.Finrpa.Status=30);
    if (Series[i].FMACStatusReneg>0) then MACReneg := Series[i].FMACStatusReneg;
  end;

  for i := 0 to Series.count-1 do begin
    if Series[i].CalculaSeguroNoMes then
      if Series[i].Fin.CompoeSaldo  and   // SCAt 21266
         ((Series[i].RPAS.FinRPA.NPC>0) or (not TemSerieRenegociada) or
          (TemSerieRenegociada and (MACReneg<>Series[i].RPAS.MAC))) or
          Series.TemSerieRenegAntesVenc(Series[i].Fin.DataRef) then begin // copia do teste da consolidarpa
        SaldoSerie := 0;  
        if Series[i].RPAS.Temp11.CampovBaseMip = 8 then
          SaldoSerie := Series[i].RPAS.Temp12.SaldoVenc
        else if Series[i].RPAS.Temp11.CampovBaseMip = cVbaseMip_Amaisj then
          SaldoSerie := Series[i].RPAS.ValRPA.Amaisj
        else if Series[i].RPAS.Temp11.CampovBaseMip in [11,12] then begin  
          {
            105105
            N o havia tratamento para esta configura  o no c lculo de v rias s ries.
            Estou copiando do financ. din mico(uevolui3, TEvolui3.CalcMipNovoMetodoPorApolice)
            No financ. din mico ainda h  tratamento para somar tb valores de vendedores, mas eu n o sei
            como ser  o comportamento quando houver apenas s ries com esse tipo de cen rio, j  que o saldo
            de vendedores   liberado sendo passado a saldo de financ. din mico e n o de s ries.
            Certamente quando houver valores de vendedores, esta implementa  o estar  incompleta.
          }
          SaldoSerie := Series[i].RPAS.Temp12.SaldoVenc;
        end
        else begin
          SaldoSerie := Series[i].RPAS.Temp.SalDevAnt + Series[i].RPAS.Temp.CorrSaldo
                    - Series[i].RPAS.Temp11.SaldoPgParcialAntecAnt - Series[i].RPAS.Temp11.CorrPgParcialAntec;
        end;            
        result := result + SaldoSerie;
        if assigned(LegLinkItem) then
          if SaldoSerie > zero then begin
            LegLinkItem.valores['Tipo de valor base para MIP s rie '+DescrSerie(Series[i].Fin.TipoSerie)] := cTipoCampoVBaseMip[Series[i].RPAS.Temp11.CampoVBaseMip]+'('+intstr(Series[i].RPAS.Temp11.CampoVBaseMip)+')<br>';
            LegLinkItem.valores['Saldo base MIP S rie '+DescrSerie(Series[i].Fin.TipoSerie)] := strgrana(SaldoSerie);
          end;  
      end;

    // o atraso deve ser considerado no valor base para calculo do seguro
    // mesmo que a s rie n o tenha seguro neste m s - sol. 56967
    if Series[i].fin.CompoeSaldo or Series[i].fin.CompoeEntrada then begin
      result := result + Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc;
      if assigned(LegLinkItem) then
        if Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc > zero then
          LegLinkItem.valores['Atraso da S rie '+DescrSerie(Series[i].Fin.TipoSerie)+' considerada no saldo base para c lculo do MIP'] := strgrana(Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc);
    end;  
  end;

  if assigned(LegLinkItem) then
    LegLinkItem.valores['Saldo base consolidado para c lculo do MIP'] := strgrana(result);

end;

function TContrato.EscolheSerieParaCobrancadeDFI : longint;
var
  i,
  seriecomsegimv,
  prazoseriebase : integer;
begin
  result := 0;

  if not Ctr_Ativo(RPAF) then begin // garantir que o DFI sempre vai priorizar o fin. din mico ativo sol. 54482
    seriecomsegimv := -1; prazoseriebase := 0;
    for i := 0 to Series.count-1 do begin // Tenta achar uma s rie mensal onde possa ser cobrado seguro DFI
      Series[i].RPAS.FinRPA.ValAVal := 0;
  //    Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro - Series[i].RPAS.ValRPA.SegImv;   n o zerar a escolhida, pois pode ser que ela n o seja trocada
  //    Series[i].RPAS.ValRPA.SegImv := 0;
      AtualizaTotPrest(Series[i].RpaS);
      if (Series[i].Fin.PerParcelas=1) and 
        ((Series[i].CalculaSeguroNomes and (Series[i].RPAS.FinRpa.IndSegImv >= 0) and 
         (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))) or 
         (Series[i].CalculaSeguroDFINoMes(true,(Series[i].RPAS.FinRpa.IndSegimv > 0) and 
         (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))))) then
        seriecomsegimv := i;
    end;
    for i := 0 to series.Count -1 do // Tenta achar a s rie mensal de maior prazo onde possa ser cobrado seguro DFI, j  iniciada
      if (Series[i].Fin.PerParcelas=1) and
         (Series[i].Fin.Prazo>prazoseriebase) and
         (Series[i].RPAS.FinRPA.NPC > 0) and
         ((Series[i].CalculaSeguroNomes and (Series[i].RPAS.FinRpa.IndSegImv >= 0) and 
          (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))) or (Series[i].CalculaSeguroDFINoMes(true,(Series[i].RPAS.FinRpa.IndSegimv > 0) and 
          (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))))) then begin
        seriecomsegimv := i;
        prazoseriebase := Series[i].Fin.Prazo;
      end;
    if seriecomsegimv < 0 then
      for i := 0 to series.Count -1 do // Tenta achar a s rie mensal de maior prazo onde possa ser cobrado seguro DFI
        if (Series[i].Fin.PerParcelas=1) and
           (Series[i].Fin.Prazo>prazoseriebase) and
           ((Series[i].CalculaSeguroNomes and (Series[i].RPAS.FinRPA.IndSegImv >= 0) and
           (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))) or
           (Series[i].CalculaSeguroDFINoMes(true,(Series[i].RPAS.FinRpa.IndSegimv > 0) and
           (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))))) then begin
          seriecomsegimv := i;
          prazoseriebase := Series[i].Fin.Prazo;
        end;
    if seriecomsegimv < 0 then // Se n o achou uma s rie mensal, escolhe uma qualquer onde possa se cobrado o seguro DFI
      for i := 0 to Series.count-1 do begin                   
        if ((Series[i].CalculaSeguroNomes and (Series[i].RPAS.FinRpa.IndSegImv >= 0) and 
           (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))) or
           (Series[i].CalculaSeguroDFINoMes(true,(Series[i].RPAS.FinRpa.IndSegimv > 0) and 
           (not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0))))) then
          seriecomsegimv := i;
      end;
    if seriecomsegimv > -1 then begin
      if abs(RPA.FinRPA.ValAVal) > zero then
        Series[seriecomsegimv].RPAS.FinRPA.ValAval := RPA.FinRPA.ValAVal
      else
        Series[seriecomsegimv].RPAS.FinRPA.ValAval := MutDsk.Financ.ValAval;
      if abs(RPA.Temp9.ValBaseSegDFI) > zero then
        Series[seriecomsegimv].RPAS.Temp9.ValBaseSegDFI := RPA.Temp9.ValBaseSegDFI;
      if abs(Series[seriecomsegimv].RPAS.FinRPA.ValAval) < Zero then Series[seriecomsegimv].RPAS.FinRPA.ValAval := Mutdsk.Cad.ValComVen;
      if (Series[seriecomsegimv].Fin.IndSegImv>Zero) and (Series[seriecomsegimv].RPAS.FinRPA.IndSegImv<Zero)then begin
        Series[seriecomsegimv].RPAS.FinRPA.IndSegImv := Series[seriecomsegimv].Fin.IndSegImv;
        Series[seriecomsegimv].RPAS.Temp11.NaoReajustaDFI := Series[seriecomsegimv].Fin.NaoReajustaSegDFI;
      end;
      if Series[seriecomsegimv].RPAS.FinRPA.IndSegImv < zero then Series[seriecomsegimv].RPAS.FinRPA.IndSegImv := Mutdsk.Financ.IndSegImv;
      result := Series[seriecomsegimv].fin.Codserie;
    end;
  end;
  
  TrocouSerieComDFI := SerieComDFI <> result;
  SerieComDFI := result;

  for i := 0 to Series.count-1 do
    if Series[i].Fin.codSerie <> result then begin
      Series[i].RPAS.FinRPA.ValAVal := 0;
      Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro - Series[i].RPAS.ValRPA.SegImv;
      Series[i].RPAS.ValRPA.SegImv := 0;
      AtualizaTotPrest(Series[i].RpaS);
    end;
    
  if result > 0 then begin
    RPA.ValRPA.Seguro := RPA.ValRPA.Seguro - RPA.ValRPA.SegImv;
    RPA.ValRPA.SegImv := 0;
    AtualizaTotPrest(RPA);
    AtualizaDescSeg(RPA);
  end;
end;

procedure TContrato.CalculaValAvalCorr;
// Vai calcular ValAvalCor corrigindo o ultimo valaval existente na s rie anterior e passar para a s rie escolhida para
// para cobran a de MIPPorValAval (FSerieParaDFI)
var
  i:integer;
begin
  
  // Calcula o ValAvaCorr
  for i := 0 to Series.count-1 do
    if Series[i].Fin.codSerie = FSerieParaDFI then begin
      if Series[i].RPAS.Temp12.ValAvalCorr = 0 then
        Series[i].RPAS.Temp12.ValAvalCorr := RPA.Temp12.ValAvalCorr;
      if Series[i].RPAS.Temp12.ValAvalCorr = 0 then
        Series[i].RPAS.Temp12.ValAvalCorr := Series[i].RPAS.finRpa.ValAval;
      AjustaMoeda2(Rpa.MAC-1,Rpa.Mac,Series[i].RPAS.Temp12.ValAvalCorr);
      Series[i].RPAS.Temp12.ValAvalCorr := 
        Series[i].RPAS.Temp12.ValAvalCorr * Series[i].Rpas.FinRpa.TxSD;
      if Series[i].RPAS.Temp5.MACAval = Rpa.MAC then
        Series[i].RPAS.Temp12.ValAvalCorr := Series[i].RPAS.finRpa.ValAval;
      Rpa.Temp12.ValAvalCorr := Series[i].RPAS.Temp12.ValAvalCorr;
    end;            
  // Zera o ValAvalCorr das outras s ries
  for i := 0 to Series.count-1 do
    if Series[i].Fin.codSerie <> FSerieParaDFI then begin
      Series[i].RPAS.Temp12.ValAvalCorr := 0;
    end;
end;

procedure TContrato.EscolheSerieParaCobrancadeMIPPorValAVal;
var
  i,
  seriecommip,
  prazoseriebase : integer;
begin
  FSerieParaMIPPorValAVal := -1;
  if RPA.Temp8.CalcSegMIPPeloValAval then begin
    prazoseriebase := 0;
    seriecommip := -1;
    // Zera seguro anterior
    for i := 0 to Series.count-1 do begin
      Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro - Series[i].RPAS.ValRPA.SegFin;
      Series[i].RPAS.ValRPA.SegFin := 0;
      AtualizaTotPrest(Series[i].RpaS);
    end;

    // S  calcula na s rie, se n o houver financ. din mico, ou n o existir presta  o de financ. din mico no m s
    if not Ctr_Ativo(RPAF) or (RPAF.FinRPA.NPC=0) then begin

      // Escolhe a primeira que possa ser cobrada mensal
      for i := 0 to Series.Count-1 do
        if (Series[i].Fin.PerParcelas=1) and Series[i].CalculaSeguroNoMes then
          seriecommip := i;

      // Tenta achar a s rie mensal de maior prazo onde possa ser cobrado seguro MIP, j  iniciada
      for i := 0 to series.Count -1 do
        if (Series[i].Fin.PerParcelas=1) and
           (Series[i].Fin.Prazo>prazoseriebase) and
           (Series[i].RPAS.FinRPA.NPC > 0) and
           Series[i].CalculaSeguroNoMes then begin
          seriecommip := i;
          prazoseriebase := Series[i].Fin.Prazo;
        end;

      // Tenta achar a s rie mensal de maior prazo onde possa ser cobrado seguro MIP
      if seriecommip < 0 then
        for i := 0 to series.Count -1 do
          if (Series[i].Fin.PerParcelas=1) and
             (Series[i].Fin.Prazo>prazoseriebase) and
             Series[i].CalculaSeguroNoMes then begin
            seriecommip := i;
            prazoseriebase := Series[i].Fin.Prazo;
          end;
        
      // Se n o achou uma s rie mensal, escolhe uma qualquer onde possa se cobrado o seguro MIP
      if seriecommip < 0 then
        for i := 0 to Series.count-1 do
          if Series[i].CalculaSeguroNoMes then
            seriecommip := i;
    end;
    if seriecommip >= 0 then
      FSerieParaMIPPorValAVal := Series[seriecommip].Fin.CodSerie;
  end;
  
  if (FSerieParaMIPPorValAVal > 0) then begin
    RPA.ValRPA.Seguro := RPA.ValRPA.Seguro - RPA.ValRPA.SegFin;
    RPA.ValRPA.SegFin := 0;
    AtualizaTotPrest(RPA);
    AtualizaDescSeg(RPA);
  end;
end;

function TContrato.ConsolidaSeguroSerie(RegSeries : TpSeries; MAC : integer) : boolean;
begin
  result := (RegSeries.CompoeSaldo or RegSeries.CompoeEntrada) and (MAC >= mes_int(RegSeries.DataRef.MesAno));
end;

procedure TContrato.CopiaDadosSeguroRPA(Var RPAOrigem, RPADestino : TpRPA);
begin
  RPADestino.FinRPA.IndSegFin := RPAOrigem.FinRPA.IndSegFin;
  RPADestino.FinRPA.IndSegImv := RPAOrigem.FinRPA.IndSegImv;
  RPADestino.Temp11.Seguradora := RPAOrigem.Temp11.Seguradora;
  RPADestino.Temp11.SeguradoraDFI := RPAOrigem.Temp11.SeguradoraDFI;
  RPADestino.Temp10.CodApolice := RPAOrigem.Temp10.CodApolice;
  RPADestino.Temp11.CodApoliceDfi := RPAOrigem.Temp11.CodApoliceDfi;
