procedure TContrato.IncluiIncorporacao( DataRef : Tdata;
                                        ValorIncorp : real;
                                        Prazo : integer;
                                        txJuros : real;
                                        Plano : integer;
                                        CondAdversa : smallint;
                                        CodSerie : integer;
                                        NaoAfetaRisco,
                                        SemRecalculo : boolean;
                                        MAFim : TMes_Ano;
                                        QtdIncorp : integer);
var
  ChaveLog : TpChaveLogMem;
  DataHist : TData;
begin
  ChaveLog := 0;
  if juliano(DataRef) > juliano(DataH) then
    DataHist := DataH
  else
    DataHist := DataRef;
  if SemReCalculo then begin
    IncluiLogMem (FHistMem, Mutdsk.cad.ctr, 42, 0{CodFCVS}, DataHist, 'Incorporacao', ChaveLog);
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 105, 1);
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 172, Mes_Int(MAFim));
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 173, QtdIncorp);
  end
  else begin
    IncluiLogMem (FHistMem, Mutdsk.cad.ctr, 95, 0{CodFCVS}, DataHist, 'Incorporacao', ChaveLog);
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 102, 1, CodSerie);           // Opcao que id. Inc.c/Rec.
  end;
  IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 250, Valorincorp, CodSerie);       // ValorInc
  IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 248, DataRef.Dia, CodSerie);   // Dia Am/Inc
  IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno,330, 18, CodSerie);           // ExOpc p/ Incorp.
  if Prazo > 0 then
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 80, Prazo, CodSerie);      // Novo Prazo
  if abs(TxJuros) > zero then
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 17, TxJuros, CodSerie);    // Nova TxJuros
  if Plano > 0 then
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 25, Plano, CodSerie);    // Novo Plano
  if CondAdversa > 0 then
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 349, CondAdversa, CodSerie);    // Condi  es adversas
  if NaoAfetaRisco then
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 348, 1, CodSerie) // Reneg Sem Risco
  else
    IncluiDatMem (FHistMem, ChaveLog, DataRef.MesAno, 348, 0, CodSerie); // Reestrutura o contrato
  Processa_Hist(DataRef,FHistMem,FHEvo);
end;

procedure TContrato.TiraQuitacaoAnterior(pProcessaHist : boolean = false);
var 
  i      : Integer;
  Hist   : TpHistEdit;
begin
  if not FHistoricosLidos then LeHistoricos;
  (* esta rotina retira os historicos de quitacao para permitir simulacao
     de quitacao em mutuario ja' quitados *)
  Hist[0].Tam := 0;
  fillchar(Hist,sizeof(TpHistEdit),0);
  i := 1; 
  while (i <= FHistmem[0].Tam) do
  begin
    if (FHistMem[i].Log.CodMov <> 01) and  { Liq. Antecipada    }
       (FHistMem[i].Log.CodMov <> 96) and  { Liq. de Futura Aq. }
       ((not (FHistMem[i].Log.CodMov in [2,7,8]))) then begin
      inc(Hist[0].Tam);
      Hist[Hist[0].Tam] := FHistMem[i];
    end;
    inc(i);
  end;
  FHistmem := Hist;
  if pProcessaHist then
    Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.TiraRescisao;
var
  i      : Integer;
  Hist   : TpHistEdit;
begin
  if not FHistoricosLidos then LeHistoricos;
  (* esta rotina retira os historicos de rescisao para permitir simulacao
     de rescisao em mutuario ja' rescindido *)
  Hist[0].Tam := 0;
  fillchar(Hist,sizeof(TpHistEdit),0);
  i := 1;
  while (i <= FHistmem[0].Tam) do
  begin
    if FHistMem[i].Log.CodMov <> 52 then begin
      inc(Hist[0].Tam);
      Hist[Hist[0].Tam] := FHistMem[i];
    end;
    inc(i);
  end;
  FHistmem := Hist;
end;

procedure TContrato.TiraRetomadaOuTermConsolid;
var
  i      : Integer;
  Hist   : TpHistEdit;
begin
  if not FHistoricosLidos then LeHistoricos;
  (* esta rotina retira os historicos de retomada para permitir simulacao
     de quitacao em mutuario ja' retomado ou t rmino consolida  o*)
  Hist[0].Tam := 0;
  fillchar(Hist,sizeof(TpHistEdit),0);
  i := 1;
  while (i <= FHistmem[0].Tam) do
  begin
    if (FHistMem[i].Log.CodMov <> 3) and
       (FHistMem[i].Log.CodMov <> 126) then begin
      inc(Hist[0].Tam);
      Hist[Hist[0].Tam] := FHistMem[i];
    end;
    inc(i);
  end;
  FHistmem := Hist;
  Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.TiraSinistro;
var
  i : integer;
begin
  i := 1;
  while i <= FHistMem[0].Tam do begin
    if (FHistMem[i].Log.CodMov in [2,34]) then
      FHistMem[i].Log.MarcaLog := True;
    inc(i);
  end;
  Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.InibeHistoricos;
var
  i : integer;
begin
  if not FHistoricosLidos then LeHistoricos;
  i := 1;
  while i <= FHistMem[0].Tam do begin
    FHistMem[i].Log.MarcaLog := True;
    inc(i);
  end;
  Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.InibeHistoricoAltVencPosData(DtInf : TData);
var
  i : integer;
begin
  i := 1;
  while (i <= FHistMem[0].Tam) do begin
    if (FHistMem[i].Log.CodMov = 51) and
       (juliano(FHistMem[i].Log.Data) > juliano(DtInf)) then
      FHistMem[i].Log.MarcaLog := true;
    inc(i);
  end;
  Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.InibeHistoricoRenegociacao(DtInf : TData);
var
  i : integer;
begin
  i := 1;
  while (i <= FHistMem[0].Tam) do begin
    if (FHistMem[i].Log.CodMov = 45) and
       (juliano(FHistMem[i].Log.Data) = juliano(DtInf)) then
      FHistMem[i].Log.MarcaLog := true;
    inc(i);
  end;
  Processa_Hist(DataH,FHistMem,FHEvo);
end;

procedure TContrato.DefineDataDaVenda(Var DataVenda : TData);
var
  i : integer;
begin
  DataVenda := Mutdsk.Financ.DtAssin;
  if DataVenda.dia = 0 then
    for i := 0 to FSeries.count - 1 do
      if (FSeries[i].Fin.CompoeSaldo or
          FSeries[i].Fin.CompoeEntrada) and
         (FSeries[i].Fin.DataRef.dia > 0) and
         ((Juliano(DataVenda) > Juliano(FSeries[i].Fin.DataRef)) or
          (DataVenda.dia = 0)) then
        DataVenda := FSeries[i].Fin.DataRef;
end;

procedure TContrato.ProjetaIndiceAteDataref(DataRef : Tdata);
var
  j : integer;
begin
  if TemFinancDinamico(MutDsk) then begin
    if RPAF.Temp6.CodReajSD > 0 then
      scciio.ProjetaIndiceAteDataref(RPAF.Temp6.CodReajSD,DataRef,RPAF.FinRPA.DiaVenc);
    if RPAF.FinRpa.CodReaj=23 then
      scciio.ProjetaIndiceAteDataref(RPAF.Temp7.CodTabelaGenerica,DataRef,RPAF.FinRPA.DiaVenc);
    scciio.ProjetaIndiceAteDataref(100,DataRef,RPAF.FinRPA.DiaVenc);
  end;
  if MutDsk.Cad2.TemSerie and (Series.Count > 0) then
    for j := 0 to Series.Count-1 do begin
      if Series[j].RPAS.Temp10.CodTabGPreChvCorr > 0 then
        scciio.ProjetaIndiceAteDataref(Series[j].RPAS.Temp10.CodTabGPreChvCorr,DataRef,Series[j].RPAS.FinRPA.DiaVenc);
      if Series[j].RPAS.Temp10.CodTabGCorr > 0 then
        scciio.ProjetaIndiceAteDataref(Series[j].RPAS.Temp10.CodTabGCorr,DataRef,Series[j].RPAS.FinRPA.DiaVenc);
      if Series[j].RPAS.Temp6.CodReajSD > 0 then
        scciio.ProjetaIndiceAteDataref(Series[j].RPAS.Temp6.CodReajSD,DataRef,Series[j].RPAS.FinRPA.DiaVenc);
      if Series[j].RPAS.FinRpa.CodReaj=23 then
        scciio.ProjetaIndiceAteDataref(Series[j].RPAS.Temp7.CodTabelaGenerica,DataRef,Series[j].RPAS.FinRPA.DiaVenc);
      scciio.ProjetaIndiceAteDataref(100,DataRef,Series[j].RPAS.FinRPA.DiaVenc);
    end;
end;

