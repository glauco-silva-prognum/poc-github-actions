function TSerie.EstaEmAtrasoRpaS(DataRef : Tdata) : boolean;
var
  DtVenc : TData;
  DtIsen : TData;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  result := false;
  if assigned(FParcelaDoMes) then begin
    DtVenc.Dia := FParcelaDoMes.DiaVenc;
    Int_Mes(FParcelaDoMes.MAC,DtVenc.MesAno);
    DtIsencaoMora(Contrato.Mutdsk,RpaS,DtVenc,DtIsen,RPAS.Temp11.DiaIsencao);
    result := (Contrato.DiasDeAtrasoEntreDatas(DtIsen,DataRef) > 0) and
              (not EstaPagaRpaS(DataRef)) and
              ( (not (Fin.FinancBancario or (Fin.CodClassificacao = serie_Chaves))) or
               ((RpaS.FinRPA.NPC = 0) and
                (RpaS.MAC > Mes_Int(RPAS.FinRPA.DtAssin.MesAno)) and
                (RpaS.ValRPA.TotPrest-RPAS.ValRPA.Desc > Zero)) or
               ESerieFinBancChavesDevida(RpaS.Temp10.DtHabit,DataRef) );
  end;
end;

function TSerie.EstaEmAtrasoRpaS(Reg : TValoresPorMac; DataRef : Tdata) : boolean;
var
  DtVenc : TData;
  DtIsen : TData;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  result := false;
  if assigned(Reg.ParcelaDoMes) then begin
    DtVenc.Dia := Reg.ParcelaDoMes.DiaVenc;
    Int_Mes(Reg.ParcelaDoMes.MAC,DtVenc.MesAno);
    DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsen,Reg.DiaIsencao);
