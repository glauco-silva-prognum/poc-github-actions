     else if (Collection is TPagamentosParciaisSerie) then begin
       Serie := (Collection as TPagamentosParciaisSerie).FOwner as TSerie;
       if  assigned(Serie) then
         Result := Serie.Parcelas.ObtemParcelaPorMAC(MAC);
     end;
  end;
end;

