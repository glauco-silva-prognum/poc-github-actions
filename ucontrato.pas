function TSerieFinanciamentoDinamico.NumPrstAtraso5Evo(DtRef: TData; 
                                                       ConsideraAgenda : boolean = false;
                                                       ConsideraPrstSoDeAcessorios : boolean = false) : SmallInt;
// O contrato j  tem que ter sido evolu do at  pelo menos a dataref, pois ser  lido o vencimento da presta  o
var
  AuxAnt,
  AUX : SmallInt;
  fim : boolean;
  dtmac,
  dtisen,
  DtInFin : tdata;
  Mac : integer;
  Parcela : TParcela;
  Reg : TValoresPorMac;
  lAcessorios : real;
begin
  DtIsen.dia := 0; DtIsen.Mes := 0; DtIsen.Ano := 0;
  AUX := 0 ; fim := false;
  if (not ( Contrato.MutDsk.Financ.Status in StatusTermino )) and
     (not (Contrato.MutDsk.Cad.TipoCtr in [1,2])) then begin
    if (juliano(Contrato.MutDsk.Financ.DtInFin) < juliano(Contrato.Mutdsk.Financ.DtAssin)) and
       ((Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1) < Mes_Int(Contrato.MutDsk.Financ.DtAssin.MesAno)) then begin
      DtInFin := Contrato.MutDsk.Financ.DtAssin;
      DecMA(DtInFin.MesAno);
    end else DtInFin := Contrato.MutDsk.Financ.DtInFin;
    DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),Contrato.MutDsk.Financ.DtInFin.Dia);
    dtmac := dtref;
    Reg := ObtemValoresPorMac(mes_int(dtmac.MesAno));
    if ConsideraPrstSoDeAcessorios then
      lAcessorios := Reg.TotalAcessorios
    else
      lAcessorios := 0;  
    if Reg.DiaVencOrig > 0 then 
      dtmac.dia := DIA_VENC( mes_int(dtmac.mesano),Reg.DiaVencOrig)
    else
      dtmac.dia := DIA_VENC( mes_int(dtmac.mesano),Reg.DiaVenc);

    DtIsencaoMora( dtmac, DtIsen, Contrato.MutDsk.Cad.DiaIsencao );
    DtMac := DtIsen;
    Mac := Mes_int(DtRef.MesAno);

    if DiasDeAtrasoEntreDatas( dtmac, DtRef ) <= 0 then dec( Mac );
    decMA(DtMac.MesAno);
    if Reg.DiaVencOrig > 0 then 
      DtMac.Dia := Dia_venc(Mes_Int(DtMAC.Mesano),Reg.DiaVencOrig)
    else
      DtMac.Dia := Dia_venc(Mes_Int(DtMAC.Mesano),Reg.DiaVenc);

    if DiasDeAtrasoEntreDatas( dtmac, DtRef ) <= 0 then dec( Mac );

    while ( Mac > mes_int(DtInFin.MesAno) ) and ( not fim ) do begin
      AuxAnt := AUX;
      Parcela := Parcelas.ObtemParcelaPorMac(Mac);
      if not assigned(parcela) or not Parcela.EstaPaga(DtRef,lAcessorios) then begin
        Reg := ObtemValoresPorMac(Mac);
        if not ConsideraAgenda or not Contrato.PrestAgendada(reg,DtRef) then
          inc(Aux);
      end;
      dec( Mac );
      fim := AUX = AuxAnt;
    end; { while }
  end
  else AUX := 0;
  result := AUX;
end;

