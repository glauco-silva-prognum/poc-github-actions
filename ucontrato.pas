  procedure TestaCobrancaRegistrada(RegRef : TValoresPorMac);
  var
    ReglCobr : TpTablCobr;
    vContaCorr,
    vAgencia : string;
    aux : ansistring;
  begin
    ReglCobr.LCobr := 0;
    fillchar(ReglCobr,sizeof(ReglCobr),0);
    if CalculoAtrasoParametros.TestaCobrancaRegistrada then
      if CalculoAtrasoParametros.TipoExec <> TipoExec_Atraso then begin
        LeLCobrValoresPorMac(Mutdsk,RegRef,RegLCobr);
        if RegLCobr.LCobr > 0 then begin
          if RegLcobr.CobrRegistrada1aVia then begin
            // Na web, basta o lcobr do contrato ser cob. registrada para bloquear,
            // mesmo que o lcobr2avia n o seja
            if CalculoAtrasoParametros.TestaCobrancaRegistradaParaWeb then begin
              aux := ObtemListaPgtos(RegLcobr);
              if aux > '' then raise exception.create(aux);
            end;
            if ReglCobr.Lcobr2avia > 0 then begin
              LeLcobr2aVia(RegLCobr.Lcobr,RegLCobr);
              if RegLCobr.LCobr > 0 then begin
                if ReglCobr.CobrRegistrada1aVia then begin  // Mantenho o requisito da sol. 22146, s  bloqueio se lcobr2avia for registrada tamb m
                  vContaCorr := copy(IntStr2(RegLcobr.ContaCorr,7),1,7)+RegLcobr.DvContaCorr;
                  vContaCorr := copy(vContaCorr,1,4)+'.'+copy(vContaCorr,5,4);
                  vContaCorr := copy(vContaCorr,1,length(vContaCorr)-1)+'-'+vContaCorr[Length(vContaCorr)];
                  vAgencia   := IntStr2(ReglCobr.CodAgCed,4);
                  vAgencia   := copy(vAgencia,1,4)+'-'+RegLcobr.DvAgCed;
                  // na sol. 22681 foi pedido para n o bloquear o corp, apenas avisar
                  if assigned(LstAvisos) then
                    LstAvisos.add('Este contrato est  vinculado a cobran a registrada e para '+
                                  'estes contratos estaremos efetuando a cobran a pela ag ncia : '+
                                  vAgencia+' - '+vContaCorr);
                end;
              end
              else  // A Partir deste scat, se CobrRegistrada1a via verdadeiro, o usu rio   obrigado a preencher o lcobr2avia
                raise exception.create('Para contratos com cobran a registrada n o ser  poss vel '+
                                       'a emiss o de recibos por este m dulo, para que isto seja poss vel '+
                                       '  necess rio o preenchimento do local de cobran a espec fico para 2a. via.');
            end
            else // A Partir deste scat, se CobrRegistrada1a via verdadeiro, o usu rio   obrigado a preencher o lcobr2avia
              raise exception.create('Para contratos com cobran a registrada n o ser  poss vel '+
                                     'a emiss o de recibos por este m dulo, para que isto seja poss vel '+
                                     '  necess rio o preenchimento do local de cobran a espec fico para 2a. via.');
          end;// Caso normal sem cobran a registrada
        end;// deixa dar a cr tica de local de cobran a inv lido
      end;
  end;
  
  procedure TestaDonocred(    RegRef : TValoresPorMac;
                          Var Msg : AnsiString;
                          Var Status : TCalculoAtrasoStatus);
  begin
    if (ValInt(SCCIConf.NSerie) in [5..8]) and
     ((RegRef.DonoCred = 2) or (RegRef.Conta = 29)) then begin
      Msg := 'Contrato cedido a CEF. Autorizado';
      Status := CalculoAtrasoStatus_Confirmar;
    end;
  end;

var
  RegRef : TValoresPorMac;
  UF : str3;
  CodMun : smallint;
begin
  if Mutdsk.Cad.TipoCtr=44 then
    CalculoAtrasoParametros.UsaPosicaoAtraso := true;
  UF := '';
  CodMun := -1;
  Suspendeu := false;
  result := CalculoAtrasoStatus_Ok;
  try
    RegRef := ObtemValoresPorMac(mes_int(CalculoAtrasoParametros.DataRef.MesAno));
    TestaTipoExec;
    TestaCobrancaRegistrada(RegRef);
    if MutDsk.Cad.TipoCtr in [2,22,31] then begin
      Msg   := 'Impossivel emitir recibo. ';
      if MutDsk.Cad.TipoCtr = 2 then Msg := Msg + 'Contrato de Comodato.'
      else if MutDsk.Cad.TipoCtr = 31 then Msg := Msg +'S rie de Controle de Taxas.'
      else Msg := Msg + 'Contrato CVS-Nova  o';
      raise exception.create(msg);
    end
    else if CalculoAtrasoParametros.UsaPosicaoAtraso and CalculoAtrasoParametros.LePosicaoAtrasoParaDataref then begin
      if not TemPosicaoAtrasoParaData(GetSqlConnection(pegaDirTab),Mutdsk.cad.ctr,CalculoAtrasoParametros.DataRef) then
        raise exception.create('Contrato sem atraso gravado na base para o dia '+data_str2(CalculoAtrasoParametros.DataRef));
    end;
    TestaDonoCred(RegRef,Msg,result);
    ObtemMunicipioParaCobranca(UF,CodMun);

    if scciconf.BloqueiaEmissaoDeRecibosParaDiasNaoUteis and
       not CalculoAtrasoParametros.IgnoraBloqueiaEmissaoDeRecibosParaDiasNaoUteis then begin
      if (CalculoAtrasoParametros.TipoExec in [TipoExec_2avia,TipoExec_Aberta]) and
         not Testa_Data_Fer(CalculoAtrasoParametros.DataRef,CodMun,UF) then // sol. 59472
        raise exception.create('Data de c lculo n o   dia  til');
    end;
    TestaTerminoParaCalcAtraso(RegRef.Mac,
                               CalculoatrasoParametros.CalcAtrParaInativos,
                               ((CalculoAtrasoParametros.TipoExec in [TipoExec_2avia,TipoExec_Atraso]) and ScciConf.EmiteBoletoAtrasoCtrReneg) or
                                CalculoAtrasoParametros.DevidasParaAviso,TestaGrupo);
    Suspendeu := not SuspensaoParaCalcAtrasoOk(CalculoAtrasoParametros,TestaGrupo,msg,result);
  except
    on e : exception do begin
      msg := e.message;
      result := CalculoAtrasoStatus_Erro;
    end;
  end;
end;

