constructor TContratos.create;
begin
  inherited;
  FMutDskCampos := TDBRegistroCadmut.create;
  FOrdem := 'CO_CONTRATO';
  FQry := TFastSqlQuery.create(nil);
  FCtrini := '';
  FCtrFim := '';
  FAbriuDBArqCadmut := false;
  fillchar(FMutDsk,sizeof(TpMutDsk),0);
  FUsuario := pegausuario;
  FSelecaoContratos := TSelecaoContratos.create;
  FSelecaoContratos.OnSelecaoChanged := {$IFDEF FPC}@{$ENDIF}TrataOnSelecaoChanged;
  Fcobase := 0;
  MontaQuery;
  FPesquisaComLike := False; //coloca como default a consulta a contrato por nome com like
end;

destructor TContratos.destroy;
begin
  Fecha;
  FMutDskCampos.free;
  FQry.free;
  FSelecaoContratos.free;
  inherited Destroy;
end;

procedure TContratos.Abre;
var
  st : shortstring;
  chaveImv : TpChaveImv;
  wMutdsk : tpMutDsk;
  NByte : byte;
  nLong : longint;
  ChvOperacao : TpMutdskChv14;
  ChaveEmpNomeKey : TpMutdskChv16;
begin
  wMutDsk.Cad.Ctr := '';
  fillchar(wMutDsk,sizeof(wMutdsk),0);
  Fecha;
  fillchar(FMutDsk,sizeof(TpMutDsk),0);
  if AbriuCadmutSql then begin
    if FQry.SqlConnection <> SqlConnectionCadmut then begin
//      FQry.prepared := false;  // A query nao tem parametros.
      FQry.SqlConnection := SqlConnectionCadmut;
    end;
    ResetBase;
//    if not FQry.prepared then
//      FQry.Prepared := true;     // A query nao tem parametros.
    FQry.Open;
  end
  else if AbriuCadMutXDB then begin
    AbreDBArqSemErro(FDBArqCadmut,PegaDirCor,'cadmut',FAbriuDBArqCadMut);
    if FAbriuDBArqCadMut then begin
      if FSelecaoContratos.PorSitCobj then begin
        NByte := FSelecaoContratos.SitCobj;
        AtivaIndice(7);
        if FSelecaoContratos.SitCobj > -1 then
          ProcuraReg(FDBArqcadmut,Nbyte)
        else
          PosicionaReg(FDbarqCadmut,xdb.primeiro);
      end
      else if FSelecaoContratos.Cpf > '' then begin
        st := FSelecaoContratos.Cpf;
        AtivaIndice(3);
        procuraReg(FDBArqCadmut,st);
      end
      else if FSelecaoContratos.CtrVelho > '' then begin
        st := FSelecaoContratos.CtrVelho;
        AtivaIndice(4);
        procurareg(FDBArqCadmut,st);
      end
      else if FSelecaoContratos.Matricula > '' then begin
        st := FSelecaoContratos.Matricula;
        AtivaIndice(13);
        procurareg(FDBArqCadmut,st);
      end     
      else if FSelecaoContratos.NomeIni > '' then begin
        st := FSelecaoContratos.nomeIni;
        AtivaIndice(2);
        procurareg(FDBArqCadmut,st);
      end
      else if FSelecaoContratos.CtrAntSec > '' then begin
        st := FSelecaoContratos.CtrAntSec;
        AtivaIndice(9);
        procurareg(FDBArqCadmut,st);
      end
      else if FSelecaoContratos.CtrEstrangeiro > '' then begin
        st := FSelecaoContratos.CtrEstrangeiro;
        AtivaIndice(12);
        procurareg(FDBArqCadmut,st);
      end
      else if FSelecaoContratos.NomeIniExclusivo > '' then begin
        st := FSelecaoContratos.nomeIniExclusivo;
        AtivaIndice(2);
        procurareg(FDBArqCadmut,st);
        if ok then begin
          LeReg(FDBArqCadmut,wMutDsk);
          while not DBEof(FDBArqCadmut) and (uppercase(st) = uppercase(wMutDsk.Cad.Nome)) do begin
            posicionareg(FDBArqCadmut,xdb.proximo);
            if ok then
              lereg(FDBArqCadmut,wMutdsk);
          end;
        end;
      end
      else if FSelecaoContratos.Chaveimv.Empreend > -1 then begin
        chaveimv := FSelecaoContratos.ChaveImv;
        AtivaIndice(6);
        procurareg(FDBArqCadmut,chaveimv);
      end
      else if FSelecaoContratos.ContrMut > '' then begin
        st := FSelecaoContratos.ContrMut;
        AtivaIndice(11);
        procurareg(FDBArqCadmut,st);
      end      
      else if FSelecaoContratos.Operacao > '' then begin
        ChvOperacao.Operacao := '';
        fillchar(chvOperacao,sizeof(TpMutdskChv14),0);
        ChvOperacao.Operacao := FSelecaoContratos.Operacao;
        AtivaIndice(14);
        procurareg(FDBarqCadmut,chvOperacao);
      end
      else if FSelecaoContratos.CtrSistemaAntigoini > '' then begin
        st := FSelecaoContratos.CtrSistemaAntigoIni;
        AtivaIndice(15);
        procuraReg(FDBarqCadmut,st);
      end
      else if FSelecaoContratos.CodCRI > '' then begin
        st := FSelecaoContratos.CodCRI;
        AtivaIndice(8);
        procuraReg(FDBarqCadmut,st);
      end
      else if FSelecaoContratos.NumAverbCCI > '' then begin
        st := FSelecaoContratos.NumAverbCCI;
        AtivaIndice(18);
        procuraReg(FDBarqCadmut,st);
      end
      else if FSelecaoContratos.CerCefHab > -1 then begin
        nlong := FSelecaoContratos.CerCefHab;
        AtivaIndice(19);
        procuraReg(FDBarqCadmut,nLong);
      end
      else if FSelecaoContratos.ChaveEmpNome.Empreend > -1 then begin
        AtivaIndice(16);
        ChaveEmpNomeKey.Empreend := 0;
        fillchar(ChaveEmpNomeKey,sizeof(TpMutdskChv16),0);
        ChaveEmpNomeKey.Empreend := FSelecaoContratos.ChaveEmpNome.Empreend;
        if FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo > '' then begin
          ChaveEmpNomeKey.Nome := FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo;
          procurareg(FDBArqcadmut,ChaveEmpNomeKey);
          if ok then
            LeReg(FDBArqCadMut,wMutdsk);
          while not DBEof(FDBArqCadmut) and
               (uppercase(FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo) = uppercase(wMutDsk.Cad.Nome)) do begin
            posicionareg(FDBArqCadmut,xdb.proximo);
            if ok then
              lereg(FDBArqCadmut,wMutdsk);
          end;
        end
        else begin
          ChaveEmpNomeKey.Nome := FSelecaoContratos.ChaveEmpNome.NomeIni;
          procurareg(FDBArqcadmut,ChaveEmpNomeKey);
        end;
      end
      else if FCtrIni > '' then
        ProcuraReg(FDBArqCadmut,FCtrIni)
      else
        PosicionaReg(FDBArqCadmut,xdb.Primeiro);
      if ok then begin
        LeReg(FDBArqCadmut,FMutDsk);
      end;
    end;
  end;
end;

procedure TContratos.Fecha;
begin
  if FQry.Active then
    FQry.close;
  if FAbriuDBArqCadmut then begin
    FechaDBArq(FDBArqCadMut);
    FAbriuDBArqCadMut := false;
  end;
end;

function TContratos.Eof : boolean;
begin
  if FQry.Active then
    result := FQry.eof
  else if FAbriuDBArqCadmut then begin
    result := DBEof(FDBArqCadMut);
    if not result then begin
      LeReg(FDBarqCadmut,FMutDsk);
      if FSelecaoContratos.PorSitCobj then
        result := (FSelecaoContratos.Sitcobj>-1) and (FMutDsk.Cad.SitCobj<>FSelecaoContratos.Sitcobj)
      else if FSelecaoContratos.Cpf > '' then
        result := CpfNum(FMutdsk.Cad.Cpf) <> CpfNum(FSelecaoContratos.Cpf)
      else if FSelecaoContratos.CtrEstrangeiro > '' then
        result := FMutdsk.Cad5.CodCtrEstrangeiro <> FSelecaoContratos.CtrEstrangeiro
      else if FSelecaoContratos.CtrAntSec > '' then
        result := FMutdsk.CadSec.CtrAntSec <> FSelecaoContratos.CtrAntSec

      else if FSelecaoContratos.CtrVelho > '' then begin
        if FSelecaoContratos.CtrVelhoFim > '' then 
          result := FMutDsk.Cad.CtrVelho > FSelecaoContratos.CtrVelhoFim
        else result := FMutDsk.Cad.CtrVelho <> FSelecaoContratos.CtrVelho
      end

      else if FSelecaoContratos.CtrSistemaAntigoIni > '' then begin
        if FSelecaoContratos.CtrSistemaAntigoFim > '' then 
          result := FMutDsk.Cad5.CtrSistemaAntigo > FSelecaoContratos.CtrSistemaAntigoFim
        else result := FMutDsk.Cad5.CtrSistemaAntigo <> FSelecaoContratos.CtrSistemaAntigoIni
      end

      else if FSelecaoContratos.Matricula > '' then begin
        if FSelecaoContratos.MatriculaFim > '' then
          result := FMutDsk.Cad5.MatrIculaFuncionario > FSelecaoContratos.MatriculaFim
        else result := FMutDsk.Cad5.MatriculaFuncionario <> FSelecaoContratos.Matricula
      end

      else if FSelecaoContratos.NomeIni > '' then
        result := uppercase(FMutDsk.Cad.Nome) < uppercase(FSelecaoContratos.NomeIni)
      else if FSelecaoContratos.NomeIniExclusivo > '' then
        result := uppercase(FMutDsk.Cad.Nome) <= uppercase(FSelecaoContratos.NomeIniExclusivo)
      else if FSelecaoContratos.Chaveimv.Empreend > -1 then
        result := (FMutDsk.ChaveImv.Empreend <> Selecao.ChaveImv.Empreend) or
                  ((FMutDsk.ChaveImv.CodImv <> Selecao.ChaveImv.CodImv) and
                   (Selecao.ChaveImv.CodImv > ''))
      else if FSelecaoContratos.ContrMut > '' then begin
        if FSelecaoContratos.ContrMutFim > '' then 
          result := FMutDsk.Cad.ContrMut > FSelecaoContratos.ContrMutFim
        else result := FMutDsk.Cad.ContrMut <> FSelecaoContratos.ContrMut
      end
      else if FSelecaoContratos.Operacao > '' then
        result := FMutdsk.CadSec.Operacao <> FSelecaoContratos.Operacao
      else if FSelecaoContratos.CodCRI > '' then
        result := FMutdsk.CadSec.CodCRI <> FSelecaoContratos.CodCRI
      else if FSelecaoContratos.NumAverbCCI > '' then
        result := FMutdsk.CadSec.NumAverbCCI <> FSelecaoContratos.NumAverbCCI
      else if FSelecaoContratos.CerCefhab > -1 then
        result := FMutdsk.Cad.CerCefHab <> FSelecaoContratos.CerCefHab
      else if FSelecaoContratos.ChaveEmpNome.Empreend > -1 then begin
        if FMutdsk.ChaveImv.Empreend <> FSelecaoContratos.ChaveEmpNome.Empreend then
          result := true
        else if FSelecaoContratos.ChaveEmpNome.NomeIni > '' then
          result := uppercase(FMutDsk.Cad.Nome) < uppercase(FSelecaoContratos.ChaveEmpNome.NomeIni)
        else if FSelecaoContratos.NomeIniExclusivo > '' then
          result := uppercase(FMutDsk.Cad.Nome) <= uppercase(FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo)
        else
          result := false;
      end
      else if FSelecaoContratos.Empresa > -3 then
        result := FMutdsk.Cad.CodEmpresa <> FSelecaoContratos.Empresa 
      else if FSelecaoContratos.ChaveEmpresaNome.Empresa > -3 then begin
        if FMutdsk.Cad.CodEmpresa <> FSelecaoContratos.ChaveEmpresaNome.Empresa then
          result := true
        else if FSelecaoContratos.ChaveEmpresaNome.NomeIni > '' then
          result := uppercase(FMutDsk.Cad.Nome) <= uppercase(FSelecaoContratos.ChaveEmpresaNome.NomeIni)
        else
          result := false;
      end
      else if FCtrFim > '' then
        result := FMutDsk.Cad.Ctr > FCtrFim
      else
        result := false;
    end;
  end
  else
    result := true;
end;

procedure TContratos.Proximo;
begin
  if FQry.Active then
    FQry.Next
  else if FAbriuDBArqCadmut then begin
    if (FSelecaoContratos.Cpf > '') or
       (FSelecaoContratos.CtrVelho > '') or
       (FSelecaoContratos.Matricula > '') or
       (FSelecaoContratos.CtrAntSec > '') or
       (FSelecaoContratos.NomeIni > '') or
       (FSelecaoContratos.NomeIniExclusivo > '') or
       (FSelecaoContratos.Chaveimv.Empreend > -1) or
       (FSelecaoContratos.PorSitCobj) or
       (FSelecaoContratos.CtrEstrangeiro > '') or
       (FSelecaoContratos.CtrSistemaAntigoIni > '') or
       (FselecaoContratos.ContrMut > '') or
       (FSelecaoContratos.Operacao > '') or
       (FSelecaoContratos.CodCRI > '') or
       (FSelecaoContratos.NumAverbCCI > '') or
       (FSelecaoContratos.CerCefHab > -1) or
       (FSelecaoContratos.ChaveEmpNome.Empreend > -1) or 
       (FSelecaoContratos.Empresa > -3) or 
       (FSelecaoContratos.ChaveEmpNome.Empreend > -3) then
      posicionareg(FDBArqCadmut,xdb.proximo)
    else begin
      procuraReg(FDBArqCadmut,FMutDsk.Cad.Ctr);
      if ok and existechave then
        PosicionaReg(FDBArqCadmut,xdb.proximo);
    end;
  end
  else
    raise exception.create(cTabelaNaoEstaAberta);
end;

procedure TContratos.primeiro;
begin
  if FQry.Active then
    FQry.first
  else if FAbriuDBArqCadmut then begin
    ProcuraReg(FDBArqCadmut,FCtrIni);
    if ok then
      LeReg(FDBArqCadmut,FMutDsk);
  end
  else
    raise exception.create(cTabelaNaoEstaAberta);
end;

procedure TContratos.Grava(Var pMutDsk : TpMutDsk);
var
  MutDskAnt : TpMutDsk;
begin
  MutDskAnt.Cad.Ctr := '';
  fillchar(MutDskAnt,sizeof(MutDskAnt),0);
  if FQry.Active then begin
    if Assigned(ContratoDsk) then begin
      ContratoDsk.Le(FMutDsk.Cad.Ctr,MutDskAnt);
      if ContratoDsk.Achou then
        ContratoDsk.Altera(FMutdsk.Cad.Ctr,pMutDsk);
    end;
  end
  else if FAbriuDBArqCadmut then
    GravaReg(FDBArqCadmut,pMutDsk)
  else
    raise exception.create(cTabelaNaoEstaAberta);
  FMutDsk := pMutDsk;
end;

function TContratos.GetMutDsk : tpMutdsk;
begin
  if FQry.Active then begin
    FMutDskCampos.QryToReg(FQry,FMutDsk);
    FMutdsk.Financ.DtInFin.Dia := FMutdsk.Financ.DiaVenc;
    if FMutDsk.Financ.DiaVenc=0 then begin
      FMutDsk.Financ.DtInFIn.Mes := 0;
      FMutDsk.Financ.DtInFin.Ano := 0;
    end;
    MutdskGlobal := FMutdsk;
  end
  else if FAbriuDBArqCadmut then begin
    LeReg(FDBArqCadmut,FmutDsk);
    MutdskGlobal := FMutdsk;
  end
  else
    raise exception.create(cTabelaNaoEstaAberta);
  result := FMutDsk;
end;

