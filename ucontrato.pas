procedure ObtemDataBasePosicaoAtraso(SqlConnection : TSqlConnection; Ctr : string; Var Data : Tdata);
var
  Qry : TSqlquery;
begin
  Qry := TSqlquery.create(nil);
  try
    Qry.sqlConnection := SqlConnection;
    qry.sql.add('SELECT DT_POSICAO_ATRASO FROM POSICAO_ATRASO ');
    qry.sql.add('WHERE CO_CONTRATO=:CoContrato AND ');
    qry.sql.add('DT_POSICAO_ATRASO=:DtPosicaoAtraso');
