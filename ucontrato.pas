procedure CobraCorrecaoNoAmasJ(var RPAS:TpRpa);
var
  JuroSobreCorrecao:Double;
  ll : TLegLinkItem;
begin
  ll := nil;
  if not Contrato.FInibeLegLink then 
    ll := LegLink.add(RPAS.Temp8.CodSerie,'<P/><b>C lculo dos juros vari veis pelo  ndice de corre  o</b>');
  JuroSobreCorrecao := R2((RPAS.FinRPA.TxSD-1) * Rpas.ValRpa.Juro);
  if assigned(ll) then
  begin
    ll.valores['Juro fixo'] := strgrana(Rpas.ValRpa.Juro);
    ll.valores['Base de c lculo juros vari veis'] := strgrana(Rpas.ValRpa.SaldoDev+Rpas.ValRpa.Juro);
    ll.valores['Indice de juros variaveis'] := formatfloat('0.00000000 %',(RPAS.FinRPA.TxSD-1)*100);
    ll.valores['Juros vari veis'] := strgrana(Rpas.Temp.CorrSaldo);
    ll.valores['Juros sobre juros vari veis'] := strgrana(JuroSobreCorrecao);
    ll.valores['Total Juros'] := strgrana(Rpas.ValRpa.Juro+Rpas.Temp.CorrSaldo+JuroSobreCorrecao);
  end;

  if not FusandoJurosPeloValorEmitido { 72719 }
     and fin.in_cobracorr then { 80328 } 
    Rpas.ValRpa.Juro := Rpas.ValRpa.Juro + Rpas.Temp.CorrSaldo + JuroSobreCorrecao;

  if not FusandoAmaisjpeloValorEmitido then 
  begin
    Rpas.ValRpa.AmaisJ := Rpas.ValRpa.AmaisJ + Rpas.Temp.CorrSaldo + JuroSobreCorrecao;
  // ReCalculo da presta  o para SAC
    if ((rpas.FinRPA.Plano mod 10)=SAC) and // (Fin.TpJuros = 7) and
       (rpas.valrpa.amaisj > Zero) then
    begin
      if (Rpas.finrpa.Npc=0) then
       Rpas.Valrpa.AmaisJ := Rpas.ValRpa.Juro
    else if (Rpas.finrpa.Prazo - Rpas.finrpa.Npc) > 0 then
       Rpas.Valrpa.AmaisJ := Rpas.ValRpa.Juro + int((Rpas.ValRpa.SaldoDev/(Rpas.finrpa.Prazo - Rpas.finrpa.Npc +1))*100+0.5)/100
      else 
        Rpas.ValRpa.AmaisJ := Rpas.ValRpa.Juro + (Rpas.ValRpa.SaldoDev);
    end;
  end;
  // Caso a vari vel da s rie de cobran a da corre  o esteja verdadeira
  // ele deve zerar a corre  o porque   a forma da Cibrasec trabalhar
  // neste caso o valor   somado aos juros
  if fin.in_cobracorr then
    Rpas.Temp.CorrSaldo := 0;
end;

procedure CobraCorrecaoNaAmort(var RPAS:TpRpa);
var
  ll : TLegLinkItem;
  JuroSobreCorrecao : real;
  JuroFixo : real;
  SaldoBaseJuros : real;
begin
{
  104092
  Criada a partir da CobraCorrecaoNoAmasJ, mas com o objetivo de trocar o destino da corre  o dos juros para a amortiza  o.
}
  ll := nil;
  if not Contrato.FInibeLegLink then 
    ll := LegLink.add(RPAS.Temp8.CodSerie,'<P/><b>Corre  o do saldo somada   amortiza  o</b>');
  JuroSobreCorrecao := R2((RPAS.FinRPA.Indjuros) * Rpas.Temp.CorrSaldo);
  SaldoBaseJuros := Rpas.ValRpa.SaldoDev+Rpas.Temp.CorrSaldo; // corrsaldo foi tirado antes de chamar esta rotina, ainda na quartafase
  JuroFixo := RPAs.ValRPA.Juro;
  if not FusandoJurosPeloValorEmitido then
    Rpas.ValRpa.Juro := JuroFixo + JuroSobreCorrecao;
  if assigned(ll) then
  begin
    ll.valores['Saldo devedor anterior'] := strgrana(RPAs.ValRPA.SaldoDev);
    ll.valores['Corre  o'] := strgrana(Rpas.Temp.CorrSaldo);
    ll.valores['Saldo Base para c lculo de juros'] := strgrana(SaldoBaseJuros); 
    ll.valores['Indice de juros'] := formatfloat('0.00000000 %',(RPAS.FinRPA.Indjuros)*100);
    if FusandoJurosPeloValorEmitido then
      ll.valores['Total de juros(gravado)'] := strgrana(Rpas.ValRpa.Juro)
    else begin
      ll.valores['Juros Fixo'] := strgrana(JuroFixo);
      ll.valores['Juros sobre a corre  o'] := strgrana(JuroSobreCorrecao);
      ll.valores['Total de Juros(Juros Fixo + Juros sobre a corre  o)'] := strgrana(Rpas.ValRpa.Juro);
    end;
  end;

  if FusandoAmaisjpeloValorEmitido then begin
    if assigned(ll) then begin
      ll.valores['Amaisj(Gravado)'] := strgrana(RPAS.ValRPA.Amaisj);
    end;
  end
  else begin
    if assigned(ll) then
      ll.valores['Amaisj'] := strgrana(RPAS.ValRPA.Amaisj); // na defineamaisjparcela, no caso de fin.IN_COBRACORR, o amaisj   inicializado com o valor da parcela USU
    {
      106863
      Conforme pedido, estou somando os juros sobre a corre  o no novo amaisj.
    }
    Rpas.ValRpa.AmaisJ := Rpas.ValRpa.AmaisJ + Rpas.Temp.CorrSaldo + JuroSobreCorrecao;
    if assigned(ll) then
      ll.valores['Amaisj(Amaisj + Corre  o + Juros sobre a corre  o)'] := strgrana(RPAS.ValRPA.Amaisj);
    // Na CobraCorrecaoNoAmasJ, ao modificar o amaisj, se SAC,   preciso recalcular a presta  o
    // como esta rotina s    chamada para USU, n o foi necess rio.
  end;
  // Diferente da CobraCorrecaoNoAmasJ, foi pedido para neste caso n o zerar a corre  o
end;

procedure DET_DESCONTO;
var
  LegLinkItem : TLegLinkItem;
  DescLeg : ansistring;
  ValorBaseDesc : real;
  ValorBaseDescLeg : ansistring;
begin
  DescLeg := '';
  ValorBaseDesc := 0;
  ValorBaseDescLeg := '';

  if (RPAS.Temp11.MacFimDesc > 0) and (RPAS.Temp11.MacFimDesc <= RPAS.Mac) then
    Rpas.Temp5.TipoDesc := 4;
  case RPAS.Temp5.TipoDesc of
    5 : begin
          RPAs.ValRPA.Desc := int(RPAS.Temp5.PercDesc*(RPAS.ValRPA.TotPrest)+0.5)/100;
          DescLeg := '(('+formatfloat('0.0000',RPAS.Temp5.PercDesc)+'*'+strgrana(RPAS.ValRPA.TotPrest)+'+0.5)/100)';
          ValorBaseDesc := RPAS.ValRPA.TotPrest;
          ValorBaseDescLeg := 'Total da presta  o';
        end;
    4 : RPAs.ValRPA.Desc := 0;
    9 : begin
          RPAs.ValRPA.Desc := int(RPAS.Temp5.PercDesc*(RPAS.ValRPA.Amaisj-RPAS.ValRPA.FGTS)+0.5)/100; //SCAt 36150
          DescLeg := '(('+formatfloat('0.0000',RPAS.Temp5.PercDesc)+'*'+strgrana(RPAS.ValRPA.Amaisj-RPAS.ValRPA.FGTS)+'+0.5)/100)';
          ValorBaseDesc := RPAS.ValRPA.Amaisj-RPAS.ValRPA.FGTS;
          ValorBaseDescLeg := 'Presta  o sem FGTS('+strgrana(RPAS.ValRPA.Amaisj)+'-'+strgrana(RPAS.ValRPA.FGTS)+')';
        end;
    10: begin
          {
            111385
            O desconto sobre o saldo devedor foi originalmente implementado apenas para financ. din mico, na sol. 58580.
            Como eu estava implementando o novo desconto sobre o amaisjOrig, achei melhor padronizar e manter o tipodesc 10
            igual entre s rie e financ. din mico.
          }
          RPAs.ValRPA.Desc := int(RPAS.Temp5.PercDesc*(RPAS.ValRPA.SaldoDev)+0.5)/100;// 111385
          DescLeg := '(('+formatfloat('0.0000',RPAS.Temp5.PercDesc)+'*'+strgrana(RPAS.ValRPA.SaldoDev)+'+0.5)/100)';
          ValorBaseDesc := RPAS.ValRPA.SaldoDev;
          ValorBaseDescLeg := 'Saldo Devedor';
        end;
    11: begin
          RPAs.ValRPA.Desc := int(RPAS.Temp5.PercDesc*(RPAS.Temp10.AmaisjOrig)+0.5)/100;// 111385
          DescLeg := '(('+formatfloat('0.0000',RPAS.Temp5.PercDesc)+'*'+strgrana(RPAS.Temp10.AmaisjOrig)+'+0.5)/100)';
          ValorBaseDesc := RPAS.Temp10.AmaisjOrig;
          ValorBaseDescLeg := 'Amaisj Original';
        end;
  end;
  if DescLeg > '' then begin
    LegLinkItem := LegLink.add(RPAS.Temp8.CodSerie,'<b>C lculo do desconto</b>');
    if assigned(LegLinkItem) then begin
      LegLinkItem.valores[ValorBaseDescLeg] := Strgrana(ValorBaseDesc);
      LegLinkItem.valores['Perc.Desc'] := formatfloat('0.0000',RPAS.Temp5.PercDesc);
      LegLinkItem.valores['Desconto calculado'+DescLeg] := StrGrana(RPAs.ValRPA.Desc);
    end;
  end;
  AtualizaTotPrest(RPAs);
end;

Procedure QuartaFase;
var
  AmaisjIntegralRed : real; MACMA: TMes_Ano;
  LegLinkItem: TLegLinkItem;
begin
  LegLinkItem := nil;
  with RPAS do begin
          // primeiro momento - antes da altera  o, o saldo chegava sem a amortiza  o, ent o
          //                    quero imitar a logica anterior
          // depois de ajustar para triar a amortiza  o antes da POSCALCOPC, 
          // o exemplo de Lan depois do vencimento, passou a gerar um saldo negativo aqui(saldo zerado - juro)
          // assim, inibi este bloco(o teste do status nem chegou a ser efetivado)
          // if amortizouSaldo and (FinRpa.Status = 0) then // depois de uma lan, o saldo j  est  zerado(zerou na segunda fase), n o pode tirar a amortiza  o
          // begin
          //    ValRpa.SaldoDev := ValRpa.SaldoDev + ValRpa.AmaisJ - ValRpa.Juro;
          //    amortizouSaldo := false;
          // end;
      if //(Parcelas.Count<Finrpa.Prazo) or (Parcelas.Count=0) or
         (Mes_Int(FinRPA.DtAssin.MesAno) > succ(Mes_Int(DataH.MesAno))) or  //SCAt 23252
         (Mes_Int(FinRPA.DtAssin.MesAno) > succ(Mes_Int(FinRPA.DtInFin.MesAno))) then begin
        TerminaCtr(RPAS,4,DiaLiqTmp,MacDoDiaLiqTmp);
      end;
      int_mes(MAC, MACMA);
      Valrpa.Desc :=0; //Futuramente poder  prever outros casos de desconto.
      if fin.in_cobracorr then
        Rpas.ValRpa.SaldoDev := Rpas.ValRpa.SaldoDev - Rpas.Temp.CorrSaldo;
      if abs(ValRPA.Juro) < Zero then CalcJuro(DiaVencAnt); // Pode ter sido calcula na amortizaantecipacoes
      if fin.in_cobracorr or rpas.temp12.INCCORRSDAMORT {80328} then begin
        {
          104092
          Resolvi voltar atr s e n o alterar a CobraCorrecaoNoAmasJ.
          Vou criar uma nova, baseada nela, mas jogando a corre  o na amortiza  o, como solicitado.
        }
        if (Rpas.temp7.TipoCtr=40) and ((RPAs.FinRPA.Plano mod 10)=SisAmUsu) then // 104092
          CobraCorrecaoNaAmort(RPAS)
        else 
          CobraCorrecaoNoAmasJ(RPAS);
      end;
      if fin.in_cobracorr then // 104092 - a corre  o foi retirada do saldo antes do tratamento da corre  o no amaisj/amort, 
                                //          mas foi pedido para esta corre  o seja sim somada ao saldo, ent o estou devolvendo o valor.
        Rpas.ValRpa.SaldoDev := Rpas.ValRpa.SaldoDev + Rpas.Temp.CorrSaldo;
      if Fin.CobraJurosNaCarencia and (MAC < Mes_Int(Fin.DtInicio.MesAno)) and
        (Abs(ValRPA.AmaisJ - ValRPA.Juro) <= 0.02) then { 057948 } 
        ValRPA.Juro := ValRPA.AmaisJ;
      if (ValRPA.SaldoDev>Zero) or (Fin.SistAmort = SisAmFianca) then begin
         Amortizacao := ValRPA.AmaisJ - ValRPA.Juro;
      end   
      else
       Amortizacao := 0;
      if (RPAS.TEMP12.JURPRORATAProxVENC > 0) and (FinRPA.NPC>0) and 
         (ValRpa.AmaisJ > Zero) then
      begin
        if not FusandoAmaisjpeloValorEmitido then
        begin
          if not Contrato.FInibeLegLink then 
            LegLinkItem := LegLink.Add(CodSerie,'<P/><b>Cobran a de juros pro rata da altera  o de vencimento</b>');
          if assigned(LegLinkItem) then 
          begin
            LegLinkItem.Valores['AmaisJ anterior'] := strgrana(ValRPA.AmaisJ);
            LegLinkItem.Valores['Juros pro rata'] := strgrana(RPAS.Temp12.JurProRataPRoxVenc);
            LegLinkItem.Valores['Novo amaisj'] := strgrana(ValRPA.AmaisJ+RPAS.Temp12.JurProRataPRoxVenc);
            LegLInkItem.Valores['Juro anterior'] := strgrana(RPAS.ValRpa.Juro);
            LegLInkItem.Valores['Novo juro'] := strgrana(RPAS.ValRpa.Juro+RPAS.Temp12.JurProRataPRoxVenc);
          end;
          ValRPA.AmaisJ := ValRPA.AmaisJ + RPAS.TEMP12.JURPRORATAProxVENC;
          RpaS.ValRpa.Juro := RPAS.ValRPA.Juro + RPAS.TEMP12.JURPRORATAProxVENC;
        end;
        // Zera os juros a descarregar mesmo que n o possa descarregar porque
        // o valor do amaisj est  pelo valor emitido
        RPAS.TEMP12.JURPRORATAProxVENC := 0;
      end;
      if ValRPA.AmaisJ < Zero then ValRPA.AmaisJ := 0; // SCAt 32892
// saldodev n o estava amortizado, agora passou a estar
// amortiza  o ficou maior que o saldo devedor, fazendo setar o status 7        
      if ((Amortizacao+0.02) > ValRpa.SaldoDev) and (FinRpa.Status = 0) and
         ((FinRpa.Plano mod 10) <> 8{Aluguel}) and (FinRpa.NPC <> FinRpa.Prazo{sol. 36932}) then
      begin
        if not FUsandoAmaisJPeloValorEmitido or rpas.Temp11.CobSDResUltPrest or
           SCCIConf.AmortizaSaldoResidualTPZCtrSemFcvs then
        begin
          ValRpa.AmaisJ := ValRpa.SaldoDev + ValRPa.Juro;
          Amortizacao := ValRPa.SaldoDev;
        end;
        if CodErro = 1 then CodErro := 2; (* Se n o tem  ndice para corre  o do saldo a  ltima parcela ficar  errada *)
        if not (assigned(FParceladoMes) and ((FParceladoMes.Saldo > 0) or (FParcelaDoMes.Flag=102))) then
        begin 
          Temp12.StatusAnt := FinRpa.Status;
          FinRpa.Status := 7;
          if ValRpa.MacStatus = 0 then begin
            Temp12.MacStatusAnt := ValRpa.MacStatus;
            ValRpa.MacStatus := MAC;
          end;
        end;
        Temp12.DiaLiqAnt := FinRpa.Dialiq;
        if (FUltDiaPgAntec > 0) and (abs(FPagamentoAntecipadonomes)> Zero) then 
          FinRPA.DiaLiq := FUltDiaPgAntec
        else
          FinRpa.DiaLiq := FinRpa.DiaVenc;
      end
      else if (ValRPA.MACStatus <= MAC )  and (not CTR_ATIVO(RPAS)) then
             ZeraPrest(RPAS);
      if (FinRPA.NPC>=FinRPA.Prazo) and 
         ( (FinRPA.Status=0) or 
           ( (FinRPA.Status=7) and (abs(FPagamentoAntecipadonomes)<=Zero) and (MAC=ValRpa.MACStatus) ) ) then begin // SCAt 30874
        if not AmortizouposVenc and
           not ((FinRpa.Plano mod 10) = 8 {Aluguel}) then begin
          if amortizouSaldo then
          begin
            ValRpa.SaldoDev := ValRpa.SaldoDev + ValRpa.AmaisJ - ValRpa.Juro;
            amortizouSaldo := false;
          end;
          if (abs(ValRPA.Amaisj-(Valrpa.SaldoDev+ValRPA.Juro))<Temp.Corrsaldo ) and
             Assigned(FParcelaDomes) and (FParceladoMes.ValorEmitido>Zero) then begin//SCAt 50071
            Temp.CorrSaldo := Temp.Corrsaldo-(Valrpa.Amaisj-ValRPA.SaldoDev-ValRPA.Juro);
          end
          else if (not Assigned(FParcelaDomes)) or (FParceladoMes.ValorEmitido<=Zero) then //SCAt 69464
            ValRpa.AmaisJ := ValRpa.SaldoDev + ValRpa.Juro;
          if CodErro = 1 then CodErro := 2; (* Se n o tem  ndice para corre  o do saldo a  ltima parcela ficar  errada *)
          Amortizacao := ValRpa.Amaisj - ValRpa.Juro;
          
          if assigned(FParceladomes) then begin
            if FParceladoMes.TipoPg in PgtoComRedSdDev then AmaisjIntegralRed:=0
            else AmaisjIntegralRed := Temp5.AmaisJIntegral * (1-Temp10.IndRedPrest);
          end
          else AmaisjIntegralRed := 0;
          if (scciconf.LimiteMaxParaDescNaUltParcela > Zero) and 
             (scciconf.LimiteMaxParaDescNaUltParcela >=
              (ValRpa.AmaisJ - {Temp10.AmaisJOrig}AmaisjIntegralRed)) then 
          begin
            ValRpa.Desc := ValRpa.AmaisJ - {Temp10.AmaisJOrig}AmaisjIntegralRed;
          end;
        end;
        Temp12.StatusAnt := FinRpa.Status;
        FinRPA.Status := 8;
        if ValRPA.MACStatus = 0 then begin
          Temp12.MacStatusAnt := ValRpa.MacStatus;
          Valrpa.MACStatus := MAC;
        end;
        Temp12.DiaLiqAnt := FinRpa.Dialiq;
        FinRpa.DiaLiq := FinRpa.DiaVenc;
        Temp11.MACCarenciaFinBanChv := ValRpa.MACStatus + (TemCarenciaAtrasoFinBancChaves Div 30);
      end;
      if not AmortizouSaldo then 
        ValRPA.SaldoDev := arredonda(ValRPA.SaldoDev - Amortizacao);
      if (ValRpa.Amaisj > 0) then
      begin
        if (Fin.SistAmort = 7) then
          Temp12.SaldoPrincipal := Temp12.SaldoPrincipal - Temp.ValTmp2 * (1-Temp10.IndRedPrest){ Valor da amortiza  o da parcela }
        else
          if (ValRpa.AmaisJ - ValRpa.Juro) > 0 then
            Temp12.SaldoPrincipal := Temp12.SaldoPrincipal - (ValRpa.AmaisJ - ValRpa.Juro);
      end;
      if Temp6.AmSaldoAntCorr then begin
        Temp.CorrSaldo := R2((FinRPA.TxSD-1) * ValRPA.Saldodev);
        ValRPA.SaldoDev := ValRPA.SaldoDev + Temp.CorrSaldo;
      end;
      if ((FinRPA.Plano mod 10)=SisAmUsu) and
           fin.EvoluiUsuEmPxN and 
         { Tem parcela no m s e n o tem o saldo j  calculado no arquivo de parcelas }
         Assigned(FParceladoMes) and
         (not ((abs(FParcelaDoMes.Saldo) > zero) and ScciConf.UsaArqPrest))
         then 
      begin
        EvoluiSaldoEmPxN;
        if (Temp11.PlanoSwap = 0) then // Igual ao financiamento 
          EvoluiSaldoSwapEmPxN;
      end;
//      Calc_Eventos_No_E_Apos_Venc;  // antiga Calc_multiplas_Aminc_No_E_Apos_Venc;
//      FazAjustesAntecipacoes;
      if FUsandoAmaisJPeloValorEmitido and  (ValRpa.SaldoDev<0) and
        not (Assigned(FParceladoMes) and (FParcelaDoMes.Saldo > Zero)) then
      begin
        Temp.CorrSaldo := Temp.CorrSaldo - ValRpa.SaldoDev;
        ValRpa.SaldoDev := 0;
      end;
      if (Assigned(FParceladoMes) and
         (Abs(FParcelaDoMes.Saldo - ValRpa.SaldoDev) > Zero)) and 
         (FParceladoMes.Flag<>103) and
         ((abs(FParcelaDoMes.Saldo) > zero) or (FParcelaDoMes.Flag = 102)) and
         // Deve entrar se o status for zero ou se for o termino do contrato se n o cobrar o res duo na ultima presta  o
         // No termino do contrato o npc tem que ser maior que zero porque 
         //   antes de come ar o contrato fica com status 4 e n o deve entrar
         //   o teste do npc > 0 n o pode estar fora porque tem que entrar
         //   para o per odo de car ncia quando o npc = 0, mas o contrato est 
         //   ativo.
         // Tamb m n o deve entrar para t rmino por cess o, uma vez que a diferen a n o deve ir para a corre  o.
         ((FinRpa.Status = 0) or 
            (not(FinRpa.Status in [10{Scat 75964},70]{Scat71281}) and (rpas.finrpa.NPC >0) and not(SCCIConf.AmortizaSaldoResidualTPZCtrSemFCVS or Temp11.CobSDResUltPrest))) and
         (not DesconsideraSaldoParcela) and ScciConf.UsaArqPrest then
      begin // Recalcula a corre  o do m s ou a amortiza  o do m s caso existe diferen a do
            // Saldo Calculado para o saldo gravado nas parcelas
        if (FParceladoMes.Saldo > ValRpa.SaldoDev) then
        begin
          ValRpa.SaldoDev := ValRpa.SaldoDev - Temp.CorrSaldo;
          Temp.CorrSaldo := FParceladoMes.Saldo - ValRpa.SaldoDev;
          ValRPA.SaldoDev := ValRpa.Saldodev + Temp.CorrSaldo;
        end
        else
        begin
          RPAS.FinRPA.ValorAI := Rpas.FinRpa.ValorAI - (FParceladoMes.Saldo - ValRpa.SaldoDev);
          ValRpa.SaldoDev := FParceladoMes.Saldo;
        end;
        Rpas.ValRpa.Juro := int(RPAS.FinRPA.IndJuros*(RPAS.ValRPA.Saldodev+(ValRPA.Amaisj-ValRPA.Juro))*100+0.5)/100;
        if ScciConf.UsaArqPrest and 
          ((FParcelaDoMes.JurosEmi >= zero) or (FParcelaDoMes.Flag = 102)) then
        begin
          FUsandoJurosPeloValorEmitido := true;
          RpaS.ValRpa.Juro := FParcelaDoMes.JurosEmi;
        end;
        if ((FParceladoMes.ValorEmitido > Zero) or (FParcelaDoMes.Flag = 102)) and 
            (not FDesconsideraParcela) and
            ScciConf.UsaArqPrest then     
          Rpas.ValRpa.Amaisj := FParcelaDoMes.ValorEmitido;
      end;
      ValRpa.SaldoDev := arredonda(ValRpa.SaldoDev);
      Temp12.SaldoVenc := Valrpa.SaldoDev - FListaEventosAmInc.SomaValorAIAposVenc;
      if Assigned(FParceladoMes) and (FParceladoMes.Flag=103) then 
        Temp12.SaldoVenc := FParceladoMes.Saldo;
      if (abs(ValRpa.SaldoDev) <= zero) and (FinRpa.Status = 0) and
         ((FinRpa.Plano mod 10) <> 8{Aluguel}) and (FinRpa.NPC <> FinRpa.Prazo{sol. 36932}) and
         ((not Assigned(FParcelaDoMes)) or (FParcelaDoMes.Flag <> 102)) then begin
        Temp12.StatusAnt := FinRpa.Status;
        FinRpa.Status := 7;
        if ValRpa.MacStatus = 0 then begin
          Temp12.MacStatusAnt := ValRpa.MacStatus;
          ValRpa.MacStatus := MAC;
        end;
        Temp12.DiaLiqAnt := FinRpa.Dialiq;
        FinRpa.DiaLiq := FinRpa.DiaVenc;
      end;
      ValRPA.Coment := FinRPA.ExOpc;
      if ValRPA.Coment = 0 then ValRPA.Coment := FinRPA.ExAmInc;
      ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
      // Hoje tem que ser zerado, pois no c lculo de seguros, ser  acumulada.
(*---- Movido daqui pela sol071434 mais para baixo ap s o TotPrest ser definido (-FGTS)
      if assigned(FParcelaDoMes) then begin
        if FParcelaDoMes.ValorDescConcedido > zero then ValRpa.Desc := ValRpa.Desc + FParcelaDoMes.ValorDescConcedido
        else if FParcelaDoMes.PercDescConcedido > zero then ValRpa.Desc := ValRpa.Desc + int(FParcelaDoMes.PercDescConcedido*(ValRpa.TotPrest-ValRPA.Desc)+0.5)/100;
      end;
-----------------------------------------------------------------------*)
      (* --- Scat 72164 
         O C lculo do ValAvalCorr foi movido para a CalculaValAvalCorr
         que   chamada na consolidarpas dentro da calculaseguro
         Foi necess rio porque o ValAvalCorr precisa ser continuar sendo
         corrigido quando passa de uma s rie para outra, 
      ValAvalAux := FinRPA.ValAval;
      if Abs(ValAvalAux) > Zero then begin
        if Temp5.MACAval = MAC then
          Temp12.IndSaldoAcumMacAval := Temp3.IndSaldoAcum * FinRPA.TxSD;
        if Temp5.MACAval > 0 then
          AjustaMoeda2(Temp5.MACAval,Mac,ValAvalAux)
        else
          AjustaMoeda2(mes_int(FinRPA.DtAssin.mesano),Mac,ValAvalAux);
        if Temp12.IndSaldoAcumMacAval > zero then 
          Temp12.ValAvalCorr := int((ValAvalAux*Temp3.IndSaldoAcum*FinRPA.TxSD/Temp12.IndSaldoAcumMacAval*100) + 0.5)/100
        else 
          Temp12.ValAValCorr := ValAvalAux;
      end;
      *)
      EvoluiSaldoAmortNeg;
      ValRpa.FGTS := 0;
      AtualizaTotPrest(RPAS);
      DET_DESCONTO;
      if assigned(FParcelaDoMes) and (not FDesconsideraParcela) and
         ((FParcelaDoMes.FGTSEmi > zero) or (FParcelaDoMes.Flag=102)) then begin
        if FParcelaDoMes.FGTSEmi > zero then
          ATUALIZA_FGTS(RPAS,FParcelaDoMes.FGTSEmi, 0, 0,0,false,false,false) //SCAt 66936
        else ValRpa.Fgts := 0;
      end
      else
        ATUALIZA_FGTS(RPAS,0,0,0,0,false,false,false);
//         ValRpa.FGTS := FParcelaDoMes.FGTSEmi;
      ValRpa.FGTS := int( ValRPA.FGTS * 100 + 0.5 ) / 100 ;
      ValRpa.TotPrest := ValRpa.TotPrest - ValRpa.FGTS;
      ValRpa.TotPrest := int( ValRpa.TotPrest * 100 + 0.5 ) / 100;
      if assigned(FParcelaDoMes) then begin
        if FParcelaDoMes.ValorDescConcedido > zero then ValRpa.Desc := ValRpa.Desc + FParcelaDoMes.ValorDescConcedido
        else if FParcelaDoMes.PercDescConcedido > zero then ValRpa.Desc := ValRpa.Desc + int(FParcelaDoMes.PercDescConcedido*(ValRpa.TotPrest-ValRPA.Desc)+0.5)/100;
      end;
  end;
end;

function CalculaValorFuturoLiquidoDeAntecipacoes:Double;
var
  i,maci : Integer;
  ValorPresenteLiquido,
  ValorFuturoLiquido,
  ValTaxaGestao: Double;
begin
  Result := 0;
  for i := 0 to FparcelasAntecipadasNoMes.Count-1 do
  begin
    with FparcelasAntecipadasNoMes[i] as TParcelaSerie do
    begin
      MacI := mes_int(Rpas.FinRpa.DtAssin.MesAno);
      if  Rpas.Sec.TpTaxaGestao = 3 then
//        ValTaxaGestao := int(Rpas.Sec.PercTaxaGestao * Rpas.Temp3.IndSaldoAcum*100+0.5)/100
        ValTaxaGestao := int(Rpas.Sec.PercTaxaGestao * Rpas.Temp5.TxPstAcum*100+0.5)/100
      else
        ValTaxaGestao := 0; // S  existe esta implementa  o para tipo de taxa de gest o = 3;

      ValorPresenteLiquido := PresentValue(Fin.TxJuros/1200,mac-maci,0,Valor*Rpas.Temp3.IndSaldoAcum-ValTaxaGestao,PtEndOfPeriod);
      ValorFuturoLiquido := FutureValue(Fin.TxJurosDesconto/1200,rpas.mac-maci,0,ValorPresenteLiquido,ptEndOfPeriod);
        Result := Result + ValorFuturoLiquido;
    end;
  end;
end;

procedure CalculaAdquirido;
begin
  with RPAS.sec3, RPAS do
    if not Fin.SerieNaoSecuritizada then begin
      AmaisJAdquirido        := ValRpa.AmaisJ - Sec.AmaisJColateral;
      JuroAdquirido          := ValRpa.Juro - Sec.JuroColateral;
      CorrSaldoAdquirido     := Temp.CorrSaldo - Sec.CorrSaldoColateral;
      SaldoDevAdquirido      := ValRPA.SaldoDev - Sec.SaldoDevColateral;
      SaldoDevAntAdquirido   := Temp.SalDevAnt - Sec.SaldoDevAntColateral;
    end
    else begin
      AmaisJAdquirido        := 0;
      JuroAdquirido          := 0;
      CorrSaldoAdquirido     := 0;
      SaldoDevAdquirido      := 0;
      SaldoDevAntAdquirido   := 0;
    end;
end;
                                                        
procedure CalculaJurosSwap;
var
  DtIniJuros,
  Dt2: TData;
  LegLinkItem: TLegLinkItem;
  UltimoDiaMes: boolean;
  IndJurosSwap: Double;
begin
  LegLinkItem := nil;
  if (rpas.Temp11.PlanoSwap = 8) then // Juros definidos pelo usu rio
  begin
    if assigned(FParcelaDoMes) then
      Rpas.Sec.JuroSwap := int(FParcelaDoMes.JSwap*Rpas.sec.TxPstSwap*100+0.5)/100
    else
      Rpas.Sec.JuroSwap := 0;
  end
  else
  begin
    DtIniJuros := RPAS.FinRpa.DtAssin;
    if (Fin.DtCarenciaDeJuros.Dia > 0) and
       (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
       DtIniJuros := Fin.DtCarenciaDeJuros;

    if (Fin.DtCarenciaJurosSwap.Dia > 0) and
       (Juliano(Fin.DtCarenciaJurosSwap) > Juliano(RPAS.FinRpa.DtAssin)) then
       DtIniJuros := Fin.DtCarenciaJurosSwap;

    if Rpas.Temp11.TxJurosSwap > Zero then
      IndJurosSwap :=  Rpas.Temp11.TxJurosSwap/1200
    else if Fin.EvoluiAgioCalcSwap then
      IndJurosSwap := Fin.TxJurosDesconto/1200
    else
      IndJurosSwap := RPAS.FinRPA.IndJuros;

    if Fin.JurProRata or Fin.IncluiFracaodoMes then
    begin
      if  (RpaS.Mac = mes_int(DtIniJuros.MesAno)) then 
      begin
        UltimoDiaMes :=  (DtIniJuros.Dia>=DIAS_MES(mes_int(DtIniJuros.MesAno))) and
                         (FDiaVencOrig{Fin.DtInicio.Dia}>=DIAS_MES(mes_int(DtIniJuros.MesAno)));
        if (Fin.JurProRata) and (FDiaVencOrig{Fin.DtInicio.Dia} > DtIniJuros.Dia) and (not UltimoDiaMes) then 
          IndJurosSwap := pot(1+IndJurosSwap,(FDiaVencOrig{Fin.DtInicio.Dia} - DtIniJuros.Dia)/30)-1
        else 
        begin
          if Fin.IncluiFracaodoMes then // A taxa permanece a mesma
          else IndJurosSwap := 0; 
        end;
      end 
      else if  (RpaS.Mac = mes_int(DtIniJuros.MesAno)+1) then 
      begin
        if (FDiaVencOrig {Fin.DtInicio.Dia} < DtIniJuros.Dia) then 
        begin
          Dt2 := DtIniJuros; Dt2.Dia := FdiaVencOrig {Fin.DtInicio.Dia}; INCMA(Dt2.MesAno);
          if Fin.ProRataJurosDiasCorridos then
            IndJurosSwap := pot(1+IndJurosSwap,((Juliano(Dt2) - Juliano(DtIniJuros))/30))-1
          else 
            IndJurosSwap := pot(1+IndJurosSwap,(30+(FDiaVencOrig {Fin.DtInicio.Dia} - DtIniJuros.Dia))/30)-1
        end;
      end
      else if (Rpas.Mac < mes_int(DtIniJuros.MesAno)) then
        IndJurosSwap := 0;
      if not Contrato.FInibeLegLink then 
        LegLinkItem := LegLink.Add(CodSerie,'<P/>Calculo de Juros Pro Rata Swap');
      if assigned(LegLinkItem) then
      begin
        if Fin.ProRataJurosDiasCorridos then 
        begin
          LegLinkItem.Valores['DataInicial'] :=Data_Str(DtIniJuros);
          LegLinkItem.Valores['DataFinal'] := Data_Str(Dt2);
        end
        else 
        begin
          LegLinkItem.Valores['DiaInicial'] :=inttostr(FDiaVencOrig {Fin.DtInicio.Dia});
          LegLinkItem.Valores['DiaFinal'] := inttostr(DtIniJuros.Dia);
        end;
        if Fin.ProRataJurosDiasCorridos then
          LegLinkItem.Valores['N mero de dias numerador (DataFinal - DataInicial)'] := inttostr(Juliano(Dt2) - Juliano(DtIniJuros))
        else
          LegLinkItem.Valores['N mero de dias numerador (30+(Dia Inicial - Dia Vencimento)'] := inttostr(30+(FDiaVencOrig{Fin.DtInicio.Dia} - DtIniJuros.Dia));

        LegLinkItem.Valores['N mero de dias denominador'] := inttostr(30);
        LegLinkItem.Valores['IndProrataSwap'] := formatfloat('0.00000000',IndJurosSwap);
      end;
    end;

    if not ((fin.EvoluiUsuEmPxN or
             ((Fin.SistAmort = 7) {SCP} and Fin.JurosSimples)) and (Rpas.Temp11.planoswap = 0){Igual ao financiamento}
             // Nestes casos os juros s o calculados em outro ponto
           ) then
    begin
      Rpas.Sec.JuroSwap := int(IndJurosSwap*Rpas.Sec.SaldoDevSwap*100+0.5)/100
    end;
  end;
end;

procedure CalculaSecuritizacao;
var
  DataUltDiaMes : TData;
  SaldoDesagioISwapAnt,
  ValorPresenteLiquido,
  ValorFuturoLiquido,
  ValorFuturoLiquidoDeAntecipacoes : Double;
begin                                                   
  with RPAS do begin

// Trata Colateral scat 17162
      if Sec.PercColateral>=Zero then 
      with Sec do begin
        if CorrSaldoColateral = 0 then // Pode j  ter sido calculado na amortiza antecipa  es
        begin
          if fin.EvoluiUsuEmPxN then
            CorrSaldoColateral := R2(Rpas.Temp.CorrSaldo) * Sec.PercColateral
          else 
            CorrSaldoColateral   := R2((FinRPA.TxSD-1)*SaldoDevColateral);
          SaldoDevAntColateral := SaldoDevColateral;
          SaldoDevColateral    := SaldoDevColateral + CorrSaldoColateral;
        end;
        if JuroColateral = 0 then // Pode j  ter sido calculado na amortiza antecipa  es
          CalculaJuroSecuritizacao;
        Amortizacao := R2(AmaisJColateral - JuroColateral);
        if (Amortizacao > SaldoDevColateral) or (finrpa.npc = finrpa.prazo) then begin
          Amortizacao     := SaldoDevColateral;
          AmaisJColateral := SaldoDevColateral + JuroColateral;
        end;
        SaldoDevColateral := R2(SaldoDevColateral - Amortizacao);
      end;

      // Trata Saldo Swap scat 17162
      if (Temp12.CodReajSwap>0) or (Temp11.TxJurosSwap > Zero) or 
         (Temp11.PlanoSwap>0) then 
      with RPAS.Sec do begin
        int_mes(Mac,DataUltDiaMes.MesAno);
        DataUltDiaMes.Dia := Dias_Mes(Mac);
        SaldoOperSwap := SomadasParcelasEmAberto(DataUltDiaMes) * (1 - Sec.PercColateral);
        // DeterminaTxSdSwap; J  foi calculado na segunda fase
        // Ajusata a amortiza  o antes do vencimento swap para o valor m ximo
        // do saldo devedor
        if FValorAntecAntesVencSwap > SaldoDevSwap then
          FValorAntecAntesVencSwap := SaldoDevSwap;
        SaldoDevSwap := SaldoDevSwap - FValorAntecAntesVencSwap;
        CorrSaldoSwap := R2((TxSDSwap-1) * SaldodevSwap);
        SaldoDevAntSwap := SaldoDevSwap;
        SaldodevSwap := SaldoDevSwap + CorrSaldoSwap;

        CalculaJurosSwap;

        Amortizacao := AmaisjSwap - JuroSwap;
        Temp12.VlrAmortSwap := FValorAntecAntesVencSwap +
            FValorAntecPosVencSwap + FValorAntecNoVencSwap; { Scat 43475 }
        if (Amortizacao > SaldoDevSwap) or (finrpa.NPC=finrpa.Prazo) then 
        begin 
            Amortizacao := SaldoDevSwap-FValorAntecNoVencSwap-FValorAntecPosVencSwap; 
            AmaisJSwap := SaldoDevSwap + JuroSwap-FValorAntecNoVencSwap-FValorAntecPosVencSwap;
        end
        else
        begin
          Amortizacao := AmaisjSwap - JuroSwap;
        end;
        SaldoDevSwap := SaldoDevSwap - Amortizacao - Temp12.VlrAmortSwap + FValorAntecAntesVencSwap;
        // Ajusta se a amortiza  o levar a um saldo negativo
        if (SaldoDevSwap < 0) and (Temp12.VlrAmortSwap > SaldoDevSwap) then
        begin
          Temp12.VlrAmortSwap := Temp12.VlrAmortSwap + SaldoDevSwap;
          SaldoDevSwap := 0;
        end;
        if FAlterouValCed then begin
          SaldoDevSwap := Temp3.ValCed; //SCAt 52811
          FinRpa.Plano := Temp11.PlanoSwap + 110;
          AmaisjSwap := int( CalcAmaisJ( FinRPA.Plano,FinRPA.Prazo-FinRPA.NPC+1,SaldoDevSwap,Temp11.TxJurosSwap/1200)*100)/100;
        end;
        if (RPAS.FinRPA.Status  = 1) and (Rpas.MAC = RPAS.ValrPA.MacStatus) and
           (Rpas.FinRpa.DiaLiq >= Rpas.FinRpa.DiaVenc) then
        begin
          RPas.Temp12.VlrLiqSwap := Rpas.sec.SaldoDevSwap;
        end;
      end;
      with RPAS.Sec, RPAS.FinRPA, RPAS.ValRPA, RPAS.Temp do begin
      if ((RPAS.Temp12.CodReajSwap=0) or ((Temp12.CodreajSwap=FinRPA.CodReaj) and (Defas=Temp12.DefSwap) ) ) and
         (RPAS.Temp11.PlanoSwap=0) and
         ((abs(Temp11.TxJurosSwap)<=Zero) or (abs(Fin.TxJuros-Temp11.TxJurosSwap)<=Zero)) then begin  //SCAt 49581
        TxSDSwap := TxSD;
        CorrSaldoSwap   := R2(CorrSaldo - CorrSaldoColateral);
        SaldoDevAntSwap := SaldevAnt;
        AmaisJColateral := R2(AmaisJColateral);
        AmaisJSwap   := R2(AmaisJ - AmaisJColateral);
        SaldoDevSwap := SaldoDev - SaldoDevColateral;
        JuroSwap     := R2(Juro - JuroColateral);
      end;
      if fin.SerieNaoSecuritizada then begin
        CorrSaldoSwap := 0; AmaisjSwap := 0; Saldodevswap := 0; JuroSwap:=0;
      end;
      end; //with

      // Determina o valor do des gio
      if not ((Fin.TpJuros = 2) and (abs(Fin.TxJuros-Fin.TxJurosDesconto)<Zero)) then
      begin
        with Sec do 
        begin
          SaldoDesagioAnt := SaldoDesagio;
          SaldoAdquirido  := R2(ValRPA.SaldoDev - SaldoDevColateral);
          if (fin.TpJuroSec = 6) or (fin.TpJuroSec = 7) { Por Dia Corrido Efetivo 360  ou Efetivo / 252} then
          // Scat 62948 nestes casos n o   respeitada a vari vel TpCalcDesagio
          begin
            SaldoDesagio := SaldoDesagioAnt -
               (CalculaJurosDescontoPorDiasCorridosOuUteis(diavencant) - rpas.valrpa.juro); 
            if SaldoDesagio < 0 then
              SaldoDesagio := 0;
          end
          else if TpCalcDesagio = 2 then // Calculo pelo percentual diferido
          begin
           VPLTaxaDesconto := 0;
            SaldoDesagio := int(SaldoAdquirido * PercDesagio + 0.5) / 100.00;
          end
          else
          begin // C lculo pelo VPL
            VPLTaxaDesconto := Temp3.IndSaldoAcum *
               (1-Temp10.IndRedPrest) *
               ValorPresentedasParcelasAdquiridasRemanescentes( MAC, Fin.TxJurosDesconto/1200 );
            if VPLTaxaDesconto < SaldoAdquirido then 
              SaldoDesagio := R2(SaldoAdquirido-VPLTaxaDesconto)
            else 
              SaldoDesagio := 0;
          end;
          ParcelaDesagio := R2(SaldoDesagioAnt-SaldoDesagio);
        end;

        // Determina valor do desagio no indice swap Scat 21698
        with Sec2 do
        begin
          if (Temp12.CodReajSwap>0) and (SaldoAdquirido > Zero) then 
          begin
            SaldoDesagioISwapAnt := SaldoDesagioISwap;
            if Sec.TpCalcDesagio = 2 then // Calculo pelo percentual diferido
            begin
              VPLTaxaDescontoISwap := 0;
              SaldoDesagioISwap := int(Sec.SaldoDevSwap * Sec.PercDesagio + 0.5) / 100.00;
            end
            else
            begin // C lculo pelo VPL
              VPLTaxaDescontoISwap := int((Sec.VPLTaxaDesconto / SaldoAdquirido * Sec.SaldoDevSwap)*100+0.5)/100;
              if VPLTaxaDescontoISwap < Sec.SaldoDevSwap then
                SaldoDesagioISwap := Sec.SaldoDevSwap - VPLTaxaDescontoISwap
              else SaldoDesagioISwap := 0;
           end;
           ParcelaDesagioISwap := SaldoDesagioISwapAnt-SaldoDesagioISwap;
          end
          else
          begin
            VPLTaxaDescontoISwap := Sec.VPLTaxaDesconto;
            SaldoDesagioISwap := Sec.SaldoDesagio;
            ParcelaDesagioISwap := Sec.ParcelaDesagio;
          end;
        end;
      end;

  // Determina o valor do  gio
      with Sec do begin
        if (TpCalcDesagio = 3) then { Scat 32198 }
        begin
          if (ValRpa.AMaisJ > 0) and (mac > mes_int(Rpas.FinRpa.DtAssin.MesAno)) then begin { 35670 }
            if (fin.perparcelas=1) and (rpas.finrpa.prazo > 1) and // calcula antecipadamente a taxa de gest o
               (Rpas.Sec.TpTaxaGestao = 3) then
//               ValTaxaGestao := int(Rpas.Sec.PercTaxaGestao * Rpas.Temp3.IndSaldoAcum*100+0.5)/100;
               ValTaxaGestao := int(Rpas.Sec.PercTaxaGestao * Rpas.Temp5.TxPstAcum*100+0.5)/100;
            ValorPresenteLiquido := PresentValue(Fin.TxJuros/1200,mac- mes_int(Rpas.FinRpa.DtAssin.MesAno),0,ValRpa.AmaisJ-ValTaxaGestao,PtEndOfPeriod);
            ValorFuturoLiquido := FutureValue(Fin.TxJurosDesconto/1200,mac- mes_int(Rpas.FinRpa.DtAssin.MesAno),0,ValorPresenteLiquido,ptEndOfPeriod);
          end
          else ValorFuturoLiquido := 0;
          if ValRpa.AmaisJ > 0 then
            AmaisJAgio := int((ValRpa.AmaisJ-ValTaxaGestao-ValorFuturoLiquido)*100+0.5)/100
          else
            AmaisJAgio := int((ValRpa.AmaisJ-ValorFuturoLiquido)*100+0.5)/100;

          if rpas.finrpa.valorai > 0 then
          begin
            ValorFuturoLiquidoDeAntecipacoes := CalculaValorFuturoLiquidoDeAntecipacoes;
            ValorFuturoLiquido := ValorFuturoLiquido + ValorFuturoLiquidoDeAntecipacoes;
            AmaisJAgio := AmaisJAgio + (Rpas.FinRpa.ValorAi - ValorFuturoLiquidoDeAntecipacoes);
          end;
          Sec3.AmaisJAdqVPL := ValorFuturoLiquido;
        end
        else
        begin
          RazaoAgio := int(RazaoAgio*RPAS.FinRpa.TxSD*100+0.5)/100;
          AmaisJAgio := int(AmaisJAgio*RPAS.FinRpa.TxSD*100+0.5)/100 - RazaoAgio;
        end;
        CorrSaldoAgio := R2((SaldoAgio*(RPAS.FinRpa.TxSD-1)));
        Amortizacao := 0;
        JuroAgio := 0;
        if MAC > mes_int(FinRpa.DtAssin.MesAno) then
        begin
          if (mes_int(DtVenc.MesAno) > mes_int(Fin.DtCarenciadeJuros.MesAno)) then
            JuroAgio := int(Fin.TxJurosDesconto/1200*(SaldoAgio+CorrSaldoAgio)*100+0.5)/100
          else
            JuroAgio := 0;
          Amortizacao := AmaisJAgio - JuroAgio;
          if Amortizacao > SaldoAgio then begin
            Amortizacao := SaldoAgio;
            AmaisJAgio := SaldoAgio + CorrSaldoAgio + JuroAgio;
          end;
          if Abs(AMaisjAgio) < Zero then
             RazaoAgio := 0;
        end;
        SaldoAgio := SaldoAgio + CorrSaldoAgio - Amortizacao;
      end;  

   // Calcula Evolu  o do saldo adquirido pelo valor presente liquido scat 34567
      with Sec3 do begin
        if (Sec.TpCalcDesagio = 3) then { Scat 32198 }
        begin
          CorrecaoAdqVPL := R2((FinRPA.TxSD-1)*SaldoAdqVPL);
          JurosAdqVPL := R2((SaldoAdqVPL + CorrecaoAdqVPL) * (Fin.TxJurosDesconto/1200));
          // AmaisJAdq foi calculado acima

          // Se houver uma amortiza  o extraordin ria, recalcula o vpl e
          // e o amaisj em fun  o deste novo vpl abandonando o c lculo acima
          // Scat 40818
          if (abs(Rpas.temp3.indaminc - 1) > 0) then 
          begin
            AmaisJAdqVPL := -(Temp3.IndSaldoAcum *
             VPLdasParcelasAdquiridasRemanescentes( Rpas.MAC, Fin.TxJuros/1200, Sec.ValTaxaGestao, 
                 Rpas.Sec.TpTaxaGestao, Rpas.Sec.PercTaxaGestao, Contrato.Mutdsk.CadSec.PerReajTxCobranca, Temp10.IndRedPrest ))
             + JurosAdqVPL + SaldoAdqVPL + CorrecaoAdqVPL;
          end;


          SaldoAdqVPLAnt := SaldoAdqVPL;
          SaldoAdqVPL    := SaldoAdqVPL + CorrecaoAdqVPL;
          if (AmaisJAdqVPL > SaldoAdqVPL) then
            AmaisJAdqVPL := SaldoAdqVPL + JurosAdqVPL;
          
          SaldoAdqVPL := SaldoAdqVPL - (AmaisJAdqVPL - JurosAdqVPL);

        end
      end;

   Sec.ValTaxaGestao := 0; // Ser  calculada mais tarde na consolida rpa

   if Temp7.TipoCtr = 17 then
   begin
     // Determina o valor da garantia de Debentures
     // Est  calculando a amortiza  o com um saldo n o corrigido, o que   
     // incorreto. Isto foi feito para compatibilizar com a evolu  o das 
     // plan lhas da Cibrasec. 
     if (FinRpa.Prazo - FinRpa.NPC + 1) > 0 then
       Sec2.AmortizacaoGarantia := int(Sec2.SaldoGarantia / (FinRpa.Prazo - FinRpa.NPC + 1)*100+0.5)/100
     else
       Sec2.AmortizacaoGarantia := Sec2.SaldoGarantia;
     Sec2.CorrecaoGarantia := int((FinRPA.TxSD-1.0)*Sec2.SaldoGarantia*100+0.5)/100;
     Sec2.SaldoGarantia := Sec2.SaldoGarantia + Sec2.CorrecaoGarantia;
     Sec2.SaldoGarantia := Int((Sec2.SaldoGarantia - Sec2.AmortizacaoGarantia)*100+Zero)/100;
   end
   else // Determina a Garantia para Swap
   begin
     if Sec2.SaldoGarantia > Temp10.AmaisJOrig  then
       Sec2.AmortizacaoGarantia := Temp10.AmaisJOrig
     else
       Sec2.AmortizacaoGarantia := Sec2.SaldoGarantia;
     Sec2.CorrecaoGarantia := 0;
     Sec2.SaldoGarantia := Int((Sec2.SaldoGarantia - Sec2.AmortizacaoGarantia)*100+Zero)/100;
   end;

// Determina o valor do repasse no m s de um cr dito com securitiza  o 
      with Sec do 
        ValorRepasseMes := ValRPA.AmaisJ + ValRpa.ValTxAdm - AmaisJColateral - AmaisJAgio -
                           ValTaxaGestao -(ValRPA.AmaisJ-AmaisJColateral-AmaisJSwap);
  end;
end;
{        ------  Implementation   -----   }

var
  DtTerminoContratual : TData; 
begin  // TSerie.evolui
  FCodApoliceAnt := RPAS.Temp10.CodApolice;
  FListaEventosAmInc.clear;
  HistMes[0].Tam := 0;
  fillchar(HistMes,sizeof(HistMes),0);
  DtTerminoContratual.dia := 0; DtTerminoContratual.mes := 0; DtTerminoContratual.ano := 0;
  FAlterouValCed := false;
  FTrocouApolice := false;
  FIndJurosPorDiasCorridosOuUteis := 0;
  DiaLiqTmp := 0;
  MacDoDiaLiqTmp := 0;
  FParcelaDoMesTevePagamentoAntecipado := false;
  RPAS.Temp10.AmaisJOrig := 0;
  RPAS.Sec.JuroColateral := 0;
  RPAS.Sec.CorrSaldoColateral := 0;
  AmortizouPosVenc:=false;
  AmortizouSaldo  := false;
  Rpas.sec.juroswap := 0;
  Rpas.FinRPA.TxFull := 1.0;
  RPAS.Temp.OldNPC   := RPAS.FinRPA.NPC;
  Zera(RPAS);
  if Fin.CodAfetacaoRisco = cRiscoCovid19 then begin
//    RpaS.Temp12.Covid19 := true;
    RpaS.Temp12.CondAdversa := 1;
  end;  
  RPAS.Temp.PrazoAnt := RPAS.FinRPA.Prazo;
  RPAS.Temp12.DiaVencAnt        := RPAS.FinRPA.DiaVenc;
  RPAS.Temp12.SaldoPrincipalAnt := RPAS.Temp12.SaldoPrincipal;
  RPAS.Temp12.SaldoVencAnt := RPAS.Temp12.SaldoVenc;
  RPAS.Temp12.IndSegFinAnt := RPAS.FinRPA.IndSegFin;
  FValorAntecAntesVencSwap := 0; FValorAntecNoVencSwap := 0; FValorAntecPosVencSwap := 0;
  FSaldoCAAnt := RPAs.Temp12.SaldoCA;
  if Fin.Status > 0 then begin
    RPAS.FinRpa.Status := Fin.Status;
    RpaS.ValRpa.MacStatus := mes_int(Fin.Dataref.mesano);
    RPAS.FinRpa.DiaLiq := Fin.Dataref.Dia;
  end;
  if RPAS.FinRPA.Status in StatusTermino then ZeraSaldos(RPAS);
  AtribuiReajContrato(RPAS);
  if ( (mes_int(Fin.DtInicio.MesAno)=0) or (Fin.Valor<=Zero)) and
      (RPAS.FInRPA.Status=0) and ((RPAS.FinRpa.Plano mod 10) <> 8 {aluguel})  then begin
    Uevolui3.Obtem_Hist_mes(RPAS, FHEvoSerie, HistMes, true{IgnoraMarcaDat}); // ignorando a marcadat para poder tratar os hist ricos 42 e 45
    PrimeiraFase;
    RPAS.Temp12.StatusAnt := RPAS.FinRpa.Status;
    RPAS.FinRpa.Status := 7;
    if RPAS.ValRpa.MacStatus = 0 then begin
      RPAS.Temp12.MacStatusAnt := Rpas.ValRpa.MacStatus;
      RPAS.ValRpa.MacStatus := RPAS.MAC;
    end;
    RPAS.Temp12.DiaLiqAnt := RPAS.FinRpa.DiaLiq;
    RPAS.FinRpa.DiaLiq := RPAS.FinRpa.DiaVenc;
    inc(RPAS.MAC);inc(RPAS.Finrpa.NPC);
  end
  else 
    with RPAS do begin
      if Temp.Corrige=0 then inc(MAC) // O primeiro m s da evolu  o   repetido
                                      // para c lculos pro-rata.
      else Temp.Corrige := 0;
      ZeraDesconto(Rpas);
      Uevolui3.Obtem_Hist_mes(RPAS, FHEvoSerie, HistMes, true{IgnoraMarcaDat}); // ignorando a marcadat para poder tratar os hist ricos 42 e 45
      PrimeiraFase;
      FParcelaDoMes := nil;
      if MAC >= mes_int(FinRpa.DtAssin.MesAno) then
      begin
        FParcelaDoMes := Parcelas.ObtemParcelaPorMac(MAC) as TParcelaSerie;
        Temp10.TemParcNoMes := assigned(FParcelaDoMes) and FParcelaDoMes.ParcExisteNoMes;
        SegundaFase(FParceladoMes,Contrato.FDataRefHist);
        TerceiraFase;
        if (Fin.CobraResiduo or ((FinRPA.Plano mod 10)=SACR)) and Ctr_Ativo(Rpas)then CalculaResiduo(FParcelaDoMes);
        QuartaFase;
        if (MAC > mes_int(FinRPA.DtAssin.MesAno)) then CalculaSecuritizacao;
        CalculaAdquirido;
        if assigned(FParcelaDoMes){Temp10.TemParcNoMes} and 
           not fin.DiaVencParcPeloUsuario and 
           (Fin.SistAmort <> SisAmFianca) then // 100868 - se for fian a quero respeitar o diavenc da parcela
        begin
            // Acerta o dia de vencimento das Parcelas
            FParcelaDoMes.DiaVenc := FinRpa.DiaVenc;  
        end;
//        if HDesc>0 then RPA.ValRPA.Desc := HDesc;
      end; //if MAC
      if ValRPA.Amaisj>Zero then AmaisjAnt := ValRPA.AmaisJ;
    end; //with
  if (RPAS.ValRpa.MacStatus = RPAS.Mac) and 
     ((RPAS.FinRpa.DiaLiq >= RPAS.FinRpa.DiaVenc) or (RPAS.FinRpa.DiaLiq = 0)) and
     (RPAS.ValRpa.TotPrest > zero) then RPAS.Temp12.StatusNoDiaVenc := 0
  else RPAS.Temp12.StatusNoDiaVenc := RPAS.FinRpa.Status;
  DeterminaTermino(RPAS,DtTerminoContratual,true{Considera Terminos antecipados});
  if (RPAS.FinRPA.Status=30) and (RPAS.ValRPA.MACStatus=RPAS.MAC) then FMACStatusReneg := RPAS.MAC;
  if Mes_int(DtTerminoContratual.mesAno)>=Mes_int(Fin.DtInicio.mesano) then
    RPAS.Temp11.PrazoEmMeses := Mes_int(DtTerminoContratual.mesAno)-Mes_int(Fin.DtInicio.mesano)+1
  else RPAS.Temp11.PrazoEmMeses := 0;
  RPAS.Temp11.MesesReman := (mes_int(Fin.DtInicio.MesAno) + Fin.PerParcelas * (RPAS.FinRPA.Prazo-1)+1) - RPAS.MAC;
  if (RPAS.Temp11.MesesReman < 0) or (RPAS.FinRPA.Status > 0) then begin
    RPAS.Temp11.MesesReman := 0;
    if Ctr_Ativo(RPAS) then RPAS.Temp11.MesesReman := 1; //nao concordo com isso mas   a l gica para o TPZ e antes desconsiderava t rminos
  end;
  If RpaS.FinRpa.Npc > 0 then RPAS.Temp11.TottotPrestAcum := RPAS.Temp11.TotTotPrestAcum + RPAS.ValRpa.TotPrest;
end;

procedure TSerie.CalcAM( var RPAS: TpRPA);
var
  ValorAIAntesVenc, ValorAInoVenc, ValorAIPosVenc,
  SaldoAAmortizarNoPrincipal : Real;
  N: Integer;
  DtIniJuros: TData;
  indpersin : real;
  CountAmInc: integer;
begin
  ValorAIAntesVenc := 0;
  ValorAInoVenc := 0;
  ValorAIPosVenc := 0;
  with RPAS, RPAS.FinRPA, RPAS.ValRPA do begin

    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - RPAS.Temp.CorrSaldo; // Desfaz a corre  o do saldo
    if (Temp4.DiaAmInc)<byte(DiaVenc) then
    begin
      if Fin.CompoeSaldo or Fin.CompoeEntrada then // SCAt 46549
      if ((ExOpc = 35) or (ExAmInc = 35)) and (FinRPA.IndSegFin > zero) then begin // Sinistro Parcial
//          if (Temp2.Persin<=Zero) then Temp2.PerSin := trunc(ValorAI*100+Zero);
        if (Temp2.Persin <= zero) and (Temp11.ValorPgSeg > zero) then begin
          if abs(SaldoDev) > zero then // 99318 - proteger contra diviz o por zero
            Temp2.Persin := trunc((Temp11.ValorPgSeg/SaldoDev)*10000+Zero)
          else  
            Temp2.Persin := 0;
          Temp9.ValorSin := Temp11.ValorPgSeg;
        end
        else if abs(SaldoDev) > zero then // 99318 - proteger contra diviz o por zero
          Temp9.ValorSin := int(Temp2.PerSin/100 * SaldoDev) / 100
        else  
          Temp9.ValorSin := 0;

        indpersin := Temp2.PerSin / 10000;
        Temp10.IndRedPrest := 1-((1-Temp10.IndRedPrest) * (1-indpersin));
//          Temp10.IndRedPrest := 1-((1-Temp10.IndRedPrest) * indpersin);
//          Temp10.IndRedPrest := (1+Temp10.IndRedPrest) * (1+Temp2.PerSin / 10000) -1;
        if FinRPA.IndSegFin > Zero then
          Temp10.ValorARessarc := int(SegFin/IndSegFin*100+Zero)/100;
      end;
      ValorAIAntesVenc := Temp9.ValorSin;
      if (Exopc=21) or (ExAmInc=21) then
      begin
        if Abs(SaldoDev) > Zero then 
          Temp3.IndAmInc := 1-ValorAI/(SaldoDev)
        else
          Temp3.IndAmInc := 0;
        Temp10.IndRedPrest := 1-((1-Temp10.IndRedPrest) * Temp3.IndAmInc);
        ValorAIAntesVenc := ValorAIAntesVenc + ValorAI;
      end;
    end;
    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - ValorAIAntesVenc;
    if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then // Scat 52359
    begin
      DtIniJuros := RPAS.FinRpa.DtAssin;
      if (Fin.DtCarenciaDeJuros.Dia > 0) and
          (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
          DtIniJuros := Fin.DtCarenciaDeJuros;
      N :=  Rpas.Mac - mes_int(DtIniJuros.MesAno) - 1;
      SaldoAAmortizarNoPrincipal := (ValorAIAntesVenc) / (1+N*RPAS.FinRPA.IndJuros);
      // Desfaz a corre  o do saldo principal
      Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal / rpas.FinRPA.TxSD;
      Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal - SaldoAAmortizarNoPrincipal;      
      // Refaz a corre  o do saldo principal
      Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal * rpas.FinRPA.TxSD;
    end;      

    RPAS.Temp.SaldevAnt := RPAS.ValRPA.SaldoDev;
    if RPAS.Temp6.AmSaldoAntCorr then RPAS.Temp.CorrSaldo := 0 // SCAt 27613
    else begin
      RPAS.Temp.CorrSaldo := R2((RPAS.FinRPA.TxSD-1) * RPAS.ValRPA.Saldodev);
    end;

    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + RPAS.Temp.CorrSaldo;
    CalcJuro(RPAS.FinRPA.Diavenc);

// as antecipa  es ser o tratadas na Calc_Eventos_No_E_Apos_Venc, na quartafase, depois de chamar
// a PosCalcOpc, ent o n o precisa abater aqui
//    RPAS.ValRpa.SaldoDev := RPAS.ValRpa.SaldoDev -  Rpas.Temp12.PagAntecNoVenc -  Rpas.Temp12.PagAntecPosVenc;
//    Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal - FValorAntecNoVencPrincipal - FValorAntecPosVencPrincipal;

//    FAmortizouSaldoComPgtoNoEPosVenc := true;
    if (Temp4.DiaAmInc>=Byte(DiaVenc)) then
    begin
      if Fin.CompoeSaldo or Fin.CompoeEntrada then //SCAt 46549
      if ((ExOpc = 35) or (ExAmInc = 35)) and (FinRPA.IndSegFin > zero) then begin // Sinistro Parcial

//          if Temp2.PerSin <= Zero then Temp2.PerSin := trunc(ValorAI*100+Zero);
        if (Temp2.Persin <= zero) and (Temp11.ValorPgSeg > zero) and (abs(SaldoDev-(AmaisJ - Juro)) > zero) then begin
          Temp2.Persin := trunc((Temp11.ValorPgSeg/(SaldoDev-(AmaisJ - Juro)))*10000+Zero);
          Temp9.ValorSin := Temp11.ValorPgSeg;
        end
        else
          Temp9.ValorSin := int(Temp2.PerSin/100 * (SaldoDev-(AmaisJ - Juro))) / 100;
//          indpersin := Temp2.PerSin / 10000;
//          Temp10.IndRedPrest := 1-((1-Temp10.IndRedPrest) * indpersin);
        Temp10.IndRedPrest := (1+Temp10.IndRedPrest) * (1+Temp2.PerSin / 10000) -1;
        if FinRPA.IndSegFin > Zero then
          Temp10.ValorARessarc := int(SegFin/IndSegFin*100+Zero)/100;
        if (Temp4.DiaAmInc=Byte(DiaVenc)) then
          ValorAINoVenc := Temp9.ValorSin
        else
          ValorAIPosVenc := Temp9.ValorSin;
      end;
      if (Exopc=21) or (ExAmInc=21) then begin
        if Abs(SaldoDev) > Zero then 
          Temp3.IndAmInc := 1-ValorAI/(SaldoDev-(AmaisJ - Juro))
        else
          Temp3.IndAmInc := 0;
        Temp10.IndRedPrest := 1-((1-Temp10.IndRedPrest) * Temp3.IndAmInc);
        if (Temp4.DiaAmInc=Byte(DiaVenc)) then
          ValorAINoVenc := ValorAINoVenc + ValorAI
        else
          ValorAIPosVenc := ValorAiPosVenc + ValorAI;
      end;
    end;
    if ((ExOpc = 35) or (ExAmInc = 35)) and (Temp2.PerSin > zero) then begin
      CountAmInc := 0;
      if Temp4.DiaAmInc > 0 then
        CountAmInc := FListaEventosAmInc.RetornaIndAmInc(35,Temp4.DiaAmInc,0)
      else if FinRPA.DiaLiq > 0 then 
        CountAmInc := FListaEventosAmInc.RetornaIndAmInc(35,FinRPA.DiaLiq,0);
      if (CountAmInc > -1) and (FListaEventosAmInc[CountAmInc].PerSin <= zero) then
        FListaEventosAmInc[CountAmInc].PerSin := Temp2.PerSin;
    end;

    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - ValorAInoVenc;
    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - ValorAIposVenc;

    if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then // Scat 52359
    begin
      DtIniJuros := RPAS.FinRpa.DtAssin;
      if (Fin.DtCarenciaDeJuros.Dia > 0) and
          (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
          DtIniJuros := Fin.DtCarenciaDeJuros;
      N :=  Rpas.Mac - mes_int(DtIniJuros.MesAno);
      SaldoAAmortizarNoPrincipal := (ValorAInoVenc + ValorAIposVenc) / (1+N*RPAS.FinRPA.IndJuros);
      Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal - SaldoAAmortizarNoPrincipal;      
    end;      

    AmortizaSaldosSecuritizados(ValorAIAntesVenc,ValorAInoVenc,ValorAIPosVenc);
    FValorAntecAntesVencSwap := FValorAntecAntesVencSwap + ValorAIAntesVenc;
    FValorAntecNoVencSwap := FValorAntecNoVencSwap + ValorAInoVenc;
    FValorAntecPosVencSwap := FValorAntecPosVencSwap + ValorAIPosVenc;

    if Temp6.AmSaldoAntCorr then begin
      RPAS.Temp.CorrSaldo := R2((RPAS.FinRPA.TxSD-1) * RPAS.ValRPA.Saldodev);
      RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + RPAS.Temp.CorrSaldo;
    end;
    if (Temp4.DiaAmInc<byte(DiaVenc)) then begin
      if not FUsandoAmaisJPeloValorEmitido then
        if assigned(FParceladoMes) and Temp10.TemParcNoMes then begin
          if FParceladoMes.TipoPg in PgtoComRedSdDev then ValRPA.Amaisj:=0
          else ValRPA.AmaisJ := (1-Temp10.IndRedPrest)*Temp5.AmaisJIntegral;
        end
        else ValRpa.AmaisJ := 0;
      if (Fin.RecalculaPrestacao) or ((Plano mod 10)=SACR) then 
        Temp10.IndRedPrest := 0.0;
    end
    else Temp.IndAcum := Temp3.Indaminc;
    Prazo := Prazo - NPAI;
  end;
end;

procedure TSerie.CalcInc( var Rpas: TpRPA );
var
  ValorAiAntesVenc, ValorAINoVenc, ValorAIPosVenc: Double;
  leglinkItem: TLegLinkItem;
  CountAmInc: integer;
begin
  LegLinkItem   := nil;
  ValorAInoVenc := 0;
  ValorAiAntesVenc := 0;
  ValorAiPosVenc := 0;
  CountAmInc := FListaEventosAmInc.RetornaIndAmInc(18,Rpas.Temp6.DiaInc,0);
  RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - RPAS.Temp.CorrSaldo; // Desfaz a corre  o do saldo
  

  // S  estamos trabando incorpora  o no vencimento
  RPAS.Temp.SaldevAnt := RPAS.ValRPA.SaldoDev;
  if RPAS.Temp6.AmSaldoAntCorr then RPAS.Temp.CorrSaldo := 0 // SCAt 27613
  else begin 
    RPAS.Temp.CorrSaldo := R2((RPAS.FinRPA.TxSD-1) * RPAS.ValRPA.Saldodev);
  end;

  RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + RPAS.Temp.CorrSaldo;
  CalcJuro(RPAS.FinRPA.Diavenc);

  //RPAS.ValRpa.SaldoDev := RPAS.ValRpa.SaldoDev -  Rpas.Temp12.PagAntecNoVenc -  Rpas.Temp12.PagAntecPosVenc;
  //Rpas.Temp12.SaldoPrincipal := Rpas.Temp12.SaldoPrincipal - FValorAntecNoVencPrincipal - FValorAntecPosVencPrincipal;

  if Fin.CompoeSaldo or Fin.CompoeEntrada then //SCAt 46549
  begin
    if ((Rpas.FinRpa.ExOpc = 18) or (Rpas.Temp7.ExInc=18)) then 
    begin
      if (rpas.Temp7.TipoIncorp <> 1) then
      begin
        if Abs(Rpas.ValRpa.SaldoDev) > Zero then 
          Rpas.Temp3.IndAmInc := 1+RPAS.temp7.ValorInc/(Rpas.ValRpa.SaldoDev-(Rpas.ValRpa.AmaisJ - Rpas.Valrpa.Juro))
        else
          Rpas.Temp3.IndAmInc := 0;
        Rpas.Temp10.IndRedPrest := 1-((1-Rpas.Temp10.IndRedPrest) * Rpas.Temp3.IndAmInc);
      end;
      ValorAINoVenc := ValorAINoVenc - RPAS.temp7.ValorInc;
    end;
  end;
  if (CountAmInc > -1) then
  begin
    FListaEventosAmInc[CountAmInc].ValorAINoVencto := RPAS.temp7.ValorInc;
    FListaEventosAmInc[CountAmInc].DiaVenc := Rpas.FinRpa.DiaVenc;
    FListaEventosAmInc[CountAmInc].SaldoDevAntes := Rpas.ValRpa.SaldoDev-(Rpas.ValRpa.AmaisJ - Rpas.Valrpa.Juro);
    FListaEventosAmInc[CountAmInc].CmProRataAteEvento := 0;
    FListaEventosAmInc[CountAmInc].SaldoProRata       := Rpas.ValRpa.SaldoDev-(Rpas.ValRpa.AmaisJ - Rpas.Valrpa.Juro);
  end;

  RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - ValorAInoVenc;

  if (CountAmInc > -1) then
    FListaEventosAmInc[CountAmInc].NovoSaldoNoEvento := Rpas.ValRpa.SaldoDev;

  if not Contrato.FInibeLegLink then 
    leglinkItem := LegLink.Add(fin.codserie,'<br><br><b>Incorpora  o no vencimento</b><br>');
  if assigned(legLinkItem) then
  begin
    leglinkItem.Valores['Saldo devedor antes da incorpora  o'] := strgrana(RPAS.ValRPA.SaldoDev+ValorAInoVenc-(Rpas.ValRpa.AmaisJ - Rpas.Valrpa.Juro));
    leglinkItem.Valores['Valor incorporado'] := strgrana(-ValorAInoVenc);
    leglinkItem.Valores['Saldo devedor depois da incorpora  o'] := strgrana(RPAS.ValRPA.SaldoDev-(Rpas.ValRpa.AmaisJ - Rpas.Valrpa.Juro));
    leglinkItem.Valores['Percentual incorporado'] := formatfloat('0.0000000000%',(Rpas.Temp3.IndAmInc-1)*100);
    leglinkItem.Valores['Fator de multiplica  o da presta  o'] := formatfloat('0.00000000',1-Rpas.Temp10.IndRedPrest);
  end;
  if (Rpas.FinRpa.ExOpc=0) and (Rpas.Temp7.ExInc=18) then begin
    Rpas.FinRpa.ExOpc := 18;
    Rpas.Temp7.ExInc := 0;
  end;

  AmortizaSaldosSecuritizados(ValorAIAntesVenc,ValorAInoVenc,ValorAIPosVenc);
  FValorAntecAntesVencSwap := FValorAntecAntesVencSwap + ValorAIAntesVenc;
  FValorAntecNoVencSwap := FValorAntecNoVencSwap + ValorAInoVenc;
  FValorAntecPosVencSwap := FValorAntecPosVencSwap + ValorAIPosVenc;

  if Rpas.Temp6.AmSaldoAntCorr then begin
    RPAS.Temp.CorrSaldo := R2((RPAS.FinRPA.TxSD-1) * RPAS.ValRPA.Saldodev);
    RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + RPAS.Temp.CorrSaldo;
  end;
  
end;

procedure TSerie.TerminaCtr(var RPAS: TpRPA; n:integer; DiaLiqTmp : shortint; MacDoDiaLiqTmp : integer);
var
  DataRefCtb : TData;
begin
  DataRefCtb.Dia := 0; fillchar(DataRefCtb,sizeof(DataRefCtb),0);
  TerminaCtr(RPAS,n,DataRefCtb,DiaLiqTmp,MacDoDiaLiqTmp);
end;

procedure TSerie.TerminaCtr(var RPAS: TpRPA; n:integer; DataRefCtb : TData; DiaLiqTmp : shortint; MacDoDiaLiqTmp : integer);
var
  IndAmInc : integer;
begin
  if (RPAS.FinRPA.Status <> 98) then begin
//Alterada p/ manter a coerencia entre status, macstatus e dialiq  - Solic.52616 
//    if (RPAS.ValRPA.MACStatus =0) or (n=98) then
    RPAS.Temp12.MacStatusAnt := RPAS.ValRpa.MacStatus;
    RPAS.ValRPA.MACStatus := RPAS.MAC;
    RPAS.Temp12.StatusAnt := RPAS.FinRPA.Status;
    RPAS.FinRPA.Status := n;
    if TerminoTratadoAntesNaAssin(n) and 
       (MacDoDiaLiqTmp > 0) and // Estou setando MacDoDiaLiqTmp onde dialiqtmp   setado
       ((MacDoDiaLiqTmp < mes_int(RPAS.FinRPA.DtAssin.mesano)) or 
        ((MacDoDiaLiqTmp = mes_int(RPAS.FinRPA.DtAssin.mesano)) and (byte(DiaLiqTmp) < RPAS.FinRPA.DtAssin.dia))) then 
      DiaLiqTmp := Fin.DataRef.dia; // Sol. 92926 - DiaLiqTmp   dialiq do hist rico, 
                                    //              mas se o t rmino   anterior a assinatura
                                    //              quero for ar o dialiq para dataref.dia 
    if RPAS.FinRpa.DiaLiq <> DiaLiqTmp then begin
      RPAS.Temp12.DiaLiqAnt := RPAS.FinRpa.DiaLiq;
      RPAS.FinRpa.DiaLiq := DiaLiqTmp;
    end;
    if RPAS.FinRPA.DiaLiq=0 then // sol. 92926 - Voltei o c digo original. Foi alterado de forma incorreta na sol. 44173
      RPAS.FinRPA.DiaLiq := RPAS.FinRPA.DiaVenc;
    if (RPAS.FinRPA.DiaLiq >= RPAS.FinRPA.DiaVenc) and (n <> 20) then CalcJuro(RPAS.FinRPA.DiaVenc); // SCAt 29231
    if (n = 2) then begin
      if CalcIndenizSemProrataEJuros(RPAS.Temp11.Seguradora) then begin
        if ((RPAS.FinRpa.DiaLiq < RPAS.FinRpa.DiaVenc) or 
            ((RPAS.FinRpa.DiaLiq = RPAS.FinRpa.DiaVenc) and RPAS.Temp12.UtilizaSdAntSinistro)) and 
           (RPAS.FinRpa.NPC > 0) then
          RPAS.ValRpa.SaldoDev := RPAS.Temp.SaldevAnt;
      end;
      RPAS.FinRpa2.ValorLA  := RPAS.ValRpa.SaldoDev;
      if (RPAS.FinRPA.IndSegFin > Zero) then
        RPAS.Temp10.ValorARessarc := int(RPAS.ValRPA.SegFin/RPAS.FinRPA.IndSegFin*100+Zero)/100;

      RPAS.Temp12.SaldoDevEv := RPAS.FinRPA2.ValorLA;
      if AbriuPrst and Scciconf.UsaArqPrest then begin
        for IndAmInc := 0 to FListaEventosAmInc.count-1 do begin
          if FListaEventosAmInc[IndAmInc].ExOpc in [22,25,26,30,66,67,68,70,71,82,101] then begin
            if (Abs(FListaEventosAmInc[IndAmInc].HSaldoDevEv) > Zero) then begin
              RPAS.Temp12.SaldoDevEv := FListaEventosAmInc[IndAmInc].HSaldoDevEv;
            end;
          end;
        end;
      end;
    end;
    if not Ctr_Ativo(RPAS) then ZeraSaldos(RPAS);
  end;
end;

procedure TSerie.LiquidaCTR( var RPAS : TpRPA );
var
  IndAmInc  : integer;
begin
  if RPAS.FinRPA.Status <> 98 then begin
    with RPAS, RPAS.FinRPA, RPAS.ValRPA do begin
      if DiaLiq >= DiaVenc then begin
        if Abs(ValRPA.Juro) < Zero then CalcJuro(RPAS.FinRPA.DiaVenc); // SCAt 29231
        if NPC > 0 then begin
          SaldoDev := int((SaldoDev - (AmaisJ - Juro))*100 + 0.5)/100;
          AmortizouSaldo := true;
        end;
      end;
    end;

    if RPAS.FinRPA.Status in [0,8] then begin
      RPAS.Temp12.StatusAnt := RPAS.FinRpa.Status;
      RPAS.FinRPA.Status := 1; // SCAt 34136
    end;
    if RPAS.FinRPA.ValorAI<=Zero then RPAS.FinRPA.ValorAI:=RPAS.Temp7.ValorLiq;
    if RPAS.ValrPA.MacStatus=0 then begin
      RPAS.Temp12.MacStatusAnt := RPAS.ValRpa.MacStatus;
      RPAS.ValRPA.MACStatus := RPAS.MAC;
    end;
    RPAS.FinRPA2.ValorLA  := RPAS.ValRPA.SaldoDev;
    RPAS.Temp6.TipoEvento := TipoEvento( RPAS );
    if RPAS.Temp6.TipoEvento <> 9 then 
      RPAS.FinRPA2.Prejuliq := RPAS.FinRPA2.ValorLA - RPAS.Temp7.ValorLiq;
    // Caso a liquida  o seja depois do vencimento esta atribui  o
    // ser  feita novamente na calculasecuritiza  es
    RPas.Temp12.VlrLiqSwap := Rpas.sec.SaldoDevSwap;
    if (RPAS.FinRPA.Status = 1) or (RPAS.FinRPA.Status = 2) then begin
      RPAS.Temp12.SaldoDevEv := RPAS.ValRPA.SaldoDev;
      RPAS.Temp12.RespMutEv := RPAS.FinRPA2.ValorLA;
      RPAS.Temp12.DiferencaEv := RPAS.FinRPA2.ValorLA - RPAS.Temp7.ValorLiq;
      if AbriuPrst and Scciconf.UsaArqPrest then begin
        for IndAmInc := 0 to FListaEventosAmInc.count-1 do begin
          if FListaEventosAmInc[IndAmInc].ExOpc in [22,25,26,30,66,67,68,70,71,82,101] then begin
            if (Abs(FListaEventosAmInc[IndAmInc].HSaldoDevEv) > Zero) or
               (Abs(FListaEventosAmInc[IndAmInc].HRespMutEv) > Zero) or
               (Abs(FListaEventosAmInc[IndAmInc].HDiferencaEv) > Zero) or
               (Abs(FListaEventosAmInc[IndAmInc].HSaldoFGTSEv) > Zero) then begin
              RPAS.Temp12.SaldoDevEv := FListaEventosAmInc[IndAmInc].HSaldoDevEv;
              RPAS.Temp12.RespMutEv := FListaEventosAmInc[IndAmInc].HRespMutEv;
              RPAS.Temp12.DiferencaEv := FListaEventosAmInc[IndAmInc].HDiferencaEv;
              RPAS.Temp12.DifUPFEv := FListaEventosAmInc[IndAmInc].HDifUPFEv;
              RPAS.Temp12.SaldoFGTSEv := FListaEventosAmInc[IndAmInc].HSaldoFGTSEv;
              RPAS.Temp12.IndCorAteEv := FListaEventosAmInc[IndAmInc].HIndCorEv;
            end;
          end;
        end;
      end;
    end;
    //if not(Ctr_Ativo(RPAS)) then
    ZeraSaldos(RPAS);
  end;
end;

procedure TSerie.SuspendeOuReativaSeguro(var RPAS : TpRPA);
begin
  if RPAS.FinRPA.ExOpc = 99 then
    RPAS.Temp5.MACSuspSeg:= RPAS.MAC
  else
    RPAS.Temp5.MACSuspSeg := 0;
end;

procedure TSerie.CalcOpc( var RPAS : TpRPA ; CodClassificacao : byte; 
                              DiaLiqTmp : ShortInt; DataRefCtb : TData);
begin
  case RPAS.Temp7.ExInc of
    18       : CalcINc(RPAS);
  end;
  case RPAS.FInRPA.ExAminc of        
    21,35    : CalcAM( RPAS );
  end;
  case RPAS.FinRPA.Exopc of
    21       : CalcAm (RPAS);
    35       : CalcAM(RPAS);          // Sinistro Parcial
    37       : RPAS.Temp5.TpSRoga := 1;  // Subroga  o
    99,
    100      : SuspendeOuReativaSeguro(RPAS);
  end; // case
end;

procedure TSerie.SetaDiaLiqporExOpc(var rpas : TpRPA; var DiaLiqTmp : shortint);
var
  i : integer;
begin
  {
    109632
    No caso de haver duas renegs no mesmo m s, o dat de dialiq(47) pode ser sobrescrito
    pela segunda reneg, ou pelo dat do financ. din mico, na primeirafase.
    Ent o como solu  o, eu vou buscar na lista de eventos pelo exopc80 no m s,
    e ficar com o seu diaevento. Encontrando mais de uma vez, vou considerar o menor,
    pois n o faz sentido uma renegocia  o terminar a s rie e ela ser renegociada de novo
    no mesmo m s.
    Como a TerminaCtr na verdade considera o DiaLiqTmp como dialiq do hist rico,
    eu tenho que seta ele na verdade.
    Notar que a lista de eventos   carregada por s rie, ent o eu sei que na lista
    s  tem eventos da s rie corrente.
  }
  for i := 0 to FListaEventosAmInc.count-1 do begin
    if FListaEventosAmInc[i].exopc=RPAS.FinRPA.Exopc then begin
      if FListaEventosAmInc[i].diaevento < DiaLiqTmp then
        DiaLiqTmp := FListaEventosAmInc[i].diaevento;
    end;
  end;
end;

procedure TSerie.PosCalcOpc( var RPAS : TpRPA ; CodClassificacao : byte; 
                             DiaLiqTmp : ShortInt; DataRefCtb : TData; MacDoDiaLiqTmp : integer);
begin
  {
    109632
    No caso de haver duas renegs no mesmo m s, o dat de dialiq(47) pode ser sobrescrito
    pela segunda reneg, ou pelo dat do financ. din mico, na primeirafase.
    Ent o como solu  o, eu vou buscar na lista de eventos pelo exopc80 no m s,
    e ficar com o seu diaevento. Encontrando mais de uma vez, vou considerar o menor,
    pois n o faz sentido uma renegocia  o terminar a s rie e ela ser renegociada de novo
    no mesmo m s.
    Como a TerminaCtr na verdade considera o DiaLiqTmp como dialiq do hist rico,
    eu tenho que seta ele na verdade.
  }
  if RPAS.FinRPA.Exopc=80 then 
    SetaDiaLiqporExOpc(RPAS,DiaLiqTmp);
  case RPAS.FinRPA.Exopc of
    22,25,26,
    66,67,68,
    70,82,
    101,115  : LiquidaCtr( RPAS );     // Liquida  o
    71       : if CodClassificacao <> serie_acordo then 
                  LiquidaCtr( RPAS );  // Novacao 100%
    27       : TerminaCtr( RPAS,22,DiaLiqTmp,MacDoDiaLiqTmp ); // T rmino p/SubRoga  o
    28       : TerminaCtr( RPAS,23,DiaLiqTmp,MacDoDiaLiqTmp ); // Transfer ncia
    29       : TerminaCtr( RPAS,24,DiaLiqTmp,MacDoDiaLiqTmp ); // Parte Ideal
    30       : if Fin.CompoeSaldo then  TerminaCtr( RPAS, 2, DiaLiqTmp,MacDoDiaLiqTmp );  // Sinistro
    31       : TerminaCtr( RPAS, 3, DiaLiqTmp,MacDoDiaLiqTmp );  // Retomada
    32       : TerminaCtr( RPAS, 4, DiaLiqTmp,MacDoDiaLiqTmp );  // Outros
    33       : TerminaCtr( RPAS, 5, DiaLiqTmp,MacDoDiaLiqTmp );  // Da  o
    34       : TerminaCtr( RPAS,28, DiaLiqTmp,MacDoDiaLiqTmp);  // Arremata  o
    48       : TerminaCtr( RPAS,9, DiaLiqTmp,MacDoDiaLiqTmp);   // Arremata  o por terceiro
    51       : TerminaCtr( RPAS,10, DiaLiqTmp,MacDoDiaLiqTmp);  // Cess o
    52       : TerminaCtr( RPAS,20, DiaLiqTmp,MacDoDiaLiqTmp);  // Cancelamento Administrativo
    54       : TerminaCtr( RPAS,21, DiaLiqTmp,MacDoDiaLiqTmp);   // Recomercializac o
    80       : TerminaCtr( RPAS,30, DiaLiqTmp,MacDoDiaLiqTmp);   // Renegocia  o S ries
    81       : TerminaCtr( RPAS,29, DiaLiqTmp,MacDoDiaLiqTmp);   // Rescis o Contratual
    85       : TerminaCtr( RPAS,31, DiaLiqTmp,MacDoDiaLiqTmp);   // Permuta
    86       : Terminactr( RPAS,32, DiaLiqTmp,MacDoDiaLiqTmp);   // T rmino por Integraliza  o da fase de poupan a Sol. 27128
    89       : TerminaCtr( RPAS,70, DiaLiqTmp,MacDoDiaLiqTmp);   // T rmino por Canc. de acordo avan ado
    98       : TerminaCtr( RPAS,98,DataRefCtb, DiaLiqTmp,MacDoDiaLiqTmp); // Exclus o
    109      : TerminaCtr( RPAS,33, DiaLiqTmp,MacDoDiaLiqTmp);   // T rmino por Renova  o
    111      : TerminaCtr( RPAS,34, DiaLiqTmp,MacDoDiaLiqTmp);(* Retrocess o *)
    113      : TerminaCtr( RPAS,35, DiaLiqTmp,MacDoDiaLiqTmp);  // T rmino por Consolida  o
  end; // case
end;

function TSerie.ValorPresentedasParcelasAdquiridasRemanescentes( MACRef:integer; IndJ:double ):double;
var 
  i: integer;
  ind: integer;
  PColateral: Real;
  MacPColateral: Integer;
begin
  Result := 0;
  PColateral := Rpas.Sec.PercColateral;
  MacPColateral := 0;
  for i := 0 to Parcelas.Count-1 do
    if (Parcelas[i].MAC > MACRef) and
       ((not (Parcelas[i].TipoPg in PgtoComRedSdDev)) or
        (mes_int(Parcelas[i].DtPg.MesAno) > MacRef)) then

    begin
      for Ind := 1 to FHEvoSerie[0].Tam do
        if (MacPColateral < Mes_Int(FHEvoSerie[Ind].Ficha.MesAno)) and
           (Parcelas[i].Mac >=  Mes_Int(FHEvoSerie[Ind].Ficha.MesAno)) and
           (FHEvoSerie[Ind].Ficha.Campo = 229) then
        begin
          PColateral := (100.0-FHEvoSerie[Ind].Ficha.ValReal)/100.0;
          MacPColateral := Mes_Int(FHEvoSerie[Ind].Ficha.MesAno);
        end;
      Result := Result + (1-PColateral) * (Parcelas[i] as TParcelaSerie).ValorPresenteOrig(MACRef, IndJ);
    end;
end;

function TSerie.VPLdasParcelasAdquiridasRemanescentes( 
                MACRef:integer; IndJ:double; 
                TaxaGestaoInicial:Double; 
                TpTaxaGestao: byte;
                PercTaxaGestao:real;
                PerReajTxGestao:byte;
                IndRedPrest:Double = 0.0 ):double;
var 
  i: integer;
  ind: integer;
  PColateral: Real;
  MacPColateral: Integer;
  VPL: Double;
  n, m : integer;
  TaxaGestao: real;
begin
  Result := 0;
  TaxaGestao := TaxaGestaoInicial;
  PColateral := Rpas.Sec.PercColateral;
  MacPColateral := 0;
  for i := 0 to Parcelas.Count-1 do
    if (Parcelas[i].MAC > MACRef) and
       ((not (Parcelas[i].TipoPg in PgtoComRedSdDev)) or
        (mes_int(Parcelas[i].DtPg.MesAno) > MacRef)) then

    begin
      for Ind := 1 to FHEvoSerie[0].Tam do
        if (MacPColateral < Mes_Int(FHEvoSerie[Ind].Ficha.MesAno)) and
           (Parcelas[i].Mac >=  Mes_Int(FHEvoSerie[Ind].Ficha.MesAno)) and
           (FHEvoSerie[Ind].Ficha.Campo = 229) then
        begin
          PColateral := (100.0-FHEvoSerie[Ind].Ficha.ValReal)/100.0;
          MacPColateral := Mes_Int(FHEvoSerie[Ind].Ficha.MesAno);
        end;
        n := (Parcelas[i] as TParcelaSerie).Mac-MacRef;
        if PerReajTxGestao > 0 then
          m := (n div PerReajTxGestao)
        else
          m := 1;
        case TpTaxaGestao of
          1..4: TaxaGestao := TaxaGestaoInicial;
          5: TaxaGestao := TaxaGestaoInicial*power(1+PercTaxaGestao/100,m);
        end;
      if (Parcelas[i] as TParcelaSerie).Valor > Zero then
        VPL := (Parcelas[i] as TParcelaSerie).Valor * (1.0-IndRedPrest) - TaxaGestao
      else
        VPL := 0;
      if (Parcelas[i] as TParcelaSerie).Mac > MacRef then { Descapitalizar os juros }
         VPL := -PresentValue(IndJ,(Parcelas[i] as TParcelaSerie).Mac-MacRef,0,VPL,ptEndOfPeriod);
      Result := Result + (1-PColateral) * VPL; 
    end;
    Result := Arredonda2(Result);
end;

