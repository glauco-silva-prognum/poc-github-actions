procedure MontaDetalhesLogReevoCtr(Ctr : TpCtr;Detalhes : TStringlist);
var
  Qry : TSqlQuery;
  Xml : TpXml;
  Stream : TStringStream;
begin
  Detalhes.clear;
  Qry := TSqlQuery.create(nil);
  try
    Qry.SqlConnection := GetSqlConnection(pegaDirTab);
    Qry.Sql.add('SELECT TE_DADOS FROM LOG_EVENTOS');
    Qry.Sql.add(' WHERE  NU_CONTRATO='+QuotedStr(Ctr));
    Qry.Sql.add(' AND CO_APLIC = '+inttostr(ord(logaplic_ReevoluiCtrNaSimula)));
    Qry.Sql.add('ORDER BY DT_DATA_HORA');
    Qry.open;
      while not Qry.eof do
        Qry.next;
      if not Qry.fieldByName('TE_DADOS').isNull then begin
        Xml := TpXml.create;
        Stream := TStringStream.create('');
        try
          TBlobField(Qry.FieldByname('TE_DADOS')).savetostream(Stream);
          Stream.position := 0;
          Xml.DocumentElement.code := Stream.datastring;
          Detalhes.add('');
          Detalhes.add('Data   : '+Xml['Data'].asString);
          Detalhes.add('Hora   : '+Xml['Hora'].asString);
          Detalhes.add('Usu rio: '+Xml['Usuario'].asString);
          Detalhes.add('');
          Detalhes.add('LOG : ');
          Detalhes.add('  Data   : '+Xml['Data'].asString);
          Detalhes.add('  Hora   : '+Xml['Hora'].asString);
          Detalhes.add('  Usu rio: '+Xml['Usuario'].asString);
          Detalhes.add('  M s Inicial: '+Xml['Mes_Inicial'].asString);
          Detalhes.add('  M s Final  : '+Xml['Mes_Final'].asString);
          Detalhes.add('  C digo da S rie : '+Xml['Codigo_da_Serie'].asString);
          Detalhes.add('  Reevolui s  Saldo Devedor : '+Xml['Reevolui_so_Saldo_Devedor'].asString);
        finally
         Stream.free;
         Xml.free;
        end;
      end;
    Qry.close;    
  finally
    Qry.free;
  end;
end;

