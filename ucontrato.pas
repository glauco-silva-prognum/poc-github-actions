      if Temp12.IntervenienteQuitante = 0 then
        Temp12.IntervenienteQuitante := RPAS.Temp12.IntervenienteQuitante;
      if Temp12.CO_SITUACAO_GARANTIA = 0 then
        Temp12.CO_SITUACAO_GARANTIA := RPAS.Temp12.CO_SITUACAO_GARANTIA;
      Temp10.DtassinPropSeguro := RPAS.Temp10.DtAssinPropSeguro;
      
