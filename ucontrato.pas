        if DataEMenor(DtVenc,RPAF.FinRPA.DtAssin) then
          DtVenc := RPAF.FinRPA.DtAssin;

        if (Abs(RPAF.ValRPA.TotPrest-RPAF.Temp7.DescSeg) > Zero) and
           (Abs(RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc  ) > Zero) and
          ((not ((scciconf.ClassificaAtrDeSeguroNaCarenciaComoVincenda and 
                  (RPAF.FinRPA.NPC <= 0)
                 )                     or 
                  ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb
                )
           )                     or
           (Abs(RPAF.ValRPA.TotPrest-RPA.ValRPA.Seguro) > Zero)
          )                    and
           DataEMenorOuIgual(DtVenc,FDataRefHist) then begin
          if RPAF.FinRPA.NPC > 0 then begin
            if not assigned(Parcela) then begin
              if RPAF.Temp11.DtPrimAtrasoCtb.Dia = 0 then begin
                if (Mes_Int(FDataRefHist.MesAno) < 1501) and RegCarteira.RegimeDeCaixa and
                   (RPAF.MAC = Mes_Int(RPAF.FinRPA.DtAssin.MesAno)) then
                  RPAF.Temp11.DtPrimAtrasoCtb := RPAF.FinRPA.DtAssin
                else 
                  RPAF.Temp11.DtPrimAtrasoCtb := DtVenc;
              end;
              if Scciconf.UtilizaSituacaoCtbConfig and
                ((not Scciconf.NaoGeraEmissaoCtbSemIndice) or 
                 (RPAF.CodErro = 0) or (RPAF.MAC <> Mes_Int(FDataRefHist.MesAno))) then
                FEncargosEmAbertoCtb := Arredonda(FEncargosEmAbertoCtb + RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc);
              FTemAtrasoFDinamico := true;
              if (FDataPrimAtraso.Dia = 0) or 
                 (juliano(DtVenc) < juliano(FDataPrimAtraso)) then 
                FDataPrimAtraso := DtVenc;
            end 
            else if (not Parcela.EstaPagaCtb(FDataRefHist)) then begin
              if RPAF.Temp11.DtPrimAtrasoCtb.Dia = 0 then begin
                if (Mes_Int(FDataRefHist.MesAno) < 1501) and RegCarteira.RegimeDeCaixa and
                   (RPAF.MAC = Mes_Int(RPAF.FinRPA.DtAssin.MesAno)) then
                  RPAF.Temp11.DtPrimAtrasoCtb := RPAF.FinRPA.DtAssin
                else 
                  RPAF.Temp11.DtPrimAtrasoCtb := DtVenc;
              end;
              if Scciconf.UtilizaSituacaoCtbConfig and
                ((not Scciconf.NaoGeraEmissaoCtbSemIndice) or 
                 (RPAF.CodErro = 0) or (RPAF.MAC <> Mes_Int(FDataRefHist.MesAno))) then
                FEncargosEmAbertoCtb := Arredonda(FEncargosEmAbertoCtb + RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc);
              FTemAtrasoFDinamico := true;
              if (FDataPrimAtraso.Dia = 0) or 
                 (juliano(DtVenc) < juliano(FDataPrimAtraso)) then 
                FDataPrimAtraso     := DtVenc;
            end;
