procedure TSerie.CalculaSeguro(SaldoParaCalculoDeSeguro : real; Var RPACons : TpRPA; SerieMipValAVal : boolean);
begin
    with RPAS do begin
      if not Assigned(FParcelaDoMes) then begin
        CalculaSeguropSeries(0,SaldoParaCalculoDeSeguro,RPACons,fin.defreaj,SerieMipValAVal); //  scat 20631
        if RPAS.ValRPA.Seguro > Zero then CriaParcelaDoMesDeSeguro;
      end;
      if Assigned(FParcelaDoMes) then begin
        if Temp10.TemParcNomes and ((FinRpa.Plano<>SACR) or (FinRPA.NPC=1)) then
          CalculaSeguropSeries((FParceladoMes as TParcelaSerie).Seguro,SaldoParaCalculoDeSeguro,RPACons,fin.defreaj,SerieMipValAVal)
        else
          CalculaSeguropSeries(0,SaldoParaCalculoDeSeguro,RPACons,fin.defreaj,SerieMipValAVal); //  scat 20631
      end;
      ValRPA.Seguro := ValRPA.SegFin + ValRPA.SegCre + ValRPA.SegImv;
      AtualizaTotPrest(RpaS);
      Temp7.DescSeg := 0;
      if (Temp7.TemDescontoSegMIP) and 
         ((Temp11.MATermDescSegMIP > MAC) or (Temp11.MATermDescSegMIP = 0)) then 
        Temp7.DescSeg := ValRPA.SegFin;
      if (Temp9.TemDescontoSegDFI) and
         ((Temp11.MATermDescSegDFI > MAC) or (Temp11.MATermDescSegDFI = 0)) then 
        Temp7.DescSeg := Temp7.DescSeg + ValRPA.SegImv;
      ValRPA.Desc := ValRPA.Desc + Temp7.DescSeg;
    end
end;


procedure TSerie.CalculaSeguroDFIpSeries(SegurodaParcela:double; Var RpaCons : TpRpa);
var
  ValBaseSegAux,
  Corr,
  indapolice   : real;
  DtAval : TData;
  RegApoliceDFI : TpApolice;
begin
  RegApoliceDFI.CampoVbaseMip := 0;
  fillchar(RegApoliceDFI,sizeof(RegApoliceDFI),0);
  with RPAS do begin
    if SegurodaParcela > Zero then ValRPA.SegImv := SegurodaParcela
    else begin

      if Temp11.CodApoliceDFI > '' then begin
        LeApolice(Temp11.CodApoliceDFI,RegApoliceDFI);
        if CobraIOFApolice(RegApoliceDFI,RPAS) then
          RPAS.Temp12.PercIOFDFI := RegApoliceDFI.PercIOFDFI
        else
          RPAS.Temp12.PercIOFDFI := 0;
      end
      else
        fillchar(RegApoliceDFI,sizeof(TpApolice),0);

      Temp12.AliquotaDoContratoDFI := (RegApoliceDFI.ALIQUODOTACONTRATO and (Abs(Contrato.Mutdsk.Financ.IndSegImv) > zero)) and not ForcouIndSegImv{111863};
      if not Temp12.AliquotaDoContratoDFI then begin
        indapolice := RetornaIndSegImvApolice(RPAS,FinRPA.ValAVal,Contrato.Imovel.RegImv.cep+Contrato.Imovel.RegImv.cep2);
        if indapolice > Zero then
          FinRPA.IndSegimv := indapolice;
      end
      else
        FinRPA.IndSegimv := Contrato.Mutdsk.Financ.IndSegImv;
 
      if (abs(FinRPA.IndSegImv) < zero) and (Fin.IndSegImv > zero) then // sol. 50262
        FinRPA.IndSegImv := Fin.IndSegImv;

      if FinRPA.IndSegImv > Zero then begin
        if (Temp11.CampoVBaseDFI > 0) or (RegApoliceDFI.TpReajBase > 0) then
          ValBaseSegAux := ValBaseSegDFICorrigido(RPAS,RPACons,RegApoliceDFI)
        else begin
          ValBaseSegAux := FinRpa.ValAval;
          if (juliano(Fin.DtRenegGeradora) > 0) and
             ScciConf.CalcPremioDFIPeloValAvalCorrigido then begin
            if Temp5.MacAval > 0 then begin
              int_mes(Temp5.MacAval,DtAval.Mesano);
              Dtaval.dia := 1;
            end
            else DtAval := RpaCons.Finrpa.DtAssin;
            Corr := Correcao0(DtAval,Fin.DtRenegGeradora,RpaCons.FinRpa.DtAssin,ValBaseSegAux);
            AjustaMoeda2(mes_int(dtAval.mesano),mes_int(Fin.DtRenegGeradora.mesano),ValBaseSegAux);
            ValBaseSegAUx := ValBaseSegAux + Corr;
          end;
        end;

        if RegApoliceDFI.CodApolice > '' then
          if abs(RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI) > zero then
            if ValBaseSegAux-RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI > zero then
              ValBaseSegAux := RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI;

        if Temp11.NaoReajustaDFI or (RegApoliceDFI.TpReajBase > 0) then
          ValRPA.SegImv := int(ValBaseSegAux*FinRPA.IndSegImv*100+0.5)/100
        else
          ValRPA.SegImv := int(ValBaseSegAux*FinRPA.IndSegImv*Temp5.TxPstAcum*100+0.5)/100;
          
        if RegApoliceDFI.SeguroAVista then
          ValRPA.SegImv := 0;
      end
      else
        ValRPA.SegImv := 0.0;
    end;
    
    TrataPercIof(Temp6.EdoSFH,ObtemTipoAliquotaIof(RpaS,2{DFI}),
                 RpaS.Temp12.PercIofDFI,ValRPA.SegImv,Temp12.IofDfi);

    ValRPA.Seguro := ValRPA.SegImv+ValRPA.SegCre+ValRPA.SegFin;
  end;
end;

procedure TSerie.CalculaSeguroDFI(Var RpaCons : TpRpa);
begin
    with RPAS do begin
      if not Assigned(FParcelaDoMes) then begin
        CalculaSeguroDFIpSeries(0,RpaCons);
        if RPAS.ValRPA.Seguro > Zero then CriaParcelaDoMesDeSeguro;
      end;
      if Assigned(FParcelaDoMes) then begin
        if Temp10.TemParcNomes then
          CalculaSeguroDFIpSeries((FParceladoMes as TParcelaSerie).Seguro,RpaCons)
        else
          CalculaSeguroDFIpSeries(0,RpaCons);
      end;
      ValRPA.Seguro := ValRPA.SegFin + ValRPA.SegCre + ValRPA.SegImv;
      AtualizaTotPrest(RpaS);
      Temp7.DescSeg := 0;
      if (Temp7.TemDescontoSegMIP) and
         ((Temp11.MATermDescSegMIP > MAC) or (Temp11.MATermDescSegMIP = 0)) then
        Temp7.DescSeg := ValRPA.SegFin;
      if (Temp9.TemDescontoSegDFI) and
         ((Temp11.MATermDescSegDFI > MAC) or (Temp11.MATermDescSegDFI = 0)) then
        Temp7.DescSeg := Temp7.DescSeg + ValRPA.SegImv;
      ValRPA.Desc := ValRPA.Desc + Temp7.DescSeg;
    end
end;

procedure TSerie.CalcSaldoPagamentoAntecipadoParcial;
Var
  UtilizacaoNoMes,
  PagamentoParcialNoMes,
  CorrTemp : Double;
  ll: TLegLinkItem;
begin
  ll := nil;
  UtilizacaoNoMes := 0;
  PagamentoParcialNoMes := 0;
  RPAS.Temp11.SaldoPgParcialAntecAnt := RPAS.Temp11.SaldoPgParcialAntec;
  RPAS.Temp11.CorrPgParcialAntec := int(RPAS.Temp11.SaldoPgParcialAntec * (RpaS.FinRPA.TxSD-1) *100 + 0.5)/100;
  RPAS.Temp11.JurosPgParcialAntec:= int((RPAS.Temp11.SaldoPgParcialAntec + RPAS.Temp11.CorrPgParcialAntec) * RPAS.FinRPA.IndJuros * 100+0.5)/100;
  RPAS.Temp11.SaldoPgParcialAntec := int(PagamentosParciais.ObtemSaldoRef(Self,UtilizacaoNoMes,PagamentoParcialNoMes) * RPAS.Temp3.IndSaldoAcum*100+0.5)/100;
  if RPAS.Temp11.SaldoPgParcialAntec > Zero then
  begin
    if not Contrato.FInibeLegLink then 
      ll := LegLink.add(Fin.CodSerie,'<p/><b>Calculo da corre  o do saldo de pagamento parcial antecipado</b>');
    if assigned(ll) then
    begin
      ll.valores['Indice de corre  o acumulado'] := formatfloat('0.000000',RPAS.Temp3.IndSaldoAcum);
      ll.valores['Saldo corrigido'] := strgrana(RPAS.Temp11.SaldoPgParcialAntec);
    end;
  end;
  RPAS.Temp11.PgParcialAntecNoMes := PagamentoParcialNoMes;
  RPAS.Temp11.VUtilPgParcialAntec := int(UtilizacaoNoMes * RPAS.Temp3.IndSaldoAcum*100+0.5)/100;
  // A linha abaixo   para tirar erro de arredondamentos e a conta sempre fechar
  CorrTEMP := RPAS.Temp11.SaldoPgParcialAntec -
                        (RPAS.Temp11.SaldoPgParcialAntecAnt + RPAS.Temp11.JurosPgParcialAntec - RPAS.Temp11.VUtilPgParcialAntec);
  if abs(CorrTEMP - RPAS.Temp11.CorrPgParcialAntec) < 0.03 then
     RPAS.Temp11.CorrPgParcialAntec := CorrTEMP;
  if abs(RPAS.Temp11.PgParcialAntecNoMes) > Zero then 
    with RPAS.Temp11 do
      ProRataPgParcialNoMes :=  (SaldoPgParcialAntec - SaldoPgParcialAntecAnt - CorrPgParcialAntec - JurosPgParcialAntec - PgParcialAntecNoMes + UtilizacaoNoMes) 
  else
    Rpas.Temp11.ProRataPgParcialNoMes := 0;
end;

