function ProcSortPorMacECtr(Item1, Item2 : TCollectionItem) : integer;
var
  wParcela1,
  wParcela2 : TParcela;
begin
  // ordem menor MAC, azinho primeiro

  wParcela1 := item1 as TParcela;
  wParcela2 := item2 as TParcela;
  if wParcela1.Mac < Wparcela2.Mac then
    result := -1
  else if wParcela1.Mac > wParcela2.Mac then
    result := 1
  else if length(wParcela1.co_contrato) > Length(wparcela2.co_contrato) then
    result := -1
  else if length(wParcela1.co_contrato) < Length(wparcela2.co_contrato) then
    result := 1
  else
    result := 0;
end;

