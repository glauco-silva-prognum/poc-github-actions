function TParcela.EstaEmAtraso(Ctr : TpCtr;
                               FinancBancario : boolean;
                               CodClassificacao : byte;
                               DtInicio,DtHabit,DataRef:TData):boolean;
var
  DtVenc   : TData;
  Dias : integer;
begin
  DtVenc.Dia := DiaVenc;
  Int_Mes(MAC,DtVenc.MesAno);
  if assigned(Contrato) then
    Dias := Contrato.DiasDeAtrasoEntreDatas(DtVenc,DataRef)
  else
    Dias := sfhlib.DiasDeAtrasoEntreDatas(DtVenc,DataRef);
  result := (Dias > 0) and
            (not EstaPaga(DataRef)) and
            (((Mac < mes_int(DtInicio.MesAno)) and (TipoParc in [TpParc_Invalido,TpParc_SoSeguro])) or
             ((not FinancBancario and (CodClassificacao <> serie_Chaves)) or
              ParcelaDeFinBancChavesDevida(Contrato,DtInicio,DtHabit,DataRef,
                                           CalcCarenciaFinBancChavesPelaDtInicio(Serie.Fin,Contrato.Empreendimento))));
end;

function TParcela.EstaEmAtrasoAtual(Ctr : TpCtr;
                                    FinancBancario : boolean;
                                    CodClassificacao : byte;
                                    DtInicio,DtHabit : Tdata;
                                    DiaIsencao : integer;
                                    DataRef:TData;
                                    ConsideraIsencao : boolean = true;
                                    ConsideraVencida : boolean = false):boolean;
var
  DtVenc,
  DtIsen : TData;
  Dias : integer;
begin
  DtIsen.dia := 0; DtIsen.mes := 0; DtIsen.ano := 0;
  DtVenc.Dia := DiaVenc;
  Int_Mes(MAC,DtVenc.MesAno);
  if ConsideraIsencao then
    DtIsencaoMora(DtVenc,DtIsen,DiaIsencao)
  else
    DtIsen := DtVenc;  
  if assigned(Contrato) then
    Dias := Contrato.DiasDeAtrasoEntreDatas(DtIsen,DataRef)
  else
    Dias := sfhlib.DiasDeAtrasoEntreDatas(DtIsen,DataRef);
  result := ((Dias > 0) or (ConsideraVencida and (Juliano(DtIsen)=Juliano(DataRef)))) and
            (not EstaPaga(DataRef)) and
            (((Mac < mes_int(DtInicio.MesAno)) and (TipoParc in [TpParc_Invalido,TpParc_SoSeguro])) or
             ((not FinancBancario and (CodClassificacao <> serie_Chaves)) or
              ParcelaDeFinBancChavesDevida(Contrato,DtInicio,DtHabit,DataRef,CalcCarenciaFinBancChavesPelaDtInicio(Serie.Fin,Contrato.Empreendimento))));
end;

