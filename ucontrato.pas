function RetornaSituacaoCtb(Contrato : Tcontrato; DataRef : TData) : smallint;
var
  In_Regra_2682,
  RAAPTotalNT : boolean;
  DtEntSituacaoCtb,
  DtSituacao,
  DtAjuizamento : TData;
begin
  Result := 0;
  if Scciconf.UtilizaSituacaoCtbConfig and assigned(Contrato) then begin
    RAAPTotalNT := false;
    DtEntSituacaoCtb.Dia := 0;
    fillchar(DtEntSituacaoCtb,sizeof(TData),0);
    DtSituacao.Dia := 0;
    fillchar(DtSituacao,sizeof(TData),0);
    DtAjuizamento.Dia := 0;
    fillchar(DtAjuizamento,sizeof(TData),0);
    if Scciconf.CalculaRAAPNaoTributavel and EmExecucaoJudicial(Contrato.Mutdsk,DataRef,DtSituacao) and
       (juliano(DtSituacao) <= juliano(DataRef)) then
      DtAjuizamento := DtSituacao;
    In_Regra_2682 := Contrato.MutDsk.Cad6.In_Regra_2682;
    Result := Contrato.ObtemSituacaoCtb(DataRef,DtAjuizamento,RAAPTotalNT,DtEntSituacaoCtb,In_Regra_2682,DtEntSituacaoCtb);
  end;
end;

