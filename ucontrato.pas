  if RPAS.Temp12.Reestruturada then RPAS.Temp12.DtEvento := Fin.DataRef;
  RPAS.ValRPA.MacRecorr := Mutdsk.Financ3.MacRecorr;
  RPAS.Temp12.TabGenReavaliacao := IRetornaTabGenReavaliacao(MutDsk.ChaveImv.Empreend,MutDsk.ChaveImv.CodImv);
  RPAS.Temp12.ValReavaliacao := Mutdsk.Financ.ValAval;
  RPAS.Temp12.IndSaldoAcumMacAval := 1.0;
  RPAS.Temp12.ValAvalCorr := RPAS.FinRPA.ValAVal;
  RPAS.Temp12.MantemValorDFI := Fin.MantemValorDFI;
  RPAS.Temp12.MacFixaDFI := RPAS.Mac;
  RPAS.Temp12.MantemValorMIP := Fin.MantemValorMIP;
  RPAS.Temp12.MacFixaMIP := RPAS.Mac;
  if Contrato.TemCA and (RPAS.Temp7.TipoCtr <> 41 {98550}) then begin
    if TxJurosCaIgualaTxJuros(Contrato,RPAS.Temp8.CodSerie) then 
      RPAS.Temp12.VlInicioCA :=-RPAS.FinRPA.ValFinanc
    else 
      RPAS.Temp12.VlInicioCA := ObtemVlInicioCA(Mutdsk,RPAS.FinRPA.ValFinanc);
    RPAS.Temp12.SaldoCA    := -RPAS.Temp12.VlInicioCA;
    RPAS.Temp12.Recup_Judicial_Extra := MutDsk.Cad6.Recup_Judicial_Extra;
  end;
  if RpaS.Temp7.TipoCtr = 55 {Fianca} then begin
    RPAS.Temp12.DTPAGTOANTEC := Fin.DTPAGTOANTEC;
    RPAS.Temp12.VLPAGTOANTEC := Fin.VLPAGTOANTEC;
  end;
  InitRazao;
//  LegLinkItem := LegLink.add(fin.codserie,'C lculo Inicial do seguro'); voltar esse c digo para continuar a implementa  o do leglink para o deguro de s ries
  if assigned(LegLinkItem) and (not Contrato.FInibeLegLink) then begin
    RegApolice.codapolice := '';
    fillchar(RegApolice,sizeof(TpApolice),0);
    if LeApolice(RpaS.Temp10.CodApolice,RegApolice) then
      DescApolice := RegApolice.DescApolice
    else
      DescApolice := RpaS.Temp10.CodApolice;

    RegApolice.codapolice := '';
    fillchar(RegApolice,sizeof(TpApolice),0);
    if LeApolice(RpaS.Temp11.CodApoliceDFI,RegApoliceDFI) then
      DescApoliceDFI := RegApoliceDFI.DescApolice
    else
      DescApoliceDFI := RpaS.Temp11.CodApoliceDFI;
    LegLinkItem.valores['<table><tr><td>Seguradora MIP'] := '</td><td>'+NomeSeguradora(RPAS.Temp11.Seguradora)+'</td></tr>';
    LegLinkItem.valores['<tr><td>Ap lice MIP'] := '</td><td>'+DescApolice+'</td></tr>';
    LegLinkItem.valores['<tr><td>Seguradora DFI'] := '</td><td>'+NomeSeguradora(RPAS.Temp11.SeguradoraDFI)+'</td></tr>';
    LegLinkItem.valores['<tr><td>Ap lice DFI'] := '</td><td>'+DescApoliceDFI+'</td></tr>';
    LegLinkItem.valores['<tr><td>Grupo de Ap lice'] := '</td><td>'+inttostr(RPAS.Temp11.GrupoApolice)+'</td></tr>';
    if RPAS.Temp12.ValBaseLimiteSegMip > zero then
      LegLinkItem.valores['<tr><td>Valor Base Limite para MIP'] := '</td><td>'+strgrana(RPAS.Temp12.ValBaseLimiteSegMip)+'</td></tr>';
    LegLinkItem.valores['<tr><td>Valor Base para MIP'] := '</td><td>'+strgrana(RPAS.Temp5.ValBaseSeg)+'</td></tr>';
    LegLinkItem.valores['<tr><td>Valor Base para DFI'] := '</td><td>'+strgrana(RPAS.Temp9.ValBaseSegDfi)+'</td></tr></table>';
  end;
 end;
end;

