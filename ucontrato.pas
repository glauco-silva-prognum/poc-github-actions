procedure TSerie.CalculaJurosProgressivos;
var
  IncrementoJuros,
  JurosFinal,
  IndIncrementoJurosAoMes,
  indJurosFinalAoMes : Double;
begin
  if (Rpas.FinRpa2.JurFin > Zero) then
  begin
    IncrementoJuros := CalculaJuros(Fin.TpJuros,Rpas.FinRpa2.JurCP,Fin.PerParcelas,Fin.JurosSimples);
    JurosFinal := CalculaJuros(Fin.TpJuros,Rpas.FinRpa2.JurFin,Fin.PerParcelas,Fin.JurosSimples);
    IndIncrementoJurosAoMes :=  pot(1 + IncrementoJuros/100, 1.0 / Fin.PerParcelas ) -1 ;
    indJurosFinalAoMes :=  pot(1 + JurosFinal/100, 1.0 / Fin.PerParcelas ) -1 ;
    if (Rpas.MAC >= Rpas.FinRpa2.MACInJurP) and 
       ((Rpas.MAC - Rpas.FinRpa2.MACInJurP) mod Rpas.FinRpa2.PerJurCP = 0) and
         (abs(Rpas.FinRpa2.JurCP) > Zero) and
         (math.sign(IndIncrementoJurosAoMes)*(Rpas.FinRpa.IndJuros)+Zero < math.sign(IndIncrementoJurosAoMes)*indJurosFinalAoMes) then
    begin
      Rpas.FinRpa.IndJuros := Rpas.FinRpa.IndJuros + IndIncrementoJurosAoMes;
    end;
  end;
end;

function TSerie.HouveAumentoDePrazoIFRS9(DtReneg : Tdata; Var Rpa : TpRPA) : boolean;
var
  DtTerm,
  DtMaiorTermContratual : TData;
  i : integer;
begin
  DtMaiorTermContratual.dia := 0;
  for i := 0 to Contrato.Series.count-1 do
    if (Contrato.Series[i].Fin.CodSerie <> Fin.Codserie) and
       (Juliano(Contrato.Series[i].Fin.DtRenegGeradora) <> Juliano(DtReneg)) then begin
      DtTerm.dia := 0;
      DeterminaTermino(Contrato.Series[i].RPAS,DtTerm);
      if (DtMaiorTermContratual.dia = 0) or (Juliano(DtTerm) > Juliano(DtMaiorTermContratual)) then
        DtMaiorTermContratual := DtTerm;
    end;
  DtTerm.dia := 0;
  DeterminaTermino(Rpa,DtTerm);
  result := Juliano(DtTerm) > Juliano(DtMaiorTermContratual);
end;

