      DtIniCondAdversa := MontaDtIniCOndAdversa(RPAF,DtIniCondAdversa,FDataRefHist);
    if (Mes_Int(FDataRefHist.MesAno) < 1501) and RegCarteira.RegimeDeCaixa then begin
      if (RPAF.Temp11.DtPrimAtrasoCtb.Dia > 0) and
        ((DtPrimAtrasoBkp.Dia = 0) or 
        ((FDataPrimAtraso.Dia = 0) or 
         (Mes_Int(RPAF.Temp11.DtPrimAtrasoCtb.MesAno) < Mes_Int(FDataPrimAtraso.MesAno)))) then 
