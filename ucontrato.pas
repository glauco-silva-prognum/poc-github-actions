procedure TDadosAtrasoEvo.SomaPrest(prest : TPrestacaoAtrasoEvo);
begin
  inc(NPrest);
  TotAcordo   := TotAcordo    + Prest.ValAcordo;
  TotSerie    := TotSerie     + Prest.ValorSerie;
//  TotPoup     := TotPoup   {+ Tit.Poupanca};
  TotFGTS     := TotFGTS      + Prest.FGTS;
  TotTaxaBanco:= TotTaxaBanco + Prest.TaxaBanco;
  TotDifer    := TotDifer     + Prest.Diferenca;
  TotPrest    := TotPrest     + (Prest.TotPrest + Prest.FGTS);
  TotMora     := TotMora      + Prest.Mora;
  TotJuroscontr := TotJuroscontr + Prest.Juroscontr;
  TotCorr     := TotCorr      + Prest.Correcao;
  TotDesp     := TotDesp      + Prest.Despesas;
  TotHonor    := TotHonor     + Prest.Honorarios;
  TotMulta    := TotMulta     + Prest.Multa;
  TotDesc     := TotDesc      + Prest.Desc;
  TotIOFComp := TotIOFComp + Prest.ValIOFComplem;
  TotDescpagamento := TotDescPagamento + Prest.DescPagamento;
  TotValorPagoAntecipado := TotValorPagoAntecipado + Prest.ValorPagoAntecipado;
  TotResiduoCobrado := TotResiduoCobrado + Prest.ResiduoCobrado;
end;

procedure TDadosAtrasoEvo.MontaListaDeEmissao(pList : TStringlist; Ordena : boolean);
var
  i : integer;
begin
  pList.clear;
  for i := 0 to count-1 do begin
    if not GetPrestacao(i).Esconde then
      pList.addobject(GetPrestacao(i).NossoNum+
                     intstr2(GetPrestacao(i).MacPrst,4),
                     GetPrestacao(i));
  end;
  if Ordena then
    pList.Sort;
end;

procedure TDadosAtrasoEvo.CalculaHonorarios(CalculoAtrasoParametros : TCalculoAtrasoParametros);
var
  i : smallint;
  Honor : real;
  ValTitAmaisj : real;
begin
  if PodeCobrarHonorarios and AbriuPagamentosSql and AbriuTitSql and (PercHonorarios > Zero) then begin
//    ValorTaxa := ValorTaxa + Arredonda(ValorTaxa*PercHonorarios/100);
//    IPTU      := ValorTaxa + Arredonda(IPTU*PercHonorarios/100);
    for i := 0 to Count-1 do
      if (not Prestacao[i].Esconde) and Prestacao[i].EmAtraso and
          not Prestacao[i].EmFaseDeCarenciaFinBancChaves and
          not Prestacao[i].EmCarenciaCobAtraso and
          not Prestacao[i].SerieIsentaHonorario then begin
        Prestacao[i].ValTit := Prestacao[i].EncMes - Prestacao[i].OutAbat +
                               Prestacao[i].TaxaBanco +
                               Prestacao[i].OutRec + Prestacao[i].ValAcordo;
        Prestacao[i].PercHonorarios := PercHonorarios;
        Prestacao[i].Honorarios := Arredonda(Prestacao[i].ValTit * PercHonorarios/100);
        Prestacao[i].HonorariosTot := Prestacao[i].Honorarios;
        if Prestacao[i].IsenMora.PercDescHonorarios > Zero then
          Prestacao[i].Honorarios := Arredonda(Prestacao[i].Honorarios - (Prestacao[i].Honorarios * Prestacao[i].IsenMora.PercDescHonorarios/10000));
        Prestacao[i].ValTit := Prestacao[i].ValTit + Prestacao[i].Honorarios;
        ValTitAmaisj := Prestacao[i].Amaisj - Prestacao[i].ValorPagoParcialAmaisJ;
        Prestacao[i].HonorariosAmaisj := Arredonda(ValTitAmaisj * PercHonorarios/100);
        if Prestacao[i].IsenMora.PercDescHonorarios > Zero then
          Prestacao[i].HonorariosAmaisj := Arredonda(Prestacao[i].HonorariosAmaisj - (Prestacao[i].HonorariosAmaisj * Prestacao[i].IsenMora.PercDescHonorarios/10000));
      end;
    if ValorTaxa > zero then begin
      for i := 0 to Taxas.count-1 do 
        if (juliano(Taxas[i].Dados.DtVenc) < juliano(CalculoAtrasoParametros.Dataref)) then begin
          Honor := arredonda(Taxas[i].Dados.ValorCorrigido * PercHonorarios/100);
          Taxas[i].Dados.ValorCorrigido := Taxas[i].Dados.ValorCorrigido + Honor;
          ValorTaxa := ValorTaxa + Honor;
        end;
    end;
  end;
end;

procedure TDadosAtrasoEvo.Totalizadados;
var
  MACAtrAnt,
  i : SmallInt;
  wList : Tstringlist;
begin
  Fillchar(DtVencPrimeiraEmAtraso,sizeof(Tdata),0);
  NPrest      := 0;
  TotPrest    := 0;  TotMora  := 0;  TotDesc     := 0;
  TotCorr     := 0;  TotDesp  := 0;  TotHonor    := 0;
  TotMulta    := 0;  TotDifer := 0;  TotAcordo   := 0;
  {TotPoup     := 0;}TotFGTS  := 0;  TotSerie    := 0;
  TotTaxaBanco:= 0;  TotValorPagoAntecipado := 0; TotDescpagamento := 0;
  TotResiduoCobrado := 0; TotJuroscontr := 0; TotIOFComp := 0;
  for i := 0 to Count-1 do begin
    if not Prestacao[i].Esconde then
      SomaPrest(Prestacao[i]);
    if Prestacao[i].EmAtraso and
       ((DtVencPrimeiraEmAtraso.dia = 0) or
        (Prestacao[i].MacPrst < Mes_int(DtVencPrimeiraEmAtraso.mesano)) or
        ((Prestacao[i].MacPrst = Mes_int(DtVencPrimeiraEmAtraso.mesano)) and
         (Prestacao[i].DiaVenc < DtVencPrimeiraEmAtraso.Dia))) then begin
      int_mes(Prestacao[i].MacPrst,DtVencPrimeiraEmAtraso.mesano);
      DtVencPrimeiraEmAtraso.dia := Prestacao[i].DiaVenc;
    end;
  end;

  wList := Tstringlist.create;
  try
    MontaListaDeEmissao(wList,false);
    QtdeRecibos:= 1;  MACAtrAnt:= 0;
   if (Scciconf.SistemaDeTaxas = SisTaxaPorRecibo) and GeraUmReciboComPrstComJanela then begin
     if NumMaxParcPorRecCons=0 then
       QtdeRecibos := 1
     else
       QtdeRecibos := trunc((wList.count / NumMaxParcPorRecCons)+0.99);
    end
    else for i := 0 to wList.count - 1 do begin
      if (MACAtrAnt + 1 <> TPrestacaoAtrasoEvo(wList.objects[i]).MACPrst) and
         (MACAtrAnt > 0) and
         (MACAtrAnt <> TPrestacaoAtrasoEvo(wList.objects[i]).MACPrst) and // S rie diferente, mesmo m s , Sol. 27545
         (Scciconf.SistemaDeTaxas = SisTaxaPorRecibo) and
         not GeraUmReciboComPrstComJanela then
        inc(QtdeRecibos);
      MACAtrAnt := TPrestacaoAtrasoEvo(wList.objects[i]).MACPrst;
    end;
  finally
    wList.free;
  end;
end;

function TDadosAtrasoEvo.TestaEmissaoAnteriorXdb(Ctr : TpCtr; MacPrst : smallint; CodSerie : longint) : boolean;
var
  Regtit :TpTitulos;
  Key : TpCh3Tit;
begin
  Regtit.Ctr := '';
  fillchar(Regtit,sizeof(Regtit),0);
  result := false;
  AtivaIndice(Arqtit,3);
  try
    Key.Ctr := Ctr;
    Key.MacPrst := MacPrst;
    Key.Seq := 0;
    procurareg(Arqtit,Key);
    if ok then
      Lereg(Arqtit,Regtit);
    while Ok and not dbeof(Arqtit) and
        ( Regtit.ctr = Ctr)        and
        ( RegTit.MacPrst = MacPrst) do begin
      if (Regtit.CodSErie = CodSerie) and
         (UpCase(Regtit.Tipo) in ['N','M','G','C','I']) then
        result := true;
      Posicionareg(Arqtit,Proximo);
      if Ok then lereg(Arqtit,Regtit);
    end; //  while
    Posicionareg(Arqtit,Limbo);
  finally
    AtivaIndice(ArqTit,1);
  end;
end;

function TDadosAtrasoEvo.TestaEmissaoAnteriorSql(Ctr : TpCtr; MacPrst : smallint; CodSerie : longint) : boolean;
var
