  FLeuValorPendEmi := true;
end;

constructor TPendenciasContrato.create(Owner:TObject);
begin
  inherited create;
  Fowner := Owner;
  FLeuValorPendEmi := false;
  FValorPendEmiPorSerieEmac := TValoresPorCodSerieEMac.create;
  FQryValoresEmitidos := pdb.TSqlQuery.create(nil);
  FQryValoresEmitidos.SqlConnection := Pendlib.SqlConnectionPendencia;
  if assigned(FQryValoresEmitidos.SqlConnection) then 
    FQryValoresEmitidos.Sql.BeginUpdate;
  try
    FQryValoresEmitidos.sql.add('select coalesce(CodSerie,0),coalesce(MACCobrado,0), sum(coalesce(ValorEmis,0)) as ValorPendEmi');
    FQryValoresEmitidos.sql.add(' from pendencia where co_contrato=:co_contrato');
    FQryValoresEmitidos.sql.add(' and status in (2,3,5,13)');
    FQryValoresEmitidos.sql.add(' group by CodSerie,MacCobrado');
  finally
    if assigned(FQryValoresEmitidos.SqlConnection) then 
      FQryValoresEmitidos.sql.EndUpdate;
    FQryValoresEmitidos.Params[0].DataType := ftString;
  end;
end;

destructor TPendenciasContrato.destroy;
begin
  FValorPendEmiPorSerieEMac.free;
  FQryValoresEmitidos.free;
  inherited Destroy;
end;

procedure TPendenciasContrato.clear;
begin
  FValorPendEmiPorSerieEmac.Clear;
  FLeuValorPendEmi := false;
end;

function TPendenciasContrato.ValorPendEmi(MACRef : SmallInt; CodSerie : longint = 0) : real;
begin
  if AbriupendSql then begin
    if not FLeuValorPendEmi then
      LeValorPendEmi(Contrato.Mutdsk.Cad.Ctr);
    result := FValorPendEmiPorSerieEmac[CodSerie,MACRef];
  end
  else
    result := pendlib.ValorPendemi(Contrato.Mutdsk.Cad.Ctr,MACRef,CodSerie);
end;

