  FQryValoresEmitidos.SqlConnection := SqlConnectionPendencia;
  if not FQryValoresEmitidos.prepared then
    FQryValoresEmitidos.prepared := true;
  FQryValoresEmitidos.Parambyname('co_contrato').asstring := CtrToSqlCtr(ctr); //quotedStr(CtrToSqlCtr(Ctr));
