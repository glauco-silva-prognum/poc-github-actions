  PercDescMulta := 0;
  result := Le(CodSerie,TipoParc,NumParc,DataAgenda,
               PercDescMora,PercDescJRemuneratorios,PercDescCorr,PercDescMulta,
               Emitiu,DtIncAgend,UserAgend,MacParc);
