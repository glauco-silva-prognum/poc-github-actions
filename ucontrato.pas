function TContrato.PodeIsentarMoraAuto(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados  : TDadosAtrasoEvo; TestaGrupo : boolean = false) : boolean;
var
  TaNoPeriodo,
  PodeIsentarAux : boolean;
  DataLimite     : TData;
  SitEsp         : byte;
  i : integer;
  CarteiraOk : boolean;
begin
  DataLimite.dia := 0;
  fillchar(DataLimite,sizeof(TData),0);
  Dados.Status := CalculoAtrasoStatus_Ok;
  Dados.Msg := '';
  SitEsp := 0;
  PodeIsentarAux:= false;
  CarteiraOk := true;
  if TestaGrupo then begin
    for i := 0 to Grupo.count-1 do 
      CarteiraOk := CarteiraOk and CarteiraConcedeIsenMoraAuto(Grupo[i].Contrato.RPA.Temp5.Carteira)
  end
  else
    CarteiraOk := CarteiraConcedeIsenMoraAuto(RPA.Temp5.Carteira);
  if CarteiraOk then begin
    if ConcedeIsencaoDeMoraAuto(MutDsk,SitEsp,DataLimite,DataH) then begin
      if CalculoAtrasoParametros.DataAtr.Dia > 0 then begin
        TaNoPeriodo := (Juliano(CalculoAtrasoParametros.DataAtr) <= Juliano(DataLimite)) or
                       (Juliano(CalculoAtrasoParametros.DataAtr) <= Juliano(Scciconf.DataIsenMoraAuto));
      end
      else begin
        TaNoPeriodo := (Juliano(CalculoAtrasoParametros.DataRef) <= Juliano(DataLimite)) or
                       (Juliano(CalculoAtrasoParametros.DataRef) <= Juliano(Scciconf.DataIsenMoraAuto));
      end;
      if not TaNoPeriodo then
        Dados.Msg := 'Isenc o de Juros de Mora negada. Dt.Lim. do ctr.: '+Data_Str(DataLimite);
    end
    else begin
      if CalculoAtrasoParametros.DataAtr.Dia  > 0 then
        TaNoPeriodo := (Juliano(CalculoAtrasoParametros.DataAtr) <= Juliano(Scciconf.DataIsenMoraAuto))
      else
        TaNoPeriodo := (Juliano(CalculoAtrasoParametros.DataRef) <= Juliano(Scciconf.DataIsenMoraAuto));
      if TaNoPeriodo then
        SitEsp := ObtemSitEspPorFaixaAtr(Dados.Count)
      else
        Dados.Msg := 'Isen  o de Juros de Mora negada. Dt.Lim. projeto: '+Data_Str(Scciconf.DataIsenMoraAuto);
    end;
    if TaNoPeriodo then begin
      Dados.SitEspIsenMoraAuto := SitEsp;
      PodeIsentarAux := true;
    end
    else begin
      Dados.Status := CalculoAtrasoStatus_Erro;
    end;
  end
  else begin
    Dados.Status := CalculoAtrasoStatus_Erro;
    Dados.Msg := 'Nao   permitido isen  o de juros de mora para essa carteira';
  end;
  Result := PodeIsentarAux;
end;

procedure TContrato.VerificaResultadoCalculoAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                   Dados : TDadosAtrasoEvo; TestaGrupo : boolean = false);

  function TemAcordoNasPrestacoes : boolean;
  var
    TemAcordo : boolean;
    i : longint;
  begin
    TemAcordo := false;
    i := 0;
    while (i < Dados.count) and not TemAcordo do
      if Dados[i].NPCAcordo > 0 then TemAcordo := true
      else inc(i);
    TemAcordoNasPrestacoes := TemAcordo;
  end;

var
  RegRef : TValoresPorMac;
  DtSinistro : Tdata;
begin
  if (CalculoAtrasoParametros.TipoExec <> TipoExec_IsenMoraAuto) or
     PodeIsentarMoraAuto(CalculoAtrasoParametros,Dados,TestaGrupo) then begin
    if (Dados.Status <> CalculoAtrasoStatus_Erro) and (CalculoatrasoParametros.TipoExec = TipoExec_Incorporacao) then begin
      if (Dados.count > 36) and
         not UserHabilitado(PegaUsuario,
                            PermPodeIncorpAtrAcimaDoLimite) then begin
        Dados.Status := CalculoAtrasoStatus_Erro;
        Dados.Msg := 'Mutuario com atraso acima do permitido para incorporar.'+
                     #13+'Encaminhar processo para SEFA';
      end
      else if TemAcordoNasPrestacoes then begin
        Dados.Status := CalculoAtrasoStatus_Erro;
        Dados.Msg := 'Impossivel calcular a incorporacao, pois o mutuario '+
                     'tem parcelas de acordo em atraso.';
      end;
    end;
    // Sol. 22093
    RegRef := ObtemValoresPorMac(mes_int(CalculoAtrasoParametros.DataRef.MesAno));
    if (Dados.Status <> CalculoAtrasoStatus_Erro) and
       (CalculoatrasoParametros.TipoExec in [TipoExec_Atraso,TipoExec_Caixa,TipoExec_Vincendas,TipoExec_IsenMoraAuto,TipoExec_2avia]) and
       (Dados.Count = 0) and not RegRef.CtrAtivo and
       (RegRef.status = 2) {Sinistro} then begin
      int_mes(RegRef.MacStatus,DtSinistro.MesAno);
      DtSinistro.dia := RegRef.DiaLiq;
      Dados.Status := CalculoAtrasoStatus_Erro;
      Dados.Msg := 'Contrato com Liquida  o por Sinistro ocorrida em '+
                   data_str2(DtSinistro) + ' e sem presta  es em atraso';
    end;
  end;
end;

procedure TContrato.CalculaDifPrestOutros(MacIni,
                                          MacFim   : integer;
                                          DtCorr   : Tdata;
                                      Var PendQuit,
                                          CorrQuit,
                                          MoraQuit : real;
                                          Dados    : TDadosAcertoEvo;
                                          EmUPF    : boolean;
                                          DataEmi  : Tdata;
                                          TipoEmissao : smallint;
                                          Grava       : boolean {GravaPendEmi});
var
  I      : SmallInt;
  Dif,
  Corr,
  Mora,
  VMoeda,
  VMoedaVenc : real;
  DtAssin,
  DtPag  : tdata;
  Reg  : TValoresPorMac;
  Item : TItemAcertoEvo;
  PrstAnt : real;
  RPendEmi : TpPendEmi;
  UF : str3;
  CodMun : smallint;
  AcQuit,
  AcReneg,
  AcIncorp,
  AcAExtra : boolean;
begin
  UF := '';
  CodMun := 0;
  PendQuit := 0;
  CorrQuit := 0;
  MoraQuit := 0;
  if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);
  DtAssin.dia := 0;
  fillchar(DtAssin,sizeof(TData),0);
  if TemFinancDinamico(MutDsk) then 
    DtAssin := MutDsk.Financ.DtAssin;
  if MutDsk.Cad2.TemSerie then 
    for i := 0 to Series.Count-1 do
      if (DtAssin.Dia = 0) or 
         (juliano(Series[i].Fin.DataRef) < juliano(DtAssin)) then
        DtAssin := Series[i].Fin.DataRef;
  i := Mes_Int(DtAssin.MesAno);
  while (i <= MACFim) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if (i >= MACIni) and (i <= MACFim) and
         (Abs(Reg.ValDifPrest) > Zero) then begin
        AcQuit  := false;
        AcReneg := false;
        AcIncorp:= false;
        AcAExtra:= false;
        Dif     := 0;
        Mora    := 0;
        DtPag := Reg.DtPagValDifPrest;
        if (Reg.Status = 1) and (Reg.MACStatus = i) then begin
          if DtPag.Dia = 0 then begin
            Int_Mes(i,DtPag.MesAno);       
            if Reg.DiaLiq > 0 then DtPag.Dia := Reg.DiaLiq      
            else DtPag.Dia := Reg.DiaVenc;   
          end;
          Dif := Reg.ValDifPrest;
          AcQuit := true;
        end;
        if (Reg.Status = 30) and (Reg.MACStatus = i) then begin
          Dif := Dif + Reg.ValDifPrest;
          if DtPag.Dia = 0 then begin
            Int_Mes(i,DtPag.MesAno);       
            if Reg.DiaLiq > 0 then DtPag.Dia := Reg.DiaLiq      
            else DtPag.Dia := Reg.DiaVenc;   
          end;
          AcReneg := true;
        end;
        if (Reg.ExOpc in [18,102]) or (Reg.ExAmInc in [18,102]) or 
           (Reg.ExInc in [18,102]) then begin
          Dif := Dif + Reg.ValDifPrest;
          AcIncorp := true;
          if DtPag.Dia = 0 then begin
            Int_Mes(i,DtPag.MesAno);       
            if Reg.DiaInc > 0 then 
              DtPag.Dia := Reg.DiaInc      
            else if (Reg.DiaLiq > 0) and (Reg.Status = 0) then       
              DtPag.Dia := Reg.DiaLiq     
            else if Reg.DiaAmInc > 0 then    
              DtPag.Dia := Reg.DiaAmInc   
            else     
              DtPag.Dia := Reg.DiaAM2;
          end;
        end;
        if (Reg.ExOpc = 21) or (Reg.ExAmInc = 21) then begin
          Dif := Dif + Reg.ValDifPrest;
          AcAExtra := true;
          if DtPag.Dia = 0 then begin
            Int_Mes(i,DtPag.MesAno);      
            if Reg.DiaAMInc > 0 then DtPag.Dia := Reg.DiaAMInc         
            else if (Reg.DiaLiq > 0) and (Reg.Status = 0) then      
              DtPag.Dia := Reg.DiaLiq    
            else    
              DtPag.Dia := Reg.DiaAM2;
          end;
        end;
        if not AcQuit and not AcReneg and not AcIncorp and not AcAExtra then begin
          AcReneg := true;
          Dif := Reg.ValDifPrest;
        end;
        PrstAnt := Dif;
        if (abs(Dif) > 0) and (juliano(DtPag) > 0) and
           (Mes_int(DtPag.MesAno) >{=} MACIni) and (Mes_Int(DtPag.MesAno) <= MACFim) and
           (juliano(DtPag) > Juliano(MutDsk.Cad.DtUltRenACFin)) then begin
          if abs(Dif) > Zero then Dif := Dif*-1;
          if EmUPF then begin
            VMoeda  := LE_UPFD(DtPag);
            if VMoeda <= Zero then
              VMoeda := LE_VRF(mes_int(DtPag.Mesano));
            if VMoeda <= Zero then
              VMoeda := 1.0;
            VMoedaVenc := VMoeda;
            Dif := Dif / VMoeda;
            Mora := 0;
            Corr := 0;
          end
          else begin
            ObtemMunicipioParaCobranca(UF,CodMun);
            Corr := CorrPend(Mutdsk,UF,CodMun,DtPag,DtCorr,Dif,Mora);
            Mora := 0;
            AjustaMoeda2(Mes_Int(DtPag.MesAno),Mes_Int(DtCorr.MesAno),Dif);
            VMoeda := 0;
            VMoedaVenc := 0;
          end;
          if assigned(Dados) then begin
            Item := TItemAcertoEvo.create;
            Item.AcQuit  := AcQuit;
            Item.AcReneg := AcReneg;
            Item.AcAExtra:= AcAExtra;
            Item.AcIncorp:= AcIncorp;
            Item.DtVenc  := DtPag;
            Item.DtPag   := DtPag;
            if not EmUPF then begin
              Item.PrstAnt := PrstAnt;
              Item.PrstAtu := 0;
              Item.Dif := Item.PrstAtu - Item.PrstAnt;
            end;
            Item.DifAtu := Dif;
            Item.Mora   := Mora;
            Item.Corr   := Corr;
            Item.CodSerie := 0;
            Item.VMoeda := VMoeda;
            Item.VMoedaVenc := VMoedaVenc;
            Item.AmortNegMes := Reg.AmortNegMes;
            Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
            Item.CorrSaldoAmortNeg := Reg.CorrSaldoAmortNeg;
            Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
            Dados.add(Item);
          end;
          if Grava then begin
            RPendEmi.Ctr  := '';
            fillchar(RPendEmi,sizeof(TpPendEmi),0);
            with RPendEmi do begin
              Ctr            := MutDsk.Cad.Ctr;
              TpEmissao      := TipoEmissao;
              if AcQuit then 
                OrigPendEmi := 1  //Lan
              else if AcReneg then  
                OrigPendEmi := 2 //Reneg
              else if AcAExtra then
                OrigPendEmi := 4 // AExtra
              else 
                OrigPendEmi := 5; //Incorporacao
              DtEmi          := DataEmi;
              ValDevido      := 0;
              ValPago        := -Dif;
              DifAtual       := Dif;
              Atualizacao    := Corr + Mora;
            end;
            RPendEmi.MAC     := Mes_Int(DtPag.MesAno);
            RPendEmi.DtVenc  := DtPag;
            RPendEmi.DtPag   := DtPag;
            GravaPendEmi(RPendEmi);
          end;
          PendQuit := PendQuit + Dif;
          CorrQuit := CorrQuit + Corr;
          MoraQuit := MoraQuit + Mora;
        end;
      end;
    end;
    inc(i);
  end;
end;

