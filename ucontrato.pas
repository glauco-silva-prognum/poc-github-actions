                                               SerieF.Parcelas[i].ValorPago,
                                               SerieF.Parcelas[i].VA_DESC_ANTEC_USU);
    // Setar para n o precisar mais ler
    FOevolui3.Pagamentos.Ctr := Mutdsk.cad.Ctr;  
  end;  
end;

function TContrato.InicRpa(NaoReajusta : boolean = false):TpRpa;
var
  pMutMem : ^TPMutMem;
  wArrComp : ^TpArrComp;
  MACInicial   : smallint;
  EvoluiPEJuros : boolean;
begin
  SerieComDFI := 0;
  MenorDtAssin.dia := 0; MenorDtAssin.mes := 0; MenorDtAssin.ano := 0;
  RPA.MAC := 0; fillchar(RPA,sizeof(RPA),0);
  new(pmutmem);
  try
    pmutmem^.mutdsk := MutDsk;
    if not FHistoricosLidos then LeHistoricos;
    pMutMem^.MutDsk := MutDsk;
    SerieF.ValoresPorMacList.clear;
    FValoresPorMacList.clear;
    FIniValoresPorMac := -1;
    FEncargosEmAbertoCtb := 0;
    FDataUltEventoCASerie.Dia := 0; fillchar(FDataUltEventoCASerie,sizeof(FDataUltEventoCASerie),0);
    FCorrSaldoAcumAmIncCA := 0;
    FValAcumJurosIncorpCA := 0;
    FTxJurosCAProxMes     := 0;
    FSaldoCAAnt           := 0;
    Getmem(wArrComp,sizeof(TpArrComp));
    try
      wArrComp^ := GetArrComp;
      Init_RPA(pMutMem^,RPAF,wArrComp^,ApolicesMistas,ContratosCorrelacionados,FInibeLegLink(*$IFDEF CONSOLE*),GrupoImv(*$ENDIF*));
      if TemFinancDinamico(MutDsk) then begin
        if NaoReajusta then begin
          RPAF.FinRPA.CodReaj     := 31;
          RPAF.Finrpa2.SdRata     := 128;
          RPAF.Temp10.NaoReajusta := true;
        end;
      end;
    finally
      freemem(wArrcomp);
    end;

    if not TemFinancDinamico(MutDsk) then 
    begin // Sol. 25154
      RPAF.ValRpa.ValTxAdm := 0;
//      RPAF.FinRpa.TxAdm := 0; sol. 41746 n o zerar para ser poss vel obter quando houver troca de s rie onde a taxa vai ser cobrada
    end;
{  if (mutdsk.financ.dtinfin.ano < 60) then
    RPAF.MAC := 0;}  // Para sinalizar que o RPAF n o est  sendo evoluido 
//Trocado na consolida rpas para testar o dtinfin e n o o RPA.MAC
    MACInicial := MacMinimoInicial(MenorDtAssin);
    FSeries.InicRPAS(MutDsk,MacInicial,FHistMem,NaoReajusta);
    FSeries.SetaSeriePrincipal(True);
    IniciaValoresVendedores(RpaF); 

    if TemFinancDinamico(MutDsk) then 
    begin
      FOEvolui3.AlertaFaltadeIndiceNoSaldoProRata:= self.AlertaFaltadeIndiceNoSaldoProRata;
      CarregaPagamentosFinanc; // atribuir os pagamentos da serieF para o Evolui3, evitando novas leituras
      if MutDsk.Cad.TipoCtr in EvoPlanoEmpSet then begin { Plano Empres rio }
        FLeuLiberacoesPlanoEmp := false;
        FLeuLaudoVistoria := false;
        FOEvolui3.Evolui(FHEvo,RpaF,LiberacoesPlanoEmp,LaudoVistoria,ContratosCorrelacionados(*$IFDEF CONSOLE*),GrupoImv(*$ENDIF*));
      end
      else
        FOEvolui3.Evolui(FHEvo,RpaF,
                         nil{LiberacoesPlanoEmp},nil{LaudoVistoria},
                         ContratosCorrelacionados
                         (*$IFDEF CONSOLE*),GrupoImv(*$ENDIF*)); { A primeira evolucao depois do init_rpa
                                        obtem a prestacao 0 }
//      if TemVendedores then EvoluiSaldoVendedores(RpaF);
      self.MsgAlertaFaltadeIndiceNoSaldoProRata := FOEvolui3.MsgAlertaFaltadeIndiceNoSaldoProRata;
    end;
    if TemVendedores or TemFgtsApoioAConstrucao then EvoluiSaldoVendedores(RpaF);
    if (TemVendedores or TemFgtsApoioAConstrucao) and not TemFinancDinamico(MutDsk) then
      CopiaSaldoVendedoresNaSeriePrincipal;
    IniciaValoresDespesasComercializacaoADiferir(RpaF);
    EvoluiPEJuros := (Temfinancdinamico(MutDsk) and (Abs(MutDsk.Financ.TxJuros) > zero)) or 
                    ((not Temfinancdinamico(MutDsk)) and MutDsk.Cad2.TemSerie);
    if (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and 
        Scciconf.CalculaTJEODiferenciadaProporcional and
        scciconf.MetodologiaDiferenciadaRecReceita   and
       (juliano(MenorDtAssin) >= juliano(scciconf.DtAssinParaCustoAmortizado))  and 
       (EvoluiPEJuros) then begin
       FListaPEJurosTJEODiferenciadaProp := CacheListPeJuros(GetSqlConnection(PegaDirTab),MutDsk,FLimpaListaPEJurosTJEODiferenciadaProp);
    end;
    if MutDsk.Financ.PA = 96 then // Funding FGTS
      IniciaValoresReceitasComercializacaoADiferir(RpaF);
    if Scciconf.DtAssinParaCustoAmortizado.Dia > 0 then begin
      if Scciconf.MetodologiaDiferenciadaRecReceita then begin
        IniciaValoresReceitaEDespesaTJEODiferenciada(RpaF);
        EvoluiValoresReceitaEDespesaTJEODiferenciada;
      end;
      if assigned(FListTxJurosCA) then FListTxJurosCA.clear;
      EvoluiCA;
    end;                               
    ConsolidaRPAs;
  finally
    dispose(pmutmem);
    result := rpaf;
  end;
end;

procedure TContrato.CopiaSaldoVendedoresNaSeriePrincipal;
begin
  if assigned(Series.SeriePrincipal) then
    with Series.SeriePrincipal.rpas.temp12 do
    begin
      SaldoVendedores := RpaF.temp12.SaldoVendedores;
      CorrecaoVendedores := RpaF.temp12.CorrecaoVendedores;
      JurosVendedores := RpaF.temp12.JurosVendedores;
