procedure TSerie.TiraHistoricoDeTermino(CodLog : integer = 0);
var 
  i : SmallInt;
  InibiuHist : boolean;
begin
  InibiuHist := false;
  i := 1;
  while (i <= Contrato.FHistMem[0].Tam) do
  begin
    if (Contrato.FHistMem[i].Log.CodMov in [1..10,122]) or
      ((CodLog > 0) and (Contrato.FHistMem[i].Log.CodMov = CodLog)) then begin
      Contrato.FHistMem[i].Log.MarcaLog := True;
      InibiuHist := true;
    end;
    inc(i);
  end;
  if InibiuHist then Processa_Hist(DataH,Contrato.FHistMem,FHEvoSerie); 
end;

