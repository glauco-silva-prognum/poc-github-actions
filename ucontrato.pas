    Qry.Sql.Add('WHERE C.NU_OPERACAO = ' + IntToStr(valint(Contrato.Mutdsk.cad2.inscricao)));
    Qry.Sql.Add('ORDER BY NU_MES_LIBERACAO');
    Qry.open;
    try
      while not Qry.eof do begin
        DtParc := ObtemDataCronogramaLiberacao(Contrato.MutDsk.Financ.DtAssin,
                                               Qry.fieldbyname('CO_UF').asstring,
                                               valint(Qry.fieldbyname('NU_MUNICIPIO').asstring),
                                               Qry.fieldbyname('Nu_Mes_Liberacao').asinteger);
        inc(NuParc);
        IncluiLogMem(Contrato.FHistMem,Contrato.MutDsk.Cad.Ctr,115,CodFCVS,DataH{Dt},'', ChaveLog);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 43, 104);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 248, DtParc.Dia);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 250, Qry.fieldByName('VA_LIBERACAO').asfloat);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 290, NuParc);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 105, 1);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 284, 1);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 310, 0{VA_IOF});
        index := stlist.indexof(intstr(Juliano(DtParc)));
        if index >= 0 then begin
          obj := stlist.objects[index] as tobjValorCalculoCet;
          obj.valor := Obj.valor - Qry.fieldByName('VA_LIBERACAO').asfloat;
        end
        else begin
          obj := tobjValorCalculoCet.create;
          obj.valor := -Qry.fieldByName('VA_LIBERACAO').asfloat;
          stlist.addobject(intstr(Juliano(DtParc)),obj);
        end;
        Reg := TObjPrestCalculoCet.create;
        Reg.Data := DtParc;
        Reg.Parcela := NuParc;
        Reg.Amaisj := 0;
        Reg.Amortizacao := 0;
        Reg.Juros := 0;
        Reg.Mip := 0;
        Reg.Dfi := 0;
        Reg.ValTxAdm := 0;
        Reg.Encargo := 0;
        Reg.SaldoDevedor := 0;
        Reg.Dias := 0;
        Reg.Valor := - Qry.fieldByName('VA_LIBERACAO').asfloat;
        VencList.addObject(DataToAAAAMMDD(DtParc),Reg);
        RegValores.VlLiberado := RegValores.VlLiberado + Qry.fieldByName('VA_LIBERACAO').asfloat;
        DtUltLib := DtParc;
        Qry.next;
      end;
    finally
      Qry.close;
    end;
  finally
    Qry.free;
  end;
  Processa_Hist(DtUltLib,Contrato.FHistMem,Contrato.FHEvo);
end;

procedure GravaRelAnaliticoCustos(ctr : TpCtr; Xml : TpXml);
var
  Query : TSqlQuery;
  Stream : TStringStream;
  NuOcorrencia : integer;
begin
  Get_hora(horaH);
  Query := TSqlQuery.create(nil);
  try
    Query.SqlConnection := GetSqlConnection(PegaDirCor);
    Query.Sql.BeginUpdate;
    try
      Query.SQL.Add('INSERT INTO OCORRENCIA');
      Query.Sql.Add('(NU_OCORRENCIA, NU_CONTRATO, ' +
                    ' CO_MOTIVO, CO_STATUS, CO_USUARIO_CADASTRAMENTO, CO_GESTOR, ' +
                    ' DT_CADASTRAMENTO, DT_INICIO_EXECUCAO, DT_FIM_EXECUCAO, ' +
                    ' TE_DESCRICAO_OCORRENCIA, CO_BASE_ATUALIZADA,CO_TIPO,CO_OCORRENCIA)');
      Query.Sql.Add('VALUES');
      Query.Sql.Add('(:NU_OCORRENCIA,:NU_CONTRATO,');
      Query.Sql.add(' :CO_MOTIVO,:CO_STATUS,:CO_USUARIO_CADASTRAMENTO,:CO_GESTOR,');
      Query.Sql.add(' :DT_CADASTRAMENTO,:DT_INICIO_EXECUCAO,:DT_FIM_EXECUCAO,');
      Query.Sql.add(' :TE_DESCRICAO_OCORRENCIA,:CO_BASE_ATUALIZADA,:CO_TIPO,:CO_OCORRENCIA)');
    finally
      Query.Sql.EndUpdate;
    end;

    Query.ParamByname('NU_OCORRENCIA').datatype := ftstring;
    Query.ParamByname('NU_CONTRATO').datatype := ftstring;
    Query.ParamByname('CO_MOTIVO').datatype := ftinteger;
    Query.ParamByname('CO_STATUS').datatype := ftstring;
    Query.ParamByname('CO_USUARIO_CADASTRAMENTO').datatype := ftstring;
    Query.ParamByname('CO_GESTOR').datatype := ftstring;
    Query.ParamByname('DT_CADASTRAMENTO').datatype := ftdatetime;
    Query.ParamByname('DT_INICIO_EXECUCAO').datatype := ftdatetime;
    Query.ParamByname('DT_FIM_EXECUCAO').datatype := ftdatetime;
    Query.Parambyname('TE_DESCRICAO_OCORRENCIA').DataType := ftBlob;
    Query.ParamByname('CO_BASE_ATUALIZADA').dataType := ftinteger;
    Query.ParamByname('CO_TIPO').dataType := ftinteger;
    Query.ParamByname('CO_OCORRENCIA').dataType := ftinteger;

    NuOcorrencia := LeGenerator(Query.SqlConnection,'SECIDNUM');
    
    Query.ParamByname('NU_OCORRENCIA').asstring := IntStr2(NuOcorrencia,9);
    Query.ParamByname('NU_CONTRATO').asstring := Ctr;
    Query.ParamByname('CO_MOTIVO').asinteger := 0;
    Query.ParamByname('CO_STATUS').asstring := '005';
    Query.ParamByname('CO_USUARIO_CADASTRAMENTO').asstring := PegaUsuario;
    Query.ParamByname('CO_GESTOR').asstring := PegaUsuario;
    Query.ParamByname('DT_CADASTRAMENTO').asDateTime := DataToDateTime(DataH);
    Query.ParamByname('DT_INICIO_EXECUCAO').asDateTime := DataToDateTime(DataH) + HoraTodateTime(HoraH);
    Query.ParamByname('DT_FIM_EXECUCAO').asDateTime := DataToDateTime(DataH) + HoraTodateTime(HoraH);
    Stream := TStringStream.Create(Xml.Code);
    try
      Query.Parambyname('TE_DESCRICAO_OCORRENCIA').LoadFromStream (Stream, ftBlob);
    finally
      Stream.Free;
    end;
    Query.ParamByname('CO_BASE_ATUALIZADA').asinteger := PegaCOBase(Query.SqlConnection);
    Query.ParamByname('CO_TIPO').asinteger := 2;
    Query.ParamByname('CO_OCORRENCIA').asinteger := 0;
    Query.ExecSQL;
    
    // Excluir vers es anteriores
    Query.sql.clear;
    Query.Sql.add('DELETE FROM OCORRENCIA');
    Query.Sql.add('WHERE NU_CONTRATO=:NU_CONTRATO');
    Query.Sql.add('AND CO_TIPO=2');
    Query.Sql.add('AND NU_OCORRENCIA < :NU_OCORRENCIA');
    Query.Sql.add('AND CO_BASE_ATUALIZADA = :CO_BASE_ATUALIZADA');
    Query.ParamByname('NU_OCORRENCIA').datatype := ftstring;
    Query.ParamByname('NU_CONTRATO').datatype := ftstring;
    Query.ParamByname('CO_BASE_ATUALIZADA').dataType := ftinteger;
    Query.ParamByname('NU_OCORRENCIA').asstring := IntStr2(NuOcorrencia,9);
    Query.ParamByname('NU_CONTRATO').asstring := Ctr;
    Query.ParamByname('CO_BASE_ATUALIZADA').asinteger := PegaCOBase(Query.SqlConnection);
    Query.ExecSQL;
    
  finally
    Query.free;
  end;
end;

function CalculaCesh(ListaEvolucao : Tlist; MemCalcNode : TpXmlNode = nil; SimulaCCA : boolean=false; VaFinanc : real=0):real;
var
  i : integer;
  Ind,dias : Integer;
  RegPrestacao  : TptRegEvolucao;
  sdbase,indj,fvp,
  n : real;
  vp,seguro : real;
  tot : real;
  Reg : TObjPrestCalculoCet;
  PrestacoesNode : TpXmlNode;
  p : TpXmlNode;
  VencList : TStringlist;
begin
  tot := 0;
  sdbase := 0;
  result := 0;
  VencList := TStringlist.create;
  try
    if ListaEvolucao.Count > 0 then begin
      RegPrestacao := ListaEvolucao.Items[0];
      {
        108723
        Para contratos com cronograma de libera  o, o saldo devedor n o deve ser usado.
        Foi combinado usar o valor financiado, que est  no valor de constru  o.
        Ent o se o contrato tiver este valor, passo a considerar ele.
      }
      if RegPrestacao^.VA_FINANCCONSTRUCAO > zero then
        sdbase := RegPrestacao^.VA_FINANCCONSTRUCAO
      else
        sdbase := RegPrestacao^.va_saldo_devedor;//scat109005+RegPrestacao^.va_amortizacao;
      if SimulaCCA then
        sdbase := VaFinanc;
    end ;
    indj:= 1.008; // (calculo.VaTaxaNomimalJurosAnual/1200)+1;
    for Ind := 0 to ListaEvolucao.Count -1 do begin
      RegPrestacao := ListaEvolucao.Items[ind];
      if (RegPrestacao^.NU_PRESTACAO >= 1) or (RegPrestacao^.EXINC = 104) then begin
        dias :=  juliano(datetimetodata(regprestacao^.dt_prestacao))- juliano(datetimetodata(regprestacao^.DT_ASSIN)); // DT_ASSIN antes usava "DataCalculo", mas para compatibilizar com s ries, coloquei dentro do TpPrestacao
        n := (12*dias) / 365;
        fvp := pot(indj,n);
        seguro  :=  ((regprestacao^.va_mip + regprestacao^.va_dfi) );
        vp  := (seguro / fvp);
        tot := tot + vp;
        Reg := TObjPrestCalculoCet.create;
        Reg.Data := datetimeToData(regprestacao^.DT_PRESTACAO);
        Reg.Parcela := regprestacao^.NU_PRESTACAO;
        Reg.Amaisj := regprestacao^.VA_AMORTIZACAO+regprestacao^.VA_JUROS;
        Reg.Amortizacao := regprestacao^.VA_AMORTIZACAO;
        Reg.Juros := regprestacao^.VA_JUROS;
        Reg.Mip := regprestacao^.VA_MIP;
        Reg.Dfi := regprestacao^.VA_DFI;
        Reg.ValTxAdm := regprestacao^.VA_TAXA_ADMINISTRACAO;
        Reg.Encargo := regprestacao^.VA_PRESTACAO;
        Reg.SaldoDevedor := regprestacao^.VA_SALDO_DEVEDOR;
        Reg.Dias := Dias;
        Reg.Valor := vp;
        VencList.addObject(DataToAAAAMMDD(Reg.Data),Reg);
      end;
    end;
    if sdbase > 0 then
      result := (tot /sdbase)*100;
    result := arredondavalor(result,4); // sol. 63252
    if assigned(MemCalcNode) then begin
      MemCalcNode.add('CESH').asfloat := result;
      MemCalcNode.add('SaldoBase').asfloat := sdbase;
      PrestacoesNode := MemCalcNode.add('Prestacoes');
      for i := 0 to VencList.count-1 do begin
        p := PrestacoesNode.add('Prestacao');
        Reg := VencList.objects[i] as TObjPrestCalculoCet;
        p.add('Data').asTdata := Reg.Data;
        p.add('Parcela').asinteger := Reg.Parcela;
        p.add('Amaisj').asfloat := Reg.Amaisj;
        p.add('Amortizacao').asfloat := Reg.Amortizacao;
        p.add('Juros').asfloat := Reg.Juros;
        p.add('Mip').asfloat := Reg.Mip;
        p.add('Dfi').asfloat := Reg.Dfi;
        p.add('ValTxAdm').asfloat := Reg.ValTxAdm;
        p.add('Encargo').asfloat := Reg.Encargo;
        p.add('SaldoDevedor').asfloat := Reg.SaldoDevedor;
        p.add('Dias').asinteger := Reg.Dias;
        p.add('Valor').asfloat := Reg.Valor;
      end;
    end;
  finally
    for i := 0 to VencList.count-1 do
      VencList.objects[i].free;
    VencList.free;
  end;
end;

procedure MontaPrestacao(RPA : TpRPA; ListaEvolucao : TList; CobraSeguro : boolean = true);
var
  DtVenc : TData;
  RegPrestacaoPtr : TptRegEvolucao;
begin
  New(RegPrestacaoPtr);
  RegPrestacaoPtr^.NU_PRESTACAO          := RPA.FinRPA.NPC;
  if CobraSeguro then begin
    RegPrestacaoPtr^.VA_MIP                := RPA.ValRPA.segfin;
    RegPrestacaoPtr^.VA_DFI                := RPA.ValRPA.segimv;
    RegPrestacaoPtr^.VA_ENCARGOS           := RPA.ValRPA.TotPrest;
  end
  else begin
    RegPrestacaoPtr^.VA_MIP                := 0;
    RegPrestacaoPtr^.VA_DFI                := 0;
    RegPrestacaoPtr^.VA_ENCARGOS           := RPA.ValRPA.TotPrest-RPA.ValRpa.Seguro;
  end;
  RegPrestacaoPtr^.VA_TAXA_ADMINISTRACAO := RPA.ValRPA.ValTxAdm;
  RegPrestacaoPtr^.VA_JUROS              := RPA.ValRPA.juro;
  RegPrestacaoPtr^.VA_AMORTIZACAO        := RPA.ValRPA.Amaisj-RPA.ValRPA.Juro;
  RegPrestacaoPtr^.VA_PRESTACAO          := RPA.ValRPA.Amaisj;
  RegPrestacaoPtr^.VA_SALDO_DEVEDOR      := RPA.ValRPA.SaldoDev;
  RegPrestacaoPtr^.VA_FIA                := Rpa.Temp12.ValorFia;
  RegPrestacaoPtr^.VA_IOFDFI             := Rpa.Temp12.IOFDFI;
  RegPrestacaoPtr^.VA_IOF                := 0;
  RegPrestacaoPtr^.VA_FINANCCONSTRUCAO   := Rpa.Temp12.ValFinancConstrucao;
  RegPrestacaoPtr^.EXINC                 := Rpa.Temp7.ExInc;

  int_mes(RPA.Mac,DtVenc.Mesano);
  DtVenc.dia := RPA.FinRPA.DiaVenc;
  if DtVenc.dia > dias_mes(mes_int(DtVenc.mesano)) then 
    DtVenc.dia := Dias_mes(mes_int(DtVenc.Mesano));
  RegPrestacaoPtr^.DT_PRESTACAO := DataToDateTime(DtVenc);

  RegPrestacaoPtr^.DT_ASSIN := DataToDateTime(RPA.FinRPA.DtAssin);

  ListaEvolucao.Add(RegPrestacaoPtr);
end;

function CalculaCESHContrato(Contrato : Tcontrato; MemCalcNode : TpXmlNode = nil; InibeHistorico : boolean = true) : real;
var
  i : integer;
  ListaEvolucao : TList;
  RegPrestacao : TptRegEvolucao;
  UsaArqP : boolean;
  Qtd : integer;
begin
  ListaEvolucao := TList.create;
  try
    if Contrato.MutDsk.Cad.Ctr > '' then begin
      if InibeHistorico then
        Contrato.InibeHistoricos; // Sol 34081
      if Contrato.Mutdsk.Financ.PA =40 then 
        Contrato.IncluiLiberacaoVendedor(Contrato.MutDsk.Financ.DtInFin,Contrato.MutDsk.Financ.ValFinanc);
      UsaArqP := Scciconf.UsaArqPrest;
      try
        Scciconf.UsaArqPrest := false;
        Contrato.InicRpa(true{NaoReajusta});
        MontaPrestacao(Contrato.RPA,ListaEvolucao,
                       (Contrato.Mutdsk.Cad.SegVista > zero) or
                       Contrato.Mutdsk.Financ3.NaoCobraSegUltPrst{CobraSeguro - Sol. 67260}); // Presta  o zero
        Contrato.Evolui; // Para sair da data de assinatura
        Qtd := 0;
        while Ctr_Ativo(Contrato.RPA) and (Qtd < MaxEvoAtr) do begin
          MontaPrestacao(Contrato.RPAF,ListaEvolucao);
          for i := 0 to Contrato.Series.count-1 do
            if Ctr_Ativo(Contrato.Series[i].RPAS) and
               (Contrato.Series[i].fin.DtRenegGeradora.dia = 0) and {sol. 34081}
               ((Contrato.Series[i].RPAS.FinRPA.NPC > 0) or  { s. 21058 }
                (Contrato.Series[i].RPAS.MAC > Mes_Int(Contrato.Series[i].RPAS.FinRPA.DtAssin.MesAno))) and
               (Contrato.Series[i].RPAS.ValRPA.TotPrest-Contrato.Series[i].RPAS.ValRPA.Desc > Zero) and
               assigned(Contrato.Series[i].ParcelaDoMes) then // igual a atrlib.ParcSerieOk
              MontaPrestacao(Contrato.Series[i].RPAS,ListaEvolucao);
          inc(qtd);
          Contrato.evolui;
        end;
      finally
        Scciconf.UsaArqPrest := UsaArqP;
      end;
    end;
    result := CalculaCESH(ListaEvolucao,MemCalcNode);
  finally
    for i := 0 to ListaEvolucao.count-1 do begin
      RegPrestacao := ListaEvolucao[i];
      Dispose(RegPrestacao);
    end;
    listaEvolucao.free;
  end;
end;

function CalculaCET(Contrato : TContrato; CalcComAMaisJ : boolean = false; MemCalcNode : TpXmlNode = nil; TrataPlanoEmpNaOriginacao : boolean = false;
                    InibeHistorico : boolean = true; VaBonus : real = 0; SimulaCCA : boolean = false) : real;  overload;
var
  RegValores : TpRelCET;
begin
  RegValores.VlLiberado := 0;
  fillchar(RegValores,sizeof(RegValores),0);
  result := CalculaCET(Contrato, RegValores, CalcComAMaisJ, MemCalcNode, TrataPlanoEmpNaOriginacao, InibeHistorico, VaBonus, SimulaCCA);
end;

function TemCronogramaLiberacaoOperacao(inscricao : string) : boolean;
var
  Qry : TSqlQuery;
begin
  result := false;
  if valint(inscricao) > 0 then begin
    Qry := TSqlQuery.create(nil);
    try
      Qry.SqlConnection := GetSqlConnection(PegaDirtab);
      Qry.Sql.Add('SELECT NU_MES_LIBERACAO');
      Qry.Sql.Add('FROM CRONOGRAMA_LIBERACAO_OPERACAO');
      Qry.Sql.Add('WHERE NU_OPERACAO = ' + IntToStr(valint(inscricao)));
      Qry.open;
      result := not Qry.IsEmpty;
    finally
      Qry.free;
    end;
  end;
end;

procedure InibeSeriesParaCET(Contrato : TContrato; LstSeriesInibidas : TStrings);
var
  i : integer;
begin
  // desconsiderar s ries criadas por renegocia  o, no c lculo da CET
  for i := 0 to Contrato.Series.count-1 do
    if (Contrato.Series[i].fin.DtRenegGeradora.dia > 0) and 
       (Contrato.series[i].fin.status <> 98) then begin // n o colocar na lista status 98 para n o tirar depois na volta
      LstSeriesInibidas.addObject(intstr(Contrato.Series[i].fin.status),Contrato.Series[i]);
      Contrato.series[i].fin.status := 98;
    end;  
end;

procedure VoltaSeriesInibidasParaCET(LstSeriesInibidas : Tstrings);
var
  i : integer;
begin
  for i := 0 to LstSeriesInibidas.count-1 do
    TSerie(LstSeriesInibidas.objects[i]).fin.status := valint(LstSeriesInibidas[i]);
end;

function CalculaCET(Contrato : TContrato; var RegValores : TpRelCET; CalcComAmaisJ : boolean = false; MemCalcNode : TpXmlNode = nil;
                    TrataPlanoEmpNaOriginacao : boolean = false; InibeHistorico : boolean = true; VaBonus : real = 0; SimulaCCA : boolean = false) : real;  overload;
type
  TArrParcelas = Array of Double;
  TArrDatas = array of TDateTime;

var
  UsaArqP : boolean;
  TxJuros : real;
  Dt : Tdata;
  ArrayParcelas : TArrParcelas;
  Datas: TArrDatas;
  i,
  Qtd : integer;
  DtZero : tdata;
  DtUltLib : TData;
  stlist : Thashedstringlist;
  VencList : Tstringlist;
  obj    : tobjValorCalculoCet;
  Reg : TObjPrestCalculoCet;
  index : integer;
  Valor : real;
  JulianoStr : string;
  PlanoEmp : boolean;
  PrestacoesNode : TpXmlNode;
  p : TpXmlNode;
  LstSeriesInibidas : TStringlist;
  DtAux : TData;
begin
{$IFDEF FPC}
  ArrayParcelas := default(TArrParcelas);
  Datas:= default(TArrDatas);
{$ENDIF}
  result := 0;
  fillchar(RegValores,sizeof(TpRelCET),0);
  dtzero.dia := 0;
  fillchar(dtzero,sizeof(TData),0);
  dtultlib.dia := 0;
  fillchar(dtultlib,sizeof(TData),0);
  dtzero.dia := 1;
  dtzero.mes := 1;
  dtzero.ano := 50; // Sol. 34081
  TxJuros := 0;
  PlanoEmp := Contrato.MutDsk.cad.tipoctr in [33,34,35,36,47];
  // Sol. 75019
  // Somente considerar o calculo da CET como plano empres rio, na fase de origina  o,
  // se houver algum cronograma j  cadastrado
  if PlanoEmp and TrataPlanoEmpNaOriginacao then
    PlanoEmp := TemCronogramaLiberacaoOperacao(Contrato.Mutdsk.cad2.inscricao);
  stlist := Thashedstringlist.create;
  VencList := TStringlist.create;
  LstSeriesInibidas := TStringlist.create;
  try 
    stList.sorted := true;
    VencList.sorted := true;
    VencList.Duplicates := DupAccept;
    if Contrato.MutDsk.Cad.Ctr > '' then begin
      if InibeHIstorico then Contrato.InibeHistoricos; // Sol 34081
      InibeSeriesParaCET(Contrato,LstSeriesInibidas);
      try
        SetLength(ArrayParcelas,MaxEvoAtr);
        Setlength(Datas,MaxEvoAtr);
        for i := 0 to MaxEvoAtr-1 do begin
          ArrayParcelas[i]:= 0;
          Datas[i]:= 0;
        end;
        if Contrato.Mutdsk.Financ.PA =40 then 
          Contrato.IncluiLiberacaoVendedor(Contrato.MutDsk.Financ.DtInFin,Contrato.MutDsk.Financ.ValFinanc)
        else if PlanoEmp then
          if TrataPlanoEmpNaOriginacao then
            IncluiHistoricosDasPrevisoesEDespesasNaOriginacao(Contrato,StList,DtUltLib,RegValores,VencList)
          else
            IncluiHistoricosDasPrevisoesEDespesas(Contrato,StList,DtUltLib,RegValores,VencList);
        try
          UsaArqP := Scciconf.UsaArqPrest;
          try
            Scciconf.UsaArqPrest := false;
            Contrato.InicRpa(true{NaoReajusta});
            TxJuros := Contrato.Rpa.FinRpa.TxJuros;
            RegValores.VlTaxaIncorporadaFinanc := Contrato.MutDsk.cad6.TaxaIncorporadaFinanc;
            if not PlanoEmp then begin
              Valor := - Contrato.MutDsk.Financ.ValFinanc;
              Reg := TObjPrestCalculoCet.create;
              if Contrato.Mutdsk.Financ.PA=40 then // 99556
                Reg.Data := Contrato.RPA.FinRPA.DtInFin
              else
                Reg.Data := Contrato.RPA.FinRPA.DtAssin;
              Reg.Parcela := 0;
              Reg.Amaisj := 0;
              Reg.Amortizacao := 0;
              Reg.Juros := 0;
              Reg.Mip := 0;
              Reg.Dfi := 0;
              Reg.ValTxAdm := 0;
              Reg.Encargo := 0;
              Reg.SaldoDevedor := Contrato.MutDsk.Financ.ValFinanc;
              Reg.Dias := 0;
              Reg.Valor := - Contrato.MutDsk.Financ.ValFinanc;
              VencList.addObject(DataToAAAAMMDD(Reg.Data),Reg);

              if (VaBonus > Zero) then begin
                Valor := Valor - VaBonus;
                Reg := TObjPrestCalculoCet.create;
                Reg.Data := Contrato.RPA.FinRPA.DtAssin;
                Reg.Parcela := 0;
                Reg.Amaisj := 0;
                Reg.Amortizacao := 0;
                Reg.Juros := 0;
                Reg.Mip := 0;
                Reg.Dfi := 0;
                Reg.ValTxAdm := 0;
                Reg.Encargo := 0;
                Reg.SaldoDevedor := 0;
                Reg.Dias := 0;
                Reg.Valor := - VaBonus;
