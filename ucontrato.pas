procedure TContrato.LeOcorrenciasPagamentosFast;
var
  Qry      : TsqlQuery;
  NumParc,
  TipoParc : smallint;
  CodSerie : longint;
  iserie   : integer; 
  Parcela  : TParcela;
  OcorrPgto: TOcorrenciaPagamento;
begin
  if not FLeuOcorrenciasPagamentos then begin
    FLeuOcorrenciasPagamentos := true;
    Qry := TsqlQuery.create(niL);
    try
       Qry.SqlConnection := GetSqlConnection(PegaDirPag);
       Qry.sql.add('SELECT TIPOCTR,CO_CONTRATO,TIPOPARC,CODPARC,NUMPARC,SEQ,VALTOT,VALORJMCM,DTPG,DTPROC,');
       Qry.sql.add('TIPOPG,SEGURADORA,APROPRIADIF,TEMPGPARCIAL,DATAEV,RESIDUOCOBRADO,DESCONTO,');
       Qry.sql.add('DESCCONCEDIDO,VALPLEITEADO,PERCDESCMORA,PERCDESCCORR,PERCDESCMULTA,');
       Qry.sql.add('PERCDESCJREMUNERATORIOS,DIFEMITIDA,DESCSEG,DESCPAGAMENTO,TIPODESC,SEQPEND,');
       Qry.sql.add('VALORHONORARIOS,PERCDESCHONORARIOS,BANCO,DATAREFCALC,SEQPAG,AMAISJ ');
       Qry.sql.add(' FROM OCORRENCIAS_PAGAMENTOS WHERE TIPOCTR=1 AND CO_CONTRATO=:Ctr');
       Qry.Sql.Add(' ORDER BY CO_CONTRATO,CODPARC,NUMPARC,TIPOPARC,DTPROC,SEQ');
//       Qry.Sql.Add(' ORDER BY CO_CONTRATO,CODPARC,TIPOPARC,NUMPARC,DTPROC,SEQ');
       Qry.Params[0]{byname('Ctr')}.asString := MutDsk.Cad.Ctr;
       Qry.open;
       if not Qry.eof then
         while not Qry.eof do begin
           TipoParc  := Qry.Fields[2]{FieldByName('TIPOPARC')}.asInteger;
           CodSerie  := Qry.Fields[3]{FieldByName('CODPARC')}.asInteger;
           NumParc   := Qry.Fields[4]{FieldByName('NUMPARC')}.asInteger;
           Parcela   := nil;
           if (CodSerie = 0) and TemFinancDinamico(MutDsk) then 
             Parcela := SerieF.Parcelas.ObtemParcelaPorMAC(NumParc)
           else begin
             iserie := Series.indexof(codserie); //melhorar,   lento
             if ISerie > -1 then begin
               if TipoParc = 6 then  //   parcela de s rie
                 Parcela  := Series[ISerie].Parcelas.ObtemParcelaPorSeq(NumParc)  // rotina lenta
               else                  //   parcela de seguro
                 Parcela  := Series[ISerie].Parcelas.ObtemParcelaDeSeguroPorMAC(NumParc); //rotina lenta
             end;
           end;
           if assigned(Parcela) then begin
             OcorrPgto := Parcela.OcorrenciasPagamentos.add as TOcorrenciaPagamento;
             fillchar(OcorrPgto.RegOcorrenciasPgtos,sizeof(TpOcorrenciasPagamentos),0);
             OcorrPgto.RegOcorrenciasPgtos.TipoCtr     := Qry.Fields[0]{FieldByName('TIPOCTR')}.Asinteger;
             OcorrPgto.RegOcorrenciasPgtos.TipoParc    := TipoParc;
             OcorrPgto.RegOcorrenciasPgtos.CodParc     := CodSerie;
             OcorrPgto.RegOcorrenciasPgtos.NumParc     := NumParc;
             OcorrPgto.RegOcorrenciasPgtos.CodCtr      := Qry.Fields[1]{FieldByName('CO_CONTRATO')}.asString;
             OcorrPgto.RegOcorrenciasPgtos.Seq         := Qry.Fields[5]{FieldByName('SEQ')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.Valtot      := Qry.Fields[6]{FieldByName('VALTOT')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.ValJMCM     := Qry.Fields[7]{FieldByName('VALORJMCM')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.DtPg        := DateTimeToData(Qry.Fields[8]{FieldByName('DTPG')}.asDateTime);
             OcorrPgto.RegOcorrenciasPgtos.DtProc      := DateTimeToData(Qry.Fields[9]{FieldByName('DTPROC')}.AsDateTime);
             OcorrPgto.RegOcorrenciasPgtos.TipoPg      := Qry.Fields[10]{FieldByName('TIPOPG')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.Seguradora  := Qry.Fields[11]{FieldByName('SEGURADORA')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.ApropriaDif := Qry.Fields[12]{FieldByName('APROPRIADIF')}.asBoolean;
             OcorrPgto.RegOcorrenciasPgtos.TemPgParcial         := Qry.Fields[13]{FieldByName('TEMPGPARCIAL')}.asBoolean;
             OcorrPgto.RegOcorrenciasPgtos.DataEv               := DateTimeToData(Qry.Fields[14]{FieldByName('DATAEV')}.AsDateTime);
             OcorrPgto.RegOcorrenciasPgtos.ResiduoCobrado       := Qry.Fields[15]{FieldByName('RESIDUOCOBRADO')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.Desconto             := Qry.Fields[16]{FieldByName('DESCONTO')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.DescConcedido        := Qry.Fields[17]{FieldByName('DESCCONCEDIDO')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.valPleiteado         := Qry.Fields[18]{FieldByName('VALPLEITEADO')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.PercDescMora         := Qry.Fields[19]{FieldByName('PERCDESCMORA')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.PercDescCorr         := Qry.Fields[20]{FieldByName('PERCDESCCORR')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.PercDescMulta        := Qry.Fields[21]{FieldByName('PERCDESCMULTA')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.PercDescJRemuneratorios:= Qry.Fields[22]{FieldByName('PERCDESCJREMUNERATORIOS')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.DifEmitida           := Qry.Fields[23]{FieldByName('DIFEMITIDA')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.DescSeg              := Qry.Fields[24]{FieldByName('DESCSEG')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.DescPagamento        := Qry.Fields[25]{FieldByName('DESCPAGAMENTO')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.TipoDesc             := Qry.Fields[26]{FieldByName('TIPODESC')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.SeqPend              := Qry.Fields[27]{FieldByName('SEQPEND')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.ValorHonorarios      := Qry.Fields[28]{FieldByName('VALORHONORARIOS')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.PercDescHonorarios   := Qry.Fields[29]{FieldByName('PERCDESCHONORARIOS')}.asfloat;
             OcorrPgto.RegOcorrenciasPgtos.Banco                := Qry.Fields[30]{FieldByName('BANCO')}.asInteger;

             OcorrPgto.RegOcorrenciasPgtos.DataRefCalc          := DateTimeToData(Qry.Fields[31]{FieldByName('DATAREFCALC')}.AsDateTime);
             OcorrPgto.RegOcorrenciasPgtos.SeqPag               := Qry.Fields[32]{FieldByName('SEQPAG')}.asInteger;
             OcorrPgto.RegOcorrenciasPgtos.AmaisJ               := Qry.Fields[33]{FieldByName('AMAISJ')}.asfloat;
             if OcorrPgto.RegOcorrenciasPgtos.SeqPag = 0 then 
               inc(Parcela.OcorrenciasPagamentos.FQtdeOcorrPgtosTotais);
           end;
           Qry.Next;
         end
       else Qry.close;
    finally
      Qry.free;
    end;
  end;
end;

