procedure TContrato.CalculaTotPrestEmAtsAteVenc;
var
  Dados : TDadosAtrasoEvo;
  Parametros : TCalculoAtrasoParametros;
  i,j : integer;
  RegApolice : TpApolice;
  MacIniAtr : integer;
  LegLinkItem : TLegLinkItem;
begin
  RegApolice.CampoVbaseMip := 0;
  fillchar(RegApolice,sizeof(RegApolice),0);
  Dados := TDadosAtrasoEvo.create;
  Parametros := TCalculoAtrasoParametros.create;
  try
    Parametros.DataRef.dia := RPA.FinRPA.DiaVenc;
    int_mes(RPA.Mac,Parametros.DataRef.MesAno);
    Parametros.TipoExec := TipoExec_Atraso;
    Parametros.PermiteEvoluir := false;
    Parametros.PodeCobrarTaxaBancaria := false;
    Parametros.CobraPend := false;
    Parametros.IgnoraTaxas := true;
    LeApolice(RPA.Temp10.CodApolice,RegApolice);
    if RegApolice.CampoVbaseMip in [cVbaseMip_Saldo_Devedor_com_Atraso,cVbaseMip_Saldo_Devedor_Vendedor_com_Atraso{105540}] then
      Parametros.Tmora := 202; // 110643 troquei de 215 para 202, para isentar tamb m a corre  o, pois s  isentava mora e multa
    if RegApolice.NUMESESATRVABASEMIP > 0 then // 105540
      MacIniAtr := Rpa.mac-RegApolice.NUMESESATRVABASEMIP
    else
      MacIniAtr := 0;
    RPA.Temp11.TotPrestEmAtsAteVenc := 0;  
    CalculaAtraso(Parametros,Dados);
    {
      110643
      Foi pedida verifica  o e corre  o no c lculo de seguro que incorpore o atraso
      no saldo base, ent o resolvi melhorar a legisla  o para permitir verificar 
      os valores que foram considerados.
      Notei que n o estava considerando valores de s rie em atraso, no loop abaixo,
      pois totalizava apenas codserie=0. Estou ajustando agora.
    }
    LegLinkItem := LegLink.add(0,'C lculo do atraso at  o vencimento');
    if assigned(LegLinkItem) then begin
      LegLinkItem.consolidado := true; // para sair em qualquer sele  o de s rie, incluindo no consolidado
      LegLinkItem.valores['Data de refer ncia'] := data_str2(Parametros.DataRef);
    end;

    for i := 0 to Series.count-1 do begin
      Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc := 0;
      for j := 0 to Dados.count-1 do
        if (abs(Dados[j].CodSerie) = Series[i].Fin.CodSerie) and (Dados[j].MacPrst >= MacIniAtr) then begin
          if assigned(LegLinkItem) then
            LegLinkItem.valores['S rie '+DescrSerie(Series[i].Fin.TipoSerie)+'('+intstr(Dados[j].CodSerie)+') presta  o '+mac_str(Dados[j].MacPrst)] := strgrana(Dados[j].ValTit);
          Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc := Series[i].RPAS.Temp11.TotPrestEmAtsAteVenc +
                                                        Dados[j].ValTit;
          RPA.Temp11.TotPrestEmAtsAteVenc := RPA.Temp11.TotPrestEmAtsAteVenc + Dados[j].ValTit;
        end;                                                        
    end;
    RPAF.Temp11.TotPrestEmAtsAteVenc := 0;
    if TemFinancDinamico(Mutdsk) then
      for j := 0 to Dados.count-1 do
        if (Dados[j].CodSerie = 0) and (Dados[j].MacPrst >= MacIniAtr) then begin
          if assigned(LegLinkItem) then
            LegLinkItem.valores['Financ. din mico presta  o '+mac_str(Dados[j].MacPrst)] := strgrana(Dados[j].ValTit);
          RPAF.Temp11.TotPrestEmAtsAteVenc := RPAF.Temp11.TotPrestEmAtsAteVenc +
                                              Dados[j].ValTit;
          RPA.Temp11.TotPrestEmAtsAteVenc := RPA.Temp11.TotPrestEmAtsAteVenc + Dados[j].ValTit;
        end;
// 105540
// vou totalizar junto com os valores individuais, j  que n o posso mais usar o total do atraso diretamente.
//    RPA.Temp11.TotPrestEmAtsAteVenc := Dados.TotalGeral;
    if assigned(LegLinkItem) then
      LegLinkItem.valores['Total de presta  es em atraso at  o vencimento'] := strgrana(RPA.Temp11.TotPrestEmAtsAteVenc);
  finally
    Dados.free;
    Parametros.free;
  end;
end;



function MontaDtIniCondAdversa(const RPA : TpRPA; DtCondAdversaAnt,DataRef : TData) : TData;
begin
  Result.Dia := 0; fillchar(Result,sizeof(Result),0);
  if (RPA.Temp12.CondAdversa>0){RPA.Temp12.Covid19} and
    ((DataRef.Dia = 0) or
     (RPA.MAC <= Mes_Int(DataRef.MesAno))) then begin
    Int_Mes(RPA.MAC,Result.MesAno);
    if (RPA.FinRPA.DiaLiq > 0) and (RPA.FinRPA.Status in [0,30]) then 
      Result.Dia := RPA.FinRPA.DiaLiq
    else if RPA.Temp6.DiaInc > 0 then 
      Result.Dia := RPA.Temp6.DiaInc
    else
      Result.Dia := RPA.FinRPA.DiaVenc;
  end;
  if (Result.Dia > 0) and (DataRef.Dia > 0) and
     (juliano(Result) > juliano(DataRef)) then begin
    Result.Dia := 0; fillchar(Result,sizeof(Result),0);
    if juliano(DtCondAdversaAnt) <= juliano(DataRef) then
      Result := DtCondAdversaAnt;
  end;
end;

