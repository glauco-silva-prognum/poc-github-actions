procedure TSerie.CalculaJuroSecuritizacao;
 var
  JuroAdquirido, 
  SaldoAdquirido : Real; 
begin
  with rpas, rpas.sec do 
  begin
    if ((Fin.SistAmort = 0) { USU } and fin.JurosParcPeloUsuario) OR
       ((Fin.SistAmort = 7) {SCP} and Fin.JurosSimples) then
    begin
      JuroColateral := R2(Rpas.ValRpa.Juro * Sec.PercColateral);
    end
    else
    if FIndJurosAdquirido > Zero then // Scat 22682
    begin
      if (Rpas.Mac > mes_int(Fin.DtCarenciadeJuros.MesAno)) then
      begin
        SaldoAdquirido:= R2(Rpas.ValRpa.SaldoDev + (Rpas.ValRpa.AmaisJ-Rpas.ValRpa.Juro) - SaldoDevColateral);
        JuroAdquirido := R2(FIndJurosAdquirido*SaldoAdquirido);
        JuroColateral := R2(Rpas.ValRpa.Juro - JuroAdquirido);
      end
      else
        JuroColateral := 0;
    end
    else 
    begin
      if (Rpas.Mac > mes_int(Fin.DtCarenciadeJuros.MesAno)) then
        JuroColateral:= R2(RPAS.FinRPA.IndJuros*SaldoDevColateral)
      else
        JuroColateral := 0;
    end;
  end;
end;

procedure TSerie.AmortizaSaldosSecuritizados(ValorAIAntesVenc,ValorAInoVenc,ValorAIPosVenc:Real);
begin
  if Rpas.Sec.PercColateral>=Zero then
  with Rpas.Sec do begin
    SaldoDevColateral  := R2(SaldoDevColateral - ValorAIAntesVenc * PercColateral);
    CorrSaldoColateral := R2((Rpas.FinRPA.TxSD-1)*SaldoDevColateral);
    SaldoDevAntColateral := SaldoDevColateral;
    SaldoDevColateral  := SaldoDevColateral + CorrSaldoColateral;
    CalculaJuroSecuritizacao;
    SaldoDevColateral  := R2(SaldoDevColateral - ValorAInoVenc * PercColateral);
    SaldoDevColateral  := R2(SaldoDevColateral - ValorAIPosVenc * PercColateral);
  end;
end;

procedure TSerie.CalculaAntecipacaoPeloValorPago(    Evento  : TEventoAmInc;
                                                     Parcela : TParcelaSerie;
                                                 var ValorAIAntesVenc,
                                                     ValorAInoVenc,
                                                     ValorAIposVenc,
                                                     ValorAIDaUltima:Double; 
                                                 var UltDiaPgAntec : byte);
var
  DiasAm, DiasMes, DiasJ : Integer;
  DataSaldo, DataSaldomais1, DataAm : TData;
  Ind, IndJ, IndJCA,IndCA,IndCor: Double;
  TemCustoCA,
  IndInvalido : Boolean;
  DtIndInvalido : Tdata;
  ValorPago : real;
  DtIniJuros,
  DataDePgto : TData;
  ValorAi : real;
  leglinkItem : TLegLinkItem;
begin
  LegLinkItem := nil;
  IndInvalido := false;
  TemCustoCA  := Contrato.TemCA;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  fillchar(DtIndInvalido,sizeof(TData),0);
  Int_mes(RPAS.MAC, DataAm.MesAno);
  DataSaldo.Dia := RPAS.FinRPA.DiaVenc; Int_Mes(RPAS.MAC-1, DataSaldo.MesAno);
  DataSaldomais1 := DataSaldo; INCMA( DataSaldomais1.MesAno);
  if (Parcela.DataRefCalc.Dia > 0) and (Parcela.DtPg.Dia > 0) and
      (juliano(Parcela.DataRefCalc) > juliano(Parcela.DtPg)) and
      (Parcela.DataRefCalc.Mes = Parcela.DtPg.Mes) and (Parcela.DataRefCalc.Ano = Parcela.DtPg.Ano) then
    DataDePgto := Parcela.DataRefCalc
  else
    DataDePgto := Parcela.DtPg;
  if Evento.DiaEvento = 0 then 
    Evento.DiaEvento := DataDePgto.Dia;
  if Evento.MACEvento = 0 then 
    Evento.MACEvento := Mes_Int(DataDePgto.MesAno);
  DtIniJuros := RPAS.FinRpa.DtAssin;
  if (Fin.DtCarenciaDeJuros.Dia > 0) and 
      (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
    DtIniJuros := Fin.DtCarenciaDeJuros;

  ValorPago := Parcela.ValorPago + Parcela.DescConcedido;
  if (Parcela.DtPg.Dia < byte(RPAS.FinRPA.DiaVenc)) and 
     (ValorPago>Zero) then begin
    DataAm.Dia := Parcela.DtPg.Dia;
    diasam := Juliano(DataAm) - Juliano(DataSaldo);
    diasmes := Juliano( DataSaldomais1) - Juliano( DataSaldo );
    diasj := 30 - (datasaldo.dia - Parcela.DtPg.Dia);
    indj := pot( RPAS.FinRPA.Indjuros+1, diasj/30 );
    indcor := pot( RPAS.FinRPA.TxSD, diasam/diasmes );
    if abs(indj*indcor) > Zero then ind := indj*indcor else ind := 1.0;
    ValorAi := ValorPago/ind;
    ValorAIAntesVenc := ValorAIAntesVenc + ValorAi;
    Evento.ValorAINoVencto := ValorAI;
    Evento.IndCorEv        := indcor;
    if (Abs(IndCor-1) <= 0) or (Abs(IndCor) <= zero) then
      Evento.IncSCorr := 1;
    Evento.ComProRataJur   := fin.jurprorata and (abs(indj-1) > zero) and (abs(IndJ) > zero);
    RPAS.ValRPA.SaldoDev := R2(RPAS.ValRPA.SaldoDev - ValorAi);
    Evento.NovoSaldoNoEvento := RPAS.ValRPA.SaldoDev;
    if TemCustoCA then begin
      indjCA := pot(self.GetIndJurosCA+1, diasj/30 );
      Evento.IndJurCA    := indjCA;
      if abs(indjCA*indcor) > Zero then indCA := indjCA*indcor else indCA := 1.0;
      Evento.ValorAICANoVencto := ValorPago/indCA;
    end;

    if Parcela.DtPg.Dia >= UltDiaPgAntec then begin
      UltDiaPgAntec := Parcela.DtPg.Dia;
      ValorAIDaUltima := ValorPago/ind;
    end;
    if not Contrato.FInibeLegLink then 
      leglinkItem := LegLink.Add(CodSerie,'<P/><b>Antecipa  o de pagamento pelo valor pago antes do vencimento</b>');
    if assigned(LegLinkItem) then
    begin
      leglinkItem.Valores['DataPagamento'] := data_str(DataDePgto);
      if fin.jurprorata then
        leglinkItem.Valores['ComJurosProRata'] := 'Sim'
      else
        leglinkItem.Valores['ComJurosProRata'] := 'N o';
      leglinkItem.Valores['DiaVencimento'] := intstr(rpas.finrpa.diavenc);
      leglinkItem.Valores['DiaInicioJuros'] := intstr(DtIniJuros.Dia);
      leglinkItem.valores['MesAnoReferencia'] := mac_str(rpas.mac);
      leglinkItem.valores['MesAnoParcelaAntecipada'] := mac_str(Parcela.Mac);
      leglinkItem.valores['ValorPago'] := strgrana(ValorPago);
      leglinkItem.valores['ValorAmortizado'] := strgrana(ValorAi);
      leglinkItem.valores['SaldoAmortizado'] := strgrana(RPAS.ValRPA.SaldoDev);
    end;
  end;
  
  if Parcela.DtPg.Dia = byte(RPAS.FinRPA.DiaVenc) then begin
    ValorAInoVenc := ValorAInoVenc + ValorPago;
    RPAS.ValRPA.SaldoDev := R2(RPAS.ValRPA.SaldoDev - ValorPago);
    Evento.ValorAINoVencto   := ValorPago;
    Evento.NovoSaldoNoEvento := RPAS.ValRPA.SaldoDev;
    if TemCustoCA then 
      Evento.ValorAICANoVencto := ValorPago;

    if not Contrato.FInibeLegLink then 
      leglinkItem := LegLink.Add(CodSerie,'<P/><b>Antecipa  o de pagamento pelo valor pago no vencimento</b>');
    if assigned(LegLinkItem) then
    begin
      leglinkItem.Valores['DataPagamento'] := data_str(DataDePgto);
      if fin.jurprorata then
        leglinkItem.Valores['ComJurosProRata'] := 'Sim'
      else
        leglinkItem.Valores['ComJurosProRata'] := 'N o';
      leglinkItem.Valores['DiaVencimento'] := intstr(rpas.finrpa.diavenc);
      leglinkItem.Valores['DiaInicioJuros'] := intstr(DtIniJuros.Dia);
      leglinkItem.valores['MesAnoReferencia'] := mac_str(rpas.mac);
      leglinkItem.valores['MesAnoParcelaAntecipada'] := mac_str(Parcela.Mac);
      leglinkItem.valores['ValorPago'] := strgrana(ValorPago);
      leglinkItem.valores['ValorAmortizado'] := strgrana(ValorPago);
      leglinkItem.valores['SaldoAmortizado'] := strgrana(RPAS.ValRPA.SaldoDev);
    end;
  end;  
  
  DataSaldo.Dia := RPAS.FinRPA.DiaVenc; Int_Mes(RPAS.MAC, DataSaldo.MesAno);
  DataSaldomais1 := DataSaldo; INCMA( DataSaldomais1.MesAno);
  if (Parcela.DtPg.Dia > byte(RPAS.FinRPA.DiaVenc)) and 
     (ValorPago>Zero) then begin
    DataAm.Dia := Parcela.DtPg.Dia;
    Int_mes(RPAS.MAC, DataAm.MesAno);
    diasam := Juliano(DataAm) - Juliano(DataSaldo);
    diasmes := Juliano( DataSaldomais1) - Juliano( DataSaldo );
    diasj := Parcela.DtPg.Dia - DataSaldo.dia;
    indj := pot( RPAS.FinRPA.Indjuros+1, diasj/30 );
    indcor := detinddataadata(RPAS.Temp7.CodTabelaGenerica,Fin.DefReaj,
                              DataSaldo,DataSaldomais1,1.0, Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                              fin.CorrProRataIniPelaVarDataRef, RPAS.Temp12.CmProRataMesAnt,true);
    if IndInvalido then indcor := 1.0
    else indcor := pot( indcor, diasam/diasmes );
    if abs(indj*indcor) > Zero then ind := indj*indcor else ind := 1.0;
    ValorAi := ValorPago/ind;
    ValorAIposVenc := ValorAIposVenc + ValorAi;
    Evento.ValorAINoVencto:= ValorAI;
    RPAS.ValRPA.SaldoDev := R2(RPAS.ValRPA.SaldoDev - ValorAi);
    Evento.NovoSaldoNoEvento := RPAS.ValRPA.SaldoDev;
    Evento.IndCorEv        := indcor;
    if (Abs(IndCor-1) <= 0) or (Abs(IndCor) <= zero) then
      Evento.IncSCorr := 1;
    Evento.ComProRataJur   := fin.jurprorata and (abs(indj-1) > zero) and (abs(IndJ) > zero);
    if TemCustoCA then begin
      indjCA := pot(self.GetIndJurosCA+1, diasj/30 );
      Evento.IndJurCA  := indjCA;
      if abs(indjCA*indcor) > Zero then indCA := indjCA*indcor else indCA := 1.0;
      Evento.ValorAICANoVencto := ValorPago/indCA;
    end;

    if Parcela.DtPg.Dia >= UltDiaPgAntec then begin
      UltDiaPgAntec := Parcela.DtPg.Dia;
      ValorAIDaUltima := ValorPago/ind;
    end;

    //AmortizouposVenc := true; N o entendi porque essa variavel era setada aqui.
    //                          tentei move-la para fora da rotina, o que gera
    //                          diferen a na quarta fase, para vers es anteriores
    //                          a esta altera  o, ent o resolvi apenas inibir.

    if not Contrato.FInibeLegLink then 
      leglinkItem := LegLink.Add(CodSerie,'<P/><b>Antecipa  o de pagamento pelo valor pago ap s o vencimento</b>');
    if assigned(LegLinkItem) then
    begin
      leglinkItem.Valores['DataPagamento'] := data_str(DataDePgto);
      if fin.jurprorata then
        leglinkItem.Valores['ComJurosProRata'] := 'Sim'
      else
        leglinkItem.Valores['ComJurosProRata'] := 'N o';
      leglinkItem.Valores['DiaVencimento'] := intstr(rpas.finrpa.diavenc);
      leglinkItem.Valores['DiaInicioJuros'] := intstr(DtIniJuros.Dia);
      leglinkItem.valores['MesAnoReferencia'] := mac_str(rpas.mac);
      leglinkItem.valores['MesAnoParcelaAntecipada'] := mac_str(Parcela.Mac);
      leglinkItem.valores['ValorPago'] := strgrana(ValorPago);
      leglinkItem.valores['ValorAmortizado'] := strgrana(ValorAi);
      leglinkItem.valores['SaldoAmortizado'] := strgrana(RPAS.ValRPA.SaldoDev);
    end;
  end;
end;

procedure TSerie.CalculaAntecipacaoPeloValorPresente(    Evento  : TEventoAmInc;
                                                         Parcela : TParcelaSerie; 
                                                     var ValorAIAntesVenc,
                                                         ValorAInoVenc,
                                                         ValorAIposVenc,
                                                         ValorAIDaUltima:Double; 
                                                     var UltDiaPgAntec : byte);
var
  ValorPresenteParcelaCA,
  ValorPresenteParcela,
  ValorAmortizacaoParcela,
  ValorPresenteParcelaSwap: Double;
  UltDtPg             : TData;
  LegLinkItem : TLegLinkItem;
  DtIniJuros,
  DataDePgto,
  DtVencAnt,
  DtVencParcela,
  DtDescapitalizacao: TData;
  NMeses : Real;
  N: Integer;
  RazaoOriginal: Double;
  ValorAICA,
  ValorAI    : real;
  TemCustoCA : boolean;
begin
  TemCustoCA  := Contrato.temCA;
  LegLinkItem := nil;
  UltDtPg.dia := 0; UltDtPg.mes := 0; UltDtPg.ano := 0;
  fillchar(UltDtPg,sizeof(TData),0);
  ValorAmortizacaoParcela := 0;
  ValorPresenteParcelaCA  := 0;
  with Parcela do
  begin
    if (DataRefCalc.Dia > 0) and (DtPg.Dia > 0) and
        (juliano(DataRefCalc) > juliano(DtPg)) and
        (DataRefCalc.Mes = DtPg.Mes) and (DataRefCalc.Ano = DtPg.Ano) then
      DataDePgto := DataRefCalc
    else
      DataDePgto := DtPg;
    DtIniJuros := RPAS.FinRpa.DtAssin;
    if Evento.DiaEvento = 0 then 
      Evento.DiaEvento := DataDePgto.Dia;
    if Evento.MACEvento = 0 then 
      Evento.MACEvento := Mes_Int(DataDePgto.MesAno);
    if (Fin.DtCarenciaDeJuros.Dia > 0) and 
        (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
      DtIniJuros := Fin.DtCarenciaDeJuros;
    int_mes(Rpas.Mac,DtVencAnt.MesAno);
    if ShortInt(DataDePgto.Dia) < Rpas.FinRpa.DiaVenc then
      Decma(DtVencAnt.MesAno);
    DtVencAnt.Dia := Rpas.FinRpa.DiaVenc;
    if Juliano(DtVencAnt) > Juliano(DtIniJuros) then
      { Descapitaliza at  o m s anterior, uma vez que   posterior a data de in cio de juros }
      DtDescapitalizacao := DtVencAnt
    else
      { Descapitaliza at  o m s de in cio de juros }
      DtDescapitalizacao := DtIniJuros;
    NMeses := Mac - Mes_int(DtDescapitalizacao.MesAno);
    if fin.jurprorata then 
      NMeses := NMeses + (rpas.finrpa.diavenc-DtDescapitalizacao.Dia)/30;

    if NMeses < 0 then NMeses := 0;
    Evento.NMeses := NMeses;
    Evento.ComProRataJur  := fin.jurprorata;
    Evento.IncSCorr       := 1; //correcao cheia da origem at  DtPgto, n o   prorata
    int_mes(Mac,DtVencParcela.MesAno);
    DtVencParcela.Dia := RPAS.FinRPA.DiaVenc;
    if ShortInt(DataDePgto.Dia) < RPAS.FinRPA.DiaVenc then
    begin  { L gica alterada no scat 41691 desfazendo em parte o 
              que foi implementado no scat 34482 }
      ValorPresenteParcela := Valor * (1-Rpas.Temp10.IndRedPrest);
      if TemCustoCA then ValorPresenteParcelaCA := ValorPresenteParcela;
      if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then { Scat 41461 } 
      begin
        {   necess rio passar a raz o original e n o a corrigida. }
        { A f rmula abaixo   para recalcular a raz o a partir do valor da parcela. Scat 53628 }            
        N :=  mes_int(DtVencParcela.MesAno) - mes_int(DtIniJuros.MesAno);
        if abs(Fin.RazaoIni) > 0 then
        begin
          RazaoOriginal := abs(Fin.RazaoIni) * 1000;
          ValorAmortizacaoParcela := RazaoOriginal / RPAS.FinRPA.IndJuros / 1000 ;
        end
        else
        begin
          RazaoOriginal := (ValorPresenteParcela*(1+(N+1)*RPAS.FinRPA.IndJuros)/(1+N*RPAS.FinRPA.IndJuros)-ValorPresenteParcela)*1000;
          ValorAmortizacaoParcela := CalculaValorAtualEncargoJurosSimplesSCP(
                                    ValorPresenteParcela,DtVencParcela,DtIniJuros,RazaoOriginal);
        end;
        ValorPresenteParcela := CalculaValorAtualEncargoJurosSimplesSCP(
                                  ValorPresenteParcela,DtVencParcela,DtDescapitalizacao,RazaoOriginal);
        if TemCustoCA then
          ValorPresenteParcelaCA:= CalculaValorAtualEncargoJurosSimplesSCP(
                                      ValorPresenteParcelaCA,DtVencParcela,DtDescapitalizacao,0{RazaoOriginal});
      end
      else if (fin.EvoluiUsuEmPxN) and (Rpas.ValRpa.AmaisJ >0) then
      begin
        ValorPresenteParcela := Rpas.ValRpa.AmaisJ;
        if TemCustoCA then ValorPresenteParcelaCA:= ValorPresenteParcela;
      end
      else if Fin.JurosSimples then
      begin
        ValorPresenteParcela := ValorPresenteParcela / (1+(RPAS.FinRPA.IndJuros * NMeses));
        if TemCustoCA then begin
          ValorPresenteParcelaCA := ValorPresenteParcelaCA / (1+(self.GetIndJurosCA * NMeses));
          Evento.IndJurCA        := 1+(self.GetIndJurosCA * NMeses);
        end;
      end
      else
      begin
        ValorPresenteParcela := ValorPresenteParcela / power(1+RPAS.FinRPA.IndJuros,NMeses);
        if TemCustoCA then begin
          ValorPresenteParcelaCA := ValorPresenteParcelaCA / power(1+Self.GetIndJurosCA,NMeses);
          Evento.IndJurCA        := power(1+Self.GetIndJurosCA,NMeses)
        end;
      end;

      // Swap
      if (Fin.planoswap <> 0) then
      begin
        ValorPresenteParcelaSwap := AmaisJSwap * (1-Rpas.Temp10.IndRedPrest);
        ValorPresenteParcelaSwap := ValorPresenteParcelaSwap / power(1+ RPAS.Temp11.TxJurosSwap/1200,NMeses)
      end
      else
