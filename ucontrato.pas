function TesteReaj(MAC,mreaj,perreaj,MACReaj1,MACRef:integer):boolean;
var MAC_MA : TMes_Ano;
begin
//  result := ((pred(MAC)+mreaj) mod perreaj) = (pred(mreaj) mod perreaj);  
// Alterada pelo scat 27980

  int_mes(MAC,MAC_MA);
  if (MAC_MA.Mes = MReaj) or 
    ((MAC=MACReaj1) and ((MACReaj1-MACRef)>perreaj)) then result := true
  else
    case perreaj of
      1 : result := true;
      2 : result := (MAC_MA.Mes mod 2)=(Mreaj mod 2);
      3 : result := (MAC_MA.Mes mod 3)=(MReaj mod 3);
      6 : begin int_mes(MAC+6, MAC_MA); result :=  MAC_MA.Mes=mreaj end
      else Result := false
    end;
end;


procedure TSerie.EvoluiSaldoEmPxN;
var
  SaldoDevAnt,
  NovoSaldo,
  Dif : Double;
begin
  SaldoDevAnt := Rpas.ValRpa.SaldoDev;
  if Rpas.ValRpa.AmaisJ > 0 then 
  begin
    NovoSaldo := Rpas.ValRpa.AmaisJ * FParcelasSerie.ObtemNumeroParcelasRemanescentes(RPas.mac+1);
    Dif := (NovoSaldo - SaldoDevAnt);
    if Dif > 0 then // Houve aumento do saldo
    begin
      Rpas.Temp.CorrSaldo :=  Rpas.Temp.CorrSaldo + Dif;
      Rpas.ValRpa.SaldoDev := NovoSaldo;
    end;
  end;
end;

procedure TSerie.EvoluiSaldoSwapEmPxN;
var
  NovoSaldoSwap,
  DifSwap,
  SaldoDevAntSwap : Double;
  NumeroParcelasRemanescentes: Integer;
begin
  if Rpas.Sec.AmaisJSwap > 0 then 
  begin
    // Saldo swap ainda n o foi corrigido.   feito ap s a quarta fase
    SaldoDevAntSwap := Rpas.Sec.SaldoDevSwap + R2((Rpas.Sec.TxSDSwap-1) * Rpas.Sec.SaldodevSwap);
    NumeroParcelasRemanescentes := FParcelasSerie.ObtemNumeroParcelasRemanescentes(RPas.mac+1);
    NovoSaldoSwap := Rpas.Sec.AmaisJSwap * NumeroParcelasRemanescentes;
    DifSwap := (NovoSaldoSwap - SaldoDevAntSwap + Rpas.Sec.AmaisJSwap - FValorAntecPosVencSwap - FValorAntecPosVencSwap);
    if (Rpas.Sec.SaldoDevSwap >0) and (DifSwap > 0) then
    begin
      Rpas.Sec.JuroSwap :=  DifSwap;
    end;
  end;
end;

procedure TSerie.DetTxSDAmortNeg(var RPA : TpRPA; Dt1,Dt2 : Tdata);
var
  DtIndInvalido : TData;
  IndInvalido : boolean;
begin
  IndInvalido  := false;
  DtIndInvalido.dia := 0;
  fillchar(DtIndInvalido,sizeof(Tdata),0);

  RPA.Temp12.TxSDAmortNeg := RPA.FinRPA.TxSD;
  
  // tentar seguir a mesma l gica feita no financ. din mico
  if RPA.Temp12.CodReajSDAmortNeg > 0 then begin
    if RPA.Temp11.SaldoAmortNeg > zero then begin
      // Copiar a l gica da TxSD na segunda fase
      RPA.Temp12.TxSDAmortNeg := detinddataadata(RPA.Temp12.CodReajSDAmortNeg,RPA.Temp12.DefReajSDAmortNeg, 
                                                  Dt1,Dt2, 1.0,
                                                  Fin.CorrProRata,IndInvalido,DtIndInvalido,false,RPA.finrpa.persaldev,
                                                  fin.CorrProRataIniPelaVarDataRef,fin.cmproratamesant,true);
      if IndInvalido then
        RPA.Temp12.TxSDAmortNeg := 1;                                
    end
    else
      RPA.Temp12.TxSDAmortNeg := 1;
  end;                                            
end;

procedure TSerie.EvoluiSaldoAmortNeg;
var
  AmortizacaoMesSaldoJuros: Double;
begin
  if (Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro) < 0 then
  begin
    Rpas.Temp11.AmortNegMes := Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro;
  end
  else Rpas.Temp11.AmortNegMes := 0;
  Rpas.Temp11.CorrSaldoAmortNeg := R2((RPAS.Temp12.TxSDAmortNeg-1)* Rpas.Temp11.SaldoAmortNeg);
  Rpas.Temp11.SaldoAmortNeg :=  Rpas.Temp11.SaldoAmortNeg +  Rpas.Temp11.CorrSaldoAmortNeg - Rpas.Temp11.AmortNegMes;
  if  (Rpas.Temp11.SaldoAmortNeg > zero) and  ((Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro) > 0) then
  begin  // Se tem saldo de juros n o pagos e hove amortiza  o, amortiza o saldo de juros n o pagos tamb m
    // Financia os juros acumulados no prazo remanescente
    AmortizacaoMesSaldoJuros := (Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro);
    if ((Rpas.finrpa.Prazo-Rpas.finrpa.Npc+1) >0) then
      AmortizacaoMesSaldoJuros := Rpas.Temp11.SaldoAmortNeg / (Rpas.finrpa.Prazo - Rpas.finrpa.NPC+1);
    if AmortizacaoMesSaldoJuros > (Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro) then
      AmortizacaoMesSaldoJuros := (Rpas.ValRpa.AmaisJ - Rpas.ValRpa.Juro); 
    Rpas.Temp11.SaldoAmortNeg := Rpas.Temp11.SaldoAmortNeg  - AmortizacaoMesSaldoJuros;
    if Rpas.Temp11.SaldoAmortNeg < 0 then Rpas.Temp11.SaldoAmortNeg := 0;
  end;
end;

function TSerie.TxPstAjustado(TxPstAcum,TxPstAcumAnt,TxSD : real;Maua,MauaSD : smallint) : real;
begin
  result := TxPstAcum / TxPstAcumAnt;
  if (Maua=MauaSD) and (abs(TxSD-result)< 0.01) and
     (rpas.finrpa.perfin=rpas.finrpa.persaldev) and
     (not fin.CmproRatamesAnt) then
    result := TxSD;
end;

procedure TSerie.DefineAmaisJParcela(Parcela:TParcelaSerie);
// Define o amais que ser  o valor da parcela reajustada, ou 
// o valor emitido no caso de parceja j  emitida ou 
// zero se a parcela n o existir ou for renegociada
var
  DataBase,dtvenc,Dt2,DataBasepReajuste : TData;
  Dt2Swap, DataBasepReajusteSwap : TData;
  npSwap, mesindiceSwap : integer;
  np,mesindice,MACReaj1,MACRef : integer; IndiceateChaves:real;
  defas:byte; 
  IndInvalido: boolean;
  DtRes, DtEntHab, DataRefCalc : TData; 
  TxFullAcumAnt, AJant, AmaisJRes, VAmaisjsrecorr,ValorParcelaAjustado : double;
  MAC_MA:TMes_Ano;
  DtIndInvalido : Tdata;
  EMesRecalculo:Boolean;
  MA:TMes_Ano;
  N:Integer;
  MauAAnt : smallint;
  DataRefParaReaj,
  DataRefParaReajSwap : TData;
  TemQueReajustarNoMes : Boolean;
  ll: TLegLinkItem;
begin
  ll := nil;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  TemQueReajustarNoMes := false;
  DataRefParaReaj := fin.DataRefReaj;
  DataRefParaReajSwap := DataRefParaReaj;
  // DataRefParaReajSwap n o deve ter o efeito do MacAcumIndOrigem
  if RPAS.Temp12.MacAcumIndOrigem>0 then begin
    int_mes(RPAS.Temp12.MacAcumIndOrigem, DataRefparaReaj.MesAno);
    DataRefparaReaj.Dia := Fin.DataRef.Dia;
  end;
  if DataRefParaReaj.dia = 0 then
    DataRefParaReaj := Fin.DataRef;
  if DataRefParaReajSwap.dia = 0 then
    DataRefParaReajSwap := Fin.DataRef;
 FUsandoAmaisJPeloValorEmitido := false;
 FUsandoJurosPeloValorEmitido := false;
 IndInvalido  := false;
 fillchar(DtIndInvalido,sizeof(Tdata),0);
 FTxPstAcumAnt := RPAS.Temp5.TxPstAcum; TxFullAcumAnt := RPAS.Temp10.TxFullAcum;
 with RPAS, RPAS.FinRPA, RPAS.ValRPA do begin
   MauAAnt := Temp.Maua;
   np := (MAC-(mes_int(DataRefParaReaj.mesano)));
   if np<0 then np := 0;
   DataBasepReajuste := DataRefParaReaj;

   if (byte(FinRPA.MReaj) <> DataBasepReajuste.Mes) then begin
      DataBasepReajuste.Mes := FinRPA.MReaj;
      while Juliano(DataBasepReajuste)>Juliano(DataRefParaReaj) do
        int_mes(mes_int(DataBasepReajuste.MesAno)-PerFin, DataBasepReajuste.MesAno);
      np := (MAC-(mes_int(DataBasepReajuste.mesano)));
   end;
   mesindice := (np div PerFin)* PerFin +
                mes_int(DataBasepReajuste.MesAno);
   int_mes(mesindice, Dt2.MesAno);
  
   DataRefCalc := DataRefParaReaj; // SCAt 29769
   if (Fin.PriReajusteIntegral) and 
      (mesindice-mes_int(DataRefCalc.MesAno)<PerFin) then
        int_mes( mesindice-PerFin, DataRefCalc.MesAno);

// SCAt 25531 retirou  if (NPC=1) and Fin.RecalculaPrestacao then int_mes(MAC,Dt2.MesAno); //SCAt 22896
   int_mes(MAC,MAC_MA);
//   Dt2.Dia := Rpa.FinRPA.DiaVenc; SCAt 19671
//   Dt2.Dia := Fin.Diavenc;
   Dt2.Dia := FinRPA.DtInFin.Dia;
   if Dt2.Dia = 0 then Dt2.Dia := Fin.DtInicio.Dia;
   if Dt2.Dia = 0 then Dt2.Dia := DataRefParaReaj.Dia;       //Scat 20009
   int_mes( mac, DtRes.MesAno );
   DtRes.Dia := Dt2.Dia;
   if (fin.cmproratamesant) and (Perfin=12) then begin
     if Dt2.Mes <> Fin.DataRef.Mes then DECMA(Dt2.MesAno);
     Dt2.Dia := Fin.DataRef.Dia;
   end;
   if ((Temp12.CodReajSwap>0) and (not Temp10.NaoReajusta)) or
      (Temp11.TxJurosSwap>0) then // SCAt 49581
   begin
     // Scat 36892 Implementa  o de reajuste swap com diferente periodicidade
     if Fin.PerReajSwap = 0 then  // A data de reajuste segue a do financiamento
     begin
       Dt2Swap := Dt2;
     end
     else
     begin
       npswap := (MAC-(mes_int(DataRefParaReajSwap.mesano)));
       if npswap<0 then npswap := 0;
       DataBasepReajusteSwap := DataRefParaReajSwap;

       if byte(FinRPA.MReaj) <> DataBasepReajusteSwap.Mes then begin
         DataBasepReajusteSwap.Mes := FinRPA.MReaj;
         while Juliano(DataBasepReajusteSwap)>Juliano(DataRefParaReajSwap) do
         begin
          int_mes(mes_int(DataBasepReajusteSwap.MesAno)-Fin.PerReajSwap, DataBasepReajusteSwap.MesAno);
         end;
         npswap := (MAC-(mes_int(DataBasepReajusteSwap.mesano)));
       end;

       mesindiceSwap := (npswap div Fin.PerReajSwap)* Fin.PerReajSwap +
                    mes_int(DataBasepReajusteSwap.MesAno);
       int_mes(mesindiceSwap, Dt2Swap.MesAno);
       Dt2Swap.Dia := Dt2.Dia;
     end;
     Sec.TxPstSwap := detinddataadata(Temp12.CodreajSwap,Temp12.defswap, 
                                      DataRefParaReajSwap, Dt2Swap, Sec.TxPstSwap,
                                      Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                                      fin.CorrProRataIniPelaVarDataRef,fin.cmproratamesant,false);
     if IndInvalido then 
     begin 
       MarcaErroRPAS(RPAS,2,Temp12.CodReajSwap,DtIndInvalido);
       Sec.TxPstSwap := FTxSdSwapAcum;
     end;
     // Solu  o provis ria dada no scat 53547. Para o caso de um hist rio de 
     // cess o ou aquisi  o na presta  o zero, por um outro erro o amaisjswap
     // n o   calculado. Nesta situa  o o amaisj swap deve ser calculado pelo
     // amaisj original. N o seria poss vel calcular pelo valor correto
     // porque o valor que teria que existir na cess o seria o valor da 
     // da s rie e a s rie est  com o valor total do contrato.
     if (Temp3.Valced > Zero) and (Sec.AmaisjSwap > Zero)  then
       Sec.AmaisjSwap := int(Sec.AmaisjSwap*Sec.TxSDSwap*100+0.5)/100
     else
       if (Temp11.planoswap <> 0{Igual ao financiamento}) then 
       begin
         Sec.AmaisJSwap := int(Parcela.AmaisJSwap*Sec.TxPstSwap*(1-Temp10.IndRedPrest)*100+0.5)/100;
         rpas.Temp12.RaRdSwap := Parcela.RARDSwap;
         if not Contrato.FInibeLegLink then 
           ll := LegLink.add(CodSerie,'<P/><b>C lculo do amaisj swap corrigido.</b>');
         if assigned(ll) then
         begin
           ll.valores['Valor original'] := strgrana(Parcela.AmaisJSwap);
           ll.valores['Indice swap'] := formatfloat('0.0000000',Sec.TxPstSwap);
           ll.valores['Ind. Redu  o Presta  o'] := formatfloat('0.00000%',Temp10.IndRedPrest*100);
           ll.valores['Valor corrigido'] := formatfloat('0.0000000',Sec.AmaisJSwap);
         end;
       end
       else
       begin // Calcula a presta  o swap
         if not Contrato.FInibeLegLink then 
           ll := LegLink.add(CodSerie,'<P/><b>C lculo do amaisj swap corrigido.</b>');
         Sec.AmaisJSwap := int(Parcela.Valor*Sec.TxPstSwap*(1-Sec.PercColateral)*(1-Temp10.IndRedPrest)*100+0.5)/100;
         if assigned(ll) then
         begin
           ll.valores['Valor original'] := strgrana(Parcela.Valor);
           ll.valores['Indice swap'] := formatfloat('0.0000000',Sec.TxPstSwap);
           ll.valores['Perc. Colateral'] := formatfloat('0.00000',Sec.PercColateral*100);
           ll.valores['Ind. Redu  o Presta  o'] := formatfloat('0.00000%',Temp10.IndRedPrest*100);
           ll.valores['Valor corrigido'] := formatfloat('0.0000000',Sec.AmaisJSwap);
         end;
         //  int(Amaisj*(1-Temp10.IndRedPrest)*100+0.5)/100
         if Fin.EvoluiAgioCalcSwap then // Parcela de swap ser  pela diferen a de
                                        // juros da presta  o descontada
         begin
           Sec.AmaisJSwap := int(Parcela.Valor*
             pot((Fin.TxJurosDesconto/1200+1)/(FinRpa.IndJuros+1),npc)*
             sec.txpstswap*100+0.5)/100;
         end
      end
   end;
   DataBase := DataRefCalc;  IndiceateChaves := 1.0;
   dtvenc.dia := diavenc; int_mes(mac, dtvenc.mesano);
   defas := fin.defreaj;
   MACRef := mes_int(DataRefparaReaj.MesAno);
   MACReaj1 := Mes_int(FinRPA.DtInFin.MesAno);
   inc(MACReaj1);
   
   DtEntHab := RPAS.Temp9.DtEntregaChaves; // SCAt 29363
   if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then DtEntHab := RPAS.Temp10.DtHabit;
   if (Juliano(DtEntHab)>0) and
      (mes_int(DtEntHab.MesAno)>mes_int(DataRefParaReaj.MesAno)) and  // SCAt 21613
      (MAC>mes_int(DtEntHab.MesAno)) and
      (Fin.CodReajpreChaves>0) then begin // SCAt 35211
     DataBase := DtEntHab; DataBase.Dia := DiaVenc;
     if (mes_int(Database.MesAno) > Temp.MAUA ) and (Fin.PerReaj>1) then begin // SCAt 39021
       int_mes(Temp.MAUA, Database.MesAno);
       int_mes(Temp.MAUA, RPAS.Temp9.DtEntregaChaves.MesAno);
       if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then int_mes(Temp.MAUA, RPAS.Temp10.DtHabit.MesAno);
     end;
     IndiceAteChaves := Temp9.IndAteChaves;
     if MAC=succ(mes_int(DtEntHAB.MesAno)) then //SCAt 35680
       Temp5.TxPstAcum := 1.0; // SCAt 35211
   end
   else
     if Fin.codreajprechaves > 0 then defas := fin.defreajprechv;
   if ((not Fin.RecalculaPrestacao) and (not ((FinRPA.Plano mod 10)=SACR))
       or (NPC=1)) then begin
//     if (not Temp10.NaoReajusta) and
//       ((not Fin.RecalculaPrestacao) or (MAC_MA.Mes=DatabasepReajuste.Mes) or (NPC=1)) and
//        (not ( (MAC-mes_int(Fin.DataRef.MesAno)) < PerFin)) then  //SCAt 25531/25496
// Este bloco de cima foi substituido pelo abaixo - SCAt 26450
     if ( (not Temp10.NaoReajusta) and 
          (MAC>=mes_int(Fin.MAPrimReaj)) and  //SCAt 39021 
          ( TesteReaj(MAC, DatabasepReajuste.Mes, PerFin, MACReaj1,MACRef) or
            (((not Fin.RecalculaPrestacao) or (NPC=1))  and
            ((MAC-mes_int(Fin.DataRef.MesAno)) >= PerFin))) ) then begin  //SCAt 25531/25496

         // Corre  o com % do CDI   determinada no  ndice do saldo devedor   
         if fin.IN_COBRACORR or (fin.PERC_APLICACAO_IND_CORR <> 0) and (fin.PERC_APLICACAO_IND_CORR <> 100) then // scat 59802
         begin
           Temp5.TxPstAcum := Temp3.IndSaldoAcum * TxSD;
           TxPst := TxSD;
           IndInvalido := false;
         end  
         else
           Temp5.TxPstAcum := detinddataadata(RPAS.Temp7.CodTabelaGenerica,defas,
                                            DataBase, Dt2, Temp5.TxPstAcum,Fin.CorrProRata,
                                            IndInvalido,DtIndInvalido,false,Perfin,
                                            fin.CorrProRataIniPelaVarDataRef,
                                            Temp12.CmProratamesant,
                                            false);


        TemQueReajustarNoMes := TesteReaj(MAC, DatabasepReajuste.Mes, PerFin,MACReaj1,MACRef);
        if (not indinvalido) and Temp12.JurSCPAnuais then // scat 20548
          Temp3.IndSaldoAcum := Temp5.TxPstAcum;
     end;
     if (not Temp10.NaoReajusta) and IndInvalido then begin
       MarcaErroRPAS(RPAS,2,RPAS.Temp7.CodTabelaGenerica,DtIndInvalido);
        if ((PerFin<>1) or (Fin.PerParcelas<>1) or (NPC=1)) then // Scat 20548
          Temp5.TxPstAcum := Temp3.IndSaldoAcum * TxSD;
        Temp10.TxFullAcum := Temp5.TxPstAcum;
     end
   end;

   if not Temp10.NaoReajusta and (MAC>=mes_int(Fin.MAPrimReaj)) then
     if (fin.Indice_Obtido_Dia_Util) then // scat 59802
       Temp10.TxFullAcum := Temp3.IndSaldoAcum * TxSD 
     else
       Temp10.TxFullAcum := detinddataadata(RPAS.Temp7.CodTabelaGenerica,defas,
                                          DataBase, DtRes, Temp10.TxFullAcum,
                                          Fin.CorrProRata,IndInvalido,DtIndInvalido,false,Perfin,
                                          fin.CorrProRataIniPelaVarDataRef,temp12.CmProRataMesAnt,false);
   if (not IndInvalido) and TemQueReajustarNoMes
      or Fin.CobraResiduo then begin // Modificado pleo scat 48250
     Temp5.TxPstAcum := Temp5.TxPstAcum * IndiceAteChaves ;
     Temp10.TxFullAcum := Temp10.TxFullAcum * IndiceAteChaves;
     if not TemQueReajustarNoMes then //SCAt 63698
       Temp5.TxPstAcum := FTxPstAcumAnt;
   end  
   else begin
    if not TemQueReajustarNoMes then begin // if inserido pelo scat 26130 e modificado pelo scat 48250
      Temp5.TxPstAcum := FTxPstAcumAnt;
      Temp10.TxFullAcum := TxFullAcumAnt;
    end
    else begin // SCAt 39021
      Temp5.TxPstAcum := Temp3.IndSaldoAcum * TxSD;
      Temp10.TxFullAcum := Temp5.TxPstAcum;
    end;
   end;
   Desc      := Parcela.ValorPagoAntecipado;

//   if (not IndInvalido) then  // Retirado no scat 57097
   begin
     if (FTxPstAcumAnt > Zero) then 
     begin
        TxPst := TxPstAjustado(Temp5.TxPstAcum,FTxPstAcumAnt,TxSD,MauAAnt,Temp11.MauASd);
        if Abs(TxPst-1.0)>Zero then Temp.MAUA := MAC;
     end
     else 
     begin
       TxPst := 1.0;
       Temp5.TxPstAcum := FTxPstAcumAnt;
     end;
   end;
   if (abs(TxFullAcumAnt)>Zero) and (not IndInvalido) then TxFull:=Temp10.TxFullAcum/TxFullAcumAnt
   else TxFull := 1.0;
//   if (not (Parcela.TipoPg in PgtoComRedSdDev)) then begin Sempre calcular, conforme sol. 33039
     if ((Plano mod 10)=SACR) then begin 
       AmaisJ := int(Parcela.Valor*100+0.5)/100;
       TxPst := 1.0; TxFull := 1.0; Temp10.TxFullACum:=1.0;
     end
     else
       if Fin.CobraResiduo and (not Fin.RecalculaPrestacao) then begin // Quando existe cobran a de res duo o amaisj tem evolu  o mensal
         AmaisJ    := int(Parcela.Valor*Temp10.TxFullAcum*100+0.5)/100;
         RARD      := RARD*TxFull;
         if (fin.CmproRatamesAnt and (Perfin=1)) or 
            Temp11.AlteroudiaVenc then  TxSd := TxFull // SCAt 63968
       end else if fin.IN_COBRACORR // Scat 61369 Neste caso a presta  o n o deve ser corrigida
               or rpas.temp12.INCCORRSDAMORT {Scat 80328} then 
       begin
         amaisj := Parcela.Valor;
       end else 
       begin
         AmaisJ    := int(Parcela.Valor*Temp5.TxPstAcum*100+0.5)/100;
         if not Contrato.FInibeLegLink then 
           ll := LegLink.add(CodSerie,'<P/><b>C lculo do amaisj corrigido.</b>');
         if assigned(ll) then
         begin
           ll.valores['Valor original'] := strgrana(Parcela.Valor);
           ll.valores['Indice corre  o'] := formatfloat('0.0000000',Temp5.TxPstAcum);
           ll.valores['Valor corrigido'] := formatfloat('0.0000000',AmaisJ);
         end;
         if not ((Fin.SistAmort = 7) {SCP} and Fin.JurosSimples and
               (Temp7.Periodicidade >= 1 )) then
           { Se for scp com juros simples precisa calcular a RDRD todo m s }
           { que   feito na rotina principal da segunda fase }
           RARD      := RARD*TxPst;
       end;
     ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
     AmaisJRes := int(Parcela.Valor*Temp5.TxPstAcum*100+0.5)/100;
     AjustaMoeda2( mes_int(Fin.DataRef.MesAno), Parcela.MAC, AmaisJ);
     AjustaMoeda2( mes_int(Fin.DataRef.MesAno), Parcela.MAC, AmaisJRes);
     if Fin.EvoluiAgioCalcSwap then
       Temp10.AmaisJOrig := int(Parcela.Valor/pot(FinRpa.IndJuros+1,npc)*100+0.5)/100.0
     else
       Temp10.AmaisJOrig := Parcela.Valor;
     AjustaMoeda2( mes_int(Fin.DataRef.MesAno), Parcela.MAC, Temp10.AmaisJOrig);
     if (abs(Parcela.RARD) > Zero) and (not FDesconsideraParcela) and
         (abs(RARD-Parcela.RARD) >= 0.01) and 
         not((Fin.SistAmort = 7) {SCP} and Fin.JurosSimples) then begin
        { Para o SCP com juros simples a raz o precisa ser reajusta 
          porque   usada para c lculo dos juros, scat 42335 }
       RARD := Parcela.RARD;
       ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
     end;
     if ScciConf.UsaArqPrest and ((Parcela.JurosEmi > zero) or (Parcela.Flag=102)) then begin
       FUsandoJurosPeloValorEmitido := true;       
       Juro  := Parcela.JurosEmi;
     end;
     if ((Parcela.ValorEmitido > Zero) or (Parcela.Flag=103) or (Parcela.Flag=102)) and (not FDesconsideraParcela) and
        ScciConf.UsaArqPrest
//        and (abs(AmaisJ-Parcela.ValorEmitido) >= 0.01) then  tirado scat 50958
          { J  foi emitida, assume o valor da parcela emitida }
     then begin
       if (CodErro = 2) and (Mac = Temp11.ErroMacIndice) then begin
         CodErro := 0;
         Temp11.ErroCodigoIndice := 0;
         Temp11.ErroMacIndice := 0;
         Temp11.ErroDiaIndice := 0;
       end;
       AJAnt := int(Amaisj*(1-Temp10.IndRedPrest)*100+0.5)/100;
       Amaisj := Parcela.ValorEmitido;
       FUsandoAmaisJPeloValorEmitido := true;
       ValorParcelaAjustado := Parcela.Valor;
       if (MAC>=MACRecorr) and
          not((Fin.SistAmort = 7) {SCP} and Fin.JurosSimples) then // sol. 50598
         VamaisjsRecorr := amaisj-Recorr
       else
         VAmaisjsRecorr := Amaisj;
       AjustaMoeda2(mes_int(Fin.DataRef.MesAno), Parcela.MAC, ValorParcelaAjustado);
       if Parcela.MACEmitido>0 then // SCAt 50946
          AjustaMoeda2(Parcela.MACEmitido, Parcela.MAC, AmaisJ);
       if (abs(AjAnt-AmaisJ)>0.01) and
          (ValorParcelaAjustado > Zero) and (not RPAS.Temp11.AlterouDiaVenc) and 
          (ExOpc<>21) and (ExOpc<>35) and (ExAmInc<>21)  and // SCAt 54385
          (ValorParcelaAjustado*(1-Temp10.IndRedPrest) > zero) then begin
           Rpas.Temp5.TxPstAcum := VamaisjsRecorr/(ValorParcelaAjustado*(1-Temp10.IndRedPrest)); //Parcela.Valor SCAt22466
       end;
       if Temp11.CalculaJurosAnuais then
         if AmaisjAnt>Zero then TxPst := int(Amaisj*10000/AmaisJAnt+0.5)/10000 else TxPst := 1
       else if Fin.RecalculaPrestacao or Temp11.CalculaJurosAnuais then // SCAt 35187
         if AmaisjAnt>Zero then TxPst := (AmaisJ-Recorr)/AmaisJAnt else TxPst := 1
       else if (FTxPstAcumAnt > Zero) then
         TxPst := TxPstAjustado(Temp5.TxPstAcum,FTxPstAcumAnt,TxSD,MauAAnt,Temp11.MauASd)
       else TxPst := 1.0;
       // Sol. 94216 - n o pode misturar o amaisj lido do parcela.valoremitido com o amaisJRes
       //              se usar o amaisjpelovaloremitido tem que obrigatoriamente usar o Parcela.ResiduoGeradoEmi
       if assigned(Parcela) and FUsandoAmaisJPeloValorEmitido (*(Parcela.ResiduoGeradoEmi > Zero)*) and (not FDesconsideraParcela) and
         ScciConf.UsaArqPrest then Temp9.ResiduoMes := Parcela.ResiduoGeradoEmi
       else if Fin.CobraResiduo and (not Fin.RecalculaPrestacao) then
         Temp9.ResiduoMes := AmaisJ - AmaisJRes;
       if not Contrato.FInibeLegLink then 
         ll := LegLink.add(CodSerie,'<P/><b>C lculo da presta  o pelo valor emitido</b>');
       if assigned(ll) then
       begin
         ll.valores['Valor emitido'] := strgrana(Parcela.ValorEmitido);
       end;
     end
     else if (Rpas.Temp11.CalculaJurosAnuais) and (not Temp12.JurSCPAnuais) then begin
       if ((Prazo-NPC+1)>0) then 
       begin
         int_mes(MAC,MA);
         if fin.mreaj > 0 then
           EMesRecalculo := fin.mreaj = MA.Mes
         else 
           EMesRecalculo := ((MAC-Mes_Int(Fin.DataRef.MesAno)-1) mod 12)=0;
         if (EMesRecalculo and ((NPC>1) or ((NPC=1) and (Fin.PerParcelas>1)))) then 
         begin 
           //   necess rio fazer o c lculo da corre  o do saldo antes porque ela inda n o foi feita
           RPAS.Temp.CorrSaldo := R2((RPAS.FinRPA.TxSD-1) * RPAS.ValRPA.Saldodev);
           // A corre  o do saldo ainda n o foi incorporada ao saldo
           // Ent o o saldo anterior ainda est  na vari vel saldo
           if fin.perparcelas > 0 then
             N := (12 div fin.perparcelas)
           else
             N := 1;
            if fin.perparcelas > 1 then N := N -1;
           AmaisJ := int((Saldodev+Rpas.Temp.CorrSaldo+IndJuros*12*(SaldoDev+Rpas.Temp.CorrSaldo+N*AmaisjAnt*rpas.finrpa.txpst))/
                     succ(Prazo-Npc)*100)/100;
         end
         else
           AmaisJ := int(AmaisJAnt * TxPst*100)/100;
       end;
     end
     else if (Fin.RecalculaPrestacao or ((Plano mod 10)=SACR) or 
           FDesconsideraParcela) and (NPC>1) and
          (Parcela.ValorEmitido <= Zero) then begin
         AmaisJ := AmaisjAnt;
         ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
         if (MAC >= ValRPA.MACRecorr) then
           ValRPA.AmaisJ := ValRPA.AmaisJ + ValRPA.Recorr;
     end
     else  begin
       if assigned(Parcela) and (Parcela.ResiduoGeradoEmi > Zero) and (not FDesconsideraParcela) and
         ScciConf.UsaArqPrest then Temp9.ResiduoMes := Parcela.ResiduoGeradoEmi
       else if Fin.CobraResiduo and (not Fin.RecalculaPrestacao) then
              Temp9.ResiduoMes := AmaisJ - AmaisJRes;
     end;
//   end  Sol. 33039
   Temp5.AmaisJIntegral := AmaisJ;
   if (fin.IN_COBRACORR) then
     txPst := TxSd;
   if Parcela.TipoPg in PgtoComRedSdDev then begin
     Temp12.AmaisJSemAntec := Amaisj;
     AmaisjAnt:= AmaisJ;
     AmaisJ:=0 ;
     AmaisJRes := 0;
     Temp10.AmaisJOrig := 0;
     FParcelaDoMesTevePagamentoAntecipado := true;
   end;
   if (Temp11.planoswap <> 8){USU} and (abs(Amaisj)<=Zero) and (Temp3.ValCed<Zero) then 
     sec.AmaisJSwap := 0;
 end;
end;


procedure TestaProxDiaUtil(var Dt:TData);
begin
  while not Testa_Data_Fer(dt) do J_Data(Juliano(dt)+1,dt);
end;

function TSerie.CalcIndJurosPorDiasCorridosOuUteis : extended;
var
  Dt1, Dt2,
  DtIniJuros: TData;
begin
  Result := RPAS.FinRPA.IndJuros;
  DtIniJuros := RPAS.FinRpa.DtAssin;
  if (Fin.DtCarenciaDeJuros.Dia > 0) and
     (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
     DtIniJuros := Fin.DtCarenciaDeJuros;
  int_mes(RPAS.MAC,Dt2.Mesano);
  Dt2.Dia := byte(RPAS.FinRPA.DiaVenc);
  Dt1 := Dt2;
  DECMA(Dt1.MesAno);
  Dt1.Dia := Dia_Venc(mes_int(Dt1.MesAno),Dt1.Dia);
  if Juliano(DtIniJuros) > Juliano(Dt1) then Dt1 := DtIniJuros;
  if Juliano(Dt2) > Juliano(Dt1) then begin
    if (Fin.TpJuros = 7) then begin // Dias  teis
      TestaProxDiaUtil(Dt1);  // Estava fora do tpjuros=7 at  scat 50225
      TestaProxDiaUtil(Dt2);
      Result :=  pot(1+RPAS.FinRPA.TxJuros/100,DiasUteis(Dt1,Dt2)/252)-1
    end
    else if Fin.TpJuros = 6 { or Fin.ProRataJurosDiasCorridos)} then // Dias corridos modificado para taxa mensal pelo scat 50225
      Result :=  pot(1+RPAS.FinRPA.TxJuros/100,(Juliano(Dt2)-Juliano(dt1))/360)-1;
  end;
end;

function TSerie.CalculaJurosDescontoPorDiasCorridosOuUteis(DiaVencAnt:Byte):Double;
var                         
  Dt1, Dt2,
  DtIniJuros: TData;
  IndJuros: Extended;
  ll: TLegLinkItem;
begin
  ll := nil;
  IndJuros := 0;
  DtIniJuros := RPAS.FinRpa.DtAssin;
  if (Fin.DtCarenciaDeJuros.Dia > 0) and
     (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
     DtIniJuros := Fin.DtCarenciaDeJuros;
  int_mes(RPAS.MAC,Dt2.Mesano);
  Dt2.Dia := byte(RPAS.FinRPA.DiaVenc);
  Dt1 := Dt2;
  DECMA(Dt1.MesAno);
  if DiaVencAnt > 0 then
    Dt1.dia := DiaVencAnt
  else
    Dt1.Dia := Dia_Venc(mes_int(Dt1.MesAno),Rpas.FinRpa.DtInFin.Dia);
  if Juliano(DtIniJuros) > Juliano(Dt1) then
    Dt1 := DtIniJuros;
  if Juliano(Dt2) > Juliano(Dt1) then
  begin
    if (Fin.TpJuros = 7) then begin // Dias  teis
      TestaProxDiaUtil(Dt1);  // Estava fora do tpjuros=7 at  scat 50225
      TestaProxDiaUtil(Dt2);
      IndJuros :=  pot(1+Fin.TxJurosDesconto/100,DiasUteis(Dt1,Dt2)/252)-1;
      if IndJuros <> 0 then
      begin
        if not Contrato.FInibeLegLink then 
          ll := LegLink.Add(RPAS.Temp8.CodSerie,'<b><p>C lulo de juros de desconto por dias  teis</b>');
        if (assigned(ll)) then
        begin
          ll.valores['IndJuros'] := formatfloat('0.0000000',1+fin.txjurosDesconto/100);
          ll.valores['Data inicial'] := data_str2(dt1);
          ll.valores['Data final'] := data_str2(dt2);
          ll.valores['Dias  teis'] := inttostr(DiasUteis(Dt1,Dt2));
          ll.valores['1+IndJuros^(Dias  teis / 252)'] := formatfloat('0.00000000',1+IndJuros);
        end;
      end
    end
    else 
    begin // Dias corridos modificado para taxa mensal pelo scat 50225
      IndJuros :=  pot(1+Fin.TxJurosDesconto/100,(Juliano(Dt2)-Juliano(dt1))/360)-1;
      if IndJuros <> 0 then
      begin
        if not Contrato.FInibeLegLink then 
          ll := LegLink.Add(RPAS.Temp8.CodSerie,'<b><p>C lulo de juros de desconto por dias corridos</b>');
        if (assigned(ll)) then
        begin
          ll.valores['IndJuros'] := formatfloat('0.0000000',1+fin.txjurosDesconto/100);
          ll.valores['Data inicial'] := data_str2(dt1);
          ll.valores['Data final'] := data_str2(dt2);
          ll.valores['Dias corridos'] := inttostr(Juliano(Dt2)-Juliano(Dt1));
          ll.valores['1+IndJuros^(Dias corridos / 360)'] := formatfloat('0.00000000',1+IndJuros);
        end;
      end
    end;
  end;
  Result :=  int(IndJuros * (rpas.Temp.SalDevAnt - rpas.Sec.SaldoDevAntColateral-rpas.sec.SaldoDesagio)*100+0.5)/100;
end;

