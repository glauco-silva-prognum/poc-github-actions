       (RPAF.MAC >= Scciconf.MACIniContabilidadeDiferida) and
       (juliano(RPAF.FinRPA.DtAssin) <= juliano(FDataRefHist)) then begin
(*------coloquei esse trecho abaixo para o crit rio padr o antigo, por causa
        do novo crit rio de regime de caixa.
       (RPAF.FinRPA.NPC > 0) and 
       (Abs(RPAF.ValRPA.TotPrest-RPAF.Temp7.DescSeg) > Zero) and
       (Abs(RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc) > Zero) then begin
----------------------------------------------------------------------*)
        if not assigned(SerieF.ParcelaDoMes) then 
          Parcela := SerieF.Parcelas.ObtemParcelaPorMAC(RPAF.MAC)
        else
          Parcela := SerieF.ParcelaDoMes;
        Int_Mes(RPAF.MAC,DtVenc.MesAno);
