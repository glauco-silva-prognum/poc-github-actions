procedure TContrato.LeValoresEmitidos;
var
  Qry : TFastSqlQuery;
  DBRegistro : TDBRegistroEmicons;
  i : integer;
  SerieList : TStringlist;
  RegEmi : TpEmicons;
  Mac : longint;
begin
  RegEmi.codserie := 0;
  fillchar(RegEmi,sizeof(RegEmi),0);
  Mac := 0;
  GetSerieFinanciamentoDinamico.ValoresEmitidos.clear;
  GetSerieFInanciamentoDinamico.ValoresEmitidos.Inicio := Mes_int(Mutdsk.Financ.DtAssin.mesAno);
  Qry := TFastSqlQuery.create(nil);
  DBRegistro := TDBRegistroEmicons.create;
  SerieList := TStringlist.create;
  try
    SerieList.sorted := true;
    for i := 0 to Series.count-1 do begin
      SerieList.add(inttostr(Series[i].CodSerie));
      Series[i].ValoresEmitidos.clear;
      Series[i].ValoresEmitidos.Inicio := Mes_int(Series[i].Fin.DataRef.mesAno);
    end;
    Qry.SqlConnection := SqlConnectionEmicons;
    Qry.sql.add('SELECT');
    DBRegistro.GeraSelectStrings(Qry.Sql);
    Qry.sql.add('FROM '+DBRegistro.NomeTabela);
    qry.sql.add('WHERE ctr='+QuotedStr(CtrToSqlCtr(Mutdsk.cad.ctr)));
    Qry.sql.add('ORDER BY NU_MAC,CODSERIE');
    Qry.open;
    while not Qry.Eof do begin
      DBRegistro.QryToReg(Qry,RegEmi);
      DBRegistro.QryToMac(Qry,Mac);
      if RegEmi.NossoNum > '' then begin
        if RegEmi.CodSerie = 0 then
          GetSerieFinanciamentoDinamico.ValoresEmitidos.Adiciona(Mac,RegEmi)
        else begin
          i := SerieList.indexof(inttostr(RegEmi.codserie));
          if i >= 0 then
            Series[i].ValoresEmitidos.Adiciona(Mac,RegEmi);
        end;
      end;
      Qry.Next;
    end;
  finally
    SerieList.free;
    Qry.free;
    DBRegistro.free;
  end;
  FLeuValoresEmitidos := true;
end;

function TContrato.SubrogadoParaOutro : boolean;
var
  i, j : Integer;
  wHEvo   : TpHistEvo;
  HistAux: TpHistEdit;
begin
  wHEvo[0].Tam := 0;
  fillchar(wHEvo,sizeof(wHEvo),0);
  if not FHistoricosLidos then LeHistoricos;
  result := false;
  i := 1;
  while (i <= FHistMem[0].Tam) and (not result) do begin
    if FHistMem[i].Log.CodMov = 22 then begin
      HistAux[0].Tam := 1;
      HistAux[1] := FHistMem[i];
      Processa_Hist(DataH,HistAux,wHEvo);
      j := 1;
      while (j <= wHEvo[0].Tam) and (not result) do begin
        if (wHEvo[j].Ficha.Campo = 43) and
           (wHevo[j].Ficha.ValByte = 27) then result := true;
        inc(j);
      end;
    end;
    inc(i);
  end;
end;

