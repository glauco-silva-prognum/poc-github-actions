function CalculaIndAcumulado(const RPA                          : TpRPA;
                                   DataRefReaj                  : TData;
                                   CodTabelaGenerica            : integer;
                                   Defasagem                    : byte;
                                   PerReaj                      : byte;
                                   CalculaTxGestao              : boolean = false;
                                   PriReajusteIntegral          : boolean = false;
                                   CorrProRata                  : boolean = true;
                                   RecalculaPrestacao           : boolean = false;
                                   CorrProRataIniPelaVarDataRef : boolean = false;
                                   CalcMes                      : boolean = false;
                                   MACPrimReaj                  : smallint= 0) : real;
var
  DataCalc, 
  DataBaseCalc,  DataRefParaReaj, DataBasepReajuste : Tdata;
  IndInvalido                                       : boolean;
  DtIndInvalido                                     : TData;
  NP, MesIndice,MACReaj1,MACRef                     : smallint;
  IndAcumAnt                                        : real;
begin
  Result := 0;
  IndInvalido  := false;
  DtIndInvalido.Dia := 0;fillchar(DtIndInvalido,sizeof(Tdata),0);
  if CalculaTxGestao then 
    IndAcumAnt := RPA.Sec.IndTxGestaoAcum
  else
    IndAcumAnt := RPA.Temp12.IndTxAdmAcum;
  if Abs(IndAcumAnt) <= Zero then IndAcumAnt := 1.0;
  if CalculaTxGestao or 
    ((not RecalculaPrestacao) and (not ((RPA.FinRPA.Plano mod 10)=SACR)) or
     (RPA.FinRPA.NPC=1)) then begin
    if PerReaj <= 0 then PerReaj := 1;
    if DataRefReaj.Dia > 0 then
      DataRefParaReaj := DataRefReaj
    else
      DataRefParaReaj := RPA.FinRPA.DtAssin;
    DataBasepReajuste := DataRefParaReaj;
    DataBaseCalc       := DataRefParaReaj; // SCAt 29769

    NP := (RPA.MAC-(Mes_int(DataRefParaReaj.MesAno)));
    if NP < 0 then NP := 0;

    if (byte(RPA.FinRPA.MReaj) <> DataBasepReajuste.Mes) then begin
       DataBasePReajuste.Mes := RPA.FinRPA.MReaj;
       while Juliano(DataBasePReajuste) > Juliano(DataRefParaReaj) do
         int_mes(mes_int(DataBasePReajuste.MesAno)-PerReaj, DataBasepReajuste.MesAno);
       NP := (RPA.MAC-(mes_int(DataBasePReajuste.MesAno)));
    end;
    MesIndice := (NP div PerReaj)* PerReaj + 
                 Mes_int(DataBasepReajuste.MesAno);
    int_mes(MesIndice, DataCalc.MesAno);
    if  PriReajusteIntegral and 
       (MesIndice-Mes_Int(DataBaseCalc.MesAno) < PerReaj) then
      Int_Mes(MesIndice-PerReaj, DataBaseCalc.MesAno);
    MACRef := Mes_int(DataRefReaj.MesAno);

    MACReaj1 := Mes_int(RPA.FinRPA.DtInFin.MesAno);
    inc(MACReaj1);


    DataCalc.Dia := RPA.FinRPA.DtInFin.Dia;
    if DataCalc.Dia = 0 then DataCalc.Dia := RPA.Temp12.DiaVencOrig;
    if DataCalc.Dia = 0 then DataCalc.Dia := DataRefParaReaj.Dia;       //Scat 20009
    if (RPA.Temp12.CmProRataMesAnt) and (PerReaj=12) then begin
      if DataCalc.Mes <> RPA.FinRPA.DtAssin.Mes then DECMA(DataCalc.MesAno);
      DataCalc.Dia := RPA.FinRPA.DtAssin.Dia;
    end;
    if ( (not RPA.Temp10.NaoReajusta) and 
         (RPA.MAC >= MACPrimReaj) and  //SCAt 39021
         (TesteReaj(RPA.MAC, DatabasepReajuste.Mes, PerReaj,MACReaj1,MACRef)  or
       (((not RecalculaPrestacao) or (RPA.FinRPA.NPC=1))  and
        ((RPA.MAC-mes_int(RPA.FinRPA.DtAssin.MesAno)) >= PerReaj))) ) then begin
      Result := detinddataadata(CodTabelaGenerica,Defasagem,
                                DataBaseCalc, 
                                DataCalc,
                                1.0,
                                CorrProRata,
                                IndInvalido,
                                DtIndInvalido,
                                false{ProRataDC},
                                PerReaj,
                                CorrProRataIniPelaVarDataRef,
                                RPA.Temp12.CmProrataMesAnt,
                                CalcMes);
    end;
    if IndInvalido or (not TesteReaj(RPA.MAC, DatabasepReajuste.Mes, PerReaj,MACReaj1,MACRef)) then
      Result := IndAcumAnt;
  end;
end;


procedure TSerie.CalculaTaxapSeries;
var
  ValUPC : real;
begin
  if (Fin.TxAdm > zero) then begin
    case Fin.TTX of
      0 : begin
            ValUPC := OBTEM_MOEDA_REFD( Fin.Dataref );
            Rpas.ValRpa.ValTxAdm := int((Rpas.FinRpa.TxAdm*ValUPC)*Rpas.Temp5.TxPstAcum*100+0.5)/100;
          end;
      2 : Rpas.ValRpa.ValTxAdm := int((Rpas.FinRpa.TxAdm*Rpas.ValRpa.AmaisJ)*Rpas.Temp5.TxPstAcum*100+0.5)/100;
     14 : begin
            if Fin.CodReajTxAdm > 0 then begin
              Rpas.Temp12.IndTxAdmAcum := CalculaIndAcumulado(RpaS,Fin.DataRefReaj,
                                                              RPAS.Temp12.CodReajTxAdm,
                                                              RPAS.Temp12.DefReajTxAdm,
                                                              RPAS.Temp12.PerReajTxAdm,
                                                              false{CalculaTxGestao},
                                                              Fin.PriReajusteIntegral,
                                                              Fin.CorrProRata,
                                                              Fin.RecalculaPrestacao,
                                                              Fin.CorrProRataIniPelaVarDataref,
                                                              false{CalcMes?},
                                                              Mes_Int(Fin.MAPrimReaj));

              Rpas.ValRpa.ValTxAdm := Arredonda(Rpas.FinRpa.TxAdm*RpaS.Temp12.IndTxAdmAcum);
            end
            else
              Rpas.ValRpa.ValTxAdm := int(Rpas.FinRpa.TxAdm*Rpas.Temp5.TxPstAcum*100+0.5)/100;
          end;
     16 : Rpas.ValRpa.ValTxAdm := int(Rpas.FinRpa.TxAdm*100+0.5)/100;
    end;
  end;
end;

function TSeries.ObtemTxOriginalIFRS9(const MutDsk:TpMutDsk) : real;
var
  i : integer;
  DtAssinMaisAntiga : TData;
  TxOriginalCtrIFRS9MaisAntiga : real;
begin
{
  TEMP12_TXORIGINALCTRIFRS9 para contratos de s rie considerando:
  1 -  A taxa de juros da s rie com FINRPA_DTASSIN mais antiga, cadastrada em FINRPA_TXJUROS;
  2 - Se houver mais de uma s rie com FINRPA_DTASSIN mais antiga, considerar a maior taxa entre as s ries;
}
  FTpJurosTxOriginalCtrIFRS9      := 0;
  FPerParcelasTxOriginalCtrIFRS9  := 0;
  FJurosSimplesTxOriginalCtrIFRS9 := false;
  
  DtAssinMaisAntiga.dia := 0;
  fillchar(DtAssinMaisAntiga,sizeof(TData),0);
  TxOriginalCtrIFRS9MaisAntiga := 0;
  if TemFinancDinamico(MutDsk) then begin
    DtAssinMaisAntiga := MutDsk.Financ.DtAssin;
    TxOriginalCtrIFRS9MaisAntiga := MutDsk.Financ.TxJuros;
  end;
  if (count > 0) and 
    ((DtAssinMaisAntiga.Dia = 0) or 
     (juliano(GetSerie(0).Fin.DataRef) <= juliano(DtAssinMaisAntiga))) then begin
    DtAssinMaisAntiga := GetSerie(0).Fin.DataRef;
    if GetSerie(0).Fin.TxJuros > TxOriginalCtrIFRS9MaisAntiga then begin
      TxOriginalCtrIFRS9MaisAntiga := GetSerie(0).Fin.TxJuros;
      FTpJurosTxOriginalCtrIFRS9      := GetSerie(0).Fin.TpJuros;
      FPerParcelasTxOriginalCtrIFRS9  := GetSerie(0).Fin.perparcelas;
      FJurosSimplesTxOriginalCtrIFRS9 := GetSerie(0).Fin.JurosSimples;
    end;
  end;

  for i := 1 to count-1 do
    if (DtAssinMaisAntiga.dia = 0) or {and}
       (juliano(GetSerie(i).Fin.DataRef) <= Juliano(DtAssinMaisAntiga)) then begin
      DtAssinMaisAntiga := GetSerie(i).Fin.DataRef;
      if GetSerie(i).Fin.TxJuros > TxOriginalCtrIFRS9MaisAntiga then begin
        TxOriginalCtrIFRS9MaisAntiga   := GetSerie(i).Fin.TxJuros;
        FTpJurosTxOriginalCtrIFRS9     := GetSerie(i).Fin.TpJuros;
        FPerParcelasTxOriginalCtrIFRS9 := GetSerie(i).Fin.perparcelas;
        FJurosSimplesTxOriginalCtrIFRS9:= GetSerie(i).Fin.JurosSimples;
      end;
    end;
  result := TxOriginalCtrIFRS9MaisAntiga;
end;

procedure TSeries.InicRpaS(const MutDsk       : TpMutDsk; 
                                 MacMinimo    : Integer;
                           var   HistMem      : TpHistEdit;
                                 NaoReajusta  : boolean = false);
var
  i,prazoseriebase,
  seriecomsegimv: integer;
//  seriecomtaxa: integer; 
  RPATmp: TPRPA;
  HEvoSerie : TpHistEvo;
  RegApoliceDFI,
  RegApolice,
  RegApoliceSerie : TpApolice;
//  HistMes: TpHistEvo;
  SldParaMip : real;
  ValAValLimitado : real;
  TxOriginalCtrIFRS9 : real;
  DtTermino : Tdata;
begin
  TxOriginalCtrIFRS9 := ObtemTxOriginalIFRS9(Mutdsk);
  HEvoSerie[0].Tam := 0;
  fillchar(HEvoSerie,sizeof(HEvoSerie),0);
  RegApoliceDFI.CampoVbaseMip := 0;
  fillchar(RegApoliceDFI,sizeof(RegApoliceDFI),0);
  RegApolice.CampoVbaseMip := 0;
  fillchar(RegApolice,sizeof(RegApolice),0);
  RPATmp.MAC := MacMinimo; // Futuramente deve ser melhorado
//  Uevolui3.Obtem_hist_mes( RPATmp, FHEvo, HistMes );
  prazoseriebase :=0; seriecomsegimv := 0; 
//  seriecomtaxa := 0; scat 34442
  for i := 0 to Count -1 do  // Determina serie suporte para segimv e taxa
    if (Serie[i].Fin.PerParcelas=1) then begin
      seriecomsegimv := i;
//      seriecomtaxa := i;
    end;
  for i := 0 to Count -1 do
    if (Serie[i].Fin.PerParcelas=1) and
       (Serie[i].Fin.Prazo>prazoseriebase) and
       (Serie[i].Fin.CompoeSaldo or Serie[i].Fin.CompoeEntrada) then begin
      seriecomsegimv := i;
//      seriecomtaxa := i;
      prazoseriebase := Serie[i].Fin.Prazo; // SCAt 32927
    end;
  LeApolice(Mutdsk.cad2.Codapolice,RegApolice);
  LeApolice(Mutdsk.Cad4.CodApoliceDFI,RegApoliceDFI);
  for i := 0 to Count - 1 do
   with Serie[i] do begin
     ProcessaHistSerie(HistMem,HEvoSerie,Fin.CodSerie);
     Serie[i].InicRpaS(MacMinimo,MutDsk,HEvoSerie,NaoReajusta);
     if Serie[i].RPAS.Temp11.GrupoApolice > 0 then begin
       if RegApolice.CodApolice = Serie[i].RPAS.Temp10.CodApolice then
         RegApoliceSerie := RegApolice
       else
         LeApolice(Serie[i].RPAS.Temp10.CodApolice,RegApoliceSerie);
     end
     else
       RegApoliceSerie := RegApolice;
     if RegApoliceSerie.CodApolice > '' then begin
       RpaS.Temp11.MacIniSeguro := mes_int(RegApoliceSerie.MaIniEvo);
       RpaS.Temp11.LiberaJurNaInd := RegApoliceSerie.LiberaJurNaInd;
     end;

     if RegApoliceDFI.CodApolice > '' then begin
       RpaS.Temp11.NaoReajustaDFI := RegApoliceDFI.NaoReajustaDFI;
       RpaS.Temp11.CampoVBaseDFI := RegApoliceDFI.CampoVBaseDFI;
     end;

     if CalculaTaxasNoMes then begin
       CalculaTaxapSeries;
     end
     else Rpas.ValRpa.ValtxAdm := 0;

    // if not TemFinancDinamico(MutDsk) and (i=seriecomtaxa) then
     // begin
     //  Rpas.FinRpa.TxAdm := Mutdsk.Financ.TxAdm;
     //  case MutDsk.Financ.TTX of
     //    2 : Rpas.ValRpa.ValTxAdm := Rpas.FinRpa.TxAdm * Rpas.ValRpa.AmaisJ;
     //    3 : Rpas.ValRpa.ValTxAdm := Rpas.FinRpa.TxAdm / 12 * Rpas.ValRpa.SaldoDev;
     //    14: Rpas.ValRpa.ValTxAdm := int(Rpas.FinRpa.TxAdm*100+0.5)/100;
     //  end;
     //end;
    
     // se a s rie estiver com -1 no cadastro, respeitar na evolu  o
     // ou quando a escolha da s rie para cobran a for feita, n o ser  poss vel verificar que
     // o segimv naquela s rie era -1
     if Fin.IndSegImv < 0 then
       RPAS.FinRPA.IndSegImv := Fin.IndSegImv;

     //Inicializa seguro de im vel
     if (not TemFinancDinamico(MutDsk) and (i=seriecomsegimv)) or
        (Fin.IndSegImv>Zero)                        then begin //SCAt 29237
        RpaS.FinRPA.ValAval   := MutDsk.Financ.ValAval;
        RpaS.FinRPA.PA        := MutDsk.Financ.PA;
        if abs(RPAS.FinRPA.ValAval) < Zero then RPAS.FinRPA.ValAval := Mutdsk.Cad.ValComVen;
        if RPAS.Temp11.GrupoApolice > 0 then
          RpaS.FinRPA.IndSegImv := RetornaIndSegImvGrupoApolice(RPAS,RpaS.FinRPA.ValAVal,Contrato.Imovel.RegImv.cep+Contrato.Imovel.RegImv.cep2)
        else if stripstr(RPAS.Temp11.CodApoliceDFI) > '' then begin
          RpaS.FinRPA.IndSegImv := RetornaIndSegImvApolice(RpaS,RpaS.FinRPA.ValAVal,Contrato.Imovel.RegImv.cep+Contrato.Imovel.RegImv.cep2);
        end
        else
          RpaS.FinRPA.IndSegImv := MutDsk.Financ.IndSegImv;
        if Fin.IndSegImv>Zero then begin
          RPAS.FinRPA.IndSegImv := Fin.IndSegImv;
          RPAS.Temp11.NaoReajustaDFI := Fin.NaoReajustaSegDFI;
        end;
     end;
     // Inicializa Seguro
     if RPAS.Temp12.GrupoApoliceMista > 0 then begin
        RPAS.FinRpa.IndSegFin := 0;
        if Assigned(Contrato) then
          if Assigned(Contrato.ApolicesMistas) then
            RPAS.FinRpa.IndSegFin := Contrato.ApolicesMistas.RetornaIndSegFin(RPAS.mac);
     end
     else if RPAS.Temp11.GrupoApolice > 0 then begin
       LeApolice(RPAS.Temp10.CodApolice,RegApolice);
       RpaS.FinRPA.IndSegFin := Fin.IndSegFin;
       RpaS.Temp5.AliquotaDoContrato := RegApolice.ALIQUODOTACONTRATO and (Abs(Mutdsk.Financ.IndSegFin) > zero) and not RPAS.ForcouIndSegFin{111863};
       if not Rpas.Temp5.AliquotaDoContrato then begin
         DtTermino.dia := 0;
         fillchar(DtTermino,sizeof(Tdata),0);
         DeterminaTermino(Rpas,DtTermino,false{Considera Terminos antecipados});
         RpaS.FinRPA.IndSegFin := RetornaIndSegFinGrupoApolice(RpaS,DtTermino);
       end  
       else
         RpaS.FinRPA.IndSegFin := Mutdsk.Financ.IndSegFin;
     end
     else begin
       if StripStr(MutDsk.Cad2.CodApolice) > '' then begin
         LeApolice(MutDsk.Cad2.CodApolice,RegApolice);
         RpaS.FinRPA.IndSegFin := Fin.IndSegFin;
         RpaS.Temp5.AliquotaDoContrato := RegApolice.ALIQUODOTACONTRATO and (Abs(Mutdsk.Financ.IndSegFin) > zero) and not RPAS.ForcouIndSegFin{111863};
         if not RpaS.Temp5.AliquotaDoContrato then begin
           DtTermino.dia := 0;
           fillchar(DtTermino,sizeof(Tdata),0);
           DeterminaTermino(Rpas,DtTermino,false{Considera Terminos antecipados});
           RpaS.FinRPA.IndSegFin := RetornaIndSegFinApolice(RpaS,DtTermino);
           if (abs(RpaS.FinRPA.IndSegFin) < zero) and (Fin.IndSegFin > zero) then // sol. 50262
             RpaS.FinRPA.IndSegFin := Fin.IndSegFin;
         end
         else
           RpaS.FinRPA.IndSegFin := Mutdsk.Financ.IndSegFin;
       end
       else
         RpaS.FinRPA.IndSegfin := Fin.IndSegFin;
       if abs(RpaS.FinRPA.IndSegFin)<=Zero then
         RpaS.FinRPA.IndSegFin := MutDsk.Financ.IndSegFin;
     end;

     if RPAS.Temp8.CalcSegMIPPeloValAval then
       SldParaMip := MutDsk.Financ.ValAVal
     else
       SldParaMip := RPAS.ValRPA.SaldoDev;
     if (RPAS.FinRPA.IndSegFin > Zero) and ( not RPAS.Temp6.SegRecalcSaldo) and
        (Serie[i].Fin.CompoeSaldo or Serie[i].Fin.CompoeEntrada) then
       RPAS.ValRPA.SegFin := int(SldParaMip*RPAS.FinRPA.IndSegFin*100+0.5)/100
     else RPAS.ValRPA.SegFin := 0.0;

     ValAValLimitado := RPAS.FinRPA.ValAval;
     if RegApoliceDFI.CodApolice > '' then
       if abs(RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI) > zero then
         if ValaValLimitado-RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI > zero then
           ValaValLimitado := RegApoliceDFI.VA_MAXIMO_SEGURADO_DFI;

     if (RPAS.FinRPA.IndSegImv > Zero) and (RPAS.FinRPA.ValAval>Zero) then
         RPAS.ValRPA.SegImv := int(ValAValLimitado*RPAS.FinRPA.IndSegImv*100+0.5)/100;

     Serie[i].RPAS.Temp12.TxOriginalCtrIFRS9 := TxOriginalCtrIFRS9;

     Serie[i].evolui;
   end;
end;

function TSerie.CalculaVaEncargo(    Encargo           : real;
                                     DtVencParc        : TData;
                                     DataRef           : TData;
                                     TxPstAcum         : real;
                                     IndJuros          : real;
                                     IndRedPrest       : real;
                                     RARD              : real;
                                     TaxaOportunidade  : real;
                                     InfTxOportunidade : boolean = false) : real;
var
  Razao,
  IndJurosLc,
  VAEnc           : real;
  DtComCarencia,
  DtCarenciaLocal,
  DataRefSerie    : Tdata;
  JurosSimples    : boolean;
begin
  VaEnc   := 0;
  if Abs(Encargo) > Zero then begin
    IndJurosLc := IndJuros;
    if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples and
       (Abs(TaxaOportunidade) > Zero) and
      InfTxOportunidade then IndJurosLc := TaxaOportunidade/100;
    DtComCarencia := DataRef;
    DataRefSerie  := Fin.DataRef;
    if Fin.DtCarenciaDeJuros.dia > 0 then begin
      DtCarenciaLocal := Fin.DtCarenciaDeJuros;
      if not Fin.JurProRata then
        DtCarenciaLocal.Dia := DtVencParc.Dia;
      if Juliano(DtCarenciaLocal) > Juliano(dataref) then
        DtComCarencia := DtCarenciaLocal;
      if juliano(DtCarenciaLocal) > juliano(DataRefSerie) then
        DataRefSerie := DtCarenciaLocal;  //atualizando a calculavaencargo de acordo com a quitlib.pas
    end;

     if (Fin.SistAmort = 7) {SCP} and (not Fin.VPL_Antecipacoes) and
         Fin.JurosSimples and (Fin.TpJuros = 6) and
        (not InfTxOportunidade) then
       VaEnc := CalculaValorAtualEncargoJurosSimples360SCP(Encargo,Fin.TxJuros,{Dataref}DtComCarencia,DataRefSerie{Fin.DataRef},DtVencParc)
     else if (((Fin.SistAmort = 7) {SCP} and 
               (not Fin.VPL_Antecipacoes)) or 
               Contrato.RegCarteira.LiqCalcPorPxN) { sol.051500 } and 
               Fin.JurosSimples                    { Scat 41461 } and
              (not InfTxOportunidade) then begin   { Scat 056115}
       if Fin.PerParcelas > 0 then 
         Razao := RARD/Fin.PerParcelas
       else
         Razao := RARD;
       Razao := Razao * TxPstAcum;
       VaEnc := CalculaValorAtualEncargoJurosSimplesSCP(Encargo,DtVencParc,DtComCarencia,Razao);
     end
     else begin
       if (Fin.SistAmort = 7) {SCP} and Fin.VPL_Antecipacoes then
         JurosSimples := false
       else
         JurosSimples := Fin.JurosSimples;
       vaenc := CalculaEncargoAtualizado(Encargo,DtVencParc,
                                         DtComCarencia,IndJurosLc,
                                         Fin.JurProRata or
                                         ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                         Fin.IncluiFracaoDoMes,
                                         JurosSimples,
                                        (Fin.TpJuros = 6),
                                         DiaVencOrig,
                                        (Fin.TpJuros = 7));
     end;
  end;
  Result := VaEnc;
end;
                                 
function TSerie.CalculaVaEncargo(    SerieReneg : TSerieReneg;
                                     Reg        : TValoresPorMac;
                                     DataRef    : TData;
                                 var Encargo    : real;
                                     InfTxOportunidade : boolean = false) : real;
var
  ParcOrig : TParcela;
  DtVenc   : TData;
  ValorAtu,
  ValorPagoAntecipadoAtu : real;
begin
  Encargo := 0;
  Result  := 0;
  ParcOrig:= Reg.ParcelaDoMes;
  if assigned(ParcOrig) then begin
    Int_Mes(ParcOrig.Mac,DtVenc.MesAno);
    DtVenc.dia := ParcOrig.diavenc;

    ValorAtu := (ParcOrig as TParcelaSerie).Valor;
    ValorPagoAntecipadoAtu := (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
    Encargo := ValorAtu * SerieReneg.TxPst *
              (1-Reg.IndRedPrest) -
              (ValorPagoAntecipadoAtu * SerieReneg.TxPst);
    AjustaMoeda2(mes_int(Fin.DataRef.MesAno),Mes_int(DataRef.MesAno),Encargo);

    if Encargo < zero then Encargo := 0;
    Encargo := Arredonda(encargo);
    Result  := CalculaVaEncargo(Encargo,DtVenc,DataRef,SerieReneg.TxPst,
                                Reg.IndJuros,Reg.IndRedPrest,Reg.RARD,
                                SerieReneg.TaxaOportunidade,
                                InfTxOportunidade);
  end;
end;

procedure TSerie.MontaParcelasSacre( Parametros : TParametrosQuitacaoEvo;
                                     DtTermino : Tdata;
                                     DtInicio : Tdata;
                                     Saldo,
                                     AmaisjIni : real;
                                     Npc : integer;
                                     SerieReneg : TSerieReneg);
var
  J,
  Encargo : real;
  IndJurosAoMes : real;
  Mac : integer;
  Amortizacao : real;
  ParcOrig : TParcela;
  DtVenc : TData;
  enc, vaenc,
  pagoantec, vapagoantec : real;
  DtComCarencia : TData;
  ParcelaReneg : TParcelaReneg;
  MReaj : integer;
  RegRef : TValoresPorMac;
begin

  RegRef := ObtemValoresPorMac(mes_int(Parametros.dataRef.MesAno));

  if SerieReneg.dados.MReaj > 0 then
    MReaj := SerieReneg.dados.MReaj
  else
    MReaj := SerieReneg.Dados.DataRef.mes; // igual a evolu  o

  J := CalculaJuros(SerieReneg.Dados.TpJuros,SerieReneg.Dados.TxJuros,SerieReneg.Dados.PerParcelas);
  IndJurosAoMes := pot(1 + J/100, 1.0 / SerieReneg.Dados.PerParcelas ) -1 ;

  if DtInicio.Mes = MReaj then
    Encargo := int( CalcAmaisJ( SACR,SerieReneg.Dados.Prazo-NPC+1,Saldo,IndJurosaoMes)*100)/100
  else
    Encargo := AmaisjIni;

  Mac := mes_int(DtInicio.MesAno);
  while (Saldo > zero) and (npc <= SerieReneg.Dados.Prazo) do begin
    int_mes(Mac,DtVenc.MesAno);
    DtVenc.Dia := DtInicio.dia;
    if SerieReneg.Dados.DiaVenc > 0 then
      DtVenc.dia := SerieReneg.Dados.DiaVenc;
    if DtVenc.Dia > Dias_Mes(Mac) then
      DtVenc.Dia := Dias_Mes(mac);

    if Npc = SerieReneg.Dados.prazo then // prever a ultima
      Encargo := Saldo + (Saldo * indJurosAoMes)
    else if (DtVenc.Mes = MReaj) or (Mac = mes_int(DtInicio.MesAno)) then begin
      Encargo := int( CalcAmaisJ( SACR,SerieReneg.Dados.Prazo-NPC+1,Saldo,IndJurosaoMes)*100)/100;
    end;
    Amortizacao := Encargo - int(Saldo * IndJurosAoMes*100+0.5)/100;

    ParcOrig := Parcelas.ObtemParcelaPorMac(Mac);
    if Assigned(ParcOrig) and
       not (ParcOrig as TParcelaSerie).EstapagaReal and
       ((DtTermino.dia=0) or (Juliano(DtVenc) <= Juliano(DtTermino))) then begin
      enc := Encargo - (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
      pagoantec := (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
      DtComCarencia := Parametros.DataRef;
      if Fin.DtCarenciaDeJuros.dia > 0 then
        if Juliano(Fin.DtCarenciaDeJuros) > Juliano(Parametros.dataref) then
          DtComCarencia := Fin.DtCarenciaDeJuros;
      // Calcula o valor atual dos meses restantes
      vaenc := CalculaEncargoAtualizado(Enc,
                                        DtVenc,
                                        DtComCarencia,
                                        RegRef.IndJuros,
                                        Fin.JurProRata or
                                        ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                        Fin.IncluiFracaoDoMes,
                                        Fin.JurosSimples,
                                        Fin.TpJuros = 6,
                                        DiaVencOrig,
                                        Fin.TpJuros = 7);
      vapagoantec := CalculaEncargoAtualizado(pagoantec,
                                              DtVenc,
                                              DtComCarencia,
                                              RegRef.IndJuros,
                                              Fin.JurProRata or
                                              ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                              Fin.IncluiFracaoDoMes,
                                              Fin.JurosSimples,
                                              Fin.TpJuros = 6,
                                              DiaVencOrig,
                                              Fin.TpJuros = 7);

      if (vaenc > zero) and
         (not Parametros.IgnoraVencNoMesRef or (Mac > Mes_int(Parametros.DataRef.MesAno))) then begin
        ParcelaReneg := SerieReneg.Parcelas.add as TParcelaReneg;
        ParcelaReneg.seq       := TParcelaSerie(Parcorig).Seq;
        ParcelaReneg.mac       := Mac;
        ParcelaReneg.encargo   := enc;
        ParcelaReneg.vaEncargo := vaenc;
        ParcelaReneg.AmaisJ    := Amortizacao;
        ParcelaReneg.ValorpagoAntecipado := pagoantec;
        ParcelaReneg.vaValorpagoAntecipado := vaPagoAntec;
        LePagamentosAntecipadosReneg(Contrato.Mutdsk.Cad.Ctr,
                                     Fin.CodSerie,
                                     ParcOrig as TParcelaSerie,1,ParcelaReneg,
                                     Parametros.DataRef,RegRef.IndJuros,
                                     Fin.JurProRata,
                                     Fin.IncluiFracaoDoMes);
        ParcelaReneg.venc      := DtVenc;
        ParcelaReneg.DiaVencOrig:= DiaVencOrig;
        ParcelaReneg.mora      := 0;
        ParcelaReneg.corr      := 0;
        ParcelaReneg.multa     := 0;
        ParcelaReneg.Seleciona := true;
        ParcelaReneg.ForcaCobJurosProrataNaQuitSerie := ScciConf.ForcaCobJurosProrataNaQuitSerie;
      end;
    end;
    if not Assigned(ParcOrig) or ((ParcOrig as TParcelaSerie).TipoPg <> 80) then
      Saldo := Saldo - Amortizacao;
    Inc(Npc);
    Inc(Mac);
  end;
end;

procedure TSerie.MontaParcelasComResiduo(    Parametros : TParametrosQuitacaoEvo;
                                         Var SerieAux : TpSeries;
                                             SerieReneg : TSerieReneg;
                                             DtTermino : Tdata);
var
  Antecipadas : integer;
  Dt1a : Tdata;
  j : integer;
  ParcOrig : TParcela;
  ArrParcAuxPtr : ^TpArrayDeParcelas;
  ArrParcPtr : ^TpArrayDeParcelas;
  enc,
  vaenc,
  pagoantec,
  vapagoantec : real;
  DtComCarencia : TData;
  ParcelaReneg : TParcelaReneg;
  RegRef : TValoresPorMac;
begin
  RegRef := ObtemValoresPorMac(mes_int(Parametros.DataRef.MesAno));
  
  GetMem(ArrParcAuxPtr,sizeof(TpArrayDeParcelas));
  GetMem(ArrParcPtr,sizeof(TpArrayDeParcelas));
  try
    MontaParcelas(Contrato.MutDsk,SerieAux,ArrParcPtr^);
    Antecipadas := 0;
    dt1a.dia := 0;
    fillchar(dt1a,sizeof(Tdata),0);
    for j := 1 to ArrParcPtr^[0].chave.tam do begin
      ParcOrig := Parcelas.ObtemParcelaPorMac(mes_int(ArrParcPtr^[j].DtVenc.MesAno));
      if Assigned(ParcOrig) then begin
        if ((ParcOrig as TParcelaSerie).TipoPg = 80) then
          inc(Antecipadas)
        else if (Dt1a.dia = 0) or (Juliano(ArrParcPtr^[j].DtVenc) < Juliano(Dt1a)) then
          Dt1a := ArrParcPtr^[j].DtVenc;
      end;
    end;

    SerieAux.prazo := SerieAux.prazo - Antecipadas;
    if dt1a.dia > 0 then
      SerieAux.DtInicio := dt1a;
    if SerieAux.prazo > 0 then begin
      MontaParcelas(Contrato.MutDsk,SerieAux,ArrParcAuxPtr^);
      for j := 1 to ArrParcPtr^[0].chave.tam do
        ArrParcPtr^[j].Encargo := ArrParcAuxptr^[1].Encargo;

      for j := 1 to ArrParcPtr^[0].chave.tam do begin
        ParcOrig := Parcelas.ObtemParcelaPorMac(mes_int(ArrParcPtr^[j].DtVenc.MesAno));
        if Assigned(ParcOrig) and not (ParcOrig as TParcelaSerie).EstapagaReal and
           ((DtTermino.dia=0) or
            (Juliano(ArrParcPtr^[j].DtVenc) <= Juliano(DtTermino))) then begin
          enc := ArrParcPtr^[j].Encargo -
                 (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
          pagoantec := (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
          DtComCarencia := Parametros.DataRef;
          if Fin.DtCarenciaDeJuros.dia > 0 then
            if Juliano(Fin.DtCarenciaDeJuros) > Juliano(Parametros.dataref) then
              DtComCarencia := Fin.DtCarenciaDeJuros;
          // Calcula o valor atual dos meses restantes
          vaenc := CalculaEncargoAtualizado(Enc,
                                            ArrParcPtr^[j].DtVenc,
                                            DtComCarencia,
                                            RegRef.IndJuros,
                                            Fin.JurProRata or
                                            ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                            Fin.IncluiFracaoDoMes,
                                            Fin.JurosSimples,
                                            Fin.TpJuros = 6,
                                            DiaVencOrig,
                                            Fin.TpJuros = 7);

          vapagoantec := CalculaEncargoAtualizado(pagoantec,
                                                  ArrParcPtr^[j].DtVenc,
                                                  DtComCarencia,
                                                  RegRef.IndJuros,
                                                  Fin.JurProRata or
                                                  ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                                  Fin.IncluiFracaoDoMes,
                                                  Fin.JurosSimples,
                                                  Fin.TpJuros = 6,
                                                  DiaVencOrig,
                                                  Fin.TPJuros = 7);
          if (vaenc > zero) and
             (not Parametros.IgnoraVencNoMesRef or
             (Mes_int(ArrParcPtr^[j].DtVenc.MesAno) > Mes_int(Parametros.DataRef.MesAno))) then begin
            ParcelaReneg := SerieReneg.Parcelas.add as TParcelaReneg;
            ParcelaReneg.seq       := TParcelaSerie(Parcorig).Seq; //NPCIni + j - 1;
            ParcelaReneg.mac       := mes_int(ArrParcPtr^[j].DtVenc.MesAno);
            ParcelaReneg.encargo   := enc;
            ParcelaReneg.vaEncargo := vaenc;
            ParcelaReneg.AmaisJ    := RegRef.AmaisJ;
            ParcelaReneg.ValorpagoAntecipado := pagoantec;
            ParcelaReneg.vaValorpagoAntecipado := vaPagoAntec;
            LePagamentosAntecipadosReneg(Contrato.Mutdsk.Cad.Ctr,
                                         Fin.CodSerie,
                                         ParcOrig as TParcelaSerie,1,ParcelaReneg,
                                         Parametros.DataRef,RegRef.IndJuros,
                                         Fin.JurProRata,
                                         Fin.IncluiFracaoDoMes);
            ParcelaReneg.venc      := ArrParcPtr^[j].DtVenc;
            ParcelaReneg.DiaVencOrig:= DiaVencOrig;
            ParcelaReneg.mora      := 0;
            ParcelaReneg.corr      := 0;
            ParcelaReneg.multa     := 0;
            ParcelaReneg.Seleciona := true;
            ParcelaReneg.ForcaCobJurosProrataNaQuitSerie := ScciConf.ForcaCobJurosProrataNaQuitSerie;
          end;
        end;
      end;
    end;
  finally
    FreeMem(ArrParcAuxPtr);
    FreeMem(ArrParcPtr);
  end;
end;

procedure TSerie.CalculaQuitacaoComResiduoFinanciado(Parametros : TParametrosQuitacaoEvo;
                                                     SerieReneg : TSerieReneg);
var
  TrataComoPxN : boolean;
  ConsideraSaldoDevNoVencto : boolean;
  RegRef : TValoresPorMac;
  DtTermino : TData;
  SerieAux : TpSeries;
  AmaisjIni : real;
  NPCini : integer;
  DtVenc : Tdata;
  DiaVencAux : integer;
  ValorPorMac : TValoresPorMac;
  DtAux : TData;
  Corr,
  Mora,
  JurosContr : real;
  UF : str3;
  CodMun : smallint;
begin
  Mora := 0;
  JurosContr := 0;
  UF := '';
  CodMun := 0;
  TrataComoPxN := ((Fin.SistAmort = 7) {SCP} or
                    Contrato.RegCarteira.LiqCalcPorPxN)  and
                   (fin.perreaj = 12) and
                   (Fin.PerParcelas = 1) and
                    Fin.JurosSimples;

  ConsideraSaldoDevNoVencto := Fin.IgnoraDiaVencNaQuitacaoEAntec and
                               (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]);

  RegRef := ObtemValoresPorMac(mes_int(Parametros.DataRef.MesAno));
  if (Fin.RecalculaPrestacao or (Fin.SistAmort = 6{Sacre})) and
     (not TrataComoPxN) and
     (not Fin.CobraJurosNaCarencia) and
     RegRef.CtrAtivo and
     (not ConsideraSaldoDevNoVencto) and
     (not Parametros.RespeitaNaoCompoeDividaVinc or
      not Fin.NaoCompoeDividaVinc) then begin

    if RegRef.status > 0 then begin
      int_mes(RegRef.MacStatus,DtTermino.MesAno);
      if RegRef.dialiq > 0 then
        DtTermino.dia := RegRef.dialiq
      else
        DtTermino.dia := RegRef.diavenc;
    end
    else
      fillchar(DtTermino,sizeof(Tdata),0);

    SerieAux := Fin;

    SerieAux.Prazo := RegRef.Prazo - RegRef.NPC;
    AmaisjIni := RegRef.Amaisj;
    NPCini := RegRef.NPC;
    int_mes(RegRef.Mac,DtVenc.MesAno);
    DtVenc.dia  := RegRef.diaVenc;
    DiaVencAux  := DtVenc.Dia;

    if Parametros.DataRef.dia < DtVenc.dia then begin
      ValorPorMac := ObtemValoresPorMac(RegRef.Mac-1);
      if Assigned(ValorPorMac) then begin
        SerieAux.Prazo := RegRef.Prazo - ValorPorMac.NPC;
        AmaisjIni := ValorPorMac.Amaisj;
        DiaVencAux:= ValorPorMAC.DiaVenc;
      end;
    end
    else
      Inc(NPCIni);

    SerieAux.DtInicio := DtVenc;
    SerieAux.DataRef  := Parametros.DataRef;
    if Parametros.DataRef.dia < DtVenc.dia then begin
      SerieAux.Valor := RegRef.SalDevAnt;
      decMa(dtVenc.MesANo);
      if DiaVencAux > 0 then
        DtVenc.Dia := DiaVencAux;
    end
    else begin
      SerieAux.Valor := RegRef.SaldoDev;
      incMA(SerieAux.DtInicio.MesAno);
      if SerieAux.DtInicio.dia > Dias_Mes(mes_int(SerieAux.DtInicio.MesAno)) then
        SerieAux.DtInicio.dia := Dias_Mes(mes_int(SerieAux.DtInicio.MesAno));
    end;

    if RegRef.NPC > 0 then begin
      int_mes((((mes_int(SerieAux.DtInicio.mesano) -
                 mes_int(fin.DtInicio.MesANo)-1) div
                fin.PerParcelas) *
               fin.PerParcelas +
               mes_int(fin.DtInicio.MesANo)+
               fin.PerParcelas),Serieaux.DtInicio.MesAno);
      SerieAux.DtInicio.dia := RegRef.diaVenc;
      if SerieAux.DtInicio.dia > Dias_Mes(mes_int(SerieAux.DtInicio.MesAno)) then
        SerieAux.DtInicio.dia := Dias_Mes(mes_int(SerieAux.DtInicio.MesAno));
    end
    else
      SerieAux.DtInicio := Fin.DtInicio;

    DtAux := Parametros.DataRef;
    if not SerieAux.CorrProRata then
      DtAux.dia := DtVenc.dia;

    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    corr  := CorrecaoJMJCChaves( Contrato.MutDsk,
                                 UF,CodMun,
                                 SerieAux.Valor,
                                 DtVenc,
                                 DtAux,
                                 RegRef.IndJuros,
                                 0,
                                 Mora,
                                 JurosContr,
                                 RegRef.CodTabGPreChvCorr,
                                 RegRef.CodTabGCorr,
                                 false,
                                 Contrato.RegCarteira.NaoCobraJurosContr,
                                 Fin.DefReajPreChv,
                                 Fin.DefReaj);

    AjustaMoeda2 (mes_int(DtVenc.mesano), mes_int(Parametros.DataRef.mesano), SerieAux.Valor);
    SerieAux.Valor := SerieAux.Valor + Corr;
    JurosContr := CalcJurosProRata(SerieAux.valor,
                                   RegRef.IndJuros,
                                   DtVenc,
                                   Parametros.DataRef,
                                   Fin.JurosSimples,
                                   Fin.TpJuros = 6 {ProRataJurosDiasCorridos} );

    SerieAux.valor := SerieAux.Valor + JurosContr;

    SerieReneg.Dados := Fin;
    SerieReneg.Taxa  := RegRef.IndJuros * 100;

    if Parametros.Tx3516Default > zero then
      SerieReneg.TaxaOportunidade  := Parametros.Tx3516Default
    else
      SerieReneg.TaxaOportunidade  := Fin.TaxaOportunidade;

    if SerieReneg.Taxaoportunidade <= zero then
      SerieReneg.TaxaOportunidade := SerieReneg.Taxa;

    SerieReneg.TxPst := 1.0;
    SerieReneg.PrzReman := RegRef.Prazo - RegRef.NPC;

    if SerieReneg.Dados.SistAmort = 6 then
      MontaParcelasSacre(Parametros,
                         DtTermino, SerieAux.DtInicio, SerieAux.Valor,
                         AmaisjIni, NPCIni,
                         SerieReneg)
    else
      MontaParcelasComResiduo(Parametros,SerieAux,SerieReneg,DtTermino);

  end;
end;

procedure TSerie.CalculaQuitacao(Parametros : TParametrosQuitacaoEvo;
                                 SerieReneg : TSerieReneg);
var
  Reg : TValoresPorMac;
  i : integer;
  DtVencAjustado,
  DtVenc : Tdata;
  DtIsenMora : Tdata;
  UltimoMac : integer;
  Ndias : integer;
  MA : TMes_Ano;
  CalculoAtrasoParametros : TCalculoAtrasoParametros;
  defas,
  NumPrest : integer;
  ValoresParaDataRef : TValoresPorMac;
  NaoDescaptalizaParcelaDoMesNaQuitacao : Boolean;
  TrataComoPxN : boolean;
  DtIsencao : Tdata;
  ParcOrig : TParcela;
  IndJuros : real;
  DtEntHab,
  DtComCarencia : TData;
  enc,
  vaenc,
  PagoAntec : real;
  ValorPagoAntecipadoAtu : real;
  DtCarenciaLocal : TData;
  vaPagoAntec : real;
  ParcelaReneg : TParcelaReneg;
begin
  DtIsencao.Dia := 0; DtIsencao.Mes := 0; DtIsencao.ano := 0;
  DtIsenMora.Dia := 0; DtIsenMora.Mes := 0; DtIsenMora.ano := 0;
  SerieReneg.Dados := Fin;
  
  if Parametros.Tx3516Default > zero then
    SerieReneg.TaxaOportunidade  := Parametros.Tx3516Default
  else
    SerieReneg.TaxaOportunidade  := Fin.TaxaOportunidade;
  SerieReneg.TxPst := 1.0;
  SerieReneg.TxSdMesAcum := 1.0;
  SerieReneg.TxSdComplementar := 1.0;
  SerieReneg.MacUltReaj := 0;
  SerieReneg.JurosSimples := Fin.JurosSimples;
  SerieReneg.CalcAntecComoDescComercial := ScciConf.CalcAntecComoDescComercial;

  i := mes_int(Fin.DataRef.MesAno);
  UltimoMac := Mes_int(Parametros.DataRef.MesAno);
  if i > UltimoMac then
    i := UltimoMac;
  // Evoluir o contrato calculando todas as parcelas
  while (i < UltimoMac) and (i < FValoresPorMacList.count) do begin

    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);

      if i = mes_int(Fin.DataRef.MesAno) then begin
        SerieReneg.Taxa := Reg.IndJuros * 100;
        if SerieReneg.Taxaoportunidade <= zero then
          SerieReneg.TaxaOportunidade := SerieReneg.Taxa;
      end;
      
      Int_Mes(Reg.Mac,DtVenc.MesAno);
      DtVenc.dia := Reg.DtInFin.dia;

      DtVencAjustado := DtVenc;
      DtVencAjustado.Dia := Reg.DiaVenc;

      if juliano(DtVenc) >= juliano(Fin.DataRefReaj) then begin
        if Reg.TxSd <> 1 then
          SerieReneg.TxSdComplementar := 1.0
        else
          SerieReneg.TxSdComplementar := SerieReneg.TxSdComplementar * Reg.TxSDMes;

        if Reg.IndSaldoAcum <> 1.0 then
          SerieReneg.TxSdMesAcum := Reg.IndSaldoAcum
        else
          SerieReneg.TxSdMesAcum := SerieReneg.TxSdMesAcum * Reg.TxSDMes;
      end
      else begin
        SerieReneg.TxSdMesAcum := 1.0;
        SerieReneg.TxSdComplementar := 1.0;
      end;

      if SerieReneg.Dados.IgnoraDiaVencNaQuitacaoEAntec and
        (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]) then
        SerieReneg.TxPst := Reg.IndSaldoAcum
      else
        GuardaTxPstDataRef(Reg,Parametros.DataRef,DtVenc,SerieReneg);
        
      // MacUltReaj e TxSdComplemetar s o usados para s ries
      // com SISTAMORT=7 e JURSCPANUAIS=true
      int_mes(Reg.Mac,MA);
      if byte(Reg.MReaj) = MA.Mes then
        SerieReneg.MacUltReaj := Reg.Mac;
    end;
    inc(i);
  end;

  if assigned(FValoresPorMacList[i]) then begin

    Reg := TValoresPorMac(FValoresPorMacList[i]);

    if (byte(Reg.MReaj) = MA.Mes) or (SerieReneg.MacUltReaj = 0) then
      SerieReneg.MacUltReaj := Reg.Mac;

    // Guardar o  ndice de saldo acumulado de todas as s ries se a data ref
    //   depois do vencimento. ( A rotina GuardaTx... testa isto);
    Int_Mes(Reg.Mac,DtVenc.MesAno);
    DtVenc.dia := Reg.DtInFin.dia;
    
// TODO
(*
IMPLEMENTAR JURCP no valorespormac
    if abs(Reg.JurCP) > Zero then begin // se for juros progressivos, tem que usar o indjuros do m s - 65775
      SerieReneg.Taxa := Reg.IndJuros * 100;
      if LstTaxaOportunidadePorTaxa.indexof(inttostr(fin.codserie)) >= 0 then
        SerieReneg.TaxaOportunidade := SerieReneg.Taxa;
    end;*)

    DtVencAjustado := DtVenc;
    DtVencAjustado.Dia := Reg.DiaVenc;
    if DataEMaiorOuIgual(Parametros.DataRef,DtVencAjustado) then begin
      if juliano(DtVenc) >= juliano(Fin.DataRefReaj) then begin
        if Reg.TxSd <> 1 then
          SerieReneg.TxSdComplementar := 1.0
        else
          SerieReneg.TxSdComplementar := SerieReneg.TxSdComplementar * Reg.TxSDMes;

        if Reg.IndSaldoAcum <> 1.0 then
          SerieReneg.TxSdMesAcum := Reg.IndSaldoAcum
        else
          SerieReneg.TxSdMesAcum := SerieReneg.TxSdMesAcum * Reg.TxSDMes;
      end
      else begin
        SerieReneg.TxSdMesAcum      := 1.0;
        SerieReneg.TxSdComplementar := 1.0;
      end;
    end
    else begin
      DecMA(DtVencAjustado.MesAno);
      DtVencAjustado.Dia := Dia_Venc(Mes_Int(DtVencAjustado.MesAno),
                                     Reg.DiaVencOrig);
    end;

    if SerieReneg.Dados.IgnoraDiaVencNaQuitacaoEAntec and
       (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]) then begin
      SerieReneg.TxPst := Reg.IndSaldoAcum;
      SerieReneg.DtVencRef.MesAno := Parametros.DataRef.MesAno;
      SerieReneg.DtVencRef.Dia    := Reg.DiaVenc;
    end
    else
      GuardaTxPstDataRef(Reg,Parametros.DataRef,DtVenc,SerieReneg);
      
    if Fin.CorrProRata and (not DatasSaoIguais(DtVencAjustado,Parametros.DataRef)) then begin
      defas    := Fin.defreaj;
      DtEntHab := Reg.DtEntregaChaves; // SCAt 29363
      if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then
        DtEntHab := Reg.DtHabit;
      if not ((Juliano(DtEntHab) > 0) and
               DataEMaior(DtEntHab,Parametros.DataRef) and  // SCAt 21613
               DataEMaior(DtVencAjustado,DtEntHab)) then
        if Fin.codreajprechaves > 0 then
          Defas := Fin.defreajprechv;
      SerieReneg.TxSdMesAcum := SerieReneg.TxSdMesAcum *
                                detIndProRata(Reg.CodTabelaGenerica,
                                Defas,DtVencAjustado,Parametros.DataRef,1.0);
    end;

    SerieReneg.PrzReman := Fin.Prazo - Reg.NPC;
    if (fin.SistAmort=7) and
       fin.JURSCPANUAIS then begin
      SerieReneg.ParcelaPxN := Arredonda(Reg.Amaisj * SerieReneg.TxSdComplementar);
      if Fin.CorrProRata and (not DatasSaoIguais(DtVencAjustado,Parametros.DataRef)) then
        SerieReneg.ParcelaPxN := SerieReneg.ParcelaPxN * detIndProRata(Reg.CodTabelaGenerica,
                                                                       Fin.defreaj,DtVencAjustado,Parametros.DataRef,1.0);
      NDias := Juliano(Parametros.DataRef)-Juliano(DtVencAjustado);
      SerieReneg.ParcelaPxN := Arredonda(SerieReneg.ParcelaPxN * power(1+Reg.IndJuros,Reg.MAC-SerieReneg.MacUltReaj+ndias/30));
    end
    else if ((fin.SistAmort=0) and
              fin.EvoluiUsuEmPxN) or // sol. 56550
            (((((Fin.SistAmort = 7) {SCP} and
                not Fin.VPL_Antecipacoes) or
               Contrato.RegCarteira.LiqCalcPorPxN)  and
              (fin.perreaj = 12) and
              (Fin.PerParcelas = 1) and
               Fin.JurosSimples) and
               (not Fin.CmProRataMesAnt)) then begin
           SerieReneg.ParcelaPxN := Reg.Amaisj;
           if (Reg.MAUA < Reg.MAC) and
              (Reg.MAUA =
               Mes_Int(Reg.DtAssin.MesAno)) and
               (fin.perreaj = 12) then
             SerieReneg.ParcelaPxN := Arredonda(SerieReneg.ParcelaPxN * SerieReneg.TxSdMesAcum);
         end;

    NumPrest := 0;


    if juliano(Fin.DataRef) <= juliano(Parametros.DataRef) then begin // na rotina antiga, ignorava s ries e hist ricos futuros, ent o eu preciso ignorar as s ries futuras tb
      ValoresParaDataRef := ObtemValoresPorMac(mes_int(Parametros.DataRef.MesAno));
      SerieReneg.SaldoParaQuitacao := CalculaSaldoParaQuitacao(Parametros.DataRef,Parametros.ModuloChamador);
    end
    else
      ValoresParaDataRef := nil;

    // TODO
    SerieReneg.PrejuliqSeries := 0;
    SerieReneg.DescontoOportunidade := 0;
    SerieReneg.TotPagoAntecipadoSeries := 0;


    if not Parametros.SomenteSaldoDeSerie and (juliano(Fin.DataRef) <= juliano(Parametros.DataRef)) then begin
      CalculoAtrasoParametros := TCalculoAtrasoParametros.create;
      try
        CalculoAtrasoParametros.TipoExec := TipoExec_Atraso;

        (* O C lculo das parcelas vincendas necessita que a evolu  o tenha sido feita
           at  o t rmino do contrato. No caso do contrato estar evolu do apenas at 
           a data de refer ncia, os valores das parcelas estar  inconsistente,
           valendo apenas o saldo total. Isso   uma otimiza  o para ser poss vel
           calcular o saldo para quita  o sem precisar evoluir al m da data de refer ncia *)

        while (i < FValoresPorMacList.count) and (NumPrest<400) do begin

          inc(NumPrest);
          if assigned(FValoresPorMacList[i]) then begin

            Reg := TValoresPorMac(FValoresPorMacList[i]);

            if not Reg.CtrAtivo then
              Break;

  (* Estou pondo em coment rio essa altera  o efetuada por Mmr relativa   sol. 053340, tarefa 585789, mas essa altera  o poder  ser desfeita!
            // Este teste est  particular para este caso mas dever  ser criada um flag espec fico na s rie
            NaoDescaptalizaParcelaDoMesNaQuitacao := (Fin.SistAmort = 7) and
                                                      Fin.JurosSimples and
                                                      Fin.CmProRataMesAnt;
  ---------------------------------------------------------------------*)
            NaoDescaptalizaParcelaDoMesNaQuitacao := false;

            // Verifique se a parcela existe e est  em aberto
            TrataComoPxN := ((fin.SistAmort=7) and
                             fin.JURSCPANUAIS) or // sol. 64471
                            ((fin.SistAmort=0) and   // sol. 56550
                              fin.EvoluiUsuEmPxN) or //corre  o pela sol. 057002
                            (((((Fin.SistAmort = 7) {SCP} and
                                not Fin.VPL_Antecipacoes) or
                               Contrato.RegCarteira.LiqCalcPorPxN)  and
                              (fin.perreaj = 12) and
                              (Fin.PerParcelas = 1) and
                               Fin.JurosSimples) and
                              (not Fin.CmProRataMesAnt));

            if assigned(Reg.ParcelaDoMes) and
               not Fin.RecalculaPrestacao and
               (Fin.SistAmort <> 6{Sacre}) and
               ((not Reg.ParcelaDoMes.EstaPagaReal) or
                Parametros.IgnoraSeEstaPaga) and
               ((Reg.ParcelaDoMes.TipoPg <> 253) or
                (not Parametros.ConsideraTipoPg253ComoPaga)) and
                Reg.CtrAtivo and
                (not Parametros.RespeitaNaoCompoeDividaVinc or not Fin.NaoCompoeDividaVinc) then begin

              Int_Mes(Reg.ParcelaDoMes.Mac,DtVenc.MesAno);
              DtVenc.dia := Reg.ParcelaDoMes.diavenc;

              // S  considera parcela se n o estiver vencida
              if (Juliano(DtVenc) > Juliano(Parametros.DataRef)) and
                 (not Parametros.IgnoraVencNoMesRef or (Mes_int(DtVenc.MesAno) > Mes_int(Parametros.DataRef.MesAno))) and
                 (juliano(Fin.DataRef) <= juliano(Parametros.DataRef)) and
                ((Fin.CompoeSaldo or Fin.CompoeEntrada) or
                 (not Parametros.MontaSDSeriesQueCompoeSaldo)) then begin
                DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsencao,Contrato.MutDsk.Cad.DiaIsencao);
                if not ParcSerieOk(Contrato.Mutdsk,Reg,DtIsenMora,CalculoAtrasoParametros,false{DesconsideraSeguroSuspenso}) then begin
                  if not Parametros.DesconsideraAtrasoNaCessao or not PrestacaoCedida(Reg) then begin
                    ParcOrig := Reg.ParcelaDoMes;
                    IndJuros := Reg.IndJuros;
                    DtComCarencia := Parametros.DataRef;
                    if NaoDescaptalizaParcelaDoMesNaQuitacao and
                       (mes_int(DtVenc.MesAno) = mes_int(Parametros.DataRef.MesAno)  ) then begin
                      VaEnc := ValoresParaDataRef.AmaisJ;
                      Enc := VaEnc;
                    end
                    else if TrataComoPxN then begin
                      VAEnc := SerieReneg.ParcelaPxN;
                      Enc   := VaEnc;
                    end
                    else begin
                      if SerieReneg.Dados.IgnoraDiaVencNaQuitacaoEAntec and
                         (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]) and
                         (SerieReneg.DtVencRef.Dia > 0) then begin
                        VaEnc := CalculaVaEncargo(SerieReneg,Reg,SerieReneg.DtVencRef,Enc);
                        DtComCarencia := SerieReneg.DtVencRef;
                      end
                      else
                        VaEnc := CalculaVaEncargo(SerieReneg,Reg,Parametros.DataRef,Enc);
                    end;

                    if (CmTabErr = 0) and (SerieReneg.TxPstTabErr > 0) then begin
                      CmTabErr := SerieReneg.TxPstTabErr;
                      CmTabErrData := SerieReneg.TxPstTabErrdata;
                    end;

                    ValorPagoAntecipadoAtu := (ParcOrig as TParcelaSerie).ValorPagoAntecipado;
                    PagoAntec := ValorPagoAntecipadoAtu * SerieReneg.TxPst;
                    AjustaMoeda2(mes_int(Fin.DataRef.MesAno),Mes_int(Parametros.DataRef.MesAno),PagoAntec);

                    if Fin.DtCarenciaDeJuros.dia > 0 then begin
                      DtCarenciaLocal := Fin.DtCarenciaDeJuros;
                      if not Fin.JurProRata then
                        DtCarenciaLocal.Dia := DtVenc.Dia;
                      if Juliano(DtCarenciaLocal) > Juliano(Parametros.dataref) then
                        DtComCarencia := DtCarenciaLocal;
                    end;

                    vaPagoAntec := CalculaEncargoAtualizado(PagoAntec,DtVenc,
                                                            DtComCarencia,IndJuros,
                                                            Fin.JurProRata or
                                                            ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                                            Fin.IncluiFracaoDoMes,
                                                            Fin.JurosSimples,
                                                            Fin.TpJuros = 6,
                                                            DiaVencOrig,
                                                            Fin.TpJuros = 7);
                    if vaenc > 0 then begin
                      ParcelaReneg := SerieReneg.Parcelas.add as TParcelaReneg;
                      ParcelaReneg.seq       := (ParcOrig as TParcelaSerie).Seq;
                      ParcelaReneg.mac       := ParcOrig.Mac;
                      ParcelaReneg.encargo   := enc;
                      ParcelaReneg.AmaisJ    := Reg.AmaisJ;
                      ParcelaReneg.ValorPagoAntecipado := PagoAntec;
                      ParcelaReneg.vaValorPagoAntecipado := vaPagoAntec;
                      ParcelaReneg.vaEncargo  := vaenc;
                      ParcelaReneg.venc       := DtVenc;
                      ParcelaReneg.DiaVencOrig:= DiaVencOrig;
                      LePagamentosAntecipadosReneg(Contrato.Mutdsk.Cad.Ctr,
                                                   Fin.CodSerie,
                                                   ParcOrig as TParcelaSerie,
                                                   SerieReneg.TxPst,
                                                   ParcelaReneg,Parametros.DataRef,
                                                   Indjuros,Fin.JurProRata,
                                                   Fin.IncluiFracaoDoMes);
                      ParcelaReneg.mora      := 0;
                      ParcelaReneg.corr      := 0;
                      ParcelaReneg.multa     := 0;
                      ParcelaReneg.Seleciona := true;
                      ParcelaReneg.ForcaCobJurosProrataNaQuitSerie := ScciConf.ForcaCobJurosProrataNaQuitSerie;
                    end;
                  end;
                end;
              end;
            end;
          end;

          inc(i);

        end;
      finally
        CalculoAtrasoParametros.free;
      end;

      CalculaQuitacaoComResiduoFinanciado(Parametros,SerieReneg);

      if not Parametros.IgnoraVencNoMesRef then
        CalculaResiduoQuitacao(Parametros,SerieReneg);
    end;
  end;
end;

function TSerie.TemParcelaFuturaEmAberto(MacRef : integer) : boolean;
var
  i : integer;
begin
  result := false;
  i := 0;
  while (i < Parcelas.count) and not result do begin
    if (Parcelas[i].Mac >= Macref) and
       not Parcelas[i].EstaPagaReal then
      result := true;
    inc(i);
  end;
end;

function TSerie.CalculaSaldoParaQuitacao(    DataRef : TData;
                                             ModuloChamador : integer) : real;

var
  DtVencOrig,
  DtVenc : Tdata;
  corr,
  Mora,
  JurosContr : real;
  PagoNoMes : real;
  IndC : real;
  IndInvalido : boolean;
  DtIndInvalido : TData;
  Parcela : TParcela;
  MacUltimaPaga : smallint;
  i : integer;
  ValoresPorMac : TValoresPorMac;
  DtVencComCarencia : TData;
  CorrP,
  SaldoPgParcialAntecParaDataRef,
  SaldoPgAntecParaDataRef : real;
  MACCorSaldo  : smallint;
  TempCmTabErr : integer;
  TempCmTabErrData : tdata;
  DtVencJuros,
  DtVencCorr,
  DtAux : TData;
  SetPgtoNormal : set of byte;
  ValoresParaDataRef : TValoresPorMac;
  UF : Str3;
  CodMun : Smallint;
begin
  Mora := 0;
  JurosContr := 0;
  IndInvalido := false; 
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  UF := '';
  CodMun := 0;
  SaldoPgAntecParaDataRef := 0;
  SaldoPgParcialAntecParaDataRef := 0;
  result := 0;
  PagoNoMes := 0;
  DtVenc.MesAno := DataRef.MesAno;
  ValoresParaDataRef := ObtemValoresPorMac(mes_int(DataRef.MesAno));
  if ValoresParaDataRef.DiaVencOrig in [1..31] then
    DtVenc.Dia := ValoresParaDataref.DiaVencOrig
  else DtVenc.dia := ValoresParaDataRef.diaVenc;
  if Juliano(DtVenc) < Juliano(Fin.DataRef) then
    DtVenc := Fin.DataRef;
  DtVencOrig := DtVenc;
  DtVencJuros:= DtVenc;
  if ((ValoresParaDataRef.MacStatus > 0) and
      ((mes_int(DataRef.mesano) > ValoresParaDataRef.MacStatus) or
       ((mes_int(DataRef.mesano) = ValoresParaDataRef.MacStatus) and
        (DataRef.Dia > byte(ValoresParaDataRef.diaLiq)))) or  // terminado n o calcula saldo
     (not TemParcelaFuturaEmAberto(mes_int(DataRef.mesano)) and
      (mes_int(DataRef.mesano) = ValoresParaDataRef.MacStatus))) then // s  cobra se tiver alguma parcela futura para cobrar
    result := 0
  else if Fin.IgnoraDiaVencNaQuitacaoEAntec and
     (ModuloChamador in [cModuloQuit,cModuloAntecSeries])  then begin
    if DataRef.Dia >= DtVenc.Dia then
      result := ValoresParaDataRef.SaldoDev - ValoresParaDataRef.SaldoPgParcialAntec
    else begin
      Parcela := Parcelas.ObtemParcelaPorMac(mes_int(DtVenc.MesAno));
      if Assigned(Parcela) and Parcela.EstaPagaReal then
        result := ValoresParaDataRef.SaldoDev - ValoresParaDataRef.SaldoPgParcialAntec
      else begin
        SaldoPgParcialAntecParaDataRef := SaldoPgParcialAntec(DataRef);
        SaldoPgAntecParaDataRef := SaldoPgDesdeUltimoVenc(DataRef,true);
        result:= ValoresParaDataRef.SalDevAnt-
                 SaldoPgParcialAntecParaDataRef -
                 SaldoPgAntecParaDataRef;
        Result := Arredonda(Result + ValoresParaDataRef.CorrSaldo +
                            ValoresParaDataRef.Juro);
      end;
    end; //do mes entrar  no c lculo pelo valor presente e o Saldo n o pode estar amortizado
  end
  else begin
    if (DataRef.dia < DtVenc.dia) then begin
      Parcela := Parcelas.ObtemParcelaPorMac(mes_int(DtVenc.MesAno));
      SaldoPgParcialAntecParaDataRef := SaldoPgParcialAntec(DataRef);
      SaldoPgAntecParaDataRef := SaldoPgDesdeUltimoVenc(DataRef,true);
      result:= ValoresParaDataRef.SalDevAnt;//ValoresParaDataRef.SaldoPgParcialAntecAnt;
      if Assigned(Parcela) and Parcela.EstaPagaReal and
        (not (Parcela.TipoPg in PgtoComRedSdDev)) then begin
        PagoNoMes := ValoresParaDataRef.Amaisj;
        PagoNoMes := CalculaEncargoAtualizado(PagoNoMes,DtVenc,
                                              DataRef,ValoresParaDataRef.IndJuros,
                                              Fin.JurProRata or
                                              ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                              Fin.IncluiFracaoDoMes,
                                              fin.JurosSimples,
                                              Fin.TpJuros = 6,
                                              DiaVencOrig,
                                              Fin.TPJuros = 7);
        TempCmTabErr := CmTabErr;
        TempCmTabErrData := CmTabErrData;
        try
          IndC := detinddataadata(ValoresParaDataRef.CodTabelaGenerica,Fin.DefReaj,DataRef,DtVenc,1.0,
                                  Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                                  Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,false);
        finally
          CmTabErr := TempCmTabErr;
          CmTabErrData := TempCmTabErrData;
        end;
        if abs(IndC) > 0 then
          PagoNoMes := Arredonda(PagoNoMes / (IndC));  //acho que t  errado para ctrs sem/anuais
//        ParcPagaDeMARef := PagoNoMes; N o sei ainda para que preciso disso
      end;
      decMa(dtVenc.MesANo);
      if DiaVencOrig > 0 then
        DtVenc.Dia := DiaVencOrig
      else if DtVenc.Dia <> Fin.DtInicio.Dia then begin
        ValoresPorMac := ObtemValoresPorMac(Mes_Int(DtVenc.MesAno));
        if assigned(ValoresPorMAC) then
           DtVenc.Dia := ValoresPorMAC.DiaVenc
        else
          DtVenc.Dia := Fin.DtInicio.Dia;
      end;
      DtVencJuros:= DtVenc;
      if DataEMenor(DtVencJuros,Fin.DataRef) then
        DtVencJuros := DtVencJuros;
      DtVenc.Dia := Dia_Venc(Mes_Int(DtVenc.MesAno),DtVenc.Dia);
      if DataEMenor(DtVenc,Fin.DataRef) then
        DtVenc := Fin.Dataref;
    end
    else begin
      result := ValoresParaDataRef.SaldoDev - ValoresParaDataRef.SaldoPgParcialAntec;
    end;
    if (Fin.PerReaj = 0) {or (not Fin.CorrProRata)} then Corr := 0 // sol. 37892 para ficar compat vel com a rotina ObtemValorParcelaAntecipadaNoMes
    else begin
      DtVencCorr := DtVenc;
      DtAux      := DataRef;
      if not Fin.CorrProRata then DtAux.dia := DtVenc.dia;
      if (ValoresParaDataRef.PerSalDev >= 6) and (not Fin.CobraResiduo) then begin
        if (ValoresParaDataRef.MAUASD < Mes_Int(DataRef.MesAno)) and
           DataEMaiorOuIgual(DataRef,DtVencOrig) and
          (not Fin.CmProRataMesAnt) then begin
          Corr := ValoresParaDataRef.CorrSaldoMesAcum;
          Result:= Result + Corr;
        end
        else begin
          if ValoresParaDataRef.MAUASD > 0 then
            MACCorSaldo := ValoresParaDataRef.MAUASD
          else
            MACCorSaldo := ValoresParaDataRef.MAUA;
          if MACCorSaldo = Mes_Int(DataRef.MesAno) then begin
            if DataRef.Dia < byte(ValoresParaDataRef.DiaVenc) then
              MACCorSaldo := MACCorSaldo - ValoresParaDataRef.PerSalDev
          end
          else if (MACCorSaldo = 0) and
                 ((Mes_Int(DataRef.MesAno)-ValoresParaDataRef.PerSalDev) <=
                  Mes_Int(Fin.DataRef.MesAno)) then
                 MACCorSaldo := Mes_Int(Fin.DataRef.MesAno);
          if Mes_Int(Fin.DataRef.MesAno) >= MACCorSaldo then
            DtVencCorr := Fin.DataRef
          else if (MACCorSaldo > 0) and (MACCorSaldo <= Mes_Int(DataRef.Mesano)) then begin
            Int_Mes(MACCorSaldo,DtVencCorr.MesAno);
            if ValoresParaDataRef.DiaVencOrig in [1..31] then
              DtVencCorr.Dia := Dia_Venc(MACCorSaldo,ValoresParaDataRef.DiaVencOrig)
            else
              DtVencCorr.Dia := Dia_Venc(MACCorSaldo,ValoresParaDataRef.DiaVenc);
          end;
          if juliano(DtVencCorr) < juliano(DtVenc) then begin
            corr := (detinddataadata(ValoresParaDataRef.CodTabelaGenerica,Fin.DefReaj, DtVencCorr,DtVenc,1.0,
                               Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                               Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,false)-1) * result;
            Result:= Result + Corr;
          end;
        end;
      end;
      Corr := 0;
      if not DatasSaoIguais(DtAux,DtVenc) then begin
        if ((Fin.SistAmort = 7) and (Fin.JurosSimples) and (Fin.TpJuros = 6)) or
            Fin.CmProRataMesAnt  then begin
          corr := (detinddataadata(ValoresParaDataRef.CodTabelaGenerica,Fin.DefReaj, DtVenc,DtAux,1.0,
                  Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                  Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,true)-1) * result;
        end
        else begin
          Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
          Corr  := CorrecaoJMJCChaves(Contrato.MutDsk,UF,CodMun,Result,DtVenc,DtAux,ValoresParaDataRef.IndJuros,
                                      0,Mora,JurosContr,ValoresParaDataref.CodTabGPreChvCorr,
                                      ValoresParaDataRef.CodTabGCorr,false,
                                      Contrato.RegCarteira.NaoCobraJurosContr,
                                      ValoresParaDataRef.DefReajPrechvCorr,
                                      ValoresParadataRef.DefReajCorr);
        end;
      end;
    end;
    AjustaMoeda2 (mes_int(DtVenc.mesano), mes_int(DataRef.mesano), result);
    result := result + Corr;
    JurosContr := 0;
    if Fin.JurProRata and (not DatasSaoIguais(DtVenc,DataRef)) then begin
      if ((fin.DtCarenciaDeJuros.dia > 0) and
          (Juliano(DataRef) > Juliano(fin.DtCarenciaDeJuros))) or
         ((fin.DtCarenciaDeJuros.dia <= 0) and
          ((mes_int(Fin.DtInicio.mesano) - mes_int(fin.Dataref.mesano) <= 1) or  (* se n o tem carencia *)
           ((juliano(DataRef) >= juliano(Fin.DtInicio)) or (* se quit. depois da carencia *)
           (not ScciConf.DispensaJurosProRataNaCarencia)))) then begin (* n o dispensa juros na carencia *)
        if (fin.DtCarenciaDeJuros.dia > 0) and
           (juliano(DtVencJuros) < juliano(fin.DtCarenciaDeJuros)) then
          DtVencComCarencia := Fin.DtCarenciaDeJuros
        else DtVencComCarencia := DtVencJuros;
        // 93736 - bloco copiado da quitlib.CalculaSaldoParaQuitacao para igualar aqui
        if Fin.TpJuros = 6 then  //ajusto o dia de vencimento para o mes/ano
          DtVencComCarencia.Dia := Dia_Venc(Mes_Int(DtVencComCarencia.MesAno),DtVencComCarencia.Dia)
        else
          if DtVencComCarencia.Dia > 30 then
            DtVencComCarencia.Dia := 30;
        if (Fin.SistAmort = 7) and (Fin.JurosSimples) and (Fin.TpJuros = 6) then begin
          ValoresPorMac := ObtemValoresPorMac(Mes_Int(DtVencJuros.MesAno));
          corrp := (detinddataadata(ValoresParaDataRef.CodTabelaGenerica,Fin.DefReaj, DtVenc,DtAux,1.0,
                Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,true)-1) * ValoresPorMac.SaldoPrincipal;

          JurosContr := CalcJurosProRata(ValoresPorMac.SaldoPrincipal+Corrp,
                                         ValoresParaDataRef.IndJuros,
                                         DtVencComCarencia,DataRef,
                                         Fin.JurosSimples,
                                         Fin.TpJuros = 6 {ProRataJurosDiasCorridos});
        end
        else begin
          JurosContr := CalcJurosProRata(result,
                                         ValoresParaDataRef.IndJuros,
                                         DtVencComCarencia,DataRef,
                                         Fin.JurosSimples,
                                         Fin.TpJuros = 6 {ProRataJurosDiasCorridos});
        end;
      end
      else
        JurosContr := 0;
      result := result + JurosContr;
    end;
    if abs(SaldoPgParcialAntecParaDataRef) > zero then begin
      result := arredonda(result - SaldoPgParcialAntecParaDataRef);
    end;
    if abs(SaldoPgAntecParaDataRef) > zero then begin
      result := arredonda(result - SaldoPgAntecParaDataRef);
    end;
  end;
  {
    Sol. 50757 : Estou ativando esse c lculo em todas as situa  es pois no intermedium vi exemplos
    de pagamentos de presta  es futuras por m sem tipo de antecipa  o. Nesta situa  o,
    as parcelas n o eram desconsiderdas do saldo, pois a evolu  o somente considera pagamento
    antecipado a t tulo de amortiza  o.
    Como na evolu  o nunca vejo pagamentos n o antecipados serem considerados, n o vi motivo para
    testar se o c lculo   antes ou depois do vencimento.
    Tamb m estou tirando o teste "ConsideraSaldoDevNoVencto" da sol. 51736 pois eu quero que
    este trecho seja executado em todas as situa  es.
  }

  SetPgtoNormal := [1,29..30,37,45..47,65,68..71,77..78,81..84,96,100..101,197..199,201..205,214..215,246..247];
  MacUltimaPaga := 0;
  for i := 0 to Parcelas.count-1 do
    if Parcelas[i].EstaPagaReal and
       (Parcelas[i].Tipopg in SetPgtoNormal) and //  Considerar todos os pagamentos n o antecipados
       (Parcelas[i].Mac > Mes_int(DataRef.MesAno)) and
       (Parcelas[i].Mac > MacUltimaPaga) and
       ((mes_int(Parcelas[i].DtPg.MesAno) < Parcelas[i].Mac) or
        ((mes_int(Parcelas[i].DtPg.MesAno) = Parcelas[i].Mac) and
         (Parcelas[i].DtPg.Dia < Parcelas[i].DiaVenc))) then begin
      MacUltimaPaga := Parcelas[i].Mac;
      if not (Parcelas[i].TipoPg in PgtoComRedSdDev) then
        PagoNomes := PagoNoMes + Parcelas[i].ValorPago
      else
        PagoNomes := PagoNoMes + Parcelas[i].SeguroPago;
    end;
    
  result := result - PagoNomes;
end;

procedure TSerie.CalculaResiduoQuitacao(Parametros : TParametrosQuitacaoEvo;
                                        SerieReneg : TSerieReneg);
var
  ValoresParaDataRef : TValoresPorMac;
  j : integer;
  Diff : real;
  DataVencRef : Tdata;
  ParcelaReneg : TParcelaReneg;
  DtComCarencia : Tdata;
  DtCarenciaLocal : TData;
  DtVenc : TData;
begin

  ValoresParaDataRef := ObtemValoresPorMac(mes_int(Parametros.DataRef.MesAno));

  DtVenc.dia := ValoresParaDataRef.DiaVenc;
  int_mes(ValoresParaDataRef.Mac,DtVenc.MesAno);

  if ((Fin.SistAmort = 7) {SCP} or
       Contrato.RegCarteira.LiqCalcPorPxN) and
       Fin.JurosSimples then
    for j := 0 to SerieReneg.Parcelas.count-1 do
      SerieReneg.Parcelas[j].NaoTemDescporTaxa := true;
  if ((SerieReneg.Dados.SistAmort = 7) and
      fin.JURSCPANUAIS) or
     ((SerieReneg.Dados.SistAmort = 6) and
      Fin.Repactua_Sacre_Juros_0) then // J    o saldo por PxN
    Diff := 0
  else if ((SerieReneg.Dados.SistAmort = 7) {SCP} or
           Contrato.RegCarteira.LiqCalcPorPxN) and
           SerieReneg.Dados.JurosSimples and
          ((Abs(SerieReneg.ParcelaPxN) > Zero) or
           Parametros.InformouTxOportunidade) then { Scat 41461 }
    Diff  := 0  // A m todo series[i].desconto n o est  preparada para juros simples
  else begin
    DataVencRef := Parametros.DataRef;
    if SerieReneg.Dados.IgnoraDiaVencNaQuitacaoEAntec and
      (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]) and
      (SerieReneg.DtVencRef.Dia > 0) then
      DataVencRef  := SerieReneg.DtVencRef;
      Diff := SerieReneg.SaldoParaQuitacao - (SerieReneg.ValorVincendas - SerieReneg.DescontoVincendas(DataVencRef));
  end;
  SerieReneg.ResiduoSaldo := Diff;
  if (Abs(Diff) > zero) and Parametros.IncluiResiduoSaldo then begin
    ParcelaReneg := SerieReneg.Parcelas[SerieReneg.Parcelas.count-1];
    ParcelaReneg.vaEncargoSemResiduo := ParcelaReneg.vaEncargo;
    ParcelaReneg.vaEncargo := ParcelaReneg.vaEncargo + Diff;
    DtComCarencia := Parametros.DataRef;
    if SerieReneg.Dados.IgnoraDiaVencNaQuitacaoEAntec and
      (Parametros.ModuloChamador in [cModuloQuit,cModuloAntecSeries]) and
      (SerieReneg.DtVencRef.Dia > 0) then
      DtComCarencia := SerieReneg.DtVencRef;
    if Fin.DtCarenciaDeJuros.dia > 0 then begin
      DtCarenciaLocal := Fin.DtCarenciaDeJuros;
      if not Fin.JurProRata then
        DtCarenciaLocal.Dia := DtVenc.Dia;
      if Juliano(DtCarenciaLocal) > Juliano(Parametros.dataref) then
        DtComCarencia := DtCarenciaLocal;
    end;
    ParcelaReneg.EncargoSemResiduo := ParcelaReneg.Encargo;
    Parcelareneg.Encargo := CalculaEncargoCapitalizado(ParcelaReneg.vaEncargo,ParcelaReneg.venc,
                                                       DtComCarencia,ValoresParaDataRef.IndJuros,
                                                       Fin.JurProRata or
                                                       ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                                       Fin.TpJuros = 6,
                                                       DiaVencOrig);
  end
  else begin
    ParcelaReneg := SerieReneg.Parcelas[SerieReneg.Parcelas.count-1];
    ParcelaReneg.vaEncargoSemResiduo := ParcelaReneg.vaEncargo;
    ParcelaReneg.EncargoSemResiduo := ParcelaReneg.Encargo;
  end;
end;

