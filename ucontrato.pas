procedure RetornaPgtoParcSerie(var ArrayPgto : TpArrayVal;
                               var RegPgto   : TpValPgto;
                                   NumParc   : smallint;
                                   DataProcPgRef : TData;
                                   PgtoDeSeguro : boolean = false);
var
  i : smallint;
begin
  fillchar(RegPgto,sizeof(TpValPgto),0);
  i := 1;
  while (i <= ArrayPgto[0].Tam) and (RegPgto.CodCtr <= '') do begin
    if (ArrayPgto[i].NumParc = NumParc) and
      ((ArrayPgto[i].DtPg.Dia > 0) or (ArrayPgto[i].TipoPg in [200,253]) or
      ArrayPgto[i].TemPgParcial) and
     (PgtoDeSeguro or (not (ArrayPgto[i].TipoPg in PgtoComRedSdDev)) or
     (DataProcPgRef.Dia = 0) or (juliano(ArrayPgto[i].DtProc) <= juliano(DataProcPgRef))) then
      RegPgto := ArrayPgto[i];
    inc(i);
  end;
end;

procedure AcertaNumParcDosPagsDeSeguro(CodSerie : longint; Var ArrayPgtoSeg : TpArrayVal; var ArrayDeParcelas : TpArrayDeParcelas);
var
  iSeg,
  iParc : integer;
begin
// Existem pagamentos de seguro, na base da larcky, que est o com o numparc gravado como sequencial da parcela
// e n o mac, como esperado. Para estes casos,   preciso corrigir o numparc, pois ele ser  usado como mac
// em v rios pontos como ObtemParcelaDeSeguroPorMAC e RetornaPgtoParcSerie
// Este problema foi tratado na sol. 27917
// Note que o numparc de um pagamento de seguro TEM que ser o mac, pois em s ries n o mensais
// n o h  numparc diferente, nos meses entre presta  es.
  for iSeg := 1 to ArrayPgtoSeg[0].tam do
    if ArrayPgtoSeg[iSeg].NumParc < 300 then // se menor que 300, n o pode ser mac
      for iParc := 1 to ArrayDeParcelas[0].chave.tam do
        if ArrayDeParcelas[iParc].Seq = ArrayPgtoSeg[iSeg].NumParc then begin
          ArrayPgtoSeg[iSeg].NumParc := Mes_int(ArraydeParcelas[iParc].DtVenc.MesAno);
          break;
        end;
end;

