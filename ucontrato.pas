function TSerieFinanciamentoDinamico.ObtemValoresPorMAC(Mac : integer) : TValoresPorMAC;
begin
  if mac < FValoresPorMacList.count then
    if assigned(FValoresPorMacList[Mac]) then
      result := TValoresPorMac(FValoresPorMacList[Mac])
    else if mes_int(Contrato.MutDsk.Financ.DtAssin.mesano) < FValoresPorMacList.Count then
      if assigned(FValoresPorMacList[mes_int(Contrato.Mutdsk.Financ.DtAssin.mesano)]) then
        result := TValoresPorMac(FValoresPorMacList[mes_int(Contrato.Mutdsk.Financ.DtAssin.mesano)])
      else
        raise exception.create(' ndice n o calculado para '+MA_Str2(Contrato.MutDsk.Financ.DtAssin.mesano)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
    else
      raise exception.create(' ndice n o calculado para '+MA_Str2(Contrato.MutDsk.Financ.DtAssin.mesano)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
  else
    raise exception.create(' ndice n o calculado para '+MAC_Str(MAC)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
end;

function TSerieFinanciamentoDinamico.ObtemValoresPorMACInicial : TValoresPorMAC;
begin
