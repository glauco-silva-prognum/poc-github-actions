procedure TContrato.CalculaTaxasAtraso0(DataRef : TData;
                                        DadosTaxas : TTaxas;
                                        CobraTodasTaxas : boolean;
                                        ModuloChamador : integer;
                                        CobraTaxa2ViaAuto : boolean;
                                        CobraTaxa : boolean;
                                        IgnoraTaxas : boolean;
                                        CalculaTaxaEmissao : boolean = true);
var
  RTaxa  : TpTaxas;
  DataEmis,
  DtVencRec : TData;
  Taxa : TTaxasItem;
begin
  RTaxa.ctr := '';
  fillchar(RTaxa,sizeof(RTaxa),0);
  DadosTaxas.clear;
  DataEmis := DataRef;
  DtVencRec := DataRef;
  CalculaTaxasDoCtr(MutDsk,DataEmis,DtVencRec,1{TpEmissao},DadosTaxas,
                    CobraTodasTaxas,
                    ModuloChamador);
  if CobraTaxa2ViaAuto and
     CobraTaxa and
     not IgnoraTaxas and
     CalculaTaxaEmissao then begin
    MontaEGravaTaxaCtrPorTipoTaxa(CodTipoEmiCons,MutDsk.Cad.Ctr,
                                  0,0,0,DataRef,RTaxa,
                                  false{GravaNaBase});
    if RTaxa.ctr = MutDsk.Cad.Ctr then begin
      RTaxa.DtEmis := DataEmis;
      if Juliano(Rtaxa.DtVenc) = 0 then
        RTaxa.DtVenc := DtVencRec;
      if RTaxa.MACTaxa > 0 then
        AjustaMoeda2(RTaxa.MACTaxa,Mes_Int(DtVencRec.MesAno),RTaxa.ValorTaxa);
      RTaxa.MACTaxa:= Mes_Int(DtVencRec.MesAno);
      RTaxa.ValorCorrigido := RTaxa.ValorTaxa;
      Taxa := DadosTaxas.add as TTaxasItem;
      Taxa.Dados := RTaxa;
      Taxa.TaxaDeEmissao := true;
      DadosTaxas.IncluiuTaxaEmissao := true;
    end;
  end;
end;

procedure TContrato.CalculaTaxasAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados : TDadosAtrasoEvo; CalculaTaxaEmissao : boolean = true);
begin
  CalculaTaxasAtraso0(CalculoAtrasoParametros.DataRef,
                      Dados.Taxas,
                      CalculoAtrasoParametros.CobraTodasTaxas,
                      CalculoAtrasoParametros.ModuloChamador,
                      CalculoAtrasoParametros.CobraTaxa2ViaAuto,
                      CalculoAtrasoParametros.CobraTaxa,
                      CalculoAtrasoParametros.IgnoraTaxas,
                      CalculaTaxaEmissao);
end;

procedure TContrato.RecalculaPrestacoesComPendAEmitir(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                      RegConsRef : TValoresPorMac;
                                                      Dados : TDadosAtrasoevo);
var
  i,p : integer;
  reg : TValoresPorMac;
begin
  for p := 0 to Dados.Count-1 do
    if abs(Dados[p].DifManual{PendManAEmitir}) > zero then begin
      if Dados[p].EParcSerie then begin
        i := Series.indexof(abs(Dados[p].CodSerie));
        if i >= 0 then begin
          Reg := Series[i].ObtemValoresPorMac(Dados[p].MacPrst);
          Series[i].CalcParcSerieMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[p],true{UsaIsenSerieDefault});
        end;
      end
      else begin
        Reg := GetSerieFinanciamentoDinamico.ObtemValoresPorMac(Dados[p].MacPrst);
        GetSerieFinanciamentoDinamico.CalcPrestMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[p]);
      end;
    end;
end;                                                      

procedure TContrato.LeParcelasEmMemoria(ContratoOrigem : TContrato);
var
  i,idx : integer;
begin
  for i := 0 to Series.count-1 do begin
    idx := ContratoOrigem.Series.indexof(Series[i].fin.CodSerie);
    if idx >= 0 then begin
      Series[i].LeParcelasdaMemoria(ContratoOrigem.Series[idx]);
    end;  
  end;
end;

procedure TContrato.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                      Dados : TDadosAtrasoEvo;
                                      pCalculaTaxas : boolean = true);
var
  i : integer;
  Reg,
  RegConsRef : TValoresPorMac;
  UltimoMacConsolidado : integer;
  Total : real;
  TempCmTabErr : integer;
  TempCmTabErrdata : tdata;
begin
  if Mutdsk.Cad.TipoCtr=44 then
    CalculoAtrasoParametros.UsaPosicaoAtraso := true;
  EvoluiParaCalculoAtraso(CalculoAtrasoParametros);
  try

    TempCmTabErr := CmTabErr;
    TempCmTabErrdata := CmTabErrData;
    CmTabErr := 0;
    fillchar(CmTabErr,sizeof(Tdata),0);

    RegConsRef := ObtemValoresPorMac(Mes_int(CalculoAtrasoParametros.DataRef.MesAno));
    LeLCobrValoresPorMac(MutDsk,RegConsRef,Dados.RegLCobr);
    Dados.RegLcobrContrato := Dados.RegLCobr;
    if Dados.ReglCobr.Lcobr2avia > 0 then
      LeLcobr2aVia(Dados.RegLCobr.Lcobr,Dados.RegLCobr);
    if Dados.RegLCobr.Nu_Prest_Emissao_Carne > 0 then
      CalculoAtrasoParametros.EvoPrestMesmoSemIndice := true; // se for por lcobr, for ar o c lculo mesmo sem  ndice

    if RegConsRef.Carteira <> RegCarteira.Codigo then
      LeCarteira(RegConsRef.Carteira,Dados.RegCarteira)
    else
      Dados.RegCarteira := RegCarteira;

    UltimoMacConsolidado := RetornaUltimoMacParaCalcAtraso(CalculoAtrasoParametros,Dados.RegLCobr);
    Dados.GeraUmReciboComPrstComJanela := CalculoAtrasoParametros.GeraUmReciboComPrstComJanela;
    Dados.PodeIsentarCobrancaTaxa := (CalculoAtrasoParametros.TipoExec <> TipoExec_Incorporacao) and
                                     ((Scciconf.SistemaDeTaxas = SisTaxaPorRecibo) or
                                      (SisTaxasDiversas(Scciconf.SistemaDeTaxas)));
    Dados.PodeCobrarHonorarios := CalculoAtrasoParametros.CobraHonorarios and
                                 (CalculoAtrasoParametros.TipoExec in [TipoExec_Atraso,TipoExec_2aVia,TipoExec_Devidas,TipoExec_Renegociacao,TipoExec_Quitacao]);
    Dados.PodeFazerIncorporacao := CalculoAtrasoParametros.TipoExec = TipoExec_Incorporacao;
    Dados.SelecionaPrestApenasPorFaixa := CalculoAtrasoParametros.TipoExec = TipoExec_Incorporacao;
    Dados.SeparaSeguro := (MutDsk.Financ3.LCobrSeg > 0) and
                          (MutDsk.Financ3.LCobrSeg <> MutDsk.Financ.LCobr) and CalculoAtrasoParametros.SepararSeguroPrest;
    Dados.PercHonorarios := ObtemPercHonorariosNotificacaoAcao(Mutdsk);
    Dados.DiaVenc := RegConsRef.DiaVenc;
    if CalculoAtrasoParametros.UsaPosicaoAtraso then begin
      if CalculoAtrasoParametros.LePosicaoAtrasoParaDataref then
        GetDadosPosicaoAtraso.Le(GetSqlConnection(pegaDirTab),Mutdsk.cad.ctr,CalculoAtrasoParametros.Dataref)
    end
    else
      GetDadosPosicaoAtraso.clear;
    for i := 0 to Series.count-1 do
      Series[i].CalculaAtraso(CalculoAtrasoParametros,Mutdsk,RegConsRef,UltimoMacConsolidado,Dados);
    GetSerieFinanciamentoDinamico.CalculaAtraso(CalculoAtrasoParametros,MutDsk,
                                                RegConsRef,UltimoMacConsolidado,Dados);
    if Dados.count > 0 then begin

      Dados[Dados.count-1].UltimaPrestacao := true;
      if CalculoAtrasoParametros.UltimaPrestacaoDiferenciada then
        if Dados[Dados.count-1].EParcSerie then begin
          i := Series.indexof(abs(Dados[dados.count-1].CodSerie));
          if i >= 0 then begin
            Reg := Series[i].ObtemValoresPorMac(Dados[Dados.count-1].MacPrst);
            Series[i].CalcParcSerieMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[Dados.count-1],true{UsaIsenSerieDefault});
          end
          else
            raise exception.create('S rie da  ltima parcela gerada incorretamente');
        end
        else begin
          Reg := GetSerieFinanciamentoDinamico.ObtemValoresPorMac(Dados[Dados.count-1].MacPrst);
          GetSerieFinanciamentoDinamico.CalcPrestMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[Dados.count-1]);
        end;
      Dados.ValorTaxaBanco := DefineValorTaxaBanco(Mutdsk,Dados.RegLcobr);
      if CalculoAtrasoParametros.RespeitaNumMaxParcPorRecConsLcobr then
        Dados.NumMaxParcPorRecCons := Dados.RegLcobr.NumMaxParcPorRecCons;

      if Dados.RegLCobr.DescEmFolha and (RegConsRef.PA = 35) then
        Dados.TpEmi := 253
      else
        Dados.TpEmi := 200;
      Dados.OrdenaPorVencimentoECodSerie;
      IncluiPendenciasNoAtraso(CalculoAtrasoParametros,RegConsRef,Dados);
      if CalculoAtrasoParametros.ForcaPendAEmitirComoEmitida then begin
        // 102342 - se n o limpar o array de pend ncias contidos neste registro, ao recalcular as pend ncias vai acumular
        //          fazendo o c lculo n o conseguir cobrar o acerto financeiro.
        fillchar(Dados.PendCtr,sizeof(TpDadosPend),0);
        RecalculaPrestacoesComPendAEmitir(CalculoAtrasoParametros,RegConsRef,Dados);
        // 99545 - se tratou as pendencias manuais autorizadas como emitidas, n o quero voltar com seu valor
        //         ent o ao recalcular as pend ncias, eu for o a rotina a ignorara-las.
        IncluiPendenciasNoAtraso(CalculoAtrasoParametros,RegConsRef,Dados,true{IgnoraPendManual});
      end;  
      if CalculoAtrasoParametros.DeveCobrarTaxaBancaria then
        Dados.CalculaTaxaBanco;
      if pCalculaTaxas then begin
        Total := 0;
        for i := 0 to Dados.Count-1 do
          if not Dados[i].Esconde then
            Total := Total + Dados[i].ValTit;
        if (abs(Total) > zero) then begin
          TrataIsencaoTaxaEmissao(CalculoAtrasoParametros,Dados);
          CalculaValorTaxaAtraso(CalculoAtrasoParametros,Dados.ValorTaxa,Dados.Iptu);
          if (SisTaxasDiversas(Scciconf.SistemaDeTaxas)) then
            CalculaTaxasAtraso(CalculoAtrasoParametros,Dados);
        end;
      end;
    end;
    Dados.CalculaHonorarios(CalculoAtrasoparametros);
    Dados.TotalizaDados;
    if CmTabErr > 0 then begin
      try
        VerificaCmTabErr;
      except
        if not CalculoAtrasoParametros.IgnoraCmTabErr then
          raise;
      end;
      Dados.MsgCmTabErr := GeraMsgCmTabErr;
    end
    else begin
      CmTabErr := TempCmTabErr;
      CmTabErrData := TempCmTabErrdata;
    end;
    
  except
    on e : exception do begin
      Dados.clear;
      Dados.Status := CalculoAtrasoStatus_Erro;
      Dados.Msg := e.message;
    end;
  end;
end;

procedure TContrato.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                  Var NumPrst : integer;
                                  Var Total,
                                      TotalJurosMoratorios,
                                      TotalJurosRemuneratorios,
                                      TotalCorrecao,
                                      TotalMulta : real;
                                      Dados : TDadosAtrasoEvo = nil);
var
  i : integer;
  DadosAux : TDadosAtrasoEvo;
begin
  NumPrst := 0;
  Total := 0;
  TotalJurosMoratorios := 0;
  TotalJurosRemuneratorios := 0;
  TotalCorrecao := 0;
  TotalMulta := 0;

  if Assigned(Dados) then
    DadosAux := Dados
  else
    DadosAux := TDadosAtrasoEvo.create;
  try
    CalculaAtraso(CalculoAtrasoParametros,DadosAux);
    NumPrst := DadosAux.Count;
    for i := 0 to DadosAux.count-1 do
      if not DadosAux[i].Esconde then begin
        TotalJurosMoratorios := TotalJurosMoratorios + DadosAux[i].Mora - DadosAux[i].JurosContr;
        TotalJurosRemuneratorios := TotalJurosRemuneratorios + DadosAux[i].JurosContr;
        TotalCorrecao := TotalCorrecao + DadosAux[i].Correcao;
        TotalMulta := TotalMulta + DadosAux[i].Multa;
        Total := Total + DadosAux[i].ValTit;
      end;
    Total := Total + DadosAux.ValorTaxa + DadosAux.Iptu;
  finally
    if not Assigned(Dados) then
      DadosAux.free;
  end;
end;

procedure TContrato.CalculaAtraso(    DataRef : Tdata;
                                  Var NumPrst : integer;
                                  Var Total,
                                      TotalJurosMoratorios,
                                      TotalJurosRemuneratorios,
                                      TotalCorrecao,
                                      TotalMulta : real;
                                      Dados : TDadosAtrasoEvo = nil;
                                      CobraHonorarios : boolean = false);
var
  CalculoAtrasoParametros : TCalculoAtrasoParametros;
begin
  CalculoAtrasoParametros := TCalculoAtrasoParametros.create;
  try
    CalculoAtrasoParametros.DataRef := DataRef;
    CalculoAtrasoParametros.PermiteEvoluir := false;
    CalculoAtrasoParametros.CobraHonorarios := CobraHonorarios;
    CalculaAtraso(CalculoatrasoParametros,NumPrst,Total,
                  TotalJurosMoratorios,TotalJurosRemuneratorios,
                  TotalCorrecao,TotalMulta,Dados);
  finally
    CalculoAtrasoParametros.free;
  end;
end;

procedure TContrato.CalculaAtrasoParaAtivo(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                            Dados : TDadosAtrasoEvo);
var
  RegRef : TValoresPorMac;
begin
  // criado para no sig poder testar apenas o t rmino do contrato
  // mantendo a l gica da CalculaAtraso
  Dados.Clear;
  EvoluiParaCalculoAtraso(CalculoAtrasoParametros);
  Dados.status := CalculoAtrasoStatus_Ok;
  try
    RegRef := ObtemValoresPorMac(mes_int(CalculoAtrasoParametros.DataRef.MesAno));
    TestaTerminoParaCalcAtraso(RegRef.Mac,
                               CalculoatrasoParametros.CalcAtrParaInativos,
                               ((CalculoAtrasoParametros.TipoExec in [TipoExec_2avia,TipoExec_Atraso]) and ScciConf.EmiteBoletoAtrasoCtrReneg) or
                                CalculoAtrasoParametros.DevidasParaAviso,false{TestaGrupo});
  except
    on e : exception do begin
      Dados.msg := e.message;
      Dados.status := CalculoAtrasoStatus_Erro;
    end;
  end;
  if Dados.status <> CalculoAtrasoStatus_Erro then
    CalculaAtraso(CalculoAtrasoParametros,Dados);
end;

procedure TContrato.CalculaDadosAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                       Dados : TDadosAtrasoEvo;
                                       LstAvisos : TStringlist = nil);
begin
  Dados.Clear;
  EvoluiParaCalculoAtraso(CalculoAtrasoParametros);
  Dados.Status := PodeCalcularAtraso(CalculoAtrasoParametros,Dados.Suspendeu,Dados.Msg,LstAvisos);
  if Dados.status <> CalculoAtrasoStatus_Erro then begin
    CalculaAtraso(CalculoAtrasoParametros,Dados);
    VerificaResultadoCalculoAtraso(CalculoAtrasoParametros,Dados);
  end;
end;

procedure TContrato.RecalculaDadosAtraso(CalculoAtrasoparametros : TCalculoAtrasoParametros;
                                         Dados : TDadosAtrasoEvo;
                                         pCalculaTaxas : boolean = true);
var
  Reg,
  RegConsRef : TValoresPorMac;
  i,
  iSerie : integer;
  Total : real;
begin
  Dados.ValorTaxa := 0;
  Dados.Iptu := 0;
  fillchar(Dados.PendCtr,sizeof(TpDadosPend),0);
  if Dados.count > 0 then begin
    RegconsRef := ObtemValoresPorMac(mes_int(CalculoAtrasoparametros.DataRef.mesano));
    for i := 0 to Dados.count-1 do begin
      if (Dados[i].CodSerie = 0) or (abs(Dados[i].CodSerie)=maxint) then begin
        Reg := SerieF.ObtemValoresPorMac(Dados[i].MacPrst);
        SerieF.CalcPrestMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[i]);
      end
      else begin
        iSerie := Series.IndexOf(abs(dados[i].CodSerie));
        Reg := Series[iSerie].ObtemValoresPorMac(Dados[i].MacPrst);
        Series[iSerie].CalcParcSerieMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Dados[i],false{UsaIsenSerieDefault});
      end;
    end;
    IncluiPendenciasNoAtraso(CalculoAtrasoParametros,RegConsRef,Dados);

    if CalculoAtrasoParametros.ForcaPendAEmitirComoEmitida then begin
      // 102342 - se n o limpar o array de pend ncias contidos neste registro, ao recalcular as pend ncias vai acumular
      //          fazendo o c lculo n o conseguir cobrar o acerto financeiro.
      fillchar(Dados.PendCtr,sizeof(TpDadosPend),0);
      RecalculaPrestacoesComPendAEmitir(CalculoAtrasoParametros,RegConsRef,Dados);
      // 99545 - se tratou as pendencias manuais autorizadas como emitidas, n o quero voltar com seu valor
      //         ent o ao recalcular as pend ncias, eu for o a rotina a ignorara-las.
      IncluiPendenciasNoAtraso(CalculoAtrasoParametros,RegConsRef,Dados,true{IgnoraPendManual});
    end;  

  end;
  Total := 0;
  for i := 0 to Dados.Count-1 do
    if not Dados[i].Esconde then
      Total := Total + Dados[i].ValTit;
  if (abs(Total) > zero) and pCalculaTaxas then begin
    TrataIsencaoTaxaEmissao(CalculoAtrasoParametros,Dados);
    CalculaValorTaxaAtraso(CalculoAtrasoParametros,Dados.ValorTaxa,Dados.Iptu);
    if (SisTaxasDiversas(Scciconf.SistemaDeTaxas)) then
      CalculaTaxasAtraso(CalculoAtrasoParametros,Dados);
  end;
  Dados.CalculaHonorarios(CalculoAtrasoParametros);
  Dados.TotalizaDados;
end;

procedure TContrato.CalculaAtrasoSwap(DataRef : TData; Var Amaisj, Juros : real);
var
  i : integer;
begin
  Amaisj := 0;
  Juros := 0;
  for i := 0 to Series.count-1 do
    Series[i].CalculaAtrasoSwap(DataRef,Amaisj,Juros);
  GetSerieFinanciamentoDinamico.CalculaAtrasoSwap(DataRef,Mutdsk,Amaisj,Juros);
end;

function TContrato.CtrAtivoRec(ValoresPorMac : TValoresPorMac;
                               CalcAtrParaReneg : boolean; TestaGrupo : boolean = false): boolean;

  function TemSerieAtivaRec(Contrato : Tcontrato) : boolean;
  var
    i : integer;
    Reg : TValoresPorMac;
  begin
    // Calcula atraso para contratos ativos ou Lan,Sin,Tpz,SD Sol. 26565
    // Calcular tamb m para contrato transferido, conforme sol. 39875
    result := false;
    if TemFinancDinamico(Contrato.Mutdsk) then begin
      Reg := Contrato.SerieF.ObtemValoresPorMac(ValoresPorMac.Mac);
      result := result or Reg.CtrAtivo or (Reg.Status in [1,2,7,8,10,23]) or ((Reg.Status=30) and CalcAtrParaReneg);
    end;
    for i := 0 to Contrato.Series.count-1 do begin
      Reg := Contrato.Series[i].ObtemValoresPorMac(ValoresPorMac.Mac);
      result := result or Reg.CtrAtivo or (Reg.Status in [1,2,7,8,10,23]) or ((Reg.Status=30) and CalcAtrParaReneg);
    end;
  end;

var
  i : integer;
begin
  if Valint(ScciConf.NSerie) = NsCohapar then
  {trocando de 1 para 10, Cobrar se for contrato terminado por termino
   de cessao}
  // Calcular tamb m para contrato transferido, conforme sol. 39875
     result := ValoresPorMac.CtrAtivo or (ValoresPorMac.Status in [10,2,8,7,23]) or (CalcAtrparaReneg and (ValoresPorMac.Status=30))
  else begin
    if TestaGrupo and (Grupo.count > 1) then begin
      result := false;
      for i := 0 to Grupo.count-1 do
        result := result or TemSerieAtivaRec(Grupo[i].Contrato);
    end
    else
      result := TemSerieAtivaRec(self);
  end;
end;

procedure TContrato.TestaTerminoParaCalcAtraso(MacRef : smallint;
                                               CalcAtrParaInativos : boolean;
                                               CalcAtrParaReneg : boolean = false;
                                               TestaGrupo : boolean = false);
var
  RegRef : TValoresPorMac;
begin
  RegRef := ObtemValoresPorMac(MacRef);
  if not CalcAtrParaInativos and not CtrAtivoRec(RegRef,CalcAtrParaReneg,TestaGrupo)  then
    raise exception.create('Contrato terminado por '+DescStatus(RegRef.Status));
end;

function TContrato.EvoPrestVincendaEmiCons(mac : integer; CalculoAtrasoParametros : TCalculoAtrasoParametros) : boolean;
var
  i             : integer;
  TodasComErro : boolean;
  TodasInativas : boolean;
  Reg : TValoresPorMac;
  Dt1 : Tdata;
  dtvenc : tdata;
  // Testes excluisivos para emiss o consolidada
  // deve parar se todas as series tiverem coderro <> 0 e nenhum for coderro = 1
  //    ou se o parametro EvoPrestMesmoSemIndice estiver setado
  // tamb m deve parar se todas as s ries estiverem inativas, e nenhuma tiver dtinicio > dataref
begin
  if CalculoAtrasoParametros.TipoExec = TipoExec_2aVia then begin
    TodasComErro := not CalculoatrasoParametros.EvoPrestMesmoSemIndice;
    TodasInativas := true;

    if TemFinancDinamico(Mutdsk) then begin
      Reg := SerieF.ObtemValoresPorMac(Mac);
      TodasComErro := TodasComErro and not (Reg.Coderro in [0,1]);
      Dt1 := Reg.DtAssin;
      DtVenc.dia := Reg.DiaVenc;
      int_mes(reg.mac,dtvenc.mesano);
      TodasInativas := TodasInativas and
                       (not Reg.CtrAtivo and (Juliano(Dt1) <= Juliano(dtvenc)))
    end;

    i := 0;
    while i < Series.count do begin
      Reg := Series[i].ObtemValoresPorMac(Mac);
      TodasComErro := TodasComErro and not (Reg.CodErro in [0,1]);
      Dt1 := Reg.DtAssin;
      DtVenc.dia := Reg.DiaVenc;
      int_mes(reg.mac,dtvenc.mesano);
      TodasInativas := TodasInativas and
                       (not Reg.CtrAtivo and (Juliano(Dt1) <= Juliano(dtvenc)));

      inc(i);
    end;
    result := not TodasComErro and not TodasInativas;
  end
  else
    result := false;
end;

function TContrato.EvoPrestVincenda(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                        ValoresPorMac : TValoresPorMac;
                                        MACRef : SmallInt;
                                        RegLCobr : TpTabLCobr) : boolean;

  function TestReaj : boolean ;
  var
    anomac, proxreaj, mesessemreaj, mes112, mreaj2  : SmallInt;
    tmp                                             : boolean;
  begin
    if ((ValoresPorMac.Plano mod 10) = SACR) and ((ValoresPorMac.Plano div 10)<> PR) then tmp := false
    else
{    if ((ValoresPorMac.PA=22) or (ValoresPorMac.PA=28)) then
        tmp := (not ValoresPorMac.TanaConcessao) or (ValoresPorMac.MAC>(mes_int(ValoresPorMac.DtInfin.MesAno)+1))
    else} if (ValoresPorMac.PA=30) and (ValoresPorMac.MAC<(mes_int(ValoresPorMac.DtAssin.MesAno))+12) then tmp := false
    else begin
     if (ValoresPorMac.PrimAntecip=0) and ( (ValoresPorMac.CodReaj=5) or (ValoresPorMac.CodReaj=22) ) and
        ScciConf.PrimAntecPstSD and (ValoresPorMac.NPC>0) then tmp := true
     else begin
       if ValoresPorMac.PerFin > 0 then begin
         anomac := ((ValoresPorMac.mac-1) div 12);
         proxreaj := anomac * 12 + ValoresPorMac.MReaj ;
         mes112 := succ(pred(ValoresPorMac.MAC112) mod 12);
         MReaj2 := ValoresPorMac.MReaj + 6; if MReaj2 > 12 then dec( MReaj2, 12);
         if
            ( (ValoresPorMac.FezOPC and (1 shl 13)) = (1 shl 13) ) and (* Tem Rd-47 *)
            (mes112 <> ValoresPorMac.MReaj) and
            (mes112 <> MReaj2) (* mar/87 scat 14130 *) then mesessemreaj := 3
         else mesessemreaj := ValoresPorMac.Carencia div 30;
         if proxreaj > ValoresPorMac.mac then
           while proxreaj > ValoresPorMac.mac do proxreaj := proxreaj - ValoresPorMac.perfin
         else
           while proxreaj < ValoresPorMac.mac do proxreaj := proxreaj + ValoresPorMac.perfin ;
         if (ValoresPorMac.CodReaj=6) or (ValoresPorMac.CodReaj=7)  then
           tmp := (ValoresPorMac.ExOpc=16) or
                  ( (ValoresPorMac.MAC = proxreaj) and
                    ((ValoresPorMac.MAC>=1047) or (ValoresPorMac.MACTmp=0) or ((ValoresPorMac.MAC-ValoresPorMac.MACTmp)>2) ) )
         else
           tmp := ( ( ValoresPorMac.MAC = proxreaj ) and
                         ( ((ValoresPorMac.MAC - ValoresPorMac.MAC112) > 5) or
                           ((ValoresPorMac.MAC>=1047) and
                           (((ValoresPorMac.MAC-ValoresPorMac.MAC112)>=mesessemreaj) or
                             (valint(ScciConf.NSerie)=2) ) ) ) );
     (* No caso da Letra nao respeita carencia na RD-47 *)
       end
       else tmp := false;
     end;
    end;
    TestReaj := tmp;
  end;

  function ReajPstCodReaj28 : boolean;
  var
    MARef,
    MA       : TMes_Ano;
    ReajPst  : boolean;
  begin
    ReajPst := false;
    if ValoresPorMac.CodReaj = 28 then begin
      Int_Mes(MACRef,MARef);
      MA.Ano := MARef.Ano;
      {if ValoresPorMac.PA=22 then MA.mes := 5
      else }MA.Mes := 6;
      if MARef.Mes > MA.Mes then inc(MA.Ano);
      if Mes_Int(MA) = ValoresPorMac.MAC then ReajPst := true;
    end;
    ReajPstCodReaj28 := ReajPst;
  end;

var
  MA : TMes_Ano;
  MALimite : TMes_Ano;
begin
  int_Mes(Macref,MA);
  if (RegLCobr.Nu_Prest_Emissao_Carne > 0) then begin
    if (RegLCobr.Nu_Mes_Limite_Emissao_Carne=0) then
      incma(ma,RegLCobr.Nu_Prest_Emissao_Carne)
    else begin
      MA.Mes := RegLCobr.Nu_Mes_Limite_Emissao_Carne;
      if mes_int(MA) < macref then inc(MA.Ano);
    end;
  end;
  if (ValoresPormac.CtrAtivo) and
     (not ScciConf.NaoEvoPrestAteProxReaj) and
     (ValoresPormac.DtInFin.Dia > 0) and
     ( ((CalculoAtrasoParametros.TipoExec = TipoExec_2aVia) and EvoPrestVincendaEmiCons(ValoresPorMac.Mac,CalculoAtrasoParametros)) or
       ((ValoresPormac.CodErro = 0) or CalculoAtrasoParametros.EvoPrestMesmoSemIndice or (ValoresPormac.CodErro <> 2))) and
     (CalculoAtrasoParametros.TipoVinAlt or (CalculoAtrasoParametros.TipoExec in [TipoExec_2aVia,TipoExec_Caixa,TipoExec_Vincendas])) then
    result := true
  else if (RegLCobr.Nu_Prest_Emissao_Carne > 0) and (ValoresPorMac.mac <= mes_int(MA)) then begin
    result := true;
  end
  else begin
    result := (CalculoAtrasoParametros.TipoExec = TipoExec_Vincendas) and
              (ValoresPormac.CtrAtivo) and
              (((ValoresPormac.Residuo <= Zero) and (ValoresPormac.CotaFGTS <= Zero)) or
               (ValoresPormac.FGTS > Zero)) and
              ((ValoresPormac.AmaisJ > Zero) or
               ((ValoresPormac.TotPrest > Zero) and (Mutdsk.Cad.TipoCtr = 3)));
    if result then
      if ValoresPorMac.PA in [22,28,81] then begin
        // sol. 59114
        MALimite.mes := ScciConf.MesLimiteEmiAntecPAReajSM;
        MALimite.ano := CalculoAtrasoParametros.DataRef.ano;
        if mes_int(CalculoAtrasoParametros.DataRef.Mesano) >= mes_int(MALimite) then
          inc(MALimite.ano);
        result := (ScciConf.MesLimiteEmiAntecPAReajSM > 0) and
                  (ScciConf.MesLimiteEmiAntecPAReajSM < 13) and
                  (ValoresPorMac.Mac <= Mes_int(MALimite));
      end
      else
        result := ((not TestReaj) or CalculoAtrasoParametros.IgnoraTesteProxReaj or
                   ((ValoresPormac.CodReaj = 28)and(not ReajPstCodReaj28))) and
                  ((ValoresPormac.PA = 20) or
                   (ValoresPormac.PA = 28) or
                   (ValoresPormac.PA = 50) or
                   (ValoresPormac.PA = 51) or
                   (ValoresPormac.CodReaj = 2) or
                   (MutDsk.Cad.TipoCtr = 3) or
                   (ValoresPorMac.Plano=98));
  end;
end;

function TContrato.PrstOkGeral(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                   DtIsencao : Tdata;
                                   Reg : TValoresPorMac;
                                   IndexSerie : integer;
                                   DesconsideraSuspensao : boolean) : boolean;
var
  Parcela : TParcela;
  TpPg    : byte;
begin
  if IndexSerie < 0 then begin
    Parcela := SerieF.Parcelas.ObtemParcelaPorMAC(Reg.MAC);
    if assigned(Parcela) then
      TpPg := Parcela.TipoPg
    else
      TpPg := 0;
    PrstOkGeral := SerieF.PrstOk(CalculoAtrasoParametros,MutDsk,DtIsencao,Reg,TpPg,DesconsideraSuspensao);
  end
  else
    PrstOkGeral := Series[IndexSerie].ParcSerieOk(Mutdsk,Reg,DtIsencao,CalculoAtrasoParametros,DesconsideraSuspensao);
end;

function SuspensaoParaCalcAtrasoPorCtrOk(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                             Contrato : TContrato;
                                             EAgrupado : boolean;
                                         var msg : AnsiString;
                                         var status : TCalculoAtrasoStatus) : boolean;

  procedure DtPrimPrstCalculada(var DtPrimVenc : TData);
  var
    DtVenc : Tdata;
    DtIsenMora : TData;
    i : SmallInt;
    CountEvoAtr : integer;
    RegCons,
    Reg : TValoresPorMac;
    RegLCobr : TpTabLCobr;
  begin
    ReglCobr.LCobr := 0; 
    fillchar(ReglCobr,sizeof(ReglCobr),0);
    DtIsenMora.Dia := 0; DtIsenMora.Mes := 0; DtIsenMora.ano := 0;
    fillchar(DtPrimVenc,sizeof(Tdata),0);
    RegCons := Contrato.ObtemValoresPorMac(Mes_int(CalculoAtrasoParametros.DataRef.mesano));
    LeLCobrValoresPorMac(Contrato.MutDsk,RegCons,RegLCobr);
    if ReglCobr.Lcobr2avia > 0 then
      LeLcobr2aVia(RegLCobr.Lcobr,RegLCobr);
    RegCons := Contrato.ObtemValoresPorMac(Mes_int(RegCons.DtAssin.MesAno));
    CountEvoAtr := 1;
    while (((RegCons.Mac <= Mes_int(CalculoAtrasoParametros.DataRef.MesAno)) and (RegCons.CtrAtivo or
            (RegCons.MAC < Mes_int(CalculoAtrasoParametros.DataRef.MesAno))) and (RegCons.CodErro = 0)) or
             Contrato.EvoPrestVincenda(CalculoAtrasoParametros,RegCons,Mes_int(CalculoAtrasoParametros.DataRef.MesAno),RegLcobr)) and
            (DtPrimVenc.dia = 0) and
            (CountEvoAtr < MaxEvoAtr) do begin
        inc(CountEvoAtr);
        Int_Mes(RegCons.MAC,DtVenc.MesAno);
        DtVenc.Dia := RegCons.DiaVenc;
        if TemFinancDinamico(Contrato.Mutdsk) then begin
          Reg := Contrato.SerieF.ObtemValoresPorMac(RegCons.Mac);
          if Reg.DtInFin.Dia > 0 then begin
            DtVenc.Dia := Reg.DiaVenc;
            DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsenMora,Contrato.MutDsk.Cad.DiaIsencao);
            if Contrato.PrstOkGeral(CalculoAtrasoParametros,DtIsenMora,Reg,-1,true) then
              DtPrimVenc := DtVenc;
          end;
        end;
        if RegCons.TemSerieAtiva and (DtPrimVenc.dia = 0) then
          for i := 0 to Contrato.Series.Count-1 do begin
              Reg := Contrato.Series[i].ObtemValoresPorMac(RegCons.Mac);
              if (valInt(ScciConf.Nserie) = NsPiemonte) and
                 (Reg.Npc = 1) then
                DtVenc.Dia := Reg.DiaVenc
              else
                DtVenc.Dia := Reg.DtInFin.Dia;
              DtVenc.Dia := Dia_Venc(Mes_Int(DtVenc.MesAno),DtVenc.Dia);
              DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsenMora,Contrato.MutDsk.Cad.DiaIsencao);
              Reg := Contrato.Series[i].ObtemValoresPorMac(RegCons.Mac);
              if Contrato.PrstOkGeral(CalculoAtrasoParametros,DtIsenMora,Reg,i,true) then
                DtPrimVenc := DtVenc;
          end;
      if RegCons.Mac < Contrato.FValoresPorMacList.count-1 then
        RegCons := Contrato.ObtemValoresPorMac(RegCons.Mac+1)
      else
        break;
    end;
    if DtPrimVenc.Dia = 0 then begin
      int_mes(RegCons.mac,DtPrimVenc.mesano);
      DtPrimVenc.Dia := RegCons.diavenc;
    end;
  end;

var
  RegAcordo    : TpAcordos;
  SitEsp,
  SitCobj      : byte;
  DtPrimVenc   : tData;
  RegRef : TValoresPorMac;
begin
  RegAcordo.TipoAcordo := 0;
  fillchar(RegAcordo,sizeof(RegAcordo),0);
  SitEsp := 0;
  SitCobj := 0;
  DtPrimVenc.dia := 0;
  fillchar(DtPrimVenc,sizeof(TData),0);
  result   := true;
  if not CalculoAtrasoParametros.IgnoraSuspensao then begin
    if (Contrato.MutDsk.Cad.SitCobJ =  5) or
       (Contrato.MutDsk.Cad.SitCobJ = 15) then
      PegaAcordoEmVigor(RegAcordo,Contrato.MutDsk.Cad.Ctr)
    else
      fillchar(RegAcordo,sizeof(TpAcordos),0);
    if RegAcordo.TipoAcordo = TipoAcLeiMun8973 then begin
      result   := false;
      Status := CalculoAtrasoStatus_Erro;
      if EAgrupado then
        Msg    := 'Ctr. '+Contrato.MutDsk.Cad.Ctr+' Agrupado! Emiss o Suspensa p/quita  o pela Lei Mun. 8.973/2002'
      else
        Msg    := 'Emiss o Suspensa para quita  o pela Lei Mun. 8.973/2002';
    end
    else begin
      DtPrimPrstCalculada(DtPrimVenc);
      if (CalculoAtrasoParametros.TipoExec = TipoExec_Acordo) and SitEspSuspAcordo(Contrato.MutDsk,DtPrimVenc) then begin
        result := False;
        Status := CalculoAtrasoStatus_Erro;
        if EAgrupado then
          Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' agrupado e suspenso para Acordo'
        else
          Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' Suspenso para Acordo';
      end
      else if (CalculoAtrasoParametros.TipoExec = TipoExec_Incorporacao) and SitEspSuspPrst(Contrato.MutDsk,CalculoAtrasoParametros.DataRef,DtPrimVenc) then begin
        Msg := MsgSituacaoNotEmitePrst(Contrato.MutDsk);
        if EAgrupado then
          Msg := 'Imposs vel calcular a incorp. p/ o ctr. '+Contrato.MutDsk.Cad.Ctr+' agrupado e suspenso:'+Msg
        else
          Msg := 'Imposs vel calcular a incorp. p/ ctr. '+Contrato.MutDsk.Cad.Ctr+' suspenso:'+Msg;
        Status := CalculoAtrasoStatus_Erro;
      end
      else begin
        RegRef := Contrato.ObtemValoresPorMac(mes_int(CalculoAtrasoParametros.DataRef.MesAno));
        if (CalculoAtrasoParametros.TipoExec in [TipoExec_Vincendas,TipoExec_2aVia,TipoExec_Caixa,TipoExec_IsenMoraAuto]) and
           (not Contrato.CtrAtivoRec(RegRef,(CalculoAtrasoParametros.TipoExec in [TipoExec_2aVia,TipoExec_atraso]) and ScciConf.EmiteBoletoAtrasoCtrReneg,EAgrupado) or
            SitEspSuspPrst(Contrato.MutDsk,CalculoAtrasoParametros.DataRef,DtPrimVenc) or
            (RegRef.CodSusp = 13)) then begin
          result := false;
          if CalculoAtrasoParametros.EmiteSusp then begin
            if not CalculoAtrasoParametros.ERecalculo then begin
              if CalculoAtrasoParametros.TipoExec in [TipoExec_2aVia,TipoExec_IsenMoraAuto] then begin
                if EAgrupado then
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' agrupado e suspenso. Autoriza gera  o de recibos'
                else
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' suspenso. Autoriza geracao de recibos';
                Status := CalculoAtrasoStatus_Confirmar;
              end
              else begin
                if EAgrupado then
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' agrupado e suspenso. Autoriza pagamentos'
                else
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' suspenso. Autoriza pagamentos';
                Status := CalculoAtrasoStatus_Confirmar;
              end;
              begin
                 result := true;
                 Msg := msg + ' ?';
              end;
            end
            else
              result := true;
          end; (* if *)
          if not result then begin
            if Contrato.CtrAtivoRec(RegRef,(CalculoAtrasoParametros.TipoExec in [TipoExec_2avia,TipoExec_atraso]) and
                                            ScciConf.EmiteBoletoAtrasoCtrReneg,EAgrupado) and
               SitEspSuspPrst(Contrato.MutDsk,CalculoAtrasoParametros.DataRef,DtPrimVenc) then begin
              // Sol. 23129
              RetornaMotivoSuspPrst(Contrato.MutDsk,SitCobj,SitEsp,CalculoAtrasoParametros.DataRef);
              if Sitesp > 0 then begin
                if CalculoAtrasoParametros.UsaDescWebNoBloqueioSitEsp then
                   msg := DescWebSit(SitEsp)
                else msg := DescSit(SitEsp)
              end else   begin
                if CalculoAtrasoParametros.UsaDescWebNoBloqueioSitEsp then
                  msg := DescWebSitCj(SitCobj)
                else msg := DescSitCj(SitCobj);
              end;
              if not CalculoAtrasoParametros.UsaDescWebNoBloqueioSitEsp then begin
                if EAgrupado then
                  msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' agrupado em situa  o "'+msg+'", favor utilizar a op  o de emiss o para contratos suspensos.'
                else
                  msg := 'Contrato em situa  o "'+msg+'", favor utilizar a op  o de emiss o para contratos suspensos.';
              end;
            end
            else begin
              if not CalculoAtrasoParametros.UsaDescWebNoBloqueioSitEsp then begin
                if EAgrupado then
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' agrupado e em Situa  o '+OcorrStr[RegRef.Status]+'/'
                else
                  Msg := 'Contrato '+Contrato.MutDsk.Cad.Ctr+' em Situa  o '+OcorrStr[RegRef.Status]+'/';
                if RegRef.CodSusp > 0 then Msg := Msg + OcorrStr[RegRef.CodSusp]
                else Msg := Msg + QualSituacao(Contrato.MutDsk,CalculoAtrasoParametros.DataRef);
              end;
            end;
            Status := CalculoAtrasoStatus_Erro;
          end;
        end;
      end;
    end;
  end;
end;

function TContrato.SuspensaoParaCalcAtrasoOk(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                 TestaGrupo : boolean;
                                             var msg : AnsiString;
                                             var status : TCalculoAtrasoStatus) : boolean;
var
  i : integer;
begin
  result := true;
  if not CalculoAtrasoParametros.IgnoraSuspensao then begin
    if TestaGrupo and (Grupo.count > 1) then begin
      for i := 0 to Grupo.count-1 do
        result := result and SuspensaoParaCalcAtrasoPorCtrOk(CalculoAtrasoParametros,Grupo[i].Contrato,true{EAgrupado},msg,status)
    end
    else
      result := SuspensaoParaCalcAtrasoPorCtrOk(CalculoAtrasoParametros,self,false{EAgrupado},msg,status)
  end;
end;

