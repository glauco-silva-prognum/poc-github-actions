procedure TelaMostraMutZoom(var MutDsk : TpMutDsk; var RPA : TpRPA; Var Linhas : TpVetLinhas);
var
  Tc       : Char;
  nst,pl, i: byte;
  TavAberto,
  SemDesc  : boolean;
  St       : string;
  DataSpc,
  DtLiq    : TData;
  Sit      : array[1..10] of string;
  RegSpc   : TpSpc;
  RegHab   : TpHabilf;
begin
  RegHab.Ctr := '';
  fillchar(RegHab,sizeof(RegHab),0);
  RegSpc.Ctr := '';
  fillchar(RegSpc,sizeof(RegSpc),0);
  fillchar(Linhas,sizeof(TpLinhas),0);
  with MutDsk, RPA do begin
     if (FinRPA2.Evoluido > 3) then
       FinRPA2.Evoluido := 0;

     inc(Linhas[0].Tam);
     Linhas[Linhas[0].Tam].Lin := 'SITUA  ES DO CONTRATO'+Space(31)+'DATA';
     inc(Linhas[0].Tam);
     Linhas[Linhas[0].Tam].Lin := Space(65);


     (* ---------Define o Status do Contrato--------- *)

     inc(Linhas[0].Tam);
     if ValRPA.MACStatus > 0 then begin
       Int_Mes(ValRPA.MACStatus,DtLiq.MesAno);
       if FinRPA.DiaLiq > 0 then DtLiq.Dia := FinRPA.DiaLiq
       else DtLiq.Dia := FinRPA.DiaVenc;
     end else fillchar(DtLiq,sizeof(TData),0);
     if (FinRPA.Status = 7) and (Rpa.CodErro > 0) then
       Linhas[Linhas[0].Tam].Lin := 'SDZ - SALDO ZERADO  (ERRO)'
     else begin
       if FinRPA.Status = 0 then
         Linhas[Linhas[0].Tam].Lin := 'ATV  - CONTRATO ATIVO'
       else begin
         Linhas[Linhas[0].Tam].Lin := OcorrStr[FinRPA.Status]+'  - ';
         if (FinRPA.Status >= 20) and (FinRPA.Status < 70) then 
           Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                        StatusStr[FinRPA.Status-9]
         else if (FinRPA.Status >= 70) and (FinRPA.Status < 90) then
           Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                        StatusStr[FinRPA.Status-48]
         else if FinRPA.Status >= 90 then
           Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                        StatusStr[FinRPA.Status-77]
         else
           Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                        StatusStr[FinRPA.Status];
       end;
     end;
     if DtLiq.Dia > 0 then
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    Data_Str2(DtLiq)
     else begin
       if MutDsk.Cad.TipoCtr = 1 then { Fase de Construcao }
         Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                      Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                      Data_Str2(MutDsk.Financ.DtAssin)
       else
         Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                      Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                      ' INDEFINIDA';
     end;
     (*-------Define se o Contrato tem Liminar ou Causa Julgada------*)

     inc(Linhas[0].Tam);
     if Cad.DtCausaJ.Dia > 0 then begin
       Linhas[Linhas[0].Tam].Lin := 'CJU - CAUSA JULGADA';
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    Data_Str2(Cad.DtCausaJ);
     end
     else begin
       if TemOpcao( RPA, 14 ) then
         Linhas[Linhas[0].Tam].Lin := 'LIM  - COM LIMINAR'
       else
         Linhas[Linhas[0].Tam].Lin := 'NLM  - SEM LIMINAR';
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    ' INDEFINIDA';
     end;

     (*-----------------Define as Situacoes Especiais------------------*)
     nst := 0;
     if Cad2.Terceirizado then begin
       inc(nst);
       Sit[nst] := 'TER  - TERCEIRIZADO EM LOTE ANTERIOR';
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst]))+' INDEFINIDA';
     end;

     TavAberto := AbriuSpc;
     if not TavAberto then AbreSpc;
     LeOcorrAtualCtrSpc(MutDsk.Cad.Ctr,RegSpc);
     if not TavAberto then FechaSpc;
     if RegSpc.Ctr > '' then begin
       case RegSpc.Status of
         1    : DataSpc := RegSpc.DtComunica;
         2    : DataSpc := RegSpc.DtEnvio;
         3,
         6..8 : DataSpc := RegSpc.DtOcorrencia;
         4    : DataSpc := RegSpc.DtExcManual;
         5    : DataSpc := RegSpc.DtExclusao;
         9,12 : DataSpc := RegSpc.DtPagDebito;
         10   : DataSpc := RegSpc.DtNegociacao;
         11   : DataSpc := RegSpc.DtRevenda;
       end;
       inc(nst);
       if StatusDeIncluidoNoSpc(RegSpc) then
         St := 'SPC'
       else
         St := 'XSP';
       St := St +   '  - '+ StatusSpc2[RegSpc.Status];
       Sit[nst] := St;
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst]))+Data_Str2(DataSpc);
     end;
     if Temp4.CodSusp > 0 then
       if (not (Cad.SitCobJ in [6,7,8])) and (not (Cad.SitCobJ2 in [6,7,8])) and
          (not SitEspSuspPrst(MutDsk,DataH,DataH)) then begin
         inc(nst);
         Sit[nst] := OcorrStr[Temp4.CodSusp];
       end;
     if Cad.SitCobJ > 0 then begin
       inc(nst);
       St       := AbvSitCj(Cad.SitCobj);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSitCj(Cad.SitCobJ);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitCobj);
     end;
     if Cad.SitCobJ2 > 0 then begin
       inc(nst);
       St       := AbvSitCj(Cad.SitCobj2);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSitCj(Cad.SitCobJ2);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitCobj2);
     end;

{     if Cad.SitEsp1 > 0 then begin
       inc(nst);
       St       := AbvSit(Cad.SitEsp1);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSit(Cad.SitEsp1);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitEsp1);
     end;
     if Cad.SitEsp2 > 0 then begin
       inc(nst);
       St       := AbvSit(Cad.SitEsp2);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSit(Cad.SitEsp2);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitEsp2);
     end;
     if Cad.SitEsp3 > 0 then begin
       inc(nst);
       St       := AbvSit(Cad.SitEsp3);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSit(Cad.SitEsp3);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitEsp3);
     end;
     if Cad.SitEsp4 > 0 then begin
       inc(nst);
       St       := AbvSit(Cad.SitEsp4);
       Sit[nst] := St + Space(3-length(St))+'  - '+DescSit(Cad.SitEsp4);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitEsp4);
     end;
     if Cad.SitEsp5 > 0 then begin
       inc(nst);
       St       := AbvSit(Cad.SitEsp5);
       Sit[nst] := St+ Space(3-length(St))+'  - '+DescSit(Cad.SitEsp5);
       Sit[nst] := Sit[nst] + Space(50-length(Sit[nst])) + Data_Str2(Cad.DtSitEsp5);
     end;
}
     for i := 1 to nst do begin
       inc(Linhas[0].Tam);
       Linhas[Linhas[0].Tam].Lin := Sit[i];
     end;

     inc(Linhas[0].Tam);
     Linhas[Linhas[0].Tam].Lin := EvoStr[FinRPA2.Evoluido]+'  - ';
     case FinRPA2.Evoluido of
       0 : Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin + 'N O EVOLUIDO';
       1 : Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin + 'EVOLUIDO';
       2 : Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin + 'EVOLUIDO PELO SCCI';
       3 : Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin + 'TOTALMENTE EVOLUIDO';
     end;
     Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                  Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                  ' INDEFINIDA';
     if FinRPA.PA = 81 then begin
       inc(Linhas[0].Tam);
       Linhas[Linhas[0].Tam].Lin := 'PSH  - Programa de Subsidio de Habitacao';
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    ' INDEFINIDA';

     end;

     if (finrpa.CodReaj > 0) and (FinRPA.PA <> 81) then begin
       inc(Linhas[0].Tam);
       Linhas[Linhas[0].Tam].Lin := Reajs1[Finrpa.CodReaj]+ ' - '+Reajs[finrpa.CodReaj];
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    ' INDEFINIDA';
     end;
     LeHabilf(MutDsk.Cad.Ctr,RegHab);
     if (RegHab.Ctr = MutDsk.Cad.Ctr) and 
        (Juliano(RegHab.DataHomologacao) > 0) then begin
       inc(Linhas[0].Tam);
       Linhas[Linhas[0].Tam].Lin := 'HOM  - CONTRATO HOMOLOGADO';
       Linhas[Linhas[0].Tam].Lin := Linhas[Linhas[0].Tam].Lin +
                                    Space(50-length(Linhas[Linhas[0].Tam].Lin))+
                                    Data_Str2(RegHab.DataHomologacao);
     end;

   end; (* with *)

end;

procedure MontaContratoPorMem(ListaIn : tpMemory; Contrato : TContrato; MacIniReevo, MacFimReevo : integer);
var
  DataPrest0 : TData;
  Aux : TpMemory;
  ArrComp : TpArrComp;
  MutDsk : TpMutDsk;
  MutDskC : TpMutDskC;
  Hedit : TpHistEdit;
  ImovelAtv : TpCadImv;
  ArrSeries : tpArrCadSerie;
  i,j : integer;
{$IFDEF XE}
  erro : string;
{$ELSE}
  erro : shortstring;
{$ENDIF}
  MaxId : integer;
begin
  ImovelAtv.CodImv := '';
  fillchar(ImovelAtv,sizeof(ImovelAtv),0);
  MutDsk.Cad.Ctr := '';
  fillchar(MutDsk,sizeof(MutDsk),0);
  MutDskC.Ctr := '';
  fillchar(MutDskC,sizeof(MutDskC),0);
  erro := '';
  ArrComp[0].Tam := 0;
  fillchar(ArrComp,sizeof(TpArrComp),0);
  fillchar(MutDsk,sizeof(TpMutDsk),0);
  HEdit[0].tam := 0;
  fillchar(Hedit,sizeof(TpHistEdit),0);
  ArrSeries[0].Chave.Tam := 0;
  fillchar(ArrSeries,sizeof(tpArrCadSerie),0);
  MaxId := 0;
  Aux := TpMemory.create;
  try
    DataPrest0.MesAno := ListaIn.ReadMA('CadMut.Financ.DtInFin');
    if (DataPrest0.Mes <= 0) or (DataPrest0.Ano <= 0) then begin
      fillchar (DataPrest0, sizeof(DataPrest0), 0);
      DataPrest0.Dia := ListaIn.ReadInt('CadMut.Financ.DiaVenc');
    end
    else begin
      DecMA(DataPrest0.MesAno);
      DataPrest0.Dia := ListaIn.ReadInt('CadMut.Financ.DiaVenc');
    end;
    ListaIn.AddData('CadMut.Financ.DtInFin', DataPrest0);
    Aux.readrep('Renda',ListaIn);
    MontaCadRenda(Aux,ArrComp);
    CriticaTotRenda(ArrComp);
    Aux.readrep('vendedor',ListaIn);
    MontaVendedores(Aux,ArrComp,false);
    MontaCadMut(ListaIn,ArrComp,MutDsk,MutDskC);
    Aux.readrep('Historicos',ListaIn);
    MontaHistEdit(MutDsk.Cad.Ctr,Aux,HEdit);
    CriticaSuspReatSeg(HEdit);
    try
      Le_Imovel_Base(PegaDirAtv,MutDsk.ChaveImv,ImovelAtv);
      if ArrComp[0].tam < 1 then
        raise exception.create('Nenhum mutu rio informado');
      Aux.Readrep('Series',ListaIn);
      MontaArrSerie(Aux,MutDsk,ArrSeries);
      for i := 1 to ArrSeries[0].Chave.tam do begin
        if ArrSeries[i].CodSerie > MaxId then
          MaxId := ArrSeries[i].CodSerie;
        if not SerieOk(ArrSeries[i],Erro) then
          raise exception.create('S rie '+Trim(DescrSerie(ArrSeries[i].TipoSerie))+' inv lida :'+erro);
        If (juliano(ArrSeries[i].Dataref) < Juliano(MutDsk.financ.DtAssin)) and (Juliano(MutDsk.financ.DtAssin) > 0) then
          raise exception.create('S rie '+Trim(DescrSerie(ArrSeries[i].TipoSerie))+' com data de refer ncia ('+
                                 data_Str0(ArrSeries[i].Dataref)+') anterior a data de assinatura do contrato ('+
                                 data_Str0(MutDsk.financ.DtAssin)+'). Por favor corrija os dados antes de salvar o contrato.');
      end;
      for i := 1 to ArrSeries[0].Chave.tam do begin
        if ArrSeries[i].CodSerie < 1 then begin
          Inc(MaxId);
          ArrSeries[i].CodSerie := MaxId;
        end;
        if (ArrSeries[i].Status = 98) and (ArrSeries[i].DtExclusao.Dia = 0) then
          ArrSeries[i].DtExclusao := Datah;
      end;
      MutDsk.Cad2.TemSerie := ArrSeries[0].chave.tam > 0;
      Contrato.LeMem(MutDsk,HEdit,ArrSeries);
      Contrato.FleuArrcomp := false;
      Contrato.LeCompMem(Arrcomp);
      for i := 0 to Contrato.Series.count -1 do
        for j := 0 to Contrato.Series[i].Parcelas.count - 1 do
          if (Contrato.Series[i].Parcelas[j].Mac >= MacIniReevo) and
             (Contrato.Series[i].Parcelas[j].Mac <= MacFimReevo) then begin
            Contrato.Series[i].Parcelas[j].ValorEmitido := 0;
            Contrato.Series[i].Parcelas[j].RARD := 0;
            Contrato.Series[i].Parcelas[j].MacEmitido := 0;
            Contrato.Series[i].Parcelas[j].SegFinEmi := 0;
            Contrato.Series[i].Parcelas[j].SegImvEmi := 0;
            Contrato.Series[i].Parcelas[j].ResiduoGeradoEmi := 0;
            Contrato.Series[i].Parcelas[j].ResiduoCobradoEmi := 0;
            Contrato.Series[i].Parcelas[j].FGTSEmi := 0;
            Contrato.Series[i].Parcelas[j].JurosEmi := 0;
            Contrato.Series[i].Parcelas[j].Flag := 0;
          end;
    finally
      Desaloca_hist(Hedit);
    end;
  finally
    Aux.free;
  end;
end;

function PegaCodReajsSerieMaiorPrazoValcomVen(Contrato : TContrato; 
                                             var CodGPre : smallint) : smallint;
var
  Prazo,
  CodG,
  i    : smallint;
  DtAncora : Tdata;
begin
  DtAncora.dia := 0;
  fillchar(DtAncora,sizeof(Tdata),0);
  CodG := 0; CodGPre := 0; Prazo := 0;
  if Contrato.MutDsk.Cad2.TemSerie then
    for i := 0 to Contrato.Series.Count -1 do begin
      if (Juliano(DtAncora)>= juliano(Contrato.Series[i].Fin.dataref)) or (Juliano(dtAncora)=0) then
      if (Contrato.Series[i].Fin.Prazo > Prazo) and
         (Contrato.Series[i].Fin.CompoeSaldo or
          Contrato.Series[i].Fin.CompoeEntrada) and
         (Contrato.Series[i].Fin.CodReaj > 0) then begin
        Prazo   := Contrato.Series[i].Fin.Prazo;
        CodG    := Contrato.Series[i].Fin.CodReaj;
        CodGPre := Contrato.Series[i].Fin.CodReajPreChaves;
        DtAncora := Contrato.Series[i].Fin.dataref;
      end;

    end
  else begin
    CodG    := Contrato.MutDsk.Financ3.CodTabelaGenerica;
    CodGPre := Contrato.MutDsk.Financ3.CodTabGPreChaves;
  end;
  Result := CodG;
end;

function PegaTaxaSerieMaisAntigaValcomVen(    Contrato : TContrato;
                                          var Data : TData):real;
var
  Taxa:real;
  I   :smallint;
begin
  Taxa := 0.00;
  fillchar(Data,sizeof(TData),0);
  if Contrato.MutDsk.Cad2.TemSerie then
    for i := 0 to Contrato.Series.Count -1 do begin
      if (i = 1) or
         ((juliano(Contrato.Series[i].Fin.dataref) <= juliano(Data)) and
          (Contrato.Series[i].Fin.CompoeSaldo or Contrato.Series[i].Fin.CompoeEntrada)) then begin
        Data := Contrato.Series[i].Fin.dataref;
        Taxa := Contrato.Series[i].Fin.txjuros;
      end;
  end;
  Result := Taxa;
end;

procedure TContrato.LeDataUltimaSubrogacao(Var DtUltimaSubRogacao : Tdata);
var
  i : smallint;
begin
  fillchar(DtUltimaSubRogacao,sizeof(Tdata),0);
  i := HistMem[0].tam;
  while (i > 0) and (DtUltimaSubRogacao.dia = 0) do begin
    if HistMem[i].Log.Codmov = 22 then DtUltimaSubRogacao := HistMem[i].Log.Data;
    dec(i);
  end;
end;

procedure TContrato.CalculaValComVenCorrJur(var RPARef   : TpRPA;
                                                DataRef  : Tdata;
                                            var ValComVenAtu,
                                                Corr,
                                                Jur : real;
                                            var DtIniCorr : tdata;
                                            var TxJuros : real;
                                            var CodTabPreChv,
                                                CodTab : smallint;
                                            var DefReajPreChv,
                                                DefReaj : byte;
                                            Var IndCorr : real);
var
  RPAConsRef : TpRPA;
  JMoraAux,
  JContrAux : real;
  Fator     : real;
  NDias     : smallint;
  DiasMes   : Byte;
  ValComVenAtuCorr : real;
  DtUltimaSubRogacao : Tdata;
  UF : str3;
  CodMun : smallint;
begin
  JMoraAux := 0;
  JContrAux := 0;
  DtUltimaSubRogacao.dia := 0; DtUltimaSubRogacao.mes := 0; DtUltimaSubRogacao.ano := 0;
  UF := '';
  CodMun := 0;
  ValComVenAtu := MutDsk.cad.ValComVen;
  RPAConsRef := RPARef;
  CodTab := PegaCodReajsSerieMaiorPrazoValcomVen(self,CodTabpreChv);
  TxJuros := PegaTaxaSerieMaisAntigaValcomVen(self,DtIniCorr);
  if MutDsk.Financ.TxJuros > Zero then
    TxJuros := MutDSK.financ.TxJuros;
  if Juliano(MutDsk.Financ.DtAssin) > 0 then
    DtIniCorr := MutDsk.Financ.DtAssin;
  if juliano(DtIniCorr) <= 0 then DtIniCorr := RPAConsRef.FinRPA.DtAssin;
  LeDataUltimaSubrogacao(DtUltimaSubRogacao);
  if DtUltimaSubRogacao.dia > 0 then
    DtIniCorr := DtUltimaSubrogacao;
  if ( CodTab > 0 ) and (RPAConsRef.Temp10.CodTabGCorr=0 ) then begin
    RPAConsRef.Temp10.CodTabGCorr := CodTab;
    RPAConsRef.Temp10.CodTabGPreChvCorr := CodTabPrechv;
    RPAConsRef.Temp12.DefReajCorr := DefReaj;
    RPAConsRef.Temp12.DefReajPreChvCorr := DefReajPreChv;
  end
  else begin
    CodTab := RPAConsRef.Temp10.CodTabGCorr;
    CodTabPreChv := RPAConsRef.Temp10.CodTabGPreChvCorr;
    DefReaj := RPAConsRef.Temp12.DefReajcorr;
    DefReajPreChv := RPAConsRef.Temp12.DefReajPreChvCorr;
  end;
  NDias   := Juliano(DataRef)-Juliano(DtIniCorr);
  DiasMes := Dias_Mes(Mes_Int(DtIniCorr.mesano));                
  if abs(DiasMes) > 0 then begin
    Fator   := Pot(RPAConsref.Finrpa.IndJuros+1,1/DiasMes);
    Fator   := pot(Fator,NDias) -1;
  end
  else
    Fator := 0;

  ObtemMunicipioParaCobranca(UF,CodMun);
  Corr    := CorrecaoJMJCChaves( MutDsk,UF,CodMun,
                                 ValComVenAtu,
                                 DtIniCorr,
                                 DataRef,
                                 RPAConsRef.FinRPA.IndJuros,
                                 RPAConsRef.FinRPA.TMora,JMoraAux,JContrAux,
                                 RPAConsRef.Temp10.CodTabGPreChvCorr,
                                 RPAConsRef.Temp10.CodTabGCorr,
                                 false,false,
                                 DefReajPreChv,DefReaj{0});
  if Abs(ValComVenAtu) > zero then
    IndCorr := Corr/ValComVenAtu
  else
    IndCorr := 1.0;
  AjustaMoeda2(mes_int(DtIniCorr.MesAno),
               mes_int(DataRef.MesAno),ValComVenAtu);

  ValComVenAtuCorr := ValComVenAtu + Corr;
  if Fator > Zero then
    Jur := Fator * ValComVenAtuCorr
  else
    Jur := sfhlib.CalcjurosProrata(ValComVenAtuCorr,Indice_Juros(TxJuros),DtIniCorr,DataRef);
end;

