function TContrato.ObtemValoresPorMac(Mac : integer) : TValoresPorMac;
begin
  if mac < FValoresPorMacList.count then begin
    if assigned(FValoresPorMacList[Mac]) then
      result := TValoresPorMac(FValoresPorMacList[Mac])
    else if (FIniValoresPorMac > -1) and assigned(FValoresPorMacList[FIniValoresPorMac]) then
      result := TValoresPorMac(FValoresPorMacList[FiniValoresPorMac])
    else
      raise exception.create(' ndice n o calculado para '+MAC_Str(MAC)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
  end
  else
    raise exception.create(' ndice n o calculado para '+MAC_Str(MAC)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
end;

function TContrato.ObtemValoresPorMACInicial : TValoresPorMAC;
begin
  result := nil;
  if (FIniValoresPorMac > -1) and assigned(FValoresPorMacList[FIniValoresPorMac]) then
    result := TValoresPorMac(FValoresPorMacList[FiniValoresPorMac]);
end;

function RpaNaoOk (      Mac    : smallint;
                   const MutDsk : TpMutDsk; 
                         RpaCtr : TpCtr;
                         RpaMac : smallint;
                         RpaDtRpa : TData;
                         RpaCodErro : smallint;
                         RpaVersao  : str3): boolean;
begin
  result := (RpaCtr <> MutDsk.Cad.Ctr) or (RPAMAC <> Mac) or
            (juliano(MutDsk.Cad.DtReimp) >= Juliano(RPADtRpa)) or
            (juliano(MutDsk.Cad.DtRevisao) >= Juliano(RPADtRpa)) or 
            (RPACodErro > 0) or
            (RPAVersao <> copy(smv.versaoC,1,3));
end;

function TContrato.ObtemRpa(Mac : Integer):TpRpa;
var
  RpaAux      : TpRpa;
  DeveEvoluir : boolean;
  i           : smallint;
  BrowseRpa   : TBrowseRpa;
begin
  result.Ctr := '';
  fillchar(result,sizeof(result),0);
  RpaAux.Ctr := '';
  fillchar(RpaAux,sizeof(TpRpa),0);
  BrowseRpa := TBrowseRpa.create;
  BrowseRpa.Mac := Mac;
  BrowseRpa.Ctr := MutDsk.Cad.Ctr;
  BrowseRpa.Abre;
  while not BrowseRpa.eof do begin
    BrowseRpa.Le(RpaAux);
    RpaAux.FinRpa.DtInFin.Dia := RpaAux.Temp12.DiaInFin;
    if RpaAux.Temp8.CodSerie = -1 then RpaF := RpaAux
    else if RpaAux.Temp8.CodSerie = 0 then Rpa := RpaAux
    else if Series.indexof(RpaAux.Temp8.CodSerie) >= 0 then
      Series[Series.indexof(RpaAux.Temp8.CodSerie)].RpaS := RpaAux;
    BrowseRpa.Proximo;
  end;
  BrowseRpa.fecha;
  BrowseRpa.free;

  DeveEvoluir := RpaNaoOk(Mac,MutDsk,Rpa.Ctr,Rpa.Mac,Rpa.DtRpa,Rpa.CodErro,Rpa.ValRpa.Versao);

  if TemFinancDinamico(MutDsk) then begin
    if (not MutDsk.Cad2.TemSerie) then RPAF := RPA;
    DeveEvoluir := DeveEvoluir or RpaNaoOk(Mac,MutDsk,RpaF.Ctr,RpaF.Mac,RpaF.DtRpa,RpaF.CodErro,RpaF.ValRpa.Versao);
  end;

  for i := 0 to Series.Count-1 do 
    DeveEvoluir := DeveEvoluir or RpaNaoOk(Mac,MutDsk,Series[i].RpaS.Ctr,
                   Series[i].RpaS.Mac,Series[i].RpaS.DtRpa,Series[i].RpaS.CodErro,
                   Series[i].RpaS.ValRpa.Versao);

 
  if DeveEvoluir then begin
    InicRpa;
    while RPA.MAC < Mac do Evolui;
  end
  else begin
    RPAF.Temp8.CodSerie := 0;
    RPA.Temp8.CodSerie := -2;
    if RPAF.Ctr <= '' then RPAF.Ctr := RPA.Ctr;
    {
      112381
      Para eu saber se o RPA foi lido do disco e n o gerado por evolu  o, 
      vou setar a flag FLeuRPADoDisco.
    }
    FLeuRPADoDisco := true;
  end;
  result := Rpa;
end;


