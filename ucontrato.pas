            RPAF.Temp11.DtPrimAtrasoCtb := RPAF.FinRPA.DtAssin
        end;
    end;
    Rpa     := RpaF;
    if (not TemFinancDinamico(MutDsk)) and (RPAF.MAC < MACSalvo) then begin
