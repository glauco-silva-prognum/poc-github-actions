procedure TParcelasSerie.CriaQryLerParcelasSerie;
var
  DBRegistro : TDBRegistro;
  DBObjeto : TDBobjeto;
begin
  if assigned(gQryLerParcelasSerie) and
     (gQryLerParcelasSerie.SqlConnection <> SqlConnectionParcelas) then
    FreeAndNil(gQryLerParcelasSerie);

  if not assigned(gQryLerParcelasSerie) then begin
    gQryLerParcelasSerie := TFastSqlQuery.create(nil);
    gQryLerParcelasSerie.SqlConnection := SqlConnectionParcelas;
    gQryLerParcelasSerie.sql.add('select');

    DBRegistro := TDBRegistroParcelas.create;
    try
      DBRegistro.GeraSelectStringsComAlias(gQryLerParcelasSerie.Sql,'P');
    finally
      DBRegistro.free;
    end;
    
    gQryLerParcelasSerie.Sql.add(',');

    DBRegistro := TDBRegistroPagamentos.create;
    try
      DBRegistro.GeraSelectStringsComAlias(gQryLerParcelasSerie.Sql,'PG');
    finally
      DBRegistro.free;
    end;

    gQryLerParcelasSerie.Sql.add(',');

    DBObjeto := TInfoPagamentosObj.create;
    try
      DbObjeto.GeraSelectStringsComAlias(gQryLerParcelasSerie.Sql,'IP');
    finally
      DbObjeto.free;
    end;

    gQryLerParcelasSerie.Sql.add(',');

    DBObjeto := TDescontoConcedidoObj.create;
    try
      DbObjeto.GeraSelectStringsComAlias(gQryLerParcelasSerie.Sql,'DC');
    finally
      DbObjeto.free;
    end;

    gQryLerParcelasSerie.Sql.add(',');

    DBRegistro := TDBRegistroPagamentosParciais.create;
    try
      DBRegistro.GeraSelectStringsComAlias(gQryLerParcelasSerie.Sql,'PP');
    finally
      DBRegistro.free;
    end;

    gQryLerParcelasSerie.sql.add('FROM PARCELAS P');
    gQryLerParcelasSerie.sql.add('LEFT JOIN PAGAMENTOS PG ON PG.TIPOPARC=P.TIPO AND PG.CODPARC=P.CODIGO AND PG.NUMPARC=P.SEQ');
    gQryLerParcelasSerie.sql.add('LEFT JOIN INFO_PAGAMENTOS IP ON IP.CO_CONTRATO=PG.CO_CONTRATO AND IP.NOSSONUM=PG.NOSSONUM');
    gQryLerParcelasSerie.sql.add('LEFT JOIN DESCONTO_CONCEDIDO DC ON DC.CO_SERIE=P.CODIGO AND DC.MAC='+MontaFieldDataToMac(gQryLerParcelasSerie.SqlConnection,'P.DTVENC'));
    gQryLerParcelasSerie.sql.add('LEFT JOIN PAGAMENTOS_PARCIAIS PP ON PP.TIPOCTR=PG.TIPOCTR and PP.CO_CONTRATO=PG.CO_CONTRATO and PP.TIPOPARC=PG.TIPOPARC and PP.CODPARC=PG.CODPARC and PP.NUMPARC=PG.NUMPARC');
    gQryLerParcelasSerie.sql.add('where P.CO_BASE=:cobase AND P.CODIGO=:codigo');
    gQryLerParcelasSerie.sql.add('order by P.CO_BASE, P.CODIGO, P.TIPO, P.SEQ, PP.SEQPAG');
    gQryLerParcelasSerie.Parambyname('cobase').DataType := ftinteger;
    gQryLerParcelasSerie.Parambyname('codigo').DataType := ftinteger;
//gQryLerParcelasSerie.sql.savetofile('qry.sql');
    gQryLerParcelasSerie.prepared := true;
  end;
end;

procedure TParcelasSerie.Le(Ctr : TpCtr; RegSerie : TpSeries; DataRef : Tdata);
var
  SqlConnection : TSqlConnection;
  CoBase : integer;
  DBRegistroParcelas : TDBRegistroParcelas;
  DBRegistroPagamentos : TDBRegistroPagamentos;
  DBRegistroPagamentosParciais : TDBRegistroPagamentosParciais;
  RegParcela : TpParcelas;
  RegValPgto : TpValPgto;
  RegValPgtoParcial : TpValPgtoParcial;
  InfoPagamentosObj : TInfoPagamentosObj;
  DescontoConcedidoObj : TDescontoConcedidoObj;
  wParcela,
  wParcelaAnt : TParcelaSerie;
  offset : integer;
begin
  Self.Clear;

  CriaQryLerParcelasSerie;

  SqlConnection := GetSqlConnection(PegaDirCor);
  CoBase := PegaCoBase(SqlConnection);

  if gQryLerParcelasSerie.Active then
    gQryLerParcelasSerie.close;

  gQryLerParcelasSerie.parambyname('Codigo').asinteger := RegSerie.CodSerie;
  gQryLerParcelasSerie.parambyname('CoBase').asinteger := coBase;

  gQryLerParcelasSerie.open;

  DBRegistroParcelas := TDBRegistroParcelas.create;
  DbRegistroPagamentos := TDbRegistroPagamentos.create;
  InfoPagamentosObj := TInfoPagamentosObj.create;
  DescontoConcedidoObj := TDescontoConcedidoObj.create;
  DBRegistroPagamentosParciais := TDBRegistroPagamentosParciais.create;
  try

    wParcelaAnt := nil;
    while not gQryLerParcelasSerie.eof do begin

      RegParcela.seq := 0;
      fillchar(RegParcela,sizeof(TpParcelas),0);
      RegValpgto.tipoctr := 0;
      fillchar(RegValPgto,sizeof(TpValPgto),0);
      InfoPagamentosObj.clear;
      DescontoConcedidoObj.clear;
      RegValpgtoParcial.tipoctr := 0;
      fillchar(RegValpgtoParcial,sizeof(TpValPgtoParcial),0);

      wParcela := nil;
      offSet := 0;

      offset := DbRegistroParcelas.QryToReg(gQryLerParcelasSerie,RegParcela,Offset);

      if (RegParcela.Codigo > 0) then begin

{
  CONCEITO SOBRE PARCELAS DE SEGURO
    Todas as parcelas de seguro s o criadas no sistema.
    Ou fazem parte de uma parcela de presta  o j  lida, devido ao parcelas.dat, ou
    fazem parte de um pagamento de seguro, ou s o criadas durante a evolu  o.
    A vari vel "parceladomes" da evolu  o ent o pode conter presta  o+seguro ou apenas o seguro.
    Al m disso, tamb m   criada uma parcela no contrato para todos os pagamentos de seguro feitos a parte.
    Estas parcelas s o identificadas como seq=0. Assim,   poss vel buscar um pagamento apenas do seguro,
    pela rotina ObtemParcelaDeSeguroPorMAC.
}

{  Sol. 44826 - devido a necessidade de gravar valores de seguro no parcelas.dat, para parcelas
                s  de seguro, agora se faz necess rio gravar parcelas de seguro mesmo n o pagas.
                Da mesma forma, agora   preciso ler tais parcelas
                IMPORTANTE: as parcelas de seguro v o ser gravadas com seq=mac devido ao sequencial
                            fazer parte da chave, e n o poder ser gravado como zero, no entanto,
                            para manter a integridade do sistema, a evolu  o vai continuar a considerar
                            o seq da parcela de seguro como zero }

// Todas as parcelas de seguro, pagas a parte s o lidas, de forma a ser poss vel verificar seu pagamento
// Parcelas apenas de seguro sempre ter o o seq zerado, sendo poss vel ent o verificar o tipo de parcela
// Al m deste teste agora   poss vel testar pelo Tipoparc 7
// Pagamentos de seguro apenas, no valpgto(tipoparc 7) tem no numparc o mac, pois
// para s ries n o mensais, n o h  numparc diferente, n o sendo poss vel saber a que m s o
// pagamento pertece
// Sol. 27917


        offset := DbRegistroPagamentos.QryToReg(gQryLerParcelasSerie,RegValPgto,offset);
        offset := InfoPagamentosObj.LeFastSqlQuery(gQryLerParcelasSerie,OffSet);
        offset := DescontoConcedidoObj.LeFastSqlQuery(gQryLerParcelasSerie,OffSet);

        if RegParcela.Tipo in [TpParc_SoSeguro,TpParc_Series] then begin
          if not assigned(wParcelaAnt) or
             (wParcelaAnt.Seq <> RegParcela.Seq) then begin // mudou a parcela

            if assigned(wParcelaAnt) then
              wParcelaAnt.AcertaPagamentosParciais; // acertar detalhes ap s ler todas as antecipa  es

            // devido ao order by, as parcelas normais(6) v o ser lidas ANTES das parcelas de seguro(7)
            if RegParcela.Tipo = TpParc_SoSeguro then begin
              wParcela := ObtemParcelaPorMAC(RegValPgto.NumParc) as TParcelaSerie;
              if assigned(wParcela) then
                wParcela.LeDetalhesPagSeguro(DataRef,RegValpgto);
              wParcela := CriaParcelaSeguro(DataRef,RegSerie,RegParcela,RegValPgto,InfoPagamentosObj,DescontoConcedidoObj)
            end
            else begin // TpParc_Series
              wParcela := CriaParcela(DataRef,RegSerie,RegParcela,RegValPgto,InfoPagamentosObj,DescontoConcedidoObj);
            end;  
          end
          else // se for um pagamento parcial, n o vai mudar a parcela
            wParcela := wParcelaAnt;


          DbRegistroPagamentosParciais.QryToReg(gQryLerParcelasSerie,RegValPgtoParcial,offset);

          if (RegValPgtoParcial.SeqPag > 0) and
             (juliano(RegValPgtoParcial.DtPg) > 0) and
             (not (RegValPgtoParcial.TipoPg in [8,9,66,95])) and
             ((DataRef.dia = 0) or (Juliano(RegValPgtoParcial.DtPg) <= Juliano(DataRef))) then
            wParcela.PagamentosParciais.AddValPgtoParcial(RegValPgtoParcial);
        end;
      end;

      wParcelaAnt := wParcela;

      gQryLerParcelasSerie.next;
    end;

    if assigned(wParcelaAnt) then
      wParcelaAnt.AcertaPagamentosParciais; // acertar detalhes ap s ler todas as antecipa  es

  finally
    gQryLerParcelasSerie.close;
    DBRegistroParcelas.free;
    DBRegistroPagamentos.free;
    InfoPagamentosObj.free;
    DescontoConcedidoObj.free;
    DBRegistroPagamentosParciais.free;
  end;
end; 
