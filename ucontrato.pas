function TpJurosDaSerie(Contrato : TContrato; CodSerie : integer) : integer;
var
  index : integer;
begin
  if CodSerie = 0 then // Financ. Dinamico
    result := 2
  else begin
    index := Contrato.Series.indexof(CodSerie);
    if index >= 0 then
      result := Contrato.Series[index].Fin.TpJuros
    else
      result := 0;
  end;
end;

function ObtemTxJurosEfetivaAnual(txJuros : Real; TpJuros : byte) : real;
begin
  case TpJuros of
    1 : result := (Pot((TxJuros/100)+1,12)-1)*100;
    2 : result := (pot((txjuros/1200)+1,12)-1)*100;
    3 : result := txjuros;
    4 : result := (pot((txjuros/100)+1,12)-1)*100;
    5 : result := TxJuros*12;
    6 : result := txjuros;
    7 : result := txjuros;
    else result := 0;
  end;
end;

procedure RecalculaParcelas(Contrato : TContrato; Serie : TSerie; Txjuros : real);
var
  RegSerie : TpSeries;
  ArrayDeParcelas : TpArrayDeParcelas;
  p : integer;
  i : integer;
  Parcela : TParcelaSerie;
  DtProxPrest : TData;
begin
  // RPA posicionado no m s onde as altera  es foram feitas, n o no m s que ser  alterado
  // Tanto alt. de juros quanto incorpora  o s  afetam a presta  o seguinte

  DtProxPrest := Serie.Fin.dataRef;
  while mes_int(DtProxPrest.mesano) <= Serie.RPAs.Mac do
    Int_Mes(Mes_Int(DtProxPrest.MesAno)+Serie.Fin.PerParcelas,DtProxPrest.MesAno);

  // o rec lculo das parcelas seguintes a uma altera  o de taxa de juros, ou incorpora  o
  // ser  o mesmo que criar uma nova s rie nas mesmas condi  es, com o saldo e prazo ajustados

  ArrayDeParcelas[0].Chave.Tam := 0;
  fillchar(ArrayDeParcelas,sizeof(TpArrayDeParcelas),0);

  // usa a s rie original como base para a nova expans o de parcelas
  RegSerie := Serie.fin;
  RegSerie.AmaisjIni := 0;

  // Considera as altera  es de incorpora  o e tx de juros

  // O saldo deste m s j  deve ter o valor incorporado
  RegSerie.Valor := Serie.RPAS.ValRPA.SaldoDev;
  
  if TxJuros > 0 then
    RegSerie.TxJuros := TxJuros;

  // A nova s rie ter  o prazo remanescente como prazo
  RegSerie.Prazo := Serie.RPAS.FinRPA.Prazo-Serie.RPAS.FinRPA.NPC;

  // DataRef vai ser o m s onde houve a incorpora  o ou altera  o de tx juros
  RegSerie.DataRef.dia := Serie.RPAS.FinRPA.diavenc;
  int_mes(Serie.RPAS.Mac,RegSerie.DataRef.mesano);

  // As altera  es afetam apenas a pr xima presta  o
  RegSerie.DtInicio := DtProxPrest;

  // gera uma nova expans o de s ries
  MontaParcelas(Contrato.MutDsk,Regserie,ArrayDeParcelas);

  // usa a nova expans o como continua  o da s rie atual

  for i := 1 to ArrayDeparcelas[0].chave.tam do begin
    Parcela := TParcelaserie(Serie.Parcelas.ObtemParcelaPormac(mes_int(ArrayDeparcelas[i].dtVenc.MesAno)));
    if Assigned(parcela) then begin
      // Todos os valores devem ser ajustados para a dataref original da s rie
      Parcela.valor := ArrayDeparcelas[i].encargo/Serie.RPAS.Temp3.IndSaldoAcum;
      Parcela.AmaisJSwap := ArrayDeparcelas[i].AmaisJSwap/Serie.RPAS.Temp3.IndSaldoAcum;
      Parcela.RardSwap := ArrayDeparcelas[i].RardSwap;
      Parcela.Modificado := true;
    end;
  end;
end;

procedure MontaLstIncorp(Contrato : TContrato; LstIncorp : TLstIncorpSerie);
var
  CountEvo : integer;
  s : integer;
  ev : integer;
  ValorIncorp : real;
  DtIncorp : Tdata;
begin
  Contrato.InicRpa;
  countevo := 0;
  while Ctr_Ativo(contrato.rpa) and (countevo < maxevoatr) do begin
    inc(CountEvo);
    for s := 0 to Contrato.series.count-1 do
      for ev := 0 to Contrato.Series[s].ListaEventosAmInc.count-1 do
        if Contrato.Series[s].ListaEventosAmInc[ev].ExAmInc in [18,102] then begin
          Int_Mes(Contrato.Series[s].RPAS.Mac,DtIncorp.MesAno);
          DtIncorp.dia := Contrato.Series[s].ListaEventosAmInc[ev].DiaEvento;
          ValorIncorp := Contrato.Series[s].ListaEventosAmInc[ev].ValorAmInc;
          if (DtIncorp.dia > 0) and (abs(ValorIncorp) > zero) then
            LstIncorp.add(Contrato.Series[s].fin.codserie,DtIncorp,ValorIncorp);
        end;
    Contrato.Evolui;
  end;
end;

function IncorporacoesNoMes(DtVenc : TData; CodSerie : integer; LstIncorp : TLstIncorpSerie) : real;
var
  idx : integer;
  i : integer;
begin
  result := 0;
  if assigned(LstIncorp) then begin
    idx := LstIncorp.indexof(Codserie);
    if idx >= 0 then begin
      for i := 0 to LstIncorp[idx].count-1 do
        if mes_int(LstIncorp[idx][i].DtIncorp.mesano) = mes_int(DtVenc.mesano) then
          result := result + LstIncorp[idx][i].ValorIncorp
        else if mes_int(LstIncorp[idx][i].DtIncorp.mesano) > mes_int(DtVenc.mesano) then
          break;
    end;
  end;
end;

procedure RegeraParcelas(Contrato : Tcontrato; LstSerie : TStrings; DtIniRecalculo : Tdata; Grava : boolean = false);
type
  TArrSerieRecalc = Array of TpSerieRecalc;
var
  LstIncorp : TLstIncorpSerie;
  s,p : integer;
  LstAltJuros : TLstAltJuros;
  DtVenc : Tdata;
  QtdEvo : integer;
  idx : integer;
  Qry : TSqlQuery;
  UsaArqPrestTemp : boolean;
  ValIncorp : real;
  ArrSerieRecalc : TArrSerieRecalc;
begin
{$IFDEF FPC}
  ArrSerieRecalc := default(TArrSerieRecalc);
{$ENDIF}
  valIncorp := 0;
  if (LstSerie.count > 0) and (Contrato.series.count > 0) then begin
    setLength(ArrSerieRecalc,Contrato.series.count);
    for s := 0 to Contrato.series.count-1 do begin
      idx := LstSerie.indexof(inttostr(Contrato.series[s].fin.codserie));
      if idx >= 0 then
        ArrSerieRecalc[s].serie := Contrato.Series[s];
      ArrSerieRecalc[s].ValIncorp := 0;
    end;
    UsaArqPrestTemp := scciconf.UsaArqPrest;
    try
      LstIncorp := TLstIncorpSerie.create;
      LstAltJuros := TLstAltJuros.create;
      try
        LstAltJuros.LeEventos(Contrato.Histmem);
        MontaLstIncorp(Contrato,LstIncorp);

        if DtIniRecalculo.dia > 0 then begin

          // Evolui com arquivo de presta  es at  o m s da altera  o
          // O RPA deve ficar posicionado no m s da altera  o, requisito da RecalculaParcelas,
          // e n o no m s que ser  recalculado (o dat de alt. tx juros   cadastrado para o m s seguinte).

          Contrato.InicRpa;
          while contrato.rpa.mac < mes_int(DtIniRecalculo.mesano)-1 do begin
            for s := 0 to Length(ArrSerieRecalc)-1 do
              if assigned(ArrSerieRecalc[s].Serie) and ArrSerieRecalc[s].Serie.RPAs.Temp10.TemParcNoMes then begin
                DtVenc.dia := ArrSerieRecalc[s].Serie.RPAS.FinRPA.DiaVenc;
                int_mes(ArrSerieRecalc[s].Serie.RPAS.Mac,DtVenc.MesAno);
                ArrSerieRecalc[s].ValIncorp := IncorporacoesNoMes(DtVenc,ArrSerieRecalc[s].Serie.fin.CodSerie,LstIncorp); // incorpora  o s  na parcela seguinte
              end;
            Contrato.Evolui;
          end;
          if assigned(ArrSerieRecalc[s].Serie) and ArrSerieRecalc[s].Serie.RPAs.Temp10.TemParcNoMes then begin
            DtVenc.dia := ArrSerieRecalc[s].Serie.RPAS.FinRPA.DiaVenc;
            int_mes(ArrSerieRecalc[s].Serie.RPAS.Mac,DtVenc.MesAno);
            ArrSerieRecalc[s].ValIncorp := IncorporacoesNoMes(DtVenc,ArrSerieRecalc[s].Serie.fin.CodSerie,LstIncorp); // incorpora  o s  na parcela seguinte
          end;
        end
        else begin
          // no caso das altera  es serem no in cio do contrato
          // n o est  totalmente tratado
          Contrato.InicRpa;
        end;

        for s := 0 to Length(ArrSerieRecalc)-1 do
          if assigned(ArrSerieRecalc[s].Serie) then begin
            // recalcular se houver uma alt. de taxa de juros, ou uma incorpora  o
            // ou   o mac do in cio do recalculo (pode ser uma exclus o de hist. de alt. juros ou incorpora  o)
            idx := LstAltJuros.indexOf(ArrSerieRecalc[s].Serie.fin.codserie,ArrSerieRecalc[s].Serie.RPAs.Mac+1);
            if idx >= 0 then
              RecalculaParcelas(Contrato,ArrSerieRecalc[s].Serie,LstAltJuros[idx].Txjuros)
            else if ArrSerieRecalc[s].ValIncorp > zero then
              RecalculaParcelas(Contrato,ArrSerieRecalc[s].Serie,0{TxJurosAlt});
          end;

      finally
        LstIncorp.free;
        LstAltJuros.free;
      end;
    finally
      scciconf.UsaArqPrest := UsaArqPrestTemp;
    end;

    if Grava then begin
      Qry := TSqlQuery.create(nil);
      try
        Qry.SqlConnection := GetSqlConnection(PegaDirCor);

        Qry.sql.beginUpdate;
        try
          Qry.sql.add('UPDATE PARCELAS');
          Qry.sql.add('SET ENCARGO=:ENCARGO, AMAISJSWAP=:AMAISJSWAP, RARDSWAP=:RARDSWAP');
          Qry.sql.add('WHERE CO_BASE=:CO_BASE AND TIPO=:TIPO AND CODIGO=:CODIGO AND SEQ=:SEQ');
        finally
          Qry.sql.EndUpdate;
        end;

        Qry.parambyname('ENCARGO').datatype := ftfloat;
        Qry.parambyname('AMAISJSWAP').datatype := ftfloat;
        Qry.parambyname('RARDSWAP').datatype := ftfloat;
        Qry.parambyname('CO_BASE').datatype := ftinteger;
        Qry.parambyname('TIPO').datatype := ftinteger;
        Qry.parambyname('CODIGO').datatype := ftinteger;
        Qry.parambyname('SEQ').datatype := ftinteger;
        Qry.Prepared := true;

        for s := 0 to Contrato.Series.count-1 do
          for p := 0 to Contrato.Series[s].Parcelas.count-1 do
            if Contrato.Series[s].Parcelas[p].Modificado then begin
              Qry.parambyname('ENCARGO').asfloat := Contrato.Series[s].Parcelas[p].Valor;
              Qry.parambyname('AMAISJSWAP').asfloat := Contrato.Series[s].Parcelas[p].AmaisjSwap;
              Qry.parambyname('RARDSWAP').asfloat := Contrato.Series[s].Parcelas[p].RardSwap;
              Qry.parambyname('CO_BASE').asinteger := PegaCoBase(Qry.SqlConnection);
              Qry.parambyname('TIPO').asinteger := Contrato.Series[s].Parcelas[p].TipoParc;
              Qry.parambyname('CODIGO').asinteger := Contrato.Series[s].Fin.CodSerie;
              Qry.parambyname('SEQ').asinteger := Contrato.Series[s].Parcelas[p].Seq;
              Qry.ExecSql;
            end;
      finally
        Qry.free;
      end;
    end;
  end;
end;

{$ENDIF}


