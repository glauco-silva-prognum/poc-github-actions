           JMoraCorrido := ScciConf.JurosDeMoraEContratuaisPorDiasCorridos;
           ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := true;
           CorrecaoJMJCChaves(MutDsk,UF,CodMun,ValorPrest,
                              Prest.DtVencAtu,Prest.DtVencRec,
                              Reg.IndJuros,
                              TMora,DescMora,
                              DescJurosContr,
                              CodTabGPreChvCorr,
                              CodTabGCorr,
                              sfhlib.SfhDiasAtrasoCorridos{false},
                              Dados.RegCarteira.NaoCobraJurosContr,
                              DefReajPreChvCorr,
                              DefReajCorr{0},
                              true{CalculoDeAtraso},
                              reg.txjuros,
                              reg.CO_JUROS_FLUTUANTE,
                              reg.PERCACRESJURFLUT);
           ScciConf.MoraCapitaliz := MoraCap;
           ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := jMoraCorrido;
         end;

        Prest.Mora := Prest.mora + MoraAc;
        Prest.Correcao := Prest.correcao + CorrAc;
        if (Prest.TMoraPrst in [41,43..44,217,56,100,199,202,215]) and
           (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.Mora       := 0;
          Prest.MoraAmaisj := 0;
          DescMora       := 0;
          DescMoraAmaisj := 0;
          Prest.JurosContr := 0;
          Prest.JurosContrAmaisj := 0;
          DescJurosContr := 0;
          DescJurosContrAmaisj := 0;
          MoraSeguro := 0;
        end
        else if (Prest.TMoraPrst in [81..84]) and
                (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.Mora := Prest.JurosContr;
          Prest.MoraAmaisj := Prest.JurosContrAmaisj;
          DescMora := DescJurosContr;
          DescMoraAmaisj := DescJurosContrAmaisj;
          MoraSeguro := JurosContrSeguro;
        end
        else if (Prest.TMoraPrst in [68..71]) and
                (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.Mora      := Arredonda(Prest.Mora - Prest.JurosContr);
          Prest.MoraAmaisj:= Arredonda(Prest.MoraAmaisj - Prest.JurosContrAmaisj);
          DescMora      := Arredonda(DescMora - DescJurosContr);
          DescMoraAmaisj:= Arredonda(DescMoraAmaisj - DescJurosContrAmaisj);
          Prest.JurosContr:= 0;
          Prest.JurosContrAmaisj := 0;
          DescJurosContr:= 0;
          DescJurosContrAmaisj:= 0;
          MoraSeguro := Arredonda(MoraSeguro - JurosContrSeguro);
          JurosContrSeguro := 0;
        end;
        if (Prest.TMoraPrst in [100,202,205,42..44,59..60,69..70,81,84,219,221,223]) and
           (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.Correcao := 0;
          Prest.CorrecaoAmaisj := 0;
          CorrecaoSeguro := 0;
        end;
        if (Prest.TMoraPrst in [58..61,220..223]) and
           (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.Mora := int((Prest.Mora * 0.2)*100+0.5)/100;
          Prest.MoraAmaisj := int((Prest.MoraAmaisj * 0.2)*100+0.5)/100;
          DescMora := int((DescMora * 0.2)*100+0.5)/100;
          DescMoraAmaisj := int((DescMoraAmaisj * 0.2)*100+0.5)/100;
          MoraSeguro := int((MoraSeguro * 0.2)*100+0.5)/100;
        end;
        if (Prest.TMoraPrst in [202,207,209,211,213..215,43,52,55..56,60..62,70..71,81..82,217..219,222..223]) and
           (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
          Prest.IsenMora.IsenMulta := true;
        Prest.Despesas:= Prest.Despesas + CorrecaoJMJCChaves(MutDsk,UF,CodMun,
                                                             RegSemAjuste.Despesas,
                                                             Prest.DtVencAtu,Prest.DtVencRec,
                                                             Reg.IndJuros,
                                                             TMora,MDesp,JC,
                                                             CodTabGPreChvCorr,
                                                             CodTabGCorr,
                                                             sfhlib.SfhDiasAtrasoCorridos{false},
                                                             Dados.RegCarteira.NaoCobraJurosContr,
                                                             DefReajPreChvCorr,
                                                             DefReajCorr{0},
                                                             true{CalculoDeAtraso},
                                                             reg.txjuros,
                                                             reg.CO_JUROS_FLUTUANTE,
                                                             reg.PERCACRESJURFLUT);
        Prest.Despesas:= Prest.Despesas + MDesp;
      end;
      if (PrstEmAtrasoAtual(Reg.MAC,Reg.DiaVenc,DataRef,RetornaLCobrValoresPorMac(Mutdsk,Reg),Prest.EParcAcessorios{ConsideraPrstSoDeAcessorios})) and
         ((ValInt(Scciconf.NSerie) = nsLetra) or
          (ValInt(Scciconf.NSerie) in [5..8] )) then begin
        Prest.Desc := 0;
        RegPgtoParcial.Desc := 0;
      end
      else Prest.Desc := DescAux;
      if (Reg.PA = 81) or (TMora = 35) then
        Prest.PercMulta := 2.0
      else
        Prest.PercMulta := MutDsk.Cad.PercMulta;
      if (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,DataRef,RetornaLCobrValoresPorMac(Mutdsk,Reg),Prest.EParcAcessorios{ConsideraPrstSoDeAcessorios})) then
        if (not Prest.IsenMora.IsenMulta) then begin
          if (Contrato.DiasDeAtrasoEntreDatas(Prest.DtVencAtu,DataRef) > 0) then begin
            
            if ScciConf.NaoPenalizaAcessoriosNoAtraso then begin // 101894
              Valor := arredonda(Prest.TotPrest-Prest.Desc-(Reg.Seguro-Reg.DescSeg) - Reg.ValTxADm);
              if Valor < 0 then
                Valor := 0;
            end    
            else  
              Valor := Prest.TotPrest-Prest.Desc;

            ValorSeguro := Reg.Seguro-Reg.DescSeg;
            ValorAmaisj := Reg.Amaisj-Prest.ValorPagoParcialAmaisJ;

            if (MutDsk.Financ.TMora <> 101) then begin
              Valor := Valor+Prest.Correcao;
              ValorSeguro := ValorSeguro+CorrecaoSeguro;
              ValorAmaisj := ValorAmaisj+Prest.CorrecaoAmaisj;
            end;

            if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then begin
              Valor := Valor+Prest.Mora;
              ValorSeguro := ValorSeguro+MoraSeguro;
            end;

            Valor := Valor-(Prest.ValorPagoAntecipado-RegPgtoParcial.Desc);
            if (Reg.Desc > zero) and (Abs(Reg.Desc-Reg.DescSeg) <= zero) then
              ValorSeguro := ValorSeguro-(Prest.ValorPagoParcialSeguro-RegPgtoParcial.Desc)
            else
              ValorSeguro := ValorSeguro-Prest.ValorPagoParcialSeguro;
            ValorAmaisj := ValorAmaisj+Prest.MoraAmaisj;

            if (Reg.TMora in [38..40]) then begin
              Prest.Multa := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                        Prest.PercMulta,Valor,
                                        MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                        Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar});
              Prest.MultaAmaisj := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                              Prest.PercMulta,ValorAmaisj,
                                              MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                              Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar});
              if not ScciConf.NaoPenalizaAcessoriosNoAtraso then // 101894
                MultaSeguro  := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                          Prest.PercMulta,ValorSeguro,
                                          MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                          Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar});
            end
            else begin
              Prest.Multa := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                        Prest.PercMulta,Valor,
                                        MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                        Mutdsk.Cad6.DtIniCobMulta);
              Prest.MultaAmaisj := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                              Prest.PercMulta,ValorAmaisj,
                                              MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                              Mutdsk.Cad6.DtIniCobMulta);
              if not ScciConf.NaoPenalizaAcessoriosNoAtraso then // 101894
                MultaSeguro  := ValorMulta(Prest.DtVencAtu,Prest.DtVencRec,UF,CodMun,
                                          Prest.PercMulta,ValorSeguro,
                                          MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                          Mutdsk.Cad6.DtIniCobMulta);
            end;
          end;
        end;
    end;

    Prest.CorrecaoTot := Prest.Correcao;
    Prest.MoraTot := Prest.Mora;
    Prest.JurosContrTot := Prest.JurosContr;
    Prest.MultaTot := Prest.Multa;
    if ((Prest.isenMora.PercDescMora > zero) or
        (Prest.IsenMora.PercDescCorr > zero) or
        (Prest.IsenMora.PercDescMulta > zero) or
        (Prest.IsenMora.PercDescjremuneratorios > zero)) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
      if (Prest.IsenMora.PercDescCorr > zero) then begin
        Prest.DescIsenCorrecao := Prest.Correcao;
        Prest.Correcao := int((Prest.Correcao -(Prest.Correcao * (Prest.IsenMora.PercDescCorr/100)))*100+0.5)/100;
        Prest.CorrecaoAmaisj := int((Prest.CorrecaoAmaisj -(Prest.CorrecaoAmaisj * (Prest.IsenMora.PercDescCorr/100)))*100+0.5)/100;
        Prest.DescIsenCorrecao := Prest.DescIsenCorrecao - Prest.Correcao;
      end;
      if (Prest.IsenMora.PercDescMulta > zero) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.DescIsenMulta := Prest.Multa;
        Prest.Multa := int((Prest.Multa -(Prest.Multa * (Prest.IsenMora.PercDescMulta/100)))*100+0.5)/100;
        Prest.MultaAmaisj := int((Prest.MultaAmaisj -(Prest.MultaAmaisj * (Prest.IsenMora.PercDescMulta/100)))*100+0.5)/100;
        Prest.DescIsenMulta := Prest.DescIsenMulta - Prest.Multa;
        MultaSeguro := int((MultaSeguro -(MultaSeguro * (Prest.IsenMora.PercDescMulta/100)))*100+0.5)/100;
      end;
      JMoratorios    := Prest.Mora - Prest.JurosContr;
      JMoratoriosAmaisj := Prest.MoraAmaisj - Prest.JurosContrAmaisj;
      JMoratoriosSeg := MoraSeguro - JurosContrSeguro;
      DescJMoratorios    := DescMora - DescJurosContr;
      DescJMoratoriosAmaisj := DescMoraAmaisj - DescJurosContrAmaisj;
      if (Prest.IsenMora.PercDescJremuneratorios > zero) then begin
        Prest.DescIsenJurosContr := Prest.JurosContr;
        Prest.JurosContr := int((Prest.Juroscontr -(Prest.JurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        Prest.JurosContrAmaisj := int((Prest.JuroscontrAmaisj -(Prest.JurosContrAmaisj * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        Prest.DescIsenJurosContr := Prest.DescIsenJurosContr - Prest.JurosContr;
        JurosContrSeguro := int((JuroscontrSeguro -(JurosContrSeguro * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        DescJurosContr := int((DescJuroscontr -(DescJurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        DescJurosContrAmaisj := int((DescJuroscontrAmaisj -(DescJurosContrAmaisj * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
      end;
      if (Prest.IsenMora.PercDescMora > zero) then begin
        Prest.DescIsenJMoratorios := JMoratorios;
        JMoratorios := int((JMoratorios - (JMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        JMoratoriosAmaisj := int((JMoratoriosAmaisj - (JMoratoriosAmaisj*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        Prest.DescIsenJMoratorios := Prest.DescIsenJMoratorios - JMoratorios;
        JMoratoriosSeg := int((JMoratoriosSeg - (JMoratoriosSeg*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        DescJMoratorios := int((DescJMoratorios - (DescJMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        DescJMoratoriosAmaisj := int((DescJMoratoriosAmaisj - (DescJMoratoriosAmaisj*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
      end;
      if (Prest.IsenMora.PercDescJremuneratorios > zero) or (Prest.IsenMora.PercDescMora > Zero) then begin
        Prest.Mora := JMoratorios+Prest.JurosContr;
        Prest.MoraAmaisj := JMoratoriosAmaisj+Prest.JurosContrAmaisj;
        MoraSeguro := JMoratoriosSeg + JurosContrSeguro;
        DescMora := DescJMoratorios+DescJurosContr;
        DescMoraAmaisj := DescJMoratoriosAmaisj+DescJurosContrAmaisj;
      end;
    end;
    if (DescMora  > zero) then begin
     if (Prest.mora-DescMora > zero) then
       Prest.DescPagamento := Prest.Mora - DescMora
     else begin
       Prest.Mora := DescMora;
       Prest.MoraAmaisj := DescMoraAmaisj;
       DescMora := 0;
     end;
    end;

    Prest.ValorEmi := Prest.TotPrest+Prest.Correcao+Prest.Mora+Prest.Multa;
    if (ValInt(SCCIConf.NSerie) <> nsLetra) and
       (not (ValInt(Scciconf.NSerie) in [5..8])) then
      Prest.ValorEmi := Prest.ValorEmi - DescAux;

    Prest.ValorEmi := Prest.ValorEmi + Prest.Diferenca;
    Prest.Honorarios := RegAux.Honorarios;
    Prest.EncMes := Prest.TotPrest +
                    Prest.Mora     + Prest.Correcao  +
                    Prest.Multa    + Prest.Honorarios+
                    Prest.Despesas - Prest.ValorPagoAntecipado;
    DifAbat   := 0;
    if Prest.Diferenca > Zero then Prest.OutRec := Prest.Diferenca
    else DifAbat := Prest.Diferenca * -1;
    if (ValInt(scciconf.nserie) <> nsLetra) and
       (not (ValInt(Scciconf.NSerie) in [5..8])) then
      Prest.OutAbat := DifAbat + Prest.Desc
    else Prest.OutAbat := DifAbat;
    if Prest.DescPagamento > zero then Prest.OutAbat := Prest.Outabat + Prest.Descpagamento;
    Prest.ValTit := Prest.EncMes - Prest.OutAbat +
                    Prest.OutRec + Prest.ValAcordo + Prest.TaxaBanco +
                    Prest.ValIOFComplem;
    Prest.CorrMoraMultaSeg := CorrecaoSeguro + MoraSeguro + MultaSeguro;
  finally
    RegAux.free;
    RegSemAjuste.free;
  end;
  ScciConf.NaoCorrigeAts := SalvaNaoCorrigeAts;
end;

procedure TSerieFinanciamentoDinamico.CalcPrestMes(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                   Var Mutdsk : TpMutdsk;
                                                       Reg,
                                                       RegConsRef : TValoresPorMac;
                                                       Dados : TDadosAtrasoEvo;
                                                       Prest : TPrestacaoAtrasoEvo);
var
  dtv,
  DtIniPend,
  DataRefRecibo : Tdata;
begin
  DtIniPend.dia := 0; DtIniPend.mes := 0; DtIniPend.Ano := 0;
  int_mes(Reg.Mac,dtv.MesAno);
  dtv.Dia := Reg.DiaVenc;
  Prest.DtVencAtu := Dtv;
  {
    110643
    O Tmora 202 que usei para isentar encargos no c lculo de atraso (CalculaTotPrestEmAtsAteVenc)
    n o funciona sem a Prest.IsenMora.DataIsen preenchida, n o entendo pq.
  }
  if CalculoAtrasoParametros.TMora = 202 then
    Prest.IsenMora.DataIsen := CalculoAtrasoParametros.DataRef;
  TrataIsenMoraAuto(CalculoAtrasoParametros,Mutdsk,Reg,dtv,Prest);
  Prest.EmAtraso := CalculoAtrasoParametros.UsaPosicaoAtraso or
                    PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                      CalculoAtrasoParametros.DataRef,
                                      RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                      Reg.EParceladeSeguro{ConsideraPrstSoDeAcessorios});
  Prest.NDiasAtr := juliano(CalculoAtrasoParametros.Dataref)-juliano(Prest.DtVencAtu);
  if Prest.NDiasAtr < 0 then
    Prest.NDiasAtr := 0;
  Prest.EmFaseDeCarenciaFinBancChaves := false; // relevante s  para s ries
  Prest.EmCarenciaCobAtraso := false; // relevante s  para s ries
  if CalculoatrasoParametros.DtVencRecVincendasNoVencOrig and not Prest.EmAtraso then
    DataRefRecibo := dtv
  else
    DataRefRecibo := CalculoAtrasoParametros.DataRef;
  if Prest.ESeguro then begin
    CalculaDadosPrestSeguro(CalculoAtrasoParametros,MutDsk,Dados.RegCarteira,Reg,
                            Prest,Dtv,DataRefRecibo);
    Prest.PercHonorarios := Dados.PercHonorarios;
  end
  else
    CalculaDadosPrest(CalculoAtrasoParametros,MutDsk,Reg,RegConsRef,
                      Dados,Prest,Dtv,DtIniPend,DataRefRecibo);
  if (Prest.ValTit < Zero) and (Abs(Prest.ValTit) > Zero) then
    Prest.Esconde := true;
end;

procedure TSerieFinanciamentoDinamico.SelecionaMesAMes(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                       var Mutdsk : TpMutdsk;
                                                           Reg,
                                                           RegConsRef : TValoresPorMac;
                                                           DtIsenMora : TData;
                                                           Dados : TDadosAtrasoEvo);
var
  Parcela : TParcela;
  TpPg : byte;
  Prest : TprestacaoAtrasoEvo;
begin
  Parcela := Contrato.SerieF.Parcelas.ObtemParcelaPorMAC(Reg.Mac);
  if assigned(Parcela) then TpPg := Parcela.TipoPg else TpPg := 0;
  if PrstOk(CalculoAtrasoParametros,MutDsk,DtIsenMora,Reg,TpPg,false{desconsiderasuspensao}) then begin
    if Dados.SeparaSeguro then begin
      Prest := TprestacaoAtrasoEvo.create;
      Prest.Ctr := Contrato.Mutdsk.Cad.Ctr;
      Prest.ESeguro := true;
      Prest.TipoCtr := RegConsRef.TipoCtr;
      MontaPrestAtrEvoControverso(RegConsRef,Prest);
      CalcPrestMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Prest);
      if Prest.valtit > zero then
        Dados.Add(Prest);
    end;
    Prest := TprestacaoAtrasoEvo.create;
    Prest.Ctr := Contrato.Mutdsk.Cad.Ctr;
    Prest.TipoCtr := Reg.TipoCtr;
    Prest.SerieAtiva := Reg.CtrAtivo;
    Prest.EmiteAcordo := true;
    MontaPrestAtrEvoControverso(RegConsRef,Prest);
    Dados.Add(Prest);
    CalcPrestMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Prest);
    if (Reg.CodErro = 2) and ((Dados.MACErro2 > Reg.MAC) or (Dados.MACErro2 = 0)) then Dados.MACErro2 := Reg.MAC;
  end;
end;

procedure TSerieFinanciamentoDinamico.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                    Var MutDsk : TpMutDsk;
                                                        RegConsRef : TValoresPorMac;
                                                        UltimoMac : integer;
                                                        Dados : TDadosAtrasoEvo);
var
  Reg : TValoresPorMac;
  i : integer;
  DtVenc : Tdata;
  DtIsenMora : Tdata;
begin
  DtIsenMora.Dia := 0; DtIsenMora.Mes := 0; DtIsenMora.ano := 0;
  if (Mutdsk.Cad.SitCobj = 5) and (not CalculoAtrasoParametros.IgnoraAcordos) then
    Dados.Acordos.Le(Mutdsk.Cad.Ctr);
  i := mes_int(MutDsk.Financ.DtAssin.MesAno);
  if UltimoMac < 0 then
    UltimoMac := Mes_int(CalculoAtrasoParametros.dataRef.MesAno);
  while (i <= UltimoMac) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      DtVenc.Dia := Reg.DiaVenc;
      int_mes(reg.mac,DtVenc.MesAno);
      DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsenMora,MutDsk.Cad.DiaIsencao);
      SelecionaMesAMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,DtIsenMora,Dados);
    end;
    inc(i);
  end;
end;

procedure TSerieFinanciamentoDinamico.CalculaAtrasoSwap(    DataRef : TData;
                                                        var Mutdsk : TpMutdsk;
                                                        Var Amaisj,
                                                            Juros : real);
var
  Reg : TValoresPorMac;
  i : integer;
  UltimoMac : integer;
begin
  i := mes_int(MutDsk.Financ.DtAssin.MesAno);
  UltimoMac := Mes_int(dataRef.MesAno);
  while (i <= UltimoMac) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if assigned(Reg.parcelaDoMes) and not Reg.ParcelaDoMes.EstaPaga(DataRef) then begin
        Amaisj := Amaisj + Reg.AmaisJSwap;
        Juros := Juros + Reg.JuroSwap;
      end;
    end;
    inc(i);
  end;
end;

procedure TSerieFinanciamentoDinamico.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                    Var MutDsk : TpMutDsk;
                                                        RegConsRef : TValoresPorMac;
                                                        UltimoMac : integer;
                                                    Var NumPrst : integer;
                                                    Var Total,
                                                        TotalJurosMoratorios,
                                                        TotalJurosRemuneratorios,
                                                        TotalCorrecao,
                                                        TotalMulta : real;
                                                        Dados : TDadosAtrasoEvo = nil);
var
  DadosAux : TDadosAtrasoEvo;
  i : integer;
begin
  NumPrst := 0;
  Total := 0;
  TotalJurosMoratorios := 0;
  TotalJurosRemuneratorios := 0;
  TotalCorrecao := 0;
  TotalMulta := 0;

  DadosAux := TDadosAtrasoEvo.create;
  try
    CalculaAtraso(CalculoAtrasoParametros,Mutdsk,RegConsRef,UltimoMac,DadosAux);
    NumPrst := DadosAux.count;
    for i := 0 to DadosAux.count-1 do begin
      Total := Total + DadosAux[i].Valtit;
      TotalJurosMoratorios := TotalJurosMoratorios + (DadosAux[i].Mora - DadosAux[i].JurosContr);
      TotalJurosRemuneratorios := TotalJurosRemuneratorios + DadosAux[i].Juroscontr;
      TotalCorrecao := TotalCorrecao + DadosAux[i].Correcao;
      TotalMulta := TotalMulta + DadosAux[i].Multa;
      if Assigned(Dados) then
        Dados.Copy(DadosAux[i]);
    end;
  finally
    DadosAux.free;
  end;
end;

