                     TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA := TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJuros
                   else
                     TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA := uevolui3.TIR(ArrayParcelas,0);

                   if Scciconf.ConsideraJurosNaCarenciaNoCalculoDaTJEO and
                    ((Abs(ContratoLc.Mutdsk.Cad6.TaxaNaoIncorporadaFinanc) <= zero)
                                            or
                     (TJEOCompleta and (Abs(ContratoLc.Mutdsk.Cad6.TaxaNaoIncorpFinancTJEO) <= zero))
                    )                 and
                     (TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJuros > zero) and
                     (Abs(TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJuros-TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA) <= 0.00000009) then
                     TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA := TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJuros;
                except
                   TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA := 0;
                end
                else
                   TObjTxJurosCA(ListTxJurosCA.Objects[i]).TxJurosCA := 0;
                SetLength(TObjTxJurosCA(ListTxJurosCA.Objects[i]).ArrayParcelas,0);
                TObjTxJurosCA(ListTxJurosCA.Objects[i]).Qtd := 0;
              end; //if
            inc(i);
          end; //while
        end;  //if Contrato.MutDsk.Cad.Ctr > ''
      finally
        scciconf.DtAssinParaCustoAmortizado := DtAssinCA;
        ContratoLc.free;
        ListCodLog.free;
      end;
    end; //else if not Scciconf.MetodologiaDiferenciadaRecReceita
    if (Abs(Result) <= Zero) and assigned(ListTxJurosCA) and 
       (TObjTxJurosCA(ListTxJurosCA[MACRPA,CodSerie]).TxJurosCA > -1) then 
      Result := TObjTxJurosCA(ListTxJurosCA[MACRPA,CodSerie]).TxJurosCA;
    if assigned(ll) then
      ll.valores['TxJuros CA(TIR)'] := formatfloat('0.00000000',result);

  end; 

  CmTabErr := CmTabErrTemp;
end;

{$IFDEF CONSOLE}
function CalculaTJEOCompleta(Ctr : TpCtr) : real;
var
  MutDsk : TpMutDsk;
  ListTxJurosCA : TObjTxJurosCAPorMACCodSerie;
  CodSerie : integer;
  DtZerada : TData;
  Contrato : TContrato;
  MetodologiaDiferenciada : boolean;
begin
  result := 0;
  MutDsk.Cad.Ctr := '';
  fillchar(MutDsk,sizeof(TpMutDsk),0);
  ListTxJurosCA := nil;
  CodSerie := 0;
  DtZerada.Dia := 0;
  fillchar(DtZerada,sizeof(TData),0);
  MetodologiaDiferenciada := Scciconf.MetodologiaDiferenciadaRecReceita;
  Scciconf.MetodologiaDiferenciadaRecReceita := false;
  if Le_MutDsk(Ctr,MutDsk) then begin
    if ((Scciconf.DtAssinParaCustoAmortizado.Dia > 0) and
        (juliano(MutDsk.Financ.DtAssin) < juliano(Scciconf.DtAssinParaCustoAmortizado))) or
       ((not TemFinancDinamico(MutDsk)) and (not Mutdsk.Cad2.TemSerie)) then
      result := 0
    else begin
      if TemFinancDinamico(MutDsk) then
        CodSerie := 0
      else begin
        Contrato := TContrato.create;
        try
          Contrato.Le(MutDsk);
          if assigned(Contrato.Series.SeriePrincipal) then
            CodSerie := Contrato.Series.SeriePrincipal.Fin.CodSerie;
        finally
          Contrato.free;
        end;
      end;
      result := CalculaTxJurosCA(MutDsk,
                                 ListTxJurosCA,
                                 Mes_Int(MutDsk.Financ.DtAssin.MesAno), {MACRPA}
                                 CodSerie, {CodSerie}
                                 DtZerada, {DtUltEventoCA}
                                 false, {EventoAntesVenc}
                                 0, {TxJuros}
                                 true, {InibeLegLink}
                                 0, {TaxasElegiveisTJEOEvo}
                                 true, {CalcComAMaisJ}
                                 false, {SimulaCCA}
                                 0, {ValorSaldoCA}
                                 true {TJEOCompleta});
      if assigned(ListTxJurosCA) then
        FreeAndNil(ListTxJurosCA);
    end;
  end;
  Scciconf.MetodologiaDiferenciadaRecReceita := MetodologiaDiferenciada;
end;
{$ENDIF}

function TContrato.PercJurosTJEODiferenciadaProporcional(MACRef : smallint) : real;
var
  Perc : real;
