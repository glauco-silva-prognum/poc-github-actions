procedure LimpaCacheListPeJurosList;
var
  i : integer;
begin
  if assigned(gCacheListPeJurosList) then begin
    for i := 0 to gCacheListPeJurosList.count - 1 do
      gCacheListPeJurosList.objects[i].free;
    gCacheListPeJurosList.free;
  end;
end;


function CacheListPeJuros(SqlConnection : TSqlConnection; const MutDsk : TpMutDsk; limpaLista : boolean = false) : TCacheListPeJuros;
var
  indice : longint;
  CacheListPeJurosObj : TCacheListPeJuros;
begin
  if not assigned(gCacheListPeJurosList) then begin
    gCacheListPeJurosList := Classes.Tstringlist.create;
  end;
  indice := gCacheListPeJurosList.indexOf(MutDsk.cad.Ctr);

  if (indice >= 0) or (limpaLista and (gCacheListPeJurosList.count > 0)) then begin
    CacheListPeJurosObj := gCacheListPeJurosList.objects[0] as TCacheListPeJuros;
    if (CacheListPeJurosObj.Ctr <> MutDsk.cad.Ctr) or limpaLista then begin
      LimpaCacheListPeJurosList;
      gCacheListPeJurosList := Classes.Tstringlist.create;
      indice := gCacheListPeJurosList.indexOf(MutDsk.cad.Ctr);
    end;
  end;
  

  if (indice < 0) then begin
    try
      CacheListPeJurosObj := TCacheListPeJuros.create;
      CacheListPeJurosObj.Ctr := MutDsk.cad.Ctr;
      InicializaListaPeJurosTJEODiferenciadaProporcional(MutDsk,CacheListPeJurosObj.FListPeJuros);
      gCacheListPeJurosList.addobject(CacheListPeJurosObj.Ctr,CacheListPeJurosObj);
      indice := gCacheListPeJurosList.indexOf(CacheListPeJurosObj.Ctr);
    finally
    end;
  end;
  if indice >= 0 then
    result := gCacheListPeJurosList.objects[indice] as TCacheListPeJuros
  else
    result := nil;
end;

function Arredonda(Valor : real) : real;
begin
  if Abs(Valor) > Zero then begin
    if Valor > Zero then
      Result := Int(Valor * 100+0.5)/100
    else
      Result := -Int(Abs(Valor) * 100+0.5)/100;
  end else Result := 0;
end;

function R2(Valor : real) : real;
begin
  if Abs(Valor) > Zero then begin
    if Valor > Zero then 
      Result := Int(Valor * 100 +0.5)/100
    else
      Result := -Int(Abs(Valor) * 100 +0.5)/100;
  end else Result := 0;
end;

function DataEMenor(D1,D2 : TData): boolean;
begin
  if (Mes_Int(D1.MesAno) < Mes_Int(D2.MesAno)) or
    ((Mes_Int(D1.MesAno) = Mes_Int(D2.MesAno)) and 
     (D1.Dia < D2.Dia)) then 
    Result := true
  else
    Result := false;
end;

function DataEMaior(D1,D2 : TData) : boolean;
begin
  if (Mes_Int(D1.MesAno) > Mes_Int(D2.MesAno)) or
    ((Mes_Int(D1.MesAno) = Mes_Int(D2.MesAno)) and (D1.Dia > D2.Dia)) then 
    Result := true
  else
    Result := false;
end;

function DatasSaoIguais(D1,D2 : TData) : boolean;
begin
  Result := (Mes_Int(D1.MesAno) = Mes_Int(D2.MesAno)) and
            (D1.Dia = D2.Dia);
end;
 
function DataEMenorOuIgual(D1,D2 : TData) : boolean;
begin
  Result := DataEMenor(D1,D2) or DatasSaoIguais(D1,D2);
end;

function DataEMaiorOuIgual(D1,D2 : TData) : boolean;
begin
  Result := ((D1.Dia = D2.Dia) and (D1.Mes = D2.Mes) and (D1.Ano = D2.Ano))
                                  or
             (Mes_Int(D1.MesAno) > Mes_Int(D2.MesAno))
                                  or
            ((Mes_Int(D1.MesAno) = Mes_Int(D2.MesAno)) and (D1.Dia > D2.Dia));
end;

function GetTxJurosMensal(Contrato : TContrato; TxJuros : real; IndexSerie : longint = -1) : real;
begin
  Result := TxJuros;
  if IndexSerie < 0 then 
    Result := TxJuros/12
  else if assigned(Contrato.Series[IndexSerie]) then begin
    if Contrato.Series[IndexSerie].Fin.TpJuros <= 1 then
      Result := TxJuros
    else 
      Result := CalculaJuros(Contrato.Series[IndexSerie].Fin.TpJuros,
                             TxJuros,
                             Contrato.Series[IndexSerie].Fin.PerParcelas,
                             Contrato.Series[IndexSerie].Fin.JurosSimples);
  end; 
end;

