                                       Contrato : TContrato;
                                       Reg : TValoresPorMac;
                                       Prest : TPrestacaoAtrasoEvo;
                                   var RegCarteira : TpCarteira;
                                       IsentaMora,
                                       IsentaMulta,
                                       IsentaCorrecao: boolean;
                                       DtVencOrig    : TData;
                                       CodSerie      : longint;
                                       NumParcSerie  : smallint;
                                       DataRef : Tdata);

var
//DiasCarenciaMora, sol. 51401
  DiasCarenciaMulta,
  DiasCarenciaCorr : smallint;
  DtVencCarencia: TData;
  RegAux : TValoresPorMac;
begin
  RegAux := TValoresPorMac.create;
  try
    RegAux.Assign(Reg);
    RegAux.TotPrest := Reg.Seguro;
    RegAux.AmaisJ   := 0;
    RegAux.ValTxAdm := 0;
    RegAux.FCVS     := 0;
    RegAux.FGTS     := 0;
    RegAux.Desc     := 0;
    Prest.TotPrestOrig := RegAux.TotPrest;
    RegAux.AjustaRPA_2(RegAux.MAC,Mes_Int(DataRef.MesAno));
    AjustaMoeda2(RegAux.MAC,Mes_Int(DataRef.MesAno),RegAux.Reduzente);
    Prest.DtVencRec  := DataRef;
    if juliano(Prest.IsenMora.DataIsen) < juliano(Prest.DtVencRec) then
      Prest.DtIsenMora := Prest.DtVencRec
    else
      Prest.DtIsenMora := Prest.IsenMora.DataIsen;
    Prest.MacPrst      := RegAux.MAC;
    Prest.Prazo        := Reg.Prazo;
    Prest.NPC          := RegAux.NPC;
    if CodSerie <> 0 then Prest.TipoParc := 6;
    Prest.CodSerie     := CodSerie;
    Prest.Lcobr        := RetornaLCobrValoresPorMac(Contrato.MutDsk,Reg);
    Prest.TxSD         := RegAux.TxSD;
    Prest.NumParcSerie := NumParcSerie;
    Prest.DiaVenc      := RegAux.DiaVenc;
    int_mes(Prest.MacPrst,Prest.DtVenc.MesAno);
    Prest.DtVenc.Dia := Dia_Venc(Mes_Int(Prest.DtVenc.MesAno),RegAux.DiaVenc);
    Prest.Seguro       := RegAux.Seguro;
    Prest.TotPrest     := RegAux.Seguro;
    Prest.SaldoDev     := RegAux.SaldoDev;
    Prest.Reduzente    := RegAux.Reduzente;
    Prest.SegFin       := RegAux.SegFin;
    Prest.SegImv       := RegAux.SegImv;
    Prest.SegCre       := RegAux.SegCre;
    Prest.DescSeg      := RegAux.DescSeg;
    Prest.TMoraPrst    := Reg.TMora;
    if Mes_Int(DtVencOrig.MesAno) <= Mes_Int(Prest.DtVencRec.MesAno) then begin
        Prest.IsenMora.IsenMora     := IsentaMora;
        Prest.IsenMora.IsenMulta    := IsentaMulta;
        Prest.IsenMora.IsenCorrecao := IsentaCorrecao;
      if (IsentaMora) or (IsentaMulta) or (IsentaCorrecao)then begin
        Prest.IsenMora.DataIsen := Prest.DtVencRec;
      end;
{ sol. 51401
      if Contrato.Mutdsk.Financ3.DiasCarenciaJMora > 0 then
        DiasCarenciaMora := Contrato.Mutdsk.Financ3.DiasCarenciaJMora
      else
        DiasCarenciaMora := RegCarteira.DiasCarenciaJMora;
      if DiasCarenciaMora > 0 then begin
        J_Data(juliano(DtVencOrig)+DiasCarenciaMora,DtVencCarencia);
        if Contrato.DiasDeAtrasoEntreDatas(DtVencCarencia,Prest.DtVencRec) <= 0 then begin
          Prest.IsenMora.IsenMora := true;
          if Juliano(Prest.IsenMora.DataIsen) < Juliano(DtVencCarencia) then
            Prest.IsenMora.DataIsen := DtVencCarencia;
        end;
      end;
}
      if Contrato.Mutdsk.Financ3.DiasCarenciaMulta > 0 then
        DiasCarenciaMulta := Contrato.Mutdsk.Financ3.DiasCarenciaMulta
      else
        DiasCarenciaMulta := RegCarteira.DiasCarenciaMulta;
      if DiasCarenciaMulta > 0 then begin
        J_Data(juliano(DtVencOrig)+DiasCarenciaMulta,DtVencCarencia);
        if Contrato.DiasDeAtrasoEntreDatas(DtVencCarencia,Prest.DtVencRec) <= 0 then begin
          Prest.IsenMora.IsenMulta := true;
          if Juliano(Prest.IsenMora.DataIsen) < Juliano(DtVencCarencia) then
            Prest.IsenMora.DataIsen  := DtVencCarencia;
        end;
      end;
      if Contrato.Mutdsk.Financ3.DiasCarenciaAMonet > 0 then
        DiasCarenciaCorr  := Contrato.Mutdsk.Financ3.DiasCarenciaAMonet
      else
        DiasCarenciaCorr := RegCarteira.DiasCarenciaAmonet;
      if DiasCarenciaCorr > 0 then begin
        J_Data(juliano(DtVencOrig)+DiasCarenciaCorr,DtVencCarencia);
        if contrato.DiasDeAtrasoEntreDatas(DtVencCarencia,Prest.DtVencRec) <= 0 then begin
          Prest.IsenMora.IsenCorrecao := true;
          if Juliano(Prest.IsenMora.DataIsen) < Juliano(DtVencCarencia) then
            Prest.IsenMora.DataIsen := DtVencCarencia;
        end;
      end;
    end;
    if (Prest.IsenMora.TpDescMora = 1) and Prest.IsenMora.IsenCorrecao and
       Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := pgAcoIsCorrMultaDesc80PMora
    else if (Prest.IsenMora.TpDescMora = 1) and Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := pgAcoIsCorrDesc80PMora
    else if (Prest.IsenMora.TpDescMora = 1) and Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := pgAcoIsMultaDesc80PMora
    else if Prest.IsenMora.TpDescMora = 1 then
      Prest.TMoraPrst := pgAcoDesc80PMora
    else if (Prest.IsenMora.IsenMora or (Prest.IsenMora.IsenJM and Prest.IsenMora.IsenJC)) and Prest.IsenMora.IsenCorrecao and
       Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := 202
    else if (Prest.IsenMora.IsenMora or (Prest.IsenMora.IsenJM and Prest.IsenMora.IsenJC)) and Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 100
    else if (Prest.IsenMora.IsenMora or (Prest.IsenMora.IsenJM and Prest.IsenMora.IsenJC)) and Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := 215
    else if (Prest.IsenMora.IsenMora or (Prest.IsenMora.IsenJM and Prest.IsenMora.IsenJC)) then
      Prest.TMoraPrst := 199
    else if Prest.IsenMora.IsenJM and Prest.IsenMora.IsenMulta and
            Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 81
    else if Prest.IsenMora.IsenJM and Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := 82
    else if Prest.IsenMora.IsenJM and Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 84
    else if Prest.IsenMora.IsenJM then
      Prest.TMoraPrst := 83
    else if Prest.IsenMora.IsenJC and Prest.IsenMora.IsenMulta and
            Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 70
    else if Prest.IsenMora.IsenJC and Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := 71
    else if Prest.IsenMora.IsenJC and Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 69
    else if Prest.IsenMora.IsenJC then
      Prest.TMoraPrst := 68
    else if Prest.IsenMora.IsenCorrecao then
      Prest.TMoraPrst := 205
    else if Prest.IsenMora.IsenMulta then
      Prest.TMoraPrst := 214
    else if CalculoAtrasoParametros.TMora > 0 then
      Prest.TMoraPrst := CalculoAtrasoParametros.TMora;
    Prest.Honorarios := RegAux.Honorarios;
    Prest.Tipo := 'K';
  finally
    RegAux.free;
  end;
end;

procedure TSerie.CalculaDadosPrestSeguro(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                         var MutDsk : TpMutDsk;
                                             Reg,
                                             RegConsRef : TValoresPorMac;
                                             Dados : TDadosAtrasoEvo;
                                             Prest : TPrestacaoAtrasoEvo;
                                         var DtVencOrig,
                                             DtIniPend,
                                             DataRef : TData);
var
  VCorrecao,
  VMulta,
  JMoratorios,
  DescJMoratorios,
  DescJurosContr,
  DescMora,
  DifAbat       : real;
  NumParcSerie  : smallint;
  MoraCap,
  jMoraCorrido  : boolean;
  RegAux,
  RegSemReajuste : TValoresPorMac;
  VCorrMoraMultaSeg : real;
begin
  VCorrMoraMultaSeg := 0;
  VMulta := 0;
  VCorrecao := 0;
  {$IFDEF FPC}
  JMoratorios := 0;
  {$ENDIF}
  DescJurosContr := 0;
  DescMora := 0;
  RegAux := TValoresPorMac.create;
  RegSemReajuste := TValoresPorMac.create;
  try
    RegAux.assign(Reg);
    RegAux.TotPrest := Reg.Seguro;
    RegAux.AmaisJ   := 0;
    RegAux.Juro     := 0;
    RegAux.ValTxAdm := 0;
    RegAux.FGTS     := 0;
    RegAux.FCVS     := 0;
    RegAux.Desc     := 0;
    RegSemReajuste.assign(RegAux);
    RegAux.AjustaRPA_2(RegAux.MAC,Mes_Int(DataRef.MesAno));
    if assigned(Reg.ParcelaDoMes) then
      NumParcSerie := (Reg.ParcelaDoMes as TParcelaSerie).Seq
    else
      NumParcSerie := 0;

    PreencheDadosPrestSeguro(CalculoAtrasoParametros,Contrato,Reg,Prest,
                             Dados.RegCarteira,Fin.IsentaMora,Fin.IsentaMulta,
                             Fin.IsentaCorrecao,DtVencOrig,
                             -Fin.CodSerie,NumParcSerie,DataRef);

    DtVencOrig.Dia := Reg.DiaVenc;

    if EstaEmAtrasoAtualS(RegSemReajuste,DataRef) then begin
      CalculaCorrecaoMoraMultaRPAS(RegSemReajuste,MutDsk,DataRef,
                                   Prest.Correcao,
                                   Prest.Mora,
                                   Prest.JurosContr,
                                   Prest.Multa,
                                   Prest.CorrMoraMultaSeg,
                                   Dados.RegCarteira.NaoCobraJurosContr,
                                   sfhlib.SfhDiasAtrasoCorridos);
      if CalculoAtrasoParametros.EhQuitacaoDeDebito and ScciConf.CalcAtrasoComMoraSimplesEdiasCorridosParaQuitDeDebito then begin
        MoraCap := ScciConf.MoraCapitaliz;
        ScciConf.MoraCapitaliz := false;
        JMoraCorrido := ScciConf.JurosDeMoraEContratuaisPorDiasCorridos;
        ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := true;
        CalculaCorrecaoMoraMultaRPAS(RegSemReajuste,MutDsk,DataRef,
                                     VCorrecao,
                                     DescMora,
                                     DescJurosContr,
                                     VMulta,
                                     VCorrMoraMultaSeg,
                                     Dados.RegCarteira.NaoCobraJurosContr,
                                     sfhlib.SfhDiasAtrasoCorridos);
        ScciConf.MoraCapitaliz := MoraCap;
        ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := jMoraCorrido;
      end;
      if (Prest.TMoraPrst in [202,207,209,211,213..215,43,52,55..56,60..62,70..71,81..82,217..219,222..223]) and
         (DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
        Prest.IsenMora.IsenMulta := true;
      if (Prest.TMoraPrst in [41,43..44,217,56,100,199,202,215]) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.Mora       := 0;
        DescMora := 0;
        Prest.JurosContr := 0;
        DescJurosContr := 0;
      end
      else if (Prest.TMoraPrst in [81..84]) and
              (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.Mora := Prest.JurosContr;
        DescMora := DescJurosContr;
      end
      else if (Prest.TMoraPrst in [68..71]) and
              (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.Mora      := Arredonda(Prest.Mora - Prest.JurosContr);
        descMora         := Arredonda(DescMora - descJurosContr);
        Prest.JurosContr:= 0;
        descJurosContr := 0;
      end;
      if (Prest.TMoraPrst in [100,202,205,42..44,59..60,69..70,81,84,219,221,223]) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
        Prest.Correcao := 0;
      if (Prest.TMoraPrst in [58..61,220..223]) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.Mora := int((Prest.Mora * 0.2)*100+0.5)/100;
        DescMora := int((DescMora * 0.2)*100+0.5)/100;
      end;
      if Prest.IsenMora.IsenMulta and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
        Prest.Multa := 0;
      Prest.PercDescHonorarios := Prest.IsenMora.PercDescHonorarios/100;
      Prest.PercHonorarios     := Dados.PercHonorarios;
      Prest.CorrecaoTot := Prest.Correcao;
      Prest.MoraTot := Prest.Mora;
      Prest.JurosContrTot := Prest.JurosContr;
      Prest.MultaTot := Prest.Multa;
      if ((Prest.IsenMora.PercDescMora > zero) or
          (Prest.IsenMora.PercDescCorr > zero) or
          (Prest.IsenMora.PercDescMulta > zero) or
          (Prest.IsenMora.PercDescjremuneratorios > zero)) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
{        Prest.PercDescMora := Prest.IsenMora.PercDescMora;
        Prest.PercDescCorr := Prest.IsenMora.PercDescCorr;
        Prest.PercDescMulta:= Prest.IsenMora.PercDescMulta;
        Prest.PercDescjremuneratorios := Prest.IsenMora.PercDescjremuneratorios;}
        if (Prest.IsenMora.PercDescCorr > zero) then begin
          Prest.DescIsenCorrecao := Prest.Correcao;
          Prest.Correcao := int((Prest.Correcao -(Prest.Correcao * (Prest.IsenMora.PercDescCorr/100)))*100+0.5)/100;
          Prest.DescIsenCorrecao := Prest.DescIsenCorrecao - Prest.Correcao;
        end;
        if (Prest.IsenMora.PercDescMulta > zero) and
           (DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
          Prest.DescIsenMulta := Prest.Multa;
          Prest.Multa := int((Prest.Multa -(Prest.Multa * (Prest.IsenMora.PercDescMulta/100)))*100+0.5)/100;
          Prest.DescIsenMulta := Prest.DescIsenMulta - Prest.Multa;
        end;
        JMoratorios    := Prest.Mora - Prest.JurosContr;
        DescJMoratorios  := DescMora - DescJurosContr;
        if (Prest.IsenMora.PercDescJremuneratorios > zero) then begin
          Prest.DescIsenJurosContr := Prest.JurosContr;
          Prest.JurosContr := int((Prest.Juroscontr -(Prest.JurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
          Prest.DescIsenJurosContr := Prest.DescIsenJurosContr - Prest.JurosContr;
          DescJurosContr := int((DescJuroscontr -(DescJurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        end;
        if (Prest.IsenMora.PercDescMora > zero) then begin
          Prest.DescIsenJMoratorios := JMoratorios;
          JMoratorios := int((JMoratorios - (JMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
          Prest.DescIsenJMoratorios := Prest.DescIsenJMoratorios - JMoratorios;
          DescJMoratorios := int((DescJMoratorios - (DescJMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        end;
        if (Prest.IsenMora.PercDescJremuneratorios > Zero) or (Prest.IsenMora.PercDescMora > zero) then begin
          Prest.Mora := JMoratorios+Prest.JurosContr;
          DescMora := DescJMoratorios+DescJurosContr;
          Prest.CorrMoraMultaSeg := Prest.Correcao + Prest.Mora + Prest.Multa;
        end;
      end;
    end;

    if (DescMora  > zero) then begin
      if (Prest.mora-DescMora > zero) then
        Prest.DescPagamento := Prest.Mora - DescMora
      else begin
        Prest.Mora := DescMora;
        DescMora := 0;
      end;
    end;
    Prest.EncMes := Prest.Seguro   +
                    Prest.Mora     + Prest.Correcao  +
                    Prest.Multa ;
    DifAbat := 0;
    if Prest.Diferenca > Zero then Prest.OutRec := Prest.Diferenca
    else DifAbat := Prest.Diferenca * -1;
    if (ValInt(scciconf.nserie) <> nsLetra) and
       (not (ValInt(Scciconf.NSerie) in [5..8])) then
      Prest.OutAbat := DifAbat + Prest.Desc
    else Prest.OutAbat := DifAbat;
    if Prest.DescPagamento > zero then Prest.OutAbat := Prest.outAbat + Prest.Descpagamento;
    Prest.ValTit := Prest.EncMes - Prest.OutAbat +
                    Prest.OutRec + Prest.TaxaBanco;
    Prest.CorrMoraMultaSeg := Prest.Correcao + Prest.Mora + Prest.Multa;
  finally
    RegAux.free;
    RegSemReajuste.free;
  end;
end;

procedure TSerie.CalculaDadosPrest(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                   var MutDsk : TpMutDsk;
                                       Reg,
                                       RegConsRef : TValoresPorMac;
                                       Dados : TDadosAtrasoEvo;
                                       Prest : TPrestacaoAtrasoEvo;
                                   var DtVencOrig,
                                       DtIniPend,
                                       DataRef : TData);
var
  JMoratorios,
  JMoratoriosAmaisj,
  DifEmi,
  DifAbat : real;
  DiasDeAtraso : boolean;
  DtIsMora,
  DtVenc,
  DtVencCarencia: TData;
//DiasCarenciaMora,sol. 51401
  DiasCarenciaMulta,
  DiasCarenciaCorr,
  NMeses        : smallint;
  P : byte;
  RegAux : TValoresPorMac;
  TMora,
  TMoraTemp : integer;
  Desc,
  DescAux : real;
  Moracap,
  JMoraCorrido : boolean;
  VCorrecao,
  VCorrecaoAmaisj,
  VMulta,
  VMultaAmaisj,
  DescMora,
  DescMoraAmaisj,
  DescJurosContr,
  DescJurosContrAmaisj,
  DescJMoratorios,
  DescJMoratoriosAmaisj : real;
  RegSemReajuste : TValoresPorMac;
  VCorrMoraMultaSeg : real;
  PosicaoAtraso : TDadosPosicaoAtrasoItem;
  CodReajAtrasoTemp : smallint;
  DtAssinOrigSerie : TData;
begin
  if CalculoAtrasoParametros.UsaPosicaoAtraso then
    PosicaoAtraso := Contrato.DadosPosicaoAtraso.ObtemPrest(Fin.CodSerie,Reg.Mac)
  else
    PosicaoAtraso := nil;
  VCorrecao := 0;
  VMulta  := 0;
  VCorrMoraMultaSeg := 0;
  VCorrecaoAmaisj := 0;
  VMultaAmaisj := 0;
  DtIsMora.dia := 0; DtIsMora.mes := 0; DtIsMora.ano := 0;
  DescMora := 0;
  DescMoraAmaisj := 0;
  DescJurosContr := 0;
  DescJurosContrAmaisj := 0;
  TMora := Reg.TMora;
  Desc := Reg.Desc;
  DtVencOrig.Dia := Reg.DiaVenc;
  if Reg.TipoDesc in [5,9] then CalculoAtrasoParametros.ConcedeDesc := true;
  if (Scciconf.EmiteDescSobreAmaisJSoParaAdimp or
     (Reg.TipoDesc in [5,9])) and
     (Reg.PercDesc > Zero) and
     (Reg.Desc    > Zero) then begin
    if Reg.TipoDesc in [1,5,9] then
      Prest.DescSoParaAdimp := true;
    if CalculoAtrasoParametros.ConcedeDesc then begin
      if Reg.TipoDesc = 9 then begin
        DtVenc := DtVencOrig;
        DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsMora,MutDsk.Cad.DiaIsencao);
        DiasDeAtraso := (Contrato.DiasDeAtrasoEntreDatas(DtIsMora,DataRef) > 0);
        if DiasDeAtraso then SfhDiasAtrasoCorridos := false
        else if (juliano(DtIsMora) > juliano(Prest.IsenMora.DataIsen)) and
             SfhDiasAtrasoCorridos then begin
          Prest.IsenMora.DataIsen     := DtIsMora;
          Prest.IsenMora.IsenMora     := true;
          Prest.IsenMora.IsenCorrecao := true;
          Prest.IsenMora.IsenMulta    := true;
        end;
      end else DiasDeAtraso := (Contrato.DiasDeAtrasoEntreDatas(DtVencOrig,DataRef) > 0);
      if DiasDeAtraso and
       ((Reg.TipoDesc <> 5) or
        (not Prest.IsenMora.IsenMulta)) then CalculoAtrasoParametros.ConcedeDesc := false;
    end;
    if (not CalculoAtrasoParametros.ConcedeDesc) or
       (RegConsRef.TipoDesc = 4) then                 { ou se atualmente ha um hist. }
      Desc := 0;                                      { de canc. do desconto         }
  end;
  if (Reg.TipoDesc = 8) and (Desc > Zero) and
     (not CalculoAtrasoParametros.InibePerdaDescCessaoDePosse) then begin
    NMeses := NMesesAtraso(DtVencOrig,DataRef,MutDsk.Cad.DiaIsencao);
    Desc := Desc * (1 - NMeses/24);
    Desc := Int(Desc*100+0.5)/100;
  end;

  Prest.TotPrestOrig := Reg.TotPrest;
  RegAux := TValoresPorMac.create;
  RegSemReajuste := TValoresPorMac.create;;
  try
    RegAux.Assign(Reg);
    if Dados.SeparaSeguro then begin
      RegAux.Seguro   := 0;
      RegAux.SegCre   := 0;
      RegAux.SegFin   := 0;
      RegAux.SegImv   := 0;
      RegAux.DescSeg  := 0;
      RegAux.AtualizaTotPrest;
    end;
    RegSemReajuste.Assign(RegAux);
    RegAux.AjustaRPA_2(RegAux.Mac,mes_int(DataRef.MesAno));
    DescAux := Desc;
    AjustaMoeda2(RegAux.mac,mes_int(CalculoAtrasoParametros.DataRef.MesAno),DescAux);
    Prest.DtVencRec := DataRef;
    if juliano(Prest.IsenMora.DataIsen) < juliano(Prest.DtVencRec) then
      Prest.DtIsenMora := Prest.DtVencRec
    else
      Prest.DtIsenMora := Prest.IsenMora.DataIsen;
    if assigned(contrato) then
