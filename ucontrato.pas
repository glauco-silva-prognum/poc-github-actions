procedure TContrato.IncluiAmortizacaoRecalculo(DtRef  : TData;
                                               VlAmort,
                                               VlFGTS  : real;
                                               Parc    : integer);
begin
    inc(FHEvo[0].tam);
    with FHEvo[FHEvo[0].tam].Ficha do begin
      MesAno   := DtRef.MesAno;
      MarcaDat := False;
      if scciconf.CalcularAmortSemAbaterJuros then
        ValByte := 114
      else
        ValByte  := 103;
      Campo    := 46;   { EXOPC }
    end;
    inc(FHEvo[0].tam);
    with FHEvo[FHEvo[0].tam].Ficha do begin
      MesAno   := DtRef.MesAno;
      Campo    := 139;   
      MarcaDat := False;
      ValByte  := DtRef.Dia;
    end;
    inc(FHEvo[0].tam);
    with FHEvo[FHEvo[0].tam].Ficha do begin
      MesAno   := DtRef.MesAno;
      Campo    := 284;   
      MarcaDat := False;
      ValBool  := true;
    end;
    if VlAmort > zero then begin
      inc(FHEvo[0].tam);
      with FHEvo[FHEvo[0].tam].Ficha do begin
        MesAno   := DtRef.MesAno;
        Campo    := 18;   
        MarcaDat := False;
        ValReal  := VlAmort;
      end;
    end;
    if Parc > 0 then begin
      inc(FHEvo[0].tam);
      with FHEvo[FHEvo[0].tam].Ficha do begin
        MesAno   := DtRef.MesAno;
        Campo    := 79;   
        MarcaDat := False;
        Valintg  := Parc;
      end;
    end;
    if VlFGTS > 0 then begin
      inc(FHEvo[0].tam);
      with FHEvo[HEvo[0].tam].Ficha do begin
        MesAno   := DtRef.MesAno;
        Campo    := 67;   
        MarcaDat := False;
        ValBool  := true;
      end;
    inc(FHEvo[0].tam);
    with FHEvo[FHEvo[0].tam].Ficha do begin
      MesAno   := DtRef.MesAno;
      Campo    := 339;
      MarcaDat := False;
      ValBool  := true;
    end;      
  end;
end;

procedure TContrato.IncluiAmortizacao(DtRef  : TData;
                                      VlAmort,
                                      VlAmortPrest,
                                      VlFGTS  : real;
                                      Parc    : integer;
                                      RecalculaPrestacao : boolean);

var
  ChaveLog : TpChaveLogMem;
begin
  ChaveLog := 0;
  IncluiLogMem(FHistMem,MutDsk.Cad.Ctr,114,0,DtRef,'',ChaveLog);
  IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,139,DtRef.dia);
  if VlAmort > Zero then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,18,VlAmort);
  if VlAmortPrest > Zero then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,18,VlAmortPrest);
  if not scciconf.CalcularAmortSemAbaterJuros then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,284,1);
  if VlFGTS > Zero then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,67,VlFGTS);
  if Parc > 0 then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,79,Parc);
  if scciconf.CalcularAmortSemAbaterJuros then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,43,114)
  else
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,43,103);
  if RecalculaPrestacao then
    IncluiDatMem(FHistMem,ChaveLog,DtRef.MesAno,339,1);
  Processa_Hist(DtRef,FHistMem,FHEvo);
end;

