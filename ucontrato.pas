function TContrato.Ativo:boolean;
begin
  if (MutDsk.Cad.Ctr = '') then
    raise EContratoError.Create('Tentativa de utilizar a funcao Contrato.ativo sem inicilizar o rpa');
  if (MutDsk.Cad.Ctr <> Rpa.Ctr) then InicRPA;
  Result := Ctr_Ativo(Rpa) and (MsgErro = '');
end;

function TContrato.ListaPrstAtraso(DtRef : TData; DtAtr : Tdata; var ArrAtr : TArrayOfDatas; 
                                   DesconsideraSeguroEmAtr : boolean = false;
                                   ConsideraIsencao : boolean = true;
                                   ConsideraVencida : boolean = false):smallint;
var
  NAtr,i : smallint;
  EmAtr  : boolean;
  DtVenc : Tdata;
begin
  if DtAtr.dia = 0 then
    DtAtr := DtRef;
  NAtr := 0;
  setLength(arrAtr,0);
  InicRPA;
  while (Rpa.MAC <= Mes_Int(DtRef.MesAno)) and Ativo do begin
    EmAtr := false;
    if MutDsk.Cad2.TemSerie then begin
      for i := 0 to Series.Count-1 do begin
        if Ctr_Ativo(Series[i].RpaS) then 
          if assigned(Series[i].ParcelaDoMes) and 
            (Series[i].RPAS.Temp10.TemParcNoMes or 
            ((not DesconsideraSeguroEmAtr) and (Series[i].RpaS.MAC > Mes_Int(Series[i].Fin.Dataref.MesAno)))) and
           ( ((not (Series[i].Fin.FinancBancario or 
                   (Series[i].Fin.CodClassificacao = serie_Chaves))) and 
             (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero))) or
            (((Series[i].RpaS.FinRPA.NPC = 0) and
              (Series[i].RpaS.MAC > Mes_Int(Series[i].Fin.Dataref.MesAno))) and
             (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero)) or
            Series[i].ESerieFinBancChavesDevida(Series[i].RpaS.Temp10.DtHabit,DtAtr) then
            if Series[i].EstaEmAtrasoAtualS(DtAtr,ConsideraIsencao,ConsideraVencida) and (not Series[i].ParcelaDoMes.EstaPagaReal) then EmAtr := true;
      end;
      if EmAtr then inc(NAtr);
    end;
    if TemFinancDinamico(MutDsk) and Ctr_Ativo(RPAF) then begin
      if (RPA.MAC > Mes_Int(RPAF.FinRPA.DtInFin.MesAno)) and
         (RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc > zero) and
         SerieF.PrstEmAtrasoReal(RPAF,DtAtr,ConsideraIsencao,ConsideraVencida) and
         (not EmAtr) then begin
        inc(NAtr);
        EmAtr := true;
      end;
    end;
    if EmAtr then begin
      setLength(ArrAtr,NAtr);
      int_mes(RPA.Mac,DtVenc.MesAno);
      DtVenc.dia := RPA.FinRPA.diavenc;
      ArrAtr[NAtr-1] := DtVenc;
    end;
    Evolui;
  end;
  Result := NAtr;
end;

function TContrato.NumPrstAtrasoEvo( DtRef : TData;
                                     DtAtr : Tdata;
                                     DesconsideraSeguroEmAtr : boolean = false;
                                     ConsideraAgenda : boolean = false;
                                     RetornaQtdParcAtraso : boolean = false;
                                     ConsideraPrstSoDeAcessorios : boolean = false;
                                     ConsideraValoresPrest : boolean = false) : integer;
var
  i,j : integer;
  ArrAtr : TArrayOfDatas;
  LstConsolidado : THashedStringlist;
begin
  Result := 0;
{$IFDEF FPC} ArrAtr := default(TArrayOfDatas); {$ENDIF}
  LstConsolidado := THashedStringlist.create;
  try
    LstConsolidado.sorted := true;
    LstConsolidado.duplicates := dupignore;

    SetLength(ArrAtr,0);
    if DtAtr.dia = 0 then
      DtAtr := DtRef;

    SerieF.ListaPrstAtrasoEvo(DtRef,
                              DtAtr,
                              ArrAtr,
                              DesconsideraSeguroEmAtr,
                              ConsideraAgenda,
                              ConsideraPrstSoDeAcessorios,
                              ConsideraValoresPrest);
    for j := 0 to Length(ArrAtr)-1 do
      LstConsolidado.add(inttostr(mes_int(ArrAtr[j].mesano)));
    if (Length(ArrAtr) > 0) and 
       RetornaQtdParcAtraso then result := result + Length(ArrAtr);
    for i := 0 to Series.count-1 do begin
      Series[i].ListaPrstAtrasoEvo(DtRef,DtAtr,ArrAtr,DesconsideraSeguroEmAtr,ConsideraAgenda);
      for j := 0 to Length(ArrAtr)-1 do
        LstConsolidado.add(inttostr(mes_int(ArrAtr[j].mesano)));
      if RetornaQtdParcAtraso then result := Result + Length(ArrAtr);
    end;
    if not RetornaQtdParcAtraso then result := LstConsolidado.count;
  finally
    LstConsolidado.free;
  end;
end;

function TContrato.ListaPrstAtraso(DtRef : TData; var ArrAtr : TArrayOfDatas; DesconsideraSeguroEmAtr : boolean = false;
                                   ConsideraIsencao : boolean = true;
                                   ConsideraVencida : boolean = false):smallint;
var
  DtAtr : Tdata;
begin
  DtAtr.dia := 0;
  fillchar(DtAtr,sizeof(Tdata),0);
  result := ListaPrstAtraso(DtRef,DtAtr,ArrAtr,DesconsideraSeguroEmAtr,ConsideraIsencao,ConsideraVencida);
end;

procedure DeterminaPeriodoFinancDinamico(var Mutdsk :TpMutDsk;
                                             DtRef  : Tdata;
                                             pStatus,
                                             pMacStatus,
                                             pMAC,
                                             pDiaLiq,
                                             pDiaVenc,
                                             pDiaVenc1aPrest : integer;
                                             pDtInFin : TData;
                                             pDesconsideraPrstNoDiaSin : boolean;
                                             UF : str3;
                                             CodMun : smallint;
                                         var DtInFin,DtFim : Tdata);
var
  DiaVenc : SmallInt;
  DtIsen,
  DtUltVenc : Tdata;
begin
  {$IFDEF FPC}
  DiaVenc := 0;
  {$ENDIF}
  DtIsen.dia := 0; DtIsen.mes := 0; DtIsen.ano := 0;
  DtUltVenc.dia := 0; DtUltVenc.mes := 0; DtUltVenc.ano := 0;
  { Determinando inicio do financiamento }
  if ((Mes_Int(MutDsk.Financ.DtInFin.MesAno)+1) < Mes_Int(MutDsk.Financ.DtAssin.MesAno)) then begin
    DtInFin := MutDsk.Financ.DtAssin;
    DecMA(DtInFin.MesAno);
  end
  else DtInFin := MutDsk.Financ.DtInFin;
  DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),MutDsk.Financ.DtInFin.Dia);

  DtFim := DtRef;
  if not CTR_ATV(pStatus,pMacStatus,
                 pMAC,pDiaLiq,
                 pDiaVenc,
                 pDtInFin,
                 pDesconsideraPrstNoDiaSin) then begin
    if pDiaLiq > 0 then
      DtFim.dia := pDialiq
    else DtFim.Dia := pDiaVenc;
    int_Mes(pMacStatus,DtFim.MesAno);
    (* A condicao a baixo e' necessaria porque no caso de termino de
       prazo, o dialiq do mes do termino e' prenchido com o diavenc,
       e no caso do termino ser em fevereiro, com o contrato vencendo
       no dia 30, a evolucao ajusta tando o dialiq, quanto o dia venc
       do rpa de fevereiro para 28 ( ou 29 ). Entretanto no rparef, que
       pode ser de outro mes, estara' com o diavenc 30. Neste caso
       para a rotina ctr_ativo, que espera um rpa do mes do termino,
       funcionar adequadamente para termino de prazo, o diavenc esta'
       sendo passado como o dia do termino. ( No exemplo dia 28).

       Para compatibilizar com a evolucao, no caso do dialiq ser zero,
       este sera' mantido, para que esta rotina reproduza o mesmo erro
       da evolucao. O erro ocorre quando foi feito um historico de
       tpz em conversao sem o dialiq. Nesta situacao a evolucao nao
       preenche o dialiq, e a funcao ctrativo considera o contrato
       como inativo no mes do termino. Este comportamento nao e' o
       esperado, uma vez que os contratos estao ativos no mes do seu
       termino por prazo. *)
    if (pMacStatus = Mes_Int(pDtInfin.MesAno)+1) and
       (pDiaVenc1aPrest in [1..31]) then
      DiaVenc := pDiaVenc1aPrest
    else
      DiaVenc := pDtInFin.Dia;
    if (pStatus = 8) and (pDiaLiq > 0) then
      DiaVenc := pDiaLiq;
    if not CTR_ATV(pStatus,pMacStatus,
                   pMACStatus,pDiaLiq,
                   DiaVenc,DtInFin,
                   pDesconsideraPrstNoDiaSin) then
      DecMA(DtFim.MesAno);
  end;
  IncMA(DtInFin.MesAno); //Estou incrementando para ser a data da 1a. presta  o - sol. 043047
  if (MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then 
    DtInFin.Dia   := Dia_Venc(mes_int(DtInFin.mesano),MutDsk.Financ3.DiaVenc1aPrest)
  else
    DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),MutDsk.Financ.DtInFin.Dia);

  { tratamento da isencao de mora }
  DtUltVenc := DtFim;
  if (Mes_int(DtInFin.MesAno) = Mes_Int(DtFim.MesAno)) and
     (MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then 
    DtUltVenc.dia := Dia_Venc(mes_int(DtUltVenc.mesano),MutDsk.Financ3.DiaVenc1aPrest)
  else
    DtUltVenc.dia := Dia_Venc(mes_int(DtUltVenc.mesano),pDiaVenc);  //Recebe o dia venc atual pois este pode ter sido alterado por hist rico
  DtIsencaoMora(DtUltVenc,DtIsen,MutDsk.Cad.DiaIsencao);
  if sfhlib.DiasDeAtrasoEntreDatas(DtIsen,DtRef,UF,CodMun) <= 0 then DecMA(DtFim.MesAno);
  DecMA(DtIsen.MesAno);
  if DtIsen.Dia > DiasMes(mes_int(DtIsen.Mesano)) then 
    DtIsen.Dia :=  DiasMes(mes_int(DtIsen.Mesano));
  if sfhlib.DiasDeAtrasoEntreDatas(DtIsen,DtRef,UF,CodMun) <= 0 then decMA(DtFim.MesAno);
end;

function TContrato.NumPrstAtraso(DtRef : TData; DtAtr : Tdata; 
                                 DesconsideraSeguroEmAtr : boolean = false;
                                 ConsideraIsencao : boolean = true;
                                 ConsideraVencida : boolean = false):smallint;
var
  ArrAtr : TArrayOfDatas;
  i,
  mac : integer;
  DtInFin,
  DtIni,
  DtFim : TData;
  EmAtraso : boolean;
  Parcela : TParcela;
  UF : str3;
  CodMun : smallint;
begin
{$IFDEF FPC} ArrAtr := default(TArrayOfDatas); {$ENDIF}
  SetLength(ArrAtr,0);
  DtIni.dia := 0; DtIni.mes := 0; DtIni.ano := 0; 
  DtFim.dia := 0; DtFim.mes := 0; DtFim.ano := 0;
  UF := '';
  CodMun := 0;
{
  Esta rotina tem dois modos
  a) se o rpa estiver posicionado - a rotina usa as data de inicio e fim do financiamento para identificar o n mero
                                    de presta  es em atraso, sem a necessidade de evoluir m s a m s. Apenas os
                                    valores do rpa posicionado s o usados. Esta rotina   a mais r pida poss vel
                                    em casos onde existe o rpa em disco.
  b) se o rpa n o estiver posicionado - neste caso, a rotina   obrigada a evoluir m s a m s, pois n o tem
                                        as informa  es necess rias.
  Caso o programador queira considerar o seguro em atraso, a forma lenta(evoluindo) tem que ser usada,
  pois n o temos como saber quais meses s o de seguro apenas, ou se est o pagos, somente com o rpa da data de
  refer ncia
}
  if not DesconsideraSeguroEmAtr or (RPA.Mac <> mes_int(DtRef.mesAno)) then
    result := ListaPrstAtraso(DtRef,DtAtr,ArrAtr,DesconsideraSeguroEmAtr,
                              ConsideraIsencao,ConsideraVencida)
  else begin
     {
       Neste modo, as data de inicio do financiamento, fim e isen  o s o consideradas
       Os testes n o s o os mesmos do c lculo de atraso do sistema, mas o crit rio adotado
       aqui seria semelhante ao de atraso
     }
    if DtAtr.dia = 0 then
      DtAtr := DtRef;

    result := 0;

    { Determinando inicio do financiamento }
    if ((Mes_Int(RPA.FinRPA.DtInFin.MesAno)+1) < Mes_Int(RPA.FinRPA.DtAssin.MesAno)) then begin
      DtInFin := RPA.FinRPA.DtAssin;
      DecMA(DtInFin.MesAno);
    end
    else
      DtInFin := RPA.FinRPA.DtInFin;
    { verifica durante todo o periodo que o contrato existe, cada s rie}
    for Mac := Mes_int(DtInFin.MesAno)+1 to Mes_int(DtRef.MesAno) do begin
      EmAtraso := false; // Esta rotina verifica se o Mac est  em atraso, independente de quantas s ries estejam
      { a l gica do financiamento din mico vem da rotina pglib.NumPrstAtraso4}
      if TemFinancDinamico(MutDsk) and not (MutDsk.Cad.TipoCtr in [1,2]) then begin
        ObtemMunicipioParaCobranca(UF,CodMun);
        DeterminaPeriodoFinancDinamico(Mutdsk,DtRef,
                                       RPAf.Temp11.StatusNo1Evento,
                                       RPAf.Temp11.MacStatusNo1Evento,
                                       RPAf.MAC,
                                       RPAf.Temp11.DiaLiqNo1Evento,
                                       RPAf.FinRPA.DiaVenc,
                                       RPAf.Temp7.DiaVenc1aPrest,
                                       RPAf.FinRPA.DtInFin,
                                       RPAf.Temp7.DesconsideraPrstNoDiaSin,
                                       UF,CodMun,
                                       DtIni,DtFim);
        if (Mac >= Mes_int(DtIni.mesano)) and (mac <= Mes_Int(DtFim.mesano)) then begin
          Parcela := SerieF.Parcelas.ObtemParcelaPorMac(Mac);
          if assigned(parcela) then begin
            // adicionei o teste do prstematrasoreal, pois me pareceu errado n o ter, j  que   feito para s rie, abaixo
            if SerieF.PrstEmAtrasoReal(RPAF,DtAtr,ConsideraIsencao,ConsideraVencida) and not Parcela.EstaPagaReal then begin 
              inc(result);
              EmAtraso := true;
            end;
          end
          else begin
            EmAtraso := true;
            inc(result);
          end;
        end;
      end;
      {A l gica da s rie foi derivada da rotina ucontrato.ListaPrstAtraso}
      if MutDsk.Cad2.TemSerie then begin
        i := 0;
        while (i < Series.count) and not EmAtraso do begin
          if Ctr_Ativo(Series[i].RPAS) then
            DtFim := DtRef
          else begin
            int_mes(Series[i].RPAS.Temp11.MacStatusNo1Evento,DtFim.MesAno);
            DtFim.Dia := Series[i].RPAS.Temp11.DiaLiqNo1Evento;
          end;
          if (mac > mes_int(Series[i].RPAS.FinRPA.DtInFin.mesano)) and (mac <= mes_int(DtFim.mesAno)) then begin
            Parcela := Series[i].Parcelas.ObtemParcelaPorMac(Mac);
            if assigned(parcela) and not Parcela.EstaPagaReal then begin
              if Parcela.EstaEmAtrasoAtual(Mutdsk.Cad.Ctr,
                                           Series[i].Fin.FinancBancario,
                                           Series[i].Fin.CodClassificacao,
                                           Series[i].Fin.DtInicio,
                                           Series[i].RPAS.Temp10.DtHabit,
                                           Mutdsk.Cad.DiaIsencao,
                                           DtAtr,
                                           ConsideraIsencao,
                                           ConsideraVencida) then begin
                inc(result);
                EmAtraso := true;
              end;
            end;
          end;
          inc(i);
        end;
      end;
    end;
  end;
end;

function TContrato.NumPrstAtraso(DtRef : TData; 
                                 DesconsideraSeguroEmAtr : boolean = false;
                                 ConsideraIsencao : boolean = true;
                                 ConsideraVencida : boolean = false):smallint;
var
  DtAtr : Tdata;
begin
  DtAtr.dia := 0;
  fillchar(DtAtr,sizeof(Tdata),0);
  result := NumPrstAtraso(DtRef,DtAtr,DesconsideraSeguroEmAtr,
                          ConsideraIsencao,ConsideraVencida);
end;

function TContrato.NumMesesAtraso(DtRef : TData; DesconsideraSeguroEmAtr : boolean = false):smallint;
var
  MacAtr,i : smallint;
  EmAtr  : boolean;
begin
  MacAtr := 0;
  InicRPA;
  EmAtr := false;
  while (Rpa.MAC <= Mes_Int(DtRef.MesAno)) and Ativo and (not EmAtr) do begin
    if MutDsk.Cad2.TemSerie then begin
      for i := 0 to Series.Count-1 do begin
        if Ctr_Ativo(Series[i].RpaS) then 
          if assigned(Series[i].ParcelaDoMes) and 
            ((Series[i].RPAS.FinRPA.NPC > 0) or  { s. 21058 } 
             (Series[i].RPAS.MAC > Mes_Int(Series[i].RPAS.FinRPA.DtAssin.MesAno))) and  
             (Series[i].RPAS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero) then begin
{ Coloquei o teste acima pois o resultado esperado era ter o mesmo crit rio da rotina
  do atraso, que no caso n o selecionava a parcela de NPC zero com seguro por conta do MAC
  ser igual ao da data da assinatura. Tenho minhas d vidas se este teste da rotina
  ParcSerieOk est  correto.  ** sol. 35609 **                                             }
            if (Series[i].RPAS.Temp10.TemParcNoMes or 
               (not DesconsideraSeguroEmAtr)) and
              ( ((not (Series[i].Fin.FinancBancario or (Series[i].Fin.CodClassificacao = serie_Chaves))) and 
                (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero)) or
               Series[i].ESerieFinBancChavesDevida(Series[i].RpaS.Temp10.DtHabit,DtRef)) then begin
               if Series[i].EstaEmAtrasoRpaS(DtRef) and (not Series[i].ParcelaDoMes.EstaPagaReal) then 
                 EmAtr := true;
            end;
          end;
      end;
    end;
    if TemFinancDinamico(MutDsk) and Ctr_Ativo(RPAF) then begin
      if (RPA.MAC > Mes_Int(RPAF.FinRPA.DtInFin.MesAno)) and
         SerieF.PrstEmAtrasoReal(RPAF,DtRef) then EmAtr := true;
    end;
    if EmAtr then MacAtr := Rpa.MAC;
    Evolui;
  end;
  if MacAtr > 0 then result := Mes_Int(DtRef.MesAno) - MacAtr
  else Result := 0;
end;

// Mesmo que a NumMesesAtraso, por m usando valores do cache(sem reevolui)
function TContrato.NumMesesAtrasoEvo(DtRef : TData;
                                     DesconsideraSeguroEmAtr : boolean = false;
                                     ConsideraAgenda : boolean = false;
                                     ConsideraPrstSoDeAcessorios : boolean = false):smallint;
var
  MacAtr,
  i,s : smallint;
  Reg : TValoresPorMac;
begin
  MacAtr := 0;
  if MutDsk.Cad2.TemSerie then
    for s := 0 to Series.Count-1 do begin
      i := mes_int(Series[s].Fin.DataRef.MesAno);
      while (i <= Mes_int(DtRef.mesAno)) and (i < Series[s].ValoresPorMacList.count) and (MacAtr=0) do begin
        if assigned(Series[s].ValoresPorMacList[i]) then begin
          Reg := TValoresPorMac(Series[s].ValoresPorMacList[i]);
          if Reg.CtrAtivo then
            if assigned(Reg.ParcelaDoMes) and
              ((Reg.NPC > 0) or  { s. 21058 }
               (Reg.MAC > Mes_Int(Reg.DtAssin.MesAno))) and
               (Reg.TotPrest-Reg.Desc > Zero) then begin
  { Coloquei o teste acima pois o resultado esperado era ter o mesmo crit rio da rotina
    do atraso, que no caso n o selecionava a parcela de NPC zero com seguro por conta do MAC
    ser igual ao da data da assinatura. Tenho minhas d vidas se este teste da rotina
    ParcSerieOk est  correto.  ** sol. 35609 **                                             }
              if (Reg.TemParcNoMes or
                 (not DesconsideraSeguroEmAtr)) and
                ( ((not (Series[s].Fin.FinancBancario or (Series[s].Fin.CodClassificacao = serie_Chaves))) and
                  (Reg.TotPrest-Reg.Desc > Zero)) or
                 Series[s].ESerieFinBancChavesDevida(Reg.DtHabit,DtRef)) then begin
                 if Series[s].EstaEmAtrasoRpaS(Reg,DtRef) and
                    (not Reg.ParcelaDoMes.EstaPagaReal) and
                    (not ConsideraAgenda or not PrestAgendada(Reg,DtRef)) then begin
                   MacAtr := Reg.Mac;
                 end;
              end;
            end;
        end;
        inc(i);
      end;
    end;
    
  if TemFinancDinamico(MutDsk) then begin
    i := mes_int(MutDsk.Financ.DtAssin.MesAno);
    while (i <= mes_int(DtRef.Mesano)) and (i < SerieF.ValoresPorMacList.count) and
          ((MacAtr > i) or (MacAtr=0)) do begin {Atraso do Financ. dinamico pode ser anterior ao de uma serie}
      if assigned(SerieF.ValoresPorMacList[i]) then begin
        Reg := TValoresPorMac(SerieF.ValoresPorMacList[i]);
        if Reg.CtrAtivo then begin
          if (Reg.MAC > Mes_Int(Reg.DtInFin.MesAno)) and
             SerieF.PrstEmAtrasoReal(Reg,DtRef,
                                     true{ConsideraIsencao},
                                     false{ConsideraVencida},
                                     ConsideraPrstSoDeAcessorios) and
             (not ConsideraAgenda or not PrestAgendada(Reg,DtRef)) then MacAtr := Reg.MAC;
        end;
      end;
      inc(i);
    end;
  end;
  if MacAtr > 0 then result := Mes_Int(DtRef.MesAno) - MacAtr
  else Result := 0;
end;

function TContrato.NumDiasAtraso(DtRef : TData; DesconsideraSeguroEmAtr : boolean = false;
                                LePendenciasEmitidas : boolean = false):smallint;
var
  DtAtr : TData;
  DtAtrSerie : Tdata;
  i : smallint;
  DtIsen : TData;
  PendEmi: real;
begin
  DtIsen.dia := 0; DtIsen.mes := 0; DtIsen.ano := 0;
  DtAtr.dia := 0;
  DtAtrSerie.dia := 0;
  InicRPA;
  while (Rpa.MAC <= Mes_Int(DtRef.MesAno)) and Ativo and (DtAtr.dia = 0) do begin
    if MutDsk.Cad2.TemSerie then begin
      for i := 0 to Series.Count-1 do begin
        if Ctr_Ativo(Series[i].RpaS) then begin
          PendEmi := 0;
          if assigned(Series[i].ParcelaDoMes) and
            ((Series[i].RPAS.FinRPA.NPC > 0) or  { s. 21058 }
             (Series[i].RPAS.MAC > Mes_Int(Series[i].RPAS.FinRPA.DtAssin.MesAno))) and
             (Series[i].RPAS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero) then begin
{ Coloquei o teste acima pois o resultado esperado era ter o mesmo crit rio da rotina
  do atraso, que no caso n o selecionava a parcela de NPC zero com seguro por conta do MAC
  ser igual ao da data da assinatura. Tenho minhas d vidas se este teste da rotina
  ParcSerieOk est  correto.  ** sol. 35609 **                                             }
            if (Series[i].RPAS.Temp10.TemParcNoMes or
               (not DesconsideraSeguroEmAtr)) and
              ( ((not (Series[i].Fin.FinancBancario or (Series[i].Fin.CodClassificacao = serie_Chaves))) and
                (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero)) or
               Series[i].ESerieFinBancChavesDevida(Series[i].RpaS.Temp10.DtHabit,DtRef)) then begin
               if Series[i].EstaEmAtrasoRpaS(DtRef) and (not Series[i].ParcelaDoMes.EstaPagaReal) then begin
                 if LePendenciasEmitidas then
                   PendEmi := Pendencias.ValorPendEmi(Series[i].RPAS.MAC,Series[i].RPAS.Temp8.CodSerie);

                 if Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc+PendEmi > Zero then begin
                   DtAtrSerie.dia := Series[i].RpaS.FinRPA.DiaVenc;
                   int_mes(Series[i].RpaS.Mac,DtAtrSerie.Mesano);
                   if (DtAtr.dia = 0) or (Juliano(DtAtrserie) < Juliano(DtAtr)) then
                     DtAtr := DtAtrSerie;
                 end;
               end;
            end;
          end;
        end;
      end;
    end;
    if TemFinancDinamico(MutDsk) and Ctr_Ativo(RPAF) then begin
      if (RPA.MAC > Mes_Int(RPAF.FinRPA.DtInFin.MesAno)) and
         SerieF.PrstEmAtrasoReal(RPAF,DtRef) then begin
        PendEmi := 0;
        if LePendenciasEmitidas then 
          PendEmi := Pendencias.ValorPendEmi(RPAF.MAC,0{CodSerie});
        if ((not LePendenciasEmitidas) or 
            (RPAF.ValRPA.TotPrest-RPAF.ValRPA.Desc+PendEmi > Zero) 
           ) then begin
          DtAtrSerie.dia := RpaF.FinRPA.DiaVenc;
          int_mes(RpaF.Mac,DtAtrSerie.Mesano);
          if (DtAtr.dia = 0) or (Juliano(DtAtrserie) < Juliano(DtAtr)) then
            DtAtr := DtAtrSerie;
        end;
      end;
    end;
    Evolui;
  end;
  if juliano(DtAtr) > 0 then begin
    DtIsencaoMora(DtAtr,DtIsen,MutDsk.Cad.DiaIsencao);
    result := DiasDeAtrasoEntreDatas(DtAtr,DtRef);
  end
  else Result := 0;
end;

function TContrato.PrestAgendada(Reg : TValoresPorMac; DtRef : TData) : boolean;
var
  CodSerie : integer;
  Tipoparc : integer;
  NumParc : integer;
  MacParc : integer;
  Agendadata : TData;
  AgendaEmitiu : boolean;
  ParcSerieAntec : boolean;
  TemPgParcial : boolean;
  EncontrouSerie : boolean;
  idx : integer;
begin
  result := false;
  
  Agendadata.dia := 0;
  fillchar(AgendaData,sizeof(Tdata),0);
  AgendaEmitiu := false;
  ParcSerieAntec := false;
  TemPgParcial := false;
  EncontrouSerie := false;
  NumParc := 0;
  TipoParc := 0;
  CodSerie := 0;
  MacParc := 0;

  if Reg.CodSerie > 0 then begin
    idx := Series.indexof(Reg.CodSerie);
    if idx >= 0 then begin
      Series[idx].IdentificaParcela(Reg,ParcSerieAntec,TipoParc,
                                    NumParc,TemPgParcial);
      CodSerie := Reg.CodSerie;
      MacParc := Reg.Mac;
      EncontrouSerie := true;
    end;
  end
  else begin
    CodSerie := 0;
    Tipoparc := TpParc_Series;
    NumParc := Reg.NPC;
    MacParc := Reg.Mac;
    EncontrouSerie := true;
  end;

  if EncontrouSerie and
     DadosAgendaPagamento.Le(CodSerie,TipoParc,NumParc,
                             AgendaData,AgendaEmitiu,MacParc) then begin
    result := Juliano(AgendaData) > Juliano(DtRef);
  end;
end;

// Mesmo que a NumDiasAtraso, por m usando valores do cache(sem reevolui)
function TContrato.NumDiasAtrasoEvo(DtRef : TData; DesconsideraSeguroEmAtr : boolean = false;
                                    LePendenciasEmitidas : boolean = false;
                                    ConsideraAgenda : boolean = false;
                                    ConsideraPrstSoDeAcessorios : boolean = false;
                                    DeveTerValor : boolean = false;
                                    DeveTerNpc : boolean = false):smallint;
var
  Reg : TValoresPorMac;
  
  DtAtr : TData;
  DtAtrSerie : Tdata;
  s,i : smallint;
  DtIsen : TData;
  PendEmi: real;
begin
  DtIsen.dia := 0; DtIsen.mes := 0; DtIsen.ano := 0;
  DtAtr.dia := 0;
  DtAtrSerie.dia := 0;
  if MutDsk.Cad2.TemSerie then
    for s := 0 to Series.Count-1 do begin
      i := mes_int(Series[s].Fin.DataRef.MesAno);
      while (i <= Mes_int(DtRef.mesAno)) and (i < Series[s].ValoresPorMacList.count) do begin
        if assigned(Series[s].ValoresPorMacList[i]) then begin
          Reg := TValoresPorMac(Series[s].ValoresPorMacList[i]);
          if Reg.CtrAtivo then begin
            PendEmi := 0;
            if assigned(Reg.ParcelaDoMes) and
              ((Reg.NPC > 0) or  { s. 21058 }
               (Reg.MAC > Mes_Int(Reg.DtAssin.MesAno))) and
               (Reg.TotPrest-Reg.Desc > Zero) then begin
  { Coloquei o teste acima pois o resultado esperado era ter o mesmo crit rio da rotina
    do atraso, que no caso n o selecionava a parcela de NPC zero com seguro por conta do MAC
    ser igual ao da data da assinatura. Tenho minhas d vidas se este teste da rotina
    ParcSerieOk est  correto.  ** sol. 35609 **                                             }
              if (Reg.TemParcNoMes or
                 (not DesconsideraSeguroEmAtr)) and
                ( ((not (Series[s].Fin.FinancBancario or (Series[s].Fin.CodClassificacao = serie_Chaves))) and
                  (Reg.TotPrest-Reg.Desc > Zero)) or
                 Series[s].ESerieFinBancChavesDevida(Reg.DtHabit,DtRef)) then begin
                 if Series[s].EstaEmAtrasoRpaS(Reg,DtRef) and (not Reg.ParcelaDoMes.EstaPagaReal) and
                    (not ConsideraAgenda or not PrestAgendada(Reg,DtRef)) then begin
                   if LePendenciasEmitidas then
                     PendEmi := Pendencias.ValorPendEmi(Reg.MAC,Reg.CodSerie);

                   if Reg.TotPrest-Reg.Desc+PendEmi > Zero then begin
                     DtAtrSerie.dia := Reg.DiaVenc;
                     int_mes(Reg.Mac,DtAtrSerie.Mesano);
                     if (DtAtr.dia = 0) or (Juliano(DtAtrserie) < Juliano(DtAtr)) then
                       DtAtr := DtAtrSerie;
                   end;
                 end;
              end;
            end;
          end;
        end;
        inc(i);
      end;
    end;

  if TemFinancDinamico(MutDsk) then begin
    i := mes_int(MutDsk.Financ.DtAssin.MesAno);
    while (i <= mes_int(DtRef.Mesano)) and (i < SerieF.ValoresPorMacList.count) do begin
      if assigned(SerieF.ValoresPorMacList[i]) then begin
        Reg := TValoresPorMac(SerieF.ValoresPorMacList[i]);
        if Reg.CtrAtivo then begin
          if (Reg.MAC > Mes_Int(Reg.DtInFin.MesAno)) and
             SerieF.PrstEmAtrasoReal(Reg,DtRef,
                                     true{ConsideraIsencao},
                                     false{ConsideraVencida},
                                     ConsideraPrstSoDeAcessorios{91805}) and
             (not DeveTerValor or (Abs(reg.TotPrest-reg.Desc) > Zero)) and // 111747
             (not DeveTerNpc or (reg.NPC>0)) and // 111747
             (not ConsideraAgenda or not PrestAgendada(Reg,DtRef)) then begin
            PendEmi := 0;
            if LePendenciasEmitidas then
              PendEmi := Pendencias.ValorPendEmi(Reg.MAC,0{CodSerie});
            if ((not LePendenciasEmitidas) or
                (Reg.TotPrest-Reg.Desc+PendEmi > Zero)
               ) then begin
              DtAtrSerie.dia := Reg.DiaVenc;
              int_mes(Reg.Mac,DtAtrSerie.Mesano);
              if (DtAtr.dia = 0) or (Juliano(DtAtrserie) < Juliano(DtAtr)) then
                DtAtr := DtAtrSerie;
            end;
          end;
        end;
      end;
      inc(i);
    end;
  end;
  if juliano(DtAtr) > 0 then begin
    DtIsencaoMora(DtAtr,DtIsen,MutDsk.Cad.DiaIsencao);
    result := DiasDeAtrasoEntreDatas(DtAtr,DtRef);
  end
  else Result := 0;
end;

function TContrato.NumMesesNaoPagos(DtRef : TData; DesconsideraSeguroEmAtr : boolean = false):smallint;
var
  Atr,i : smallint;
  EmAtr  : boolean;
begin
  InicRPA;
  atr := 0;
  while (Rpa.MAC <= Mes_Int(DtRef.MesAno)) and Ativo do begin
    EmAtr := false;
    if MutDsk.Cad2.TemSerie then begin
      for i := 0 to Series.Count-1 do begin
        if Ctr_Ativo(Series[i].RpaS) then 
          if assigned(Series[i].ParcelaDoMes) and 
            ((Series[i].RPAS.FinRPA.NPC > 0) or  { s. 21058 } 
             (Series[i].RPAS.MAC > Mes_Int(Series[i].RPAS.FinRPA.DtAssin.MesAno))) and  
             (Series[i].RPAS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero) then begin
{ Coloquei o teste acima pois o resultado esperado era ter o mesmo crit rio da rotina
  do atraso, que no caso n o selecionava a parcela de NPC zero com seguro por conta do MAC
  ser igual ao da data da assinatura. Tenho minhas d vidas se este teste da rotina
  ParcSerieOk est  correto.  ** sol. 35609 **                                             }
            if (Series[i].RPAS.Temp10.TemParcNoMes or 
               (not DesconsideraSeguroEmAtr)) and
              ( ((not (Series[i].Fin.FinancBancario or (Series[i].Fin.CodClassificacao = serie_Chaves))) and 
                (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero)) or
               Series[i].ESerieFinBancChavesDevida(Series[i].RpaS.Temp10.DtHabit,DtRef)) then begin
               if Series[i].EstaEmAtrasoRpaS(DtRef) and (not Series[i].ParcelaDoMes.EstaPagaReal) then 
                 EmAtr := true;
            end;
          end;
      end;
    end;
    if TemFinancDinamico(MutDsk) and Ctr_Ativo(RPAF) then begin
      if (RPA.MAC > Mes_Int(RPAF.FinRPA.DtInFin.MesAno)) and
         SerieF.PrstEmAtrasoReal(RPAF,DtRef) then EmAtr := true;
    end;
    if EmAtr then inc(atr);
    Evolui;
  end;
  result := atr;
end;



function TContrato.NumPrstAtrSerie(DtRef : TData; DesconsideraSeguroEmAtr : boolean = false):smallint;
var
  NAtr,i : smallint;
  EmAtr  : boolean;
begin
  NAtr := 0;
  if MutDsk.Cad2.TemSerie then begin
    InicRPA;
    while (Rpa.MAC <= Mes_Int(DtRef.MesAno)) and (Ctr_Ativo(Rpa)) do begin
      EmAtr := false;
      for i := 0 to Series.Count-1 do begin
        if Ctr_Ativo(Series[i].RpaS) then 
          if assigned(Series[i].ParcelaDoMes) and 
            (Series[i].RPAS.Temp10.TemParcNoMes or 
            (not DesconsideraSeguroEmAtr)) and
           ((not (Series[i].Fin.FinancBancario or (Series[i].Fin.CodClassificacao = serie_Chaves))) or
            ((Series[i].RpaS.FinRPA.NPC = 0) and
             (Series[i].RpaS.MAC > Mes_Int(Series[i].RPAS.FinRPA.DtAssin.MesAno)) and
             (Series[i].RpaS.ValRPA.TotPrest-Series[i].RPAS.ValRPA.Desc > Zero)) or
            Series[i].ESerieFinBancChavesDevida(Series[i].RpaS.Temp10.DtHabit,DtRef)) then begin
            if Series[i].EstaEmAtrasoAtualS(DtRef) and (not Series[i].ParcelaDoMes.EstaPagaReal) then EmAtr := true;
          end;
      end;
      if EmAtr then inc(NAtr);
      Evolui;
    end;
  end;
  Result := NAtr;
end;


