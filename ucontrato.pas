{TDespesasComercializacao}
function TDespesasComercializacao.getDespesaComercializacao(Index:integer): TpDespesaComercializacao;
begin
  if (index < 0) or (index >= count) then
    raise exception.create('Despesa inexistente')
  else
    result := TDespesaComercializacao(getitem(index)).FDespesaComercializacao;
end;

function TDespesasComercializacao.somaValorADiferir:Double;
var
  i: integer;
begin
  result := 0;
  for i := 0 to count-1 do
    if item[i].In_Diferir_Comissao and (item[i].Co_Status <> 98) then
      result := result + item[i].Va_Despesa;
  if Abs(Result) > Zero then Result := Arredonda(Result);
end;


constructor TDespesasComercializacao.create; 
begin
  inherited create(TDespesaComercializacao);
  FTeveExclusao := false;
end;

destructor TDespesasComercializacao.destroy;
begin
  inherited destroy;
end;

procedure TDespesasComercializacao.Le(Ctr: TPCtr; DataRef : TData);
var
  DBRegistroDespesaComercializacao: TDBRegistroDespesaComercializacao;
  DespesaComercializacao: TDespesaComercializacao;
  SqlConnection : TSqlConnection;
  CoBase: Integer;
  Query: TFastSqlQuery;
  RegDespComercializacao : TpDespesaComercializacao;
  CtbMensal              : boolean;
begin
  if ctr <> cCtrInexistente then
  begin
    SqlConnection := GetSqlConnection(PegaDirCor);
    DBRegistroDespesaComercializacao := TDBRegistroDespesaComercializacao.Create;
    Query := TFastSqlQuery.Create(nil);
    try
      RegDespComercializacao.Co_Contrato := '';
      fillchar(RegDespComercializacao,sizeof(RegDespComercializacao),0);
      CtbMensal := (not (Scciconf.ContabDiaria or Scciconf.ContabilMisto));
      CoBase := PegaCoBase(SqlConnection);
      Query.SqlConnection := SqlConnection;
      Query.Sql.Add(DBRegistroDespesaComercializacao.GeraSelect +
                   ' where co_base='+inttostr(CoBase)+' and co_contrato='+
                   QuotedStr(CtrToSqlCtr(Ctr)));
      Query.Sql.Add(' ORDER BY CO_BASE,CO_CONTRATO,DT_IMPLANTACAO_DESPESA,DT_DESPESA');
      Query.Open;
      while not Query.eof do
      begin
        DBRegistroDespesaComercializacao.QryToReg(Query,RegDespComercializacao);
        if (RegDespComercializacao.Dt_Cancelamento_Despesa.Dia > 0) and 
           (RegDespComercializacao.CO_STATUS = 98) and
         ( (DataRef.Dia = 0) 
                              or
          ((not CtbMensal) and
            DatasSaoIguais(RegDespComercializacao.Dt_Cancelamento_Despesa,DataRef)) 
                              or
           (CtbMensal and 
           (Mes_Int(RegDespComercializacao.Dt_Cancelamento_Despesa.MesAno) = Mes_Int(DataRef.MesAno)))
          ) then FTeveExclusao := true;
  
        if (RegDespComercializacao.CO_STATUS <> 98) or (DataRef.Dia > 0) then begin
  {------------------------------------------------------------------------- 
    O teste acima   para n o correr o risco de estragar outros programas que 
    n o sejam os cont beis e entrar despesas que foram exclu das, caso utilizem o objeto 
    TDespesasComercializacao. Como DataRef = FDataRefHist e esta data s  deve 
    ser passada por programas que necessitam ter uma posi  o 
    cont bil, s  entram as despesas exclu das se FDataRefHist > 0     
  --------------------------------------------------------------------------} 
          DespesaComercializacao := add as TDespesaComercializacao;
          DespesaComercializacao.FDespesaComercializacao := RegDespComercializacao;
        end;
        Query.next;
      end;
    finally
      DBRegistroDespesaComercializacao.free;
      Query.free;
    end;
  end;
end;
  
