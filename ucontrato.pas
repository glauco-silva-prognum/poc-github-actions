function XTIR(Values: array of double; Dates: array of TDateTime; Rate: double): Double;
const
  MAX_STEPS = 30;

  function CalcValue(Rate: double): double;
    function disc(d: TDateTime; v: double): double;
    var
      Exp, Coef: double;
    begin
      Exp := (d-Dates[0])/365;
      Coef := Power(1 + Rate/100, Exp);
      if Abs(Coef) > Zero then
        Result := v / Coef
      else
        Result := 0;
    end;

  var
    i: integer;
  begin
    Result := 0;
    for i := 0 to High(Dates) do
      Result := Result + disc(Dates[i], Values[i]);
  end;
var
  SaveFPUCW: word;
  CWChgReq: boolean;
  Rate1, Rate2, RateN: double;
  F1, F2, FN, dF, Scale: double;
  Quit: boolean;
  N: integer;
  TirOk : boolean;
begin
  Assert(Length(Values) = Length(Dates));
  Assert(Length(Values) >= 2);

  { Check the FPU's CW and change if required: }
  SaveFPUCW := Get8087CW;
  CWChgReq := (SaveFPUCW and $1F3F) <> $1332;
  If CWChgReq then
  begin
    Set8087CW($1332);
  end;
  Try{Finally -- for restoring the FPU CW}
    TirOk := true;
    Rate1 := Rate;
    Rate2 := Rate + 1;
    Quit := false;
    N := 0;
    Scale := 1;
    F1 := CalcValue(Rate1);
    F2 := CalcValue(Rate2);
    FN := 0;
    RateN := 0;
    while not Quit do
    begin
      if (F2 = F1) or (Rate2 = Rate1) then
      begin
        Quit := true;
        TirOk := false;
      end
      else
      begin
        if Abs(Rate2 - Rate1) > Zero then begin
          dF := (F2 - F1) / (Rate2 - Rate1);
          if Abs(Df) > Zero then
            RateN := Rate1 + (0 - F1)/dF/Scale
          else
            RateN := 0;
        end
        else
          RateN := 0;
        N := N + 1;
        if RateN > -100 then
          FN := CalcValue(RateN);
        if (Abs(Rate1) > zero) and (Abs(RateN - Rate1)/Abs(Rate1) < 0.0000005) then
          Quit := true
        else if N >= MAX_STEPS then
        begin
          Quit := true;
          TirOk := false;
        end
        else if not (RateN > -100) then
        begin
          Scale := Scale * 2;
        end else
        begin
          Scale := 1;
          Rate2 := Rate1;
          F2 := F1;
          Rate1 := RateN;
          F1 := FN;
        end;
      end;
    end; { while }
    if TirOk then
      Result := RateN
    else
      Result := 0;
  finally
    If CWChgReq then Set8087CW(SaveFPUCW);
  end;
end;

function IniciouAlgumaSerie(Contrato : TContrato) : boolean;
var
  i : integer;
begin
  result := Contrato.RPAF.FinRPA.npc > 0;
  for i := 0 to Contrato.Series.count-1 do
    result := result or (Contrato.Series[i].RPAS.FinRPA.NPC > 0);
end;

procedure GeraTxtCet(Datas : array of tdatetime; Arrayparcelas : array of Double);
var
  txt : text;
  i : integer;
begin
  assign(txt,pegadiratv+pathdelim+'cet.txt');
  rewrite(txt);
  try
    for i := 0 to length(arrayparcelas)-1 do
      writeln(txt,formatdatetime('dd/mm/yyyy',datas[i]),' - ',realstr(arrayparcelas[i]));
  finally
    close(txt);
  end;
end;


procedure IncluiHistoricosDasPrevisoes(var Contrato : TContrato);
var
  Qry : TSqlQuery;
  CodFCVS  : smallint;
  ChaveLog : TpChaveLogMem;
  DTParc : TData;
  NuParc : integer;
  DtUltLib : TData;
begin
  NuParc := 0;
  ChaveLog := 0;
  CodFCVS := 0;
  DtUltLib.Dia := 0;
  fillchar(DtUltLib,sizeof(TData),0);
  Qry := TSqlQuery.create(nil);
  try
    Qry.SqlConnection := GetSqlConnection(PegaDirtab);
    Qry.Sql.Add('SELECT C.*,IO.CO_UF,IO.NU_MUNICIPIO');
    Qry.Sql.Add('FROM CRONOGRAMA_LIBERACAO_OPERACAO C');
    Qry.Sql.Add('LEFT JOIN IMOVEL_OPERACAO IO');
    Qry.Sql.Add('ON IO.NU_OPERACAO = C.NU_OPERACAO');
    Qry.Sql.Add('WHERE C.NU_OPERACAO = ' + IntToStr(valint(Contrato.Mutdsk.cad2.inscricao)));
    Qry.Sql.Add('ORDER BY NU_MES_LIBERACAO');
    Qry.open;
    try
      while not Qry.eof do begin
        DtParc := ObtemDataCronogramaLiberacao(Contrato.MutDsk.Financ.DtAssin,
                                               Qry.fieldbyname('CO_UF').asstring,
                                               valint(Qry.fieldbyname('NU_MUNICIPIO').asstring),
                                               Qry.fieldbyname('Nu_Mes_Liberacao').asinteger);
        inc(NuParc);
        IncluiLogMem(Contrato.FHistMem,Contrato.MutDsk.Cad.Ctr,115,CodFCVS,DataH{Dt},'', ChaveLog);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 43, 104);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 248, DtParc.Dia);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 250, Qry.fieldByName('VA_LIBERACAO').asfloat);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 290, NuParc);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 105, 1);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 284, 1);
        IncluiDatMem (Contrato.FHistMem, ChaveLog, DtParc.MesAno, 310, 0{VA_IOF});
        DtUltLib := DtParc;
        Qry.next;
      end;
    finally
      Qry.close;
    end;
  finally
    Qry.free;
  end;
  Processa_Hist(DtUltLib,Contrato.FHistMem,Contrato.FHEvo);
end;


procedure IncluiHistoricosDasPrevisoesEDespesas(Contrato : TContrato; StList : Thashedstringlist; var DtUltLib : TData; var RegValores : TpRelCET; VencList : TStringList);
var
  Qry : TSqlQuery;
  SqlConnection : TSqlConnection;
  CodFCVS  : smallint;
  ChaveLog : TpChaveLogMem;
  Obj : tobjValorCalculoCet;
  Index : integer;
  DT : TData;
  Reg : TObjPrestCalculoCet;
begin
  ChaveLog := 0;
  CodFCVS := 0;
  if (Contrato.MutDsk.Cad.Tie + Contrato.MutDsk.cad5.ValIOF) > zero then begin
    Dt := Contrato.Mutdsk.Financ.DtAssin;
    Dt.dia := Contrato.Mutdsk.Financ.DiaVenc;
    IncluiLogMem(Contrato.FHistMem,Contrato.MutDsk.Cad.Ctr,115,CodFCVS,DataH,'', ChaveLog);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 43, 104);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 248, Dt.Dia);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 250, Contrato.MutDsk.Cad.Tie+Contrato.MutDsk.cad5.ValIOF);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 290,0);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 105, 1);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 284, 1);
    IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 310, 0);
    RegValores.VlTributos := Contrato.MutDsk.Cad5.ValIOF;
    RegValores.VlTie := Contrato.MutDsk.Cad.TIE;
  end;
  if Contrato.MutDsk.Cad.Ctr <> cCtrInexistente then begin
    SqlConnection := GetSqlConnection(PegaDirCor);
    Qry := TSqlQuery.create(nil);
    try
      Qry.SqlConnection := SqlConnection;
      Qry.sql.add('SELECT * from PE_LIBERACAO WHERE ');
      Qry.sql.add(' IN_TIPO_LIBERACAO<=1 AND ');
      Qry.sql.add(' CO_BASE='+intstr(PegaCoBase(SqlConnection))+' AND ');
      Qry.sql.add(' CO_CONTRATO='+Quotedstr(CtrToSqlCtr(Contrato.MutDsk.Cad.Ctr)));
      Qry.sql.add(' ORDER BY DT_LIBERACAO');
  
      Qry.open;
      try
        while not Qry.eof do begin
          DT := dateTimeToData(Qry.fieldByName('DT_LIBERACAO').asDateTime);
          IncluiLogMem(Contrato.FHistMem,Contrato.MutDsk.Cad.Ctr,115,CodFCVS,DataH{Dt},'', ChaveLog);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 43, 104);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 248, Dt.Dia);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 250, Qry.fieldByName('VA_LIBERACAO').asfloat+Qry.fieldByName('VA_CORRECAO').asfloat);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 290,Qry.fieldByName('NU_SEQ').asInteger);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 105, 1);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 284, 1);
          IncluiDatMem (Contrato.FHistMem, ChaveLog, Dt.MesAno, 310, Qry.fieldByName('VA_IOF').asfloat);
          index := stlist.indexof(intstr(Juliano(Dt)));
          if index >= 0 then begin
            obj := stlist.objects[index] as tobjValorCalculoCet;
            obj.valor := Obj.valor - Qry.fieldByName('VA_LIBERACAO').asfloat-Qry.fieldByName('VA_CORRECAO').asfloat;
          end
          else begin
            obj := tobjValorCalculoCet.create;
            obj.valor := -Qry.fieldByName('VA_LIBERACAO').asfloat-Qry.fieldByName('VA_CORRECAO').asfloat;
            stlist.addobject(intstr(Juliano(Dt)),obj);
          end;
          Reg := TObjPrestCalculoCet.create;
          Reg.Data := Dt;
          Reg.Parcela := Qry.fieldByName('NU_SEQ').asInteger;
          Reg.Amaisj := 0;
          Reg.Amortizacao := 0;
          Reg.Juros := 0;
          Reg.Mip := 0;
          Reg.Dfi := 0;
          Reg.ValTxAdm := 0;
          Reg.Encargo := 0;
          Reg.SaldoDevedor := 0;
          Reg.Dias := 0;
          Reg.Valor := - Qry.fieldByName('VA_LIBERACAO').asfloat-Qry.fieldByName('VA_CORRECAO').asfloat;
          VencList.addObject(DataToAAAAMMDD(Dt),Reg);
          RegValores.VlLiberado := RegValores.VlLiberado + Qry.fieldByName('VA_LIBERACAO').asfloat+Qry.fieldByName('VA_CORRECAO').asfloat;
          DtUltLib := Dt;
          Qry.next;
        end;
      finally
        Qry.close;
      end;
    finally
      Qry.free;
    end;
  end;
  Processa_Hist(DtUltLib,Contrato.FHistMem,Contrato.FHEvo);
end;

function ObtemDataCronogramaLiberacao(DtAssin : Tdata;
                                      ImovelOperacaoUF : string;
                                      ImovelOperacaoCodMun : integer;
                                      NuMesLiberacao : integer) : Tdata;
begin
  result := DtAssin;
  incMA(result.mesano,NuMesLiberacao);
  if result.Dia > DiasMes(mes_int(result.Mesano)) then
    result.Dia := DiasMes(mes_int(result.Mesano));
  if Scciconf.ImpedeInformarDtAssinEmDiaNaoUtil and Not(Testa_Data_Fer(result,ImovelOperacaoCodMun,ImovelOperacaoUF)) then begin
    Inc_Data(result,1);
    while not Testa_Data_Fer(result,ImovelOperacaoCodMun,ImovelOperacaoUF) do
      Inc_Data(result,1);
  end;
end;

