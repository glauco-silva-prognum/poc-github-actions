function SomaJurosNaCarencia(const RPA : TpRPA) : boolean;
begin
  Result := false;
  if Scciconf.ConsideraJurosNaCarenciaNoCalculoDaTJEO and
     (not (RPA.Temp7.Tipoctr in EvoPlanoEmpSet)) then
