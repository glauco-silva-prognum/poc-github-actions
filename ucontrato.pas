  result := nil;
  if FIndicePorCodSerie.HasItem(CodSerie) then begin
    ArrPorMac := FIndicePorCodSerie[CodSerie] as TSparseObjectArray;
    if ArrPorMac.HasItem(Mac) then
      result := ArrPormac[Mac] as TPrestacaoAtrasoEvo;
  end;
