procedure TParcelasSerie.Le(Ctr : TpCtr; RegSerie : TpSeries; DataRef : Tdata);
var
  TpPgParcial : byte;
  j           : integer;
  pArrayDeParcelas,
  pArrayDeParcelasSeg: ^TpArrayDeParcelas;
  RegParcela  : TpParcelas;
  wParcela     : TParcelaSerie;
  pArrayPgtoSeg,
  pArrayPgto  : ^TpArrayVal;
  RegPgto     : TpValPgto;
  DtPgParc,DtPgProc    : Tdata;
  ValorAntecipadoReal,
  DescAntecip : real;
  ValorPagoNoUltimoPagamentoAux,
  AmaisjPagoAteUltimoPagamentoAux : real;
  QryDescConc : TSqlQuery;
  InfoPagamentosObj : TInfoPagamentosObj;
begin
  RegPgto.Desconto := 0;
  fillchar(RegPgto,sizeof(RegPgto),0);
  DescAntecip := 0;
  ValorAntecipadoReal := 0;
  ValorPagoNoUltimoPagamentoAux := 0;
  AmaisjPagoAteUltimoPagamentoAux := 0;
  DtPgProc.Dia := 0; DtPgProc.Mes := 0; DtPgProc.Ano := 0;
  DtPgParc.Dia := 0; DtPgParc.Mes := 0; DtPgParc.Ano := 0;
  GetMem(pArrayDeParcelas,sizeof(TpArrayDeParcelas));
  GetMem(pArrayDeParcelasSeg,sizeof(TpArrayDeParcelas));
  GetMem(pArrayPgtoSeg,sizeof(TpArrayVal));
  GetMem(pArrayPgto,sizeof(TpArrayVal));
  QryDescConc := TSqlQuery.Create(nil);
  QryDescConc.SqlConnection  := GetSqlConnection(PegaDirTab,'CADMUT');
  InfoPagamentosObj := TInfoPagamentosObj.create;
  try
    Self.Clear;
    fillchar(pArrayDeParcelas^,sizeof(TpArrayDeParcelas),0);
    fillchar(pArrayDeParcelasSeg^,sizeof(TpArrayDeParcelas),0);
    DtPgParc.Dia := 0;
    fillchar(DtPgParc,sizeof(Tdata),0);
    LeArrayDeParcelasDeSerie(6,RegSerie.CodSerie,pArrayDeParcelas^);
    LeArrayDeParcelasDeSerie(7,RegSerie.CodSerie,pArrayDeParcelasSeg^);
    LeArrPagamentos(1,Ctr,TpParc_Series,RegSerie.CodSerie,pArrayPgto^,DataRef,true,true);
    LeArrPagamentos(1,Ctr,TpParc_SoSeguro,RegSerie.CodSerie,pArrayPgtoSeg^,DataRef,true,true);
    AcertaNumParcDosPagsDeSeguro(RegSerie.CodSerie,pArrayPgtoSeg^,pArrayDeParcelas^);
    QryDescConc.sql.add('SELECT MAC,VALOR_DESC,PERC_DESC FROM DESCONTO_CONCEDIDO ');
    QryDescConc.sql.add(' WHERE CO_CONTRATO=:Ctr AND CO_SERIE = :CodSerie ORDER BY MAC');
    QryDescConc.ParamByName('Ctr').asstring    := RegSerie.ctr;
    QryDescConc.Parambyname('Codserie').asinteger := RegSerie.CodSerie;
    try
      QryDescConc.Open;
    except
    end;
    for j := 1 to pArraydeParcelas^[0].chave.Tam do
    begin
      wParcela := self.add as TParcelaSerie;
      RegParcela := pArraydeParcelas^[j];
      FIndicePorMac[RegParcela.DtVenc.Ano*12 + RegParcela.DtVenc.Mes] := wParcela;
      wParcela.TipoParc        := RegParcela.Tipo;
      wParcela.Seq             := pArrayDeParcelas^[j].Seq;
      wParcela.MAC             := RegParcela.DtVenc.Ano*12 + RegParcela.DtVenc.Mes;
      wParcela.DiaVenc         := RegParcela.DtVenc.Dia;
      wParcela.Valor           := RegParcela.Encargo;
      wParcela.Juros           := RegParcela.Juros;
      wParcela.PE_AMORT        := RegParcela.PE_AMORT;
      wParcela.JSwap           := RegParcela.JSwap;
      wParcela.AmaisJSwap      := RegParcela.AmaisJSwap;
      if Scciconf.UsaArqPrest then begin
        wParcela.Seguro          := RegParcela.Seguro;
        wParcela.ValorEmitido    := RegParcela.ValEmi;
        wParcela.RARD            := RegParcela.RARD;
        wParcela.TaxaEmi         := RegParcela.TaxaEmi;
        wParcela.Saldo           := RegParcela.Saldo;
        wParcela.SegFinEmi       := RegParcela.SegFinEmi;
        wParcela.SegImvEmi       := RegParcela.SegImvEmi;
        wParcela.ResiduoGeradoEmi:= RegParcela.ResiduoGeradoEmi;
        wParcela.ResiduoCobradoEmi:= RegParcela.ResiduoCobradoEmi;
        wParcela.RARDSwap        := RegParcela.RARDSwap;
        wParcela.FGTSEmi         := RegParcela.FGTSEmi;
        wParcela.JurosEmi        := RegParcela.JurosEmi;
        wParcela.NPCClienteEmi   := RegParcela.NPCCliente;
        wParcela.Flag            := RegParcela.Flag;
      end;
      wParcela.MACEmitido      := mes_int(RegParcela.DataEmi.MesAno);
      wParcela.DataEmi := RegParcela.DataEmi;
      wParcela.ParcExisteNoMes := true;
      RetornaPgtoParcSerie(pArrayPgto^,RegPgto,RegParcela.Seq,DataProcPgRef);
      wParcela.TemPgParcial    := RegPgto.TemPgParcial;
      wParcela.DescontoPagamento := RegPgto.Desconto;
      wParcela.DescConcedido := RegPgto.DescConcedido;
      wParcela.PercDescMora := RegPgto.PercDescMora;
      wParcela.PercDescCorr := RegPgto.PercDescCorr;
      wParcela.PercDescMulta := RegPgto.PercDescMulta;
      wParcela.PercDescJremuneratorios := RegPgto.PercDescJremuneratorios;
      wParcela.ValorHonorarios := RegPgto.ValorHonorarios;
      wParcela.PercDescHonorarios := RegPgto.PercDescHonorarios;
      wParcela.PercHonorarios := RegPgto.PercHonorarios;
      wParcela.Banco := RegPgto.Banco;
      wParcela.DataRefCalc := RegPgto.DataRefCalc;
      wParcela.DataValidadeTit := RegPgto.DataValidadeTit;
      wParcela.ResiduoSaldo := RegPgto.ResiduoSaldo;
      wParcela.Motivo := RegPgto.Motivo;
      wParcela.Caixa  := RegPgto.Caixa;
      wParcela.Agencia := RegPgto.Agencia;
      wParcela.NossoNum := RegPgto.Nossonum;
      wParcela.CorrecaoPgto := RegPgto.Correcao;
      wParcela.MoraPgto := RegPgto.Mora;
      wParcela.JRemuneratoriosPgto := RegPgto.JRemuneratorios;
      wParcela.MultaPgto := RegPgto.Multa;
      wParcela.TipoDesc := RegPgto.TipoDesc;
      wParcela.ResiduoCobrado := RegPgto.ResiduoCobrado;
      wParcela.DescSeg := RegPgto.DescSeg;
      wParcela.DescPagamento := RegPgto.DescPagamento;
      wParcela.TipoRecebimento:= RegPgto.TipoRecebimento;
      LeInfoPagamentosCache(Ctr,RegPgto.Nossonum,InfoPagamentosObj);
      wParcela.Co_Forma_Pag := InfoPagamentosObj.Co_Forma_Pag;
      wParcela.Co_LiqForm := InfoPagamentosObj.Co_LiqForm;
      wParcela.Nu_TarjaChq1 := InfoPagamentosObj.Nu_TarjaChq1;
      wParcela.Nu_TarjaChq2 := InfoPagamentosObj.Nu_TarjaChq2;
      wParcela.Nu_TarjaChq3 := InfoPagamentosObj.Nu_TarjaChq3;
      wParcela.Nu_CompChq := InfoPagamentosObj.Nu_CompChq;
      wParcela.Va_Cheque := InfoPagamentosObj.Va_Cheque;
      wParcela.Co_PagCartao := InfoPagamentosObj.Co_PagCartao;
      wParcela.Nu_Cartao := InfoPagamentosObj.Nu_Cartao;
      wParcela.No_IdentCliente := InfoPagamentosObj.No_IdentCliente;
      wParcela.Co_SegCartao := InfoPagamentosObj.Co_SegCartao;
      wParcela.Nu_AgenReceb := InfoPagamentosObj.Nu_AgenReceb;
      wParcela.ContaCorrReceb := InfoPagamentosObj.ContaCorrReceb;
      wParcela.ContaCorrDVReceb := InfoPagamentosObj.ContaCorrDVReceb;

      wParcela.LCobr  := RegPgto.LCobr;
      wParcela.ValIOFComplem := RegPgto.VALIOFCOMPLEM;
      wParcela.DifEmitida    := Regpgto.DifEmitida;
      if not QryDescConc.IsEmpty then begin
        QryDescConc.First;
        while not QryDescConc.eof do begin
          if (QryDescConc.Fields.Fields[0].asinteger = wParcela.MAC) then begin
            wParcela.ValorDescConcedido := QryDescConc.Fields.Fields[1].Asfloat;
            wParcela.PercDescConcedido := QryDescConc.Fields.Fields[2].Asfloat;
          end;
          QryDescConc.next;
        end;
      end;
      if  RegPgto.TemPgParcial and
        ((RegPgto.DtPg.Dia <= 0) or (RegPgto.TipoPg in [8..9,74,95,108,110,114,117,121,200,253])) then begin
        TpPgParcial := 0;
        wParcela.ValorPagoAntecipado := ValorTotalPagoAntecipado(1,Ctr,TpParc_Series,RegSerie.CodSerie,RegParcela.Seq,DtPgParc,DtPgProc,DataRef,ValorAntecipadoReal,DescAntecip,TpPgParcial);
        RegPgto.ValTot := 0;
        RegPgto.Desconto:= 0;
        RegPgto.ValJMCM := 0;
        if TpPgParcial > 0 then
          RegPgto.TipoPg := TpPgParcial
        else if (not (RegPgto.TipoPg in [111,115])) then
          RegPgto.tipopg := 51;
        RegPgTo.DtPg   := DtPgParc;
        RegPgTo.DtProc := DtPgProc;
      end
      else begin
        wParcela.ValorPagoAntecipado := 0;
        ValorAntecipadoReal := 0;
      end;
      wParcela.DtPg         := RegPgto.DtPg;
      wParcela.DtProcPg     := RegPgto.DtProc;
      wParcela.TipoPg       := RegPgto.TipoPg;
      wParcela.ValorPago    := RegPgto.ValTot+ValorAntecipadoReal;
      wParcela.TipoRecebimento:= RegPgto.TipoRecebimento;
      wParcela.ValorPagoNoUltimoPagamento  := wParcela.ValorPago{ + wParcela.DescConcedido Sol. 47799 } ;
      wParcela.AmaisjPagoAteUltimoPagamento := 0;
      if RegPgto.TipoPg in PgtoComRedSdDev then // Pode ter pagamentos parciais
        if ObtemValoresNoUltimoPagamento(1,Ctr,TpParc_Series,RegSerie.CodSerie,RegParcela.Seq,
                                         ValorPagoNoUltimoPagamentoAux,
                                         AmaisjPagoAteUltimoPagamentoAux) then begin
          wParcela.ValorPagoNoUltimoPagamento  := ValorPagoNoUltimoPagamentoAux;
          wParcela.AmaisjPagoAteUltimoPagamento := AmaisjPagoAteUltimoPagamentoAux;
        end;
      if pArrayPgtoSeg^[0].Tam > 0 then begin
        // Procura um pagamento a parte de seguro
        // Se a parcela for paga totalmente antecipadamente, o seguro ter  que ser pago a parte
        // e como a evolu  o l  esta parcela como "parceladomes" o sistema n o chega a ler o pagamento
        // apenas do seguro. Atribuindo estas vari veis,   poss vel verificar corretamente se o seguro
        // est  pago. Sol. 27917
        RetornaPgtoParcSerie(pArrayPgtoSeg^,RegPgto,mes_int(RegParcela.DtVenc.MesAno),DataProcPgRef,true);
        if RegPgto.CodCtr > '' then begin
          wParcela.SeguroPago := RegPgto.ValTot;
          wParcela.DtPgSeg    := RegPgto.DtPg;
          wParcela.DtProcSeg  := RegPgto.DtProc;
          wParcela.TipoPgSeg  := RegPgto.TipoPg;
          if (not wParcela.TipoPg in PgtoComRedSdDev) then
            wParcela.DataRefCalc:= RegPgto.DataRefCalc;
          wParcela.motivo     := RegPgto.Motivo;
          wParcela.DataValidadeTit := RegPgto.DataValidadeTit;
        end;
      end;
    end;

{
  CONCEITO SOBRE PARCELAS DE SEGURO
    Todas as parcelas de seguro s o criadas no sistema.
    Ou fazem parte de uma parcela de presta  o j  lida, devido ao parcelas.dat, ou
    fazem parte de um pagamento de seguro, ou s o criadas durante a evolu  o.
    A vari vel "parceladomes" da evolu  o ent o pode conter presta  o+seguro ou apenas o seguro.
    Al m disso, tamb m   criada uma parcela no contrato para todos os pagamentos de seguro feitos a parte.
    Estas parcelas s o identificadas como seq=0. Assim,   poss vel buscar um pagamento apenas do seguro,
    pela rotina ObtemParcelaDeSeguroPorMAC.
}

{  Sol. 44826 - devido a necessidade de gravar valores de seguro no parcelas.dat, para parcelas
                s  de seguro, agora se faz necess rio gravar parcelas de seguro mesmo n o pagas.
                Da mesma forma, agora   preciso ler tais parcelas
                IMPORTANTE: as parcelas de seguro v o ser gravadas com seq=mac devido ao sequencial
                            fazer parte da chave, e n o poder ser gravado como zero, no entanto,
                            para manter a integridade do sistema, a evolu  o vai continuar a considerar
                            o seq da parcela de seguro como zero }
    for j := 1 to pArraydeParcelasSeg^[0].chave.Tam do
      if pArraydeParcelasSeg^[j].Seq > 0 then begin // tem que estar preenchido no disco
        wParcela := self.add as TParcelaSerie;
        RegParcela := pArraydeParcelasSeg^[j];
        wParcela.TipoParc  := RegParcela.Tipo;
        wParcela.Seq := 0;
        wParcela.MAC := RegParcela.DtVenc.Ano*12 + RegParcela.DtVenc.Mes;
        wParcela.DataEmi := RegParcela.DataEmi;
        wParcela.DiaVenc := RegParcela.DtVenc.Dia;
        if Scciconf.UsaArqPrest then begin
          wParcela.Seguro          := RegParcela.Seguro;
          wParcela.ValorEmitido    := RegParcela.ValEmi;
          wParcela.RARD            := RegParcela.RARD;
          wParcela.TaxaEmi         := RegParcela.TaxaEmi;
          wParcela.Saldo           := RegParcela.Saldo;
          wParcela.SegFinEmi       := RegParcela.SegFinEmi;
          wParcela.SegImvEmi       := RegParcela.SegImvEmi;
          wParcela.ResiduoGeradoEmi:= RegParcela.ResiduoGeradoEmi;
          wParcela.ResiduoCobradoEmi:= RegParcela.ResiduoCobradoEmi;
          wParcela.FGTSEmi         := RegParcela.FGTSEmi;
          wParcela.JurosEmi        := RegParcela.JurosEmi;
          wParcela.NPCClienteEmi   := RegParcela.NPCCliente;
          wParcela.Flag            := RegParcela.Flag;
       end;
       wParcela.MACEmitido      := mes_int(RegParcela.DataEmi.MesAno);
      end;

    for j := 1 to pArrayPgtoSeg^[0].Tam do begin
      if pArrayPgtoSeg^[j].NumParc >= mes_int(RegSerie.DataRef.mesano) then begin //Sol. 23578
        // Todas as parcelas de seguro, pagas a parte s o lidas, de forma a ser poss vel verificar seu pagamento
        // Parcelas apenas de seguro sempre ter o o seq zerado, sendo poss vel ent o verificar o tipo de parcela
        // Al m deste teste agora   poss vel testar pelo Tipoparc 7
        // Pagamentos de seguro apenas, no valpgto(tipoparc 7) tem no numparc o mac, pois
        // para s ries n o mensais, n o h  numparc diferente, n o sendo poss vel saber a que m s o
        // pagamento pertece
        // Sol. 27917

        wParcela := ObtemParcelaDeSeguroPorMAC(pArrayPgtoSeg^[j].NumParc);
        if not Assigned(wParcela) then
          wParcela := self.add as TParcelaSerie;

        wParcela.TipoParc     := TpParc_SoSeguro;
        wParcela.Seq          := 0;
        wParcela.MAC          := pArrayPgtoSeg^[j].NumParc;
        wParcela.DiaVenc      := Dia_Venc(wParcela.MAC,RegSerie.DtInicio.Dia);
        wParcela.DescontoPagamento := pArrayPgtoSeg^[j].Desconto;
        wParcela.PercDescMora := pArrayPgtoSeg^[j].PercDescMora;
        wParcela.PercDescCorr := pArrayPgtoSeg^[j].PercDescCorr;
        wParcela.PercDescMulta := pArrayPgtoSeg^[j].PercDescMulta;
        wParcela.PercDescJremuneratorios := pArrayPgtoSeg^[j].PercDescJremuneratorios;
        wParcela.ValorHonorarios    :=  pArrayPgtoSeg^[j].ValorHonorarios;
        wParcela.PercDescHonorarios :=  pArrayPgtoSeg^[j].PercDescHonorarios;
        wParcela.PercHonorarios     :=  pArrayPgtoSeg^[j].PercHonorarios;

        // Sol. 94743 - precisei setar as vari veis de pagamento de seguro para usar no acerto financeiro
        wParcela.SeguroPago := pArrayPgtoSeg^[j].ValTot;
        wParcela.DtPgSeg    := pArrayPgtoSeg^[j].DtPg;
        wParcela.DtProcSeg  := pArrayPgtoSeg^[j].DtProc;
        wParcela.TipoPgSeg  := pArrayPgtoSeg^[j].TipoPg;

        if  pArrayPgtoSeg^[j].TemPgParcial and
          ((pArrayPgtoSeg^[j].DtPg.Dia <= 0) or (pArrayPgtoSeg^[j].TipoPg in [8..9,66,74,95,108,110,114,117,121,200,253])) then begin
          wParcela.ValorPagoAntecipado := ValorTotalPagoAntecipado(1,Ctr,TpParc_SoSeguro,RegSerie.CodSerie,
                                                                  wParcela.MAC,
                                                                  DtPgParc,
                                                                  DtPgProc,
                                                                  ValorAntecipadoReal,
                                                                  DescAntecip);
          if (not (pArrayPgtoSeg^[j].tipopg in [111,115])) then
            pArrayPgtoSeg^[j].tipopg := 51;
          pArrayPgtoSeg^[j].DtPg   := DtPgParc;
          pArrayPgtoSeg^[j].DtProc := DtPgProc;
        end
        else begin
          wParcela.ValorPagoAntecipado := 0;
          ValorAntecipadoReal := 0;
        end;

        wParcela.DtPg         := pArrayPgtoSeg^[j].DtPg;
        wParcela.DtProcPg     := pArrayPgtoSeg^[j].DtProc;
        wParcela.TipoPg       := pArrayPgtoSeg^[j].TipoPg;
        wParcela.ValorPago    := pArrayPgtoSeg^[j].ValTot+ValorAntecipadoReal;
        wParcela.DataRefCalc  := pArrayPgtoSeg^[j].DataRefCalc;
        wParcela.DataValidadeTit := pArrayPgtoSeg^[j].DataValidadeTit;
        if pArrayPgtoSeg^[j].Caixa > 0 then wParcela.Caixa := pArrayPgtoSeg^[j].Caixa;
        if pArrayPgtoSeg^[j].Agencia > 0 then wParcela.Caixa := pArrayPgtoSeg^[j].Agencia;
        if pArrayPgtoSeg^[j].NossoNum > '' then wParcela.NossoNum := pArrayPgtoSeg^[j].NossoNum;
        if pArrayPgtoSeg^[j].LCobr > 0 then wParcela.LCobr := pArrayPgtoSeg^[j].LCobr;
        if pArrayPgtoSeg^[j].VALIOFCOMPLEM > Zero then
          wParcela.ValIOFComplem := RegPgto.VALIOFCOMPLEM;
        if Abs(pArrayPgtoSeg^[j].DifEmitida) > Zero then
          wParcela.DifEmitida    := Regpgto.DifEmitida;
      end;
    end;  
  finally
    FreeMem(pArrayDeParcelas);
    FreeMem(pArrayDeParcelasSeg);
    FreeMem(pArrayPgtoSeg);
    FreeMem(pArrayPgto);
    QryDescConc.free;
    InfoPagamentosObj.free;
  end;
end;

procedure TParcelasSerie.Le(Ctr : TpCtr; RegSerie : TpSeries);
var
  DataRef : Tdata;
begin
  DataRef.Dia := 0;
  fillchar(DataRef,sizeof(Tdata),0);
  Le(Ctr,RegSerie,DataRef);
end;

function IndiceDaParcela(    DtVenc : TData;
                         Var ArrParcelas : tpArrayDeParcelas) : integer;
var
  i : integer;
begin
  result := 0;
  i := 1;
  while (i <= ArrParcelas[0].chave.tam) and (result = 0) do begin
    if mes_int(ArrParcelas[i].DtVenc.MesAno) = Mes_int(DtVenc.MesAno) then
      result := i;
    inc(i);
  end;
end;


procedure TParcelasSerie.LeMem(RegSerie : TpSeries; ArrParcMem : TpArraydeParcelas);
var
  i,indice      : integer;
  wParcela       : TParcelaSerie;
  RegSerieDisco : TpSeries;
  ArrParcDisco  : TpArrayDeParcelas;
  ArrayPgto     : TpArrayVal;
  RegPgto       : TpValPgto;
  DtPgParc,
  DtPgProc      : Tdata;
  ValorAntecipadoReal,
  DescAntecip : real;
begin
  RegSerieDisco.Ctr := '';
  fillchar(RegSerieDisco,sizeof(RegSerieDisco),0);
  ArrParcDisco[0].Chave.Tam := 0;
  fillchar(ArrParcDisco,sizeof(ArrParcDisco),0);
  RegPgto.Desconto := 0;
  fillchar(RegPgto,sizeof(RegPgto),0);
  ValorAntecipadoReal := 0;
  DescAntecip := 0;
  DtPgParc.Dia := 0; DtPgParc.Mes := 0; DtPgParc.Ano := 0;
  DtPgProc.Dia := 0; DtPgProc.Mes := 0; DtPgProc.Ano := 0;
  fillchar(DtPgParc,sizeof(Tdata),0);
  ArrayPgto[0].tam := 0;
  fillchar(ArrayPgto,sizeof(TpArrayVal),0);
  Self.Clear;
  // Recuperando Valores
  LeSerie(RegSerie.Ctr, RegSerie.CodSerie,RegSerieDisco);
  if RegSerieDisco.ctr = RegSerie.Ctr then begin
    LeArrayDeParcelas(RegSerieDisco,ArrParcDisco);
    LeArrPagamentos(1,RegSeriedisco.Ctr,TpParc_Series,RegSerieDisco.CodSerie,ArrayPgto,true);
    for i := 1 to RegSerie.Prazo do begin
      Indice := IndiceDaParcela(ArrParcMem[i].DtVenc,ArrParcDisco);
      if Indice > 0 then begin
        ArrParcMem[i].ValPg := ArrParcDisco[Indice].ValPg;
        ArrParcMem[i].TpPag := ArrParcDisco[Indice].TpPag;
        ArrParcMem[i].Dtpag := ArrParcDisco[Indice].DtPag;
        ArrParcMem[i].ValEmi:= ArrParcDisco[Indice].ValEmi;
        ArrParcMem[i].DataEmi := ArrParcDisco[Indice].DataEmi;
        ArrParcMem[i].SegFinEmi := ArrParcDisco[Indice].SegFinEmi;
        ArrParcMem[i].SegImvEmi := ArrParcDisco[Indice].SegImvEmi;
        ArrParcMem[i].ResiduoGeradoEmi:= ArrParcDisco[Indice].ResiduoGeradoEmi;
        ArrParcMem[i].ResiduoCobradoEmi:= ArrParcDisco[Indice].ResiduoCobradoEmi;
        ArrParcMem[i].FGTSEmi:= ArrParcDisco[Indice].FGTSEmi;
        ArrParcMem[i].JurosEmi:= ArrParcDisco[Indice].JurosEmi;
        ArrParcMem[i].Flag:= ArrParcDisco[Indice].Flag;
      end;
    end;
  end;
  for i := 1 to ArrParcMem[0].chave.Tam do
  begin
    wParcela := self.add as TParcelaSerie;
    wParcela.Seq             := ArrParcMem[i].Seq;
    wParcela.MAC             := ArrParcMem[i].DtVenc.Ano*12 + ArrParcMem[i].DtVenc.Mes;
    FIndicePorMac[wParcela.MAC] := wParcela;
    wParcela.DiaVenc         := ArrParcMem[i].DtVenc.Dia;
    wParcela.Valor           := ArrParcMem[i].Encargo;
    if Scciconf.UsaArqPrest then begin
      wParcela.Seguro          := ArrParcMem[i].Seguro;
      wParcela.ValorEmitido    := ArrParcMem[i].ValEmi;
      wParcela.RARD            := ArrParcMem[i].RARD;
      wParcela.TaxaEmi         := ArrParcMem[i].TaxaEmi;
      wParcela.Saldo           := ArrParcMem[i].Saldo;
      wParcela.SegFinEmi       := ArrParcMem[i].SegFinEmi;
      wParcela.SegImvEmi       := ArrParcMem[i].SegImvEmi;
      wParcela.ResiduoGeradoEmi:= ArrParcMem[i].ResiduoGeradoEmi;
      wParcela.ResiduoCobradoEmi:= ArrParcMem[i].ResiduoCobradoEmi;
      wParcela.FGTSEmi         := ArrParcMem[i].FGTSEmi;
      wParcela.JurosEmi        := ArrParcMem[i].JurosEmi;
      wParcela.NPCClienteEmi   := ArrParcMem[i].NPCCliente;
      wParcela.Flag            := ArrParcMem[i].Flag;
    end;
    wParcela.MACEmitido      := mes_int(ArrParcMem[i].DataEmi.MesAno);
    wParcela.DataEmi         := ArrParcmem[i].DataEmi;
    wParcela.ParcExisteNoMes := true;
    RetornaPgtoParcSerie(ArrayPgto,RegPgto,ArrParcMem[i].Seq,DataProcPgRef);
    wParcela.DescontoPagamento := RegPgto.Desconto;
    wParcela.DescConcedido := RegPgto.DescConcedido;
    wParcela.PercDescMora := RegPgto.PercDescMora;
    wParcela.PercDescCorr := RegPgto.PercDescCorr;
    wParcela.PercDescMulta := RegPgto.PercDescMulta;
    wParcela.PercDescJremuneratorios := RegPgto.PercDescJremuneratorios;
    wParcela.ValorHonorarios    :=  RegPgto.ValorHonorarios;
    wParcela.PercDescHonorarios :=  RegPgto.PercDescHonorarios;
    wParcela.PercHonorarios     :=  RegPgto.PercHonorarios;

    if  RegPgto.TemPgParcial and
      ((RegPgto.DtPg.Dia <= 0) or (RegPgto.TipoPg in [8..9,74,95,108,110,114,117,121,200,253])) then begin
      wParcela.ValorPagoAntecipado := ValorTotalPagoAntecipado(1,RegSerieDisco.Ctr,TpParc_Series,RegSerieDisco.CodSerie,ArrParcMem[i].Seq,DtPgParc,DtPgProc,ValorAntecipadoReal,DescAntecip);
      if (not (RegPgto.tipopg in [111,115])) then RegPgto.tipopg := 51;
      RegPgTo.DtPg   := DtPgParc;
      RegPgTo.DtProc   := DtPgProc;
    end
    else begin
      wParcela.ValorPagoAntecipado := 0;
      ValorAntecipadoReal := 0;
    end;
    wParcela.DtPg         := RegPgto.DtPg;
    wParcela.DtProcPg     := RegPgto.DtProc;
    wParcela.TipoPg       := RegPgto.TipoPg;
    wParcela.ValorPago    := RegPgto.ValTot+ValorAntecipadoReal;
    wParcela.Banco        := RegPgto.Banco;
    wParcela.DataRefCalc  := RegPgto.DataRefCalc;
    wParcela.DataValidadeTit := RegPgto.DataValidadeTit;
    wParcela.Motivo       := RegPgto.Motivo;
    wParcela.ResiduoSaldo := RegPgto.ResiduoSaldo;
    wParcela.Caixa  := RegPgto.Caixa;
    wParcela.Agencia := RegPgto.Agencia;
    wParcela.NossoNum := RegPgto.NossoNum;
    wParcela.LCobr  := RegPgto.LCobr;
    wParcela.CorrecaoPgto := RegPgto.Correcao;
    wParcela.MoraPgto := RegPgto.Mora;
    wParcela.JRemuneratoriosPgto := RegPgto.JRemuneratorios;
    wParcela.MultaPgto := RegPgto.Multa;
    wParcela.TipoDesc := RegPgto.TipoDesc;
    wParcela.ResiduoCobrado := RegPgto.ResiduoCobrado;
    wParcela.DescSeg := RegPgto.DescSeg;
    wParcela.DescPagamento := RegPgto.DescPagamento;
  end;
end;

function TParcelasSerie.ObtemParcelaPorSeq(Seq:integer):TParcelaSerie;
var i : integer;
begin
  Result := nil;
  for i := 0 to Count-1 do
    if (Parcela[i] as TParcelaSerie).Seq = Seq then begin
      Result := Parcela[i] as TParcelaSerie;
      break;
    end;
end;

function TParcelasSerie.ObtemParcela(Tipo,Seq : integer):TParcelaSerie;
begin
  result := nil;
  
  // O sequencial das parcelas s  de seguro fica zerado em mem ria
  if Tipo = TpParc_Series then
    result := ObtemParcelaPorseq(Seq)
  else if Tipo = TpParc_SoSeguro then
    result := ObtemParcelaPorMac(Seq) as TParcelaSerie;
end;

function TParcelasSerie.ObtemPagamentosAntecipadosPorMac(Mac:integer;
                                                         ListaDeParcelas : TObjectList = nil;
                                                         PagamentosNormais : TObjectList = nil):TValoresPorDia;
var
  i : integer;
begin
  if assigned(ListaDeparcelas) then
    ListaDeParcelas.clear;
  if assigned(PagamentosNormais) then
    PagamentosNormais.clear;
  Result[0] := 0;
  fillchar(Result,sizeof(TValoresPorDia),0);
  for i := 0 to Count-1 do
  begin
    if { est  paga, o M s ano   o mesmo de MAC, o tipo de pag   80 ou 243 e
         o mac   um pagamento antecipado  }
       (Parcela[i].DtPg.Dia > 0) and (Parcela[i].DtPg.Dia <= 31) and
       (Mes_int(Parcela[i].DtPg.MesAno) = Mac) and
       (Parcela[i].TipoPg in PgtoComRedSdDev) and
      ((DataprocPgRef.Dia = 0) or (juliano(Parcela[i].DtProcPg) <= juliano(DataProcPgRef) )) then begin
      { Soma o pagamento no dia }
      if assigned(ListaDeParcelas) then
        ListaDeParcelas.add(Parcela[i]);
      Result[Parcela[i].DtPg.Dia] := Result[Parcela[i].DtPg.Dia] + Parcela[i].ValorPago + Parcela[i].DescConcedido;
      Result[0] := Result[0]+1.0;
    end
    else if assigned(PagamentosNormais) and
            Parcela[i].EstaPagaReal and not (Parcela[i].TipoPg in PgtoComRedSdDev) and
            (Mes_int(Parcela[i].DtPg.MesAno) = Mac) then
      PagamentosNormais.add(Parcela[i]);
  end;
end;

function TParcelasSerie.ObtemPrazoaReduzir(MAC,Prazo,MacIni,Periodicidade:integer):integer;
var 
  i: Integer;
  MacFim: Integer;
  NovoMacFim: Integer;
begin
  MacFim := MacIni + Periodicidade * (Prazo -1);  
  NovoMacFim := MacFim;
  for i := Count-1 downto 0 do
    // Est  paga e o tipo do pagamento   80 ou 243(pg antecipado)
    // e n o foi paga ap s mac
    if (Parcela[i].DtPg.Dia > 0) and (Parcela[i].DtPg.Dia <=31) and
       (Parcela[i].TipoPg in PgtoComRedSdDev) and
       (mes_int(Parcela[i].DtPg.MesAno) <= MAC) then
    begin // se o M s/ano   o mesmo de MAC
        NovoMacFim := Parcela[i].Mac - Periodicidade;
    end
    else if Parcela[i].ParcExisteNoMes then break;
  if NovoMacFim < Mac then NovoMacFim := Mac;
  if NovoMacFim < MacFim then
    Result := (MacFim - NovoMacFim + Periodicidade - 1) div Periodicidade
  else
    Result := 0;
end;

function TParcelasSerie.ObtemNumeroParcelasRemanescentes(Mac:Integer) : Integer;
{ Obtem n mero de parcelas remanescentes sem contar as antecipadas }
var
  i:integer;
  DtVenc:Tdata;
  
begin
  Result := 0;
  { Conta n mero de parcelas do fim at  mac }
  i := Count -1;
  int_mes(Mac,DtVenc.MesAno);
  if i >=0 then 
    DtVenc.Dia := parcela[0].diaVenc;
  while (i >= 0) do
  begin
    if (Parcela[i].MAC >= MAC) and
       // N o est  paga ou o tipo do pagamento n o   80 ou 243(pg antecipado)
       // e n o foi paga ap s mac
       ((Parcela[i].DtPg.Dia = 0) or
       (not (Parcela[i].TipoPg in PgtoComRedSdDev)) or
       (juliano(Parcela[i].DtPg) >= juliano(DtVenc))) then
    inc(Result);
    dec(i);
  end;
end;


function TParcelasSerie.Soma:Real;
