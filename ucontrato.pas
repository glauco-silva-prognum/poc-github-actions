{ TParcelaSerie }

procedure TParcelaSerie.CalculaCorrecaoMoraMulta(var MutDsk   : TpMutDsk;
                                                UF : str3; CodMun : smallint;
                                                DataRef:TData;
                                            var Correcao,
                                                Mora,
                                                Multa    :Double;
                                                CodTG    : smallint);
var 
  DtAssin,
  DataVenc : TData;
  ValorAux : real;
begin
  DtAssin.dia := 0;
  fillchar(DtAssin,sizeof(TData),0);
  if assigned(self) then begin
    DataVenc.Dia := DiaVenc;
    int_mes(MAC,DataVenc.MesAno);

    Correcao := CorrLib.CorrecaoMJSemIsencao(DataVenc,DataRef,UF,CodMun,ValorCorrigido(DataVenc),
                                             0,0,Mora,DtAssin,CodTG,0{CoBase},
                                             0{Defreaj},true{CalculoDeAtraso});
    if Scciconf.CobraMultaNoAtrasoDeSeries then begin
      ValorAux := ValorCorrigido(DataVenc);
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (MutDsk.Financ.TMora <> 101) then
        ValorAux := ValorAux + Correcao;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + Mora;
      if (MutDsk.Financ.TMora in [38..40]) then
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
      else
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
    end else Multa := 0;
  end
  else begin
    correcao := 0;
    mora := 0;
    multa := 0;
  end;
end;

function TParcelaSerie.ValorCorrigido(DataRef:TData): Double;
var
  IndInvalido : boolean;
  wSerie       : TSerie;
  DtIndInvalido : Tdata;
  DataRefParaReaj : Tdata;
begin
  IndInvalido := false;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  fillchar(DtIndInvalido,sizeof(Tdata),0);
  wSerie := TParcelas(Collection).FOwner as TSerie;
  DataRefParaReaj := wSerie.fin.DataRefReaj;
  if DataRefParaReaj.dia = 0 then
    DataRefParaReaj := wSerie.Fin.DataRef;
  Result := int(Valor*detinddataadata(wserie.fin.Codreaj, wserie.fin.defreaj,DataRefParaReaj, DataRef, 1.0,
                wSerie.Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                wSerie.Fin.CorrProRataIniPelaVarDataRef,wserie.fin.CmproRatamesAnt,false{CalcMes})*100+0.5)/100;
  if IndInvalido then MarcaErroRPAS(wSerie.RPAS,2,wserie.fin.Codreaj,DtIndInvalido);
end;

function TParcelaSerie.ValorPresente(DataRef:TData; Taxa:Double):Double;
var MacRef : Integer;
begin
  Result := ValorCorrigido(DataRef);
  MacRef := mes_int(DataRef.MesAno);
  if Mac > MacRef then { Descapitalizar os juros }
    Result := -PresentValue(Taxa,Mac - MacRef,0,Result,ptEndOfPeriod);
end;

function TParcelaSerie.ValorPresenteOrig(MACRef:integer; Taxa:Double):Double;
// Retorna o valor presente original (n o corrigido) da parcela na
// moeda da dataref da S rie.
begin
  Result := Self.Valor;
  if Mac > MacRef then { Descapitalizar os juros }
    Result := -PresentValue(Taxa,Mac-MacRef,0,Result,ptEndOfPeriod);
end;

function PagamentoOk(RegPgto : TpValPgto; DataProcPgRef : Tdata; PgtoDeSeguro : boolean = false) : boolean;
begin
  result := ((RegPgto.DtPg.Dia > 0) or (RegPgto.TipoPg in [200,253]) or
              RegPgto.TemPgParcial) and
            (PgtoDeSeguro or (not (RegPgto.TipoPg in PgtoComRedSdDev)) or
             (DataProcPgRef.Dia = 0) or (juliano(RegPgto.DtProc) <= juliano(DataProcPgRef)));
end;

procedure TParcelaSerie.AcertaPagamentosParciais;
var
  i : integer;
  DtUltimoPagamento : TData;
begin
  if TemPgParcial and
     ((DtPg.Dia <= 0) or (TipoPg in [8..9,74,95,108,110,114,117,121,200,253])) then begin
    ValorPago := 0;
    DescontoPagamento := 0;
    for i := 0 to PagamentosParciais.count-1 do begin
      ValorPagoAntecipado := ValorPagoAntecipado + PagamentosParciais[i].AmaisJ;
      ValorPago := ValorPago + PagamentosParciais[i].Valor;
      if PagamentosParciais[i].TipoPgParcial > 0 then
        TipoPg := PagamentosParciais[i].TipoPgParcial
      else if (not (PagamentosParciais[i].TipoPgParcial in [111,115])) then
        TipoPg := 51;
      DtPg := PagamentosParciais[i].DtPg;
      DtProcPg := PagamentosParciais[i].DtProc;
    end;
  end;

  for i := 0 to PagamentosParciais.count-1 do begin
    PagamentosParciais[i].TipoPgTotalParcela := TipoPg;
    PagamentosParciais[i].DtPgTotalParcela := DtPg;
    PagamentosParciais[i].Mac := MAC;
    PagamentosParciais[i].DiaVenc := DiaVenc;
  end;

  ValorPagoNoUltimoPagamento  := ValorPago{ + DescConcedido Sol. 47799 } ;
  AmaisjPagoAteUltimoPagamento := 0;
  
  if TipoPg in PgtoComRedSdDev then begin // Pode ter pagamentos parciais
    ValorPagoNoUltimoPagamento := 0;
    DtUltimoPagamento := PagamentosParciais.GetUltimoPagamento;
    if Juliano(DtUltimoPagamento) > 0 then
      for i := 0 to PagamentosParciais.count-1 do
        if (juliano(PagamentosParciais[i].DtPg) <= Juliano(DtUltimoPagamento)) and
           (PagamentosParciais[i].TipoPgParcial <> 80) then
          AmaisjPagoAteUltimoPagamento := AmaisjPagoAteUltimoPagamento + PagamentosParciais[i].Amaisj
        else
          ValorPagoNoUltimoPagamento := ValorPagoNoUltimoPagamento + PagamentosParciais[i].Valor;
  end;
end;

