{TValoresEmitidos}

function TValoresEmitidosItem.total : real;
begin
  result := AmaisJ + Fcvs + Seguro + ValTxAdm - FGTS -
            Desc   + Despesa +
            ValAcordo + ResiduoCobrado + Difmanual +
            DifCalculada;
end;

function TValoresEmitidos.GetItems(Mac : integer) : TValoresEmitidosItem;
begin
  if (Mac >= FInicio) and ((Mac-FInicio) < FList.count) then
    result := TValoresEmitidosItem(FList[Mac-FInicio])
  else
    result := Nil;
end;

constructor TValoresEmitidos.create;
begin
  inherited;
  FList := TList.create;
  FInicio := 0;
end;

destructor TValoresEmitidos.destroy;
begin
  clear;
  FList.free;
  inherited destroy;
end;

procedure TValoresEmitidos.clear;
var
  i : integer;
begin
  for i := 0 to FList.count-1 do
    TValoresEmitidosItem(FList[i]).free;
  Flist.clear;
end;

procedure TValoresEmitidos.Adiciona(Mac : integer; Var RegEmi : TpEmicons);
begin
  if Mac < Finicio then
//    raise exception.create('Escrita anterior ao in cio dos valores emitidos');
// alterei para ignorar registros anteriores ao inicio do contrato
  else begin
    if (mac-FInicio) >= FList.count then
      FList.count := mac-FInicio+50;
    Flist[Mac-Finicio] := TValoresEmitidosItem.create;
    with TValoresEmitidosItem(FList[Mac-FInicio]) do begin
      AmaisJ := RegEmi.Amaisj;
      Fcvs := RegEmi.Fcvs;
      Seguro := RegEmi.Seguro;
      ValTxAdm := RegEmi.ValTxAdm;
      FGTS := RegEmi.FGTS;
      Desc := RegEmi.Desc;
      Despesa := RegEmi.Despesa;
      ValAcordo := RegEmi.ValAcordo;
      ResiduoCobrado := RegEmi.ResiduoCobrado;
      Difmanual := RegEmi.DifManual;
      DifCalculada := RegEmi.DifCalculada;
    end;
  end;
end;

