end;

procedure TSeries.CalculaQuitacao(    Parametros : TParametrosQuitacaoEvo;
                                      SeriesReneg : TSeriesReneg);
var
  i : integer;
  SerieReneg : TSerieReneg;
begin
  if Count > 0 then begin

    Parametros.InformouTxOportunidade := false;

    // Criar objetos s rie no objeto de resposta series
    if Contrato.TemRes3516Evo(Parametros.Dataref) then
      SeriesReneg.Tx3516 := TaxaSelicCache.Le(Parametros.Dataref) + Contrato.MutDsk.Cad6.TxSpread3516;
    SeriesReneg.Tx3516 := (pot ( 1 + SeriesReneg.Tx3516/100,1/12)-1)*100 ;

    for i := 0 to count-1 do begin
      SerieReneg := SeriesReneg.add as TSerieReneg;
      GetSerie(i).CalculaQuitacao(Parametros,SerieReneg);
      if SerieReneg.SaldoParaQuitacao = 0 then
        SerieReneg.free;
    end;

  end;
end;

