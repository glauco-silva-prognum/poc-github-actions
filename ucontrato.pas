procedure TContrato.CalculaPendPosTermino(    MacIni,
                                              MacFim   : integer;
                                              DtCorr   : Tdata;
                                          Var PendT,
                                              CorrT,
                                              MoraT    : real;
                                              Dados    : TDadosAcertoEvo;
                                              EmUPF    : boolean;
                                              DataEmi  : Tdata;
                                              TipoEmissao : smallint;
                                              Grava       : boolean{GravaPendEmi});
var
  ArrPend        : TpArrayPend;
  i,
  QtdPend        : smallint;
  Dif,
  Corr,
  Mora           : real;
  Item : TItemAcertoEvo;
  RPendEmi : TpPendEmi;
  DifAtu,
  PrstAnt : real;
begin
  PendT := 0;
  CorrT := 0;
  MoraT := 0;
  Mora := 0;
  Corr := 0;
  DifAtu := 0;
  ArrPend[1].ValorPend := 0;
  fillchar(ArrPend,sizeof(ArrPend),0);
  QtdPend := ObtemPendPosTermino(MutDsk,MACIni,MACFim,DtCorr,ArrPend);
  if QtdPend > 0 then begin
    for i := 1 to QtdPend do begin
      PrstAnt := (ArrPend[i].ValorPend*-1);
      Dif := ArrPend[i].ValorPend;
      AtualizaPendPosTermino(MutDsk,ArrPend[i],DtCorr,EmUpf,DifAtu,Corr,Mora);
      if assigned(Dados) then begin
        Item := TItemAcertoEvo.create;
        Item.PendPosTerm := true;
        Item.DtVenc := ArrPend[i].DataCorr;
        Item.PrstAnt := PrstAnt;
        Item.Dif := Dif;
        Item.DifAtu := DifAtu;
        Item.Corr := Corr;
        Item.CodSerie := 0;
        Dados.add(Item);
      end;
      if Grava then begin
        RPendEmi.Ctr := '';
        fillchar(RPendEmi,sizeof(TpPendEmi),0);
        with RPendEmi do begin
          Ctr            := MutDsk.Cad.Ctr;
          TpEmissao      := TipoEmissao;
          OrigPendEmi    := 3; //PendPosTerm
          DtEmi          := DataEmi;
          MAC            := Mes_Int(ArrPend[i].DataCorr.MesAno);
          ValDevido      := 0;
          ValPago        := PrstAnt;
          DifAtual       := DifAtu;
          Atualizacao    := Corr + Mora;
        end;
        RPendEmi.DtVenc  := ArrPend[i].DataCorr;
        RPendEmi.DtPag   := RPendEmi.DtVenc;
        GravaPendEmi(RPendEmi);
      end;
      PendT := PendT + Dif;
      CorrT := CorrT + Corr;
    end;
  end;
end;

procedure TContrato.ObtemPendCalcOutros(    DtIni,
                                            DtFim       : Tdata;
                                        var ValorT,
                                            CorrT,
                                            MoraT       : Real;
                                            DtCorr      : TData;
                                            Dados       : TDadosAcertoEvo;
                                            EmUpf       : boolean;
                                            CalculaSomenteDifPrest : boolean;
                                            DataEmi     : Tdata;
                                            TpEmissao   : smallint;
                                            GravaPendEmi : boolean);
var
  MacIni,
  MacFim : smallint;
  Pend,
  CorrP,
  MoraP : real;
begin
  MoraP := 0;
  CorrP := 0;
  Pend := 0;
  MacIni := Mes_int(DtIni.MesAno);
  MacFim := Mes_int(DtFim.MesAno);
  ValorT := 0; MoraT := 0; CorrT := 0;

  if TemFinancDinamico(MutDsk) then
    if MacIni < Mes_Int(MutDsk.Financ.DtInFin.MesAno)+1 then
      MacIni := Mes_Int(MutDsk.Financ.DtInFin.MesAno)+1;
  if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);

  if not CalculaSomenteDifPrest then begin
    CalculaDifPrestOutros(MacIni,MacFim,DtCorr,Pend,CorrP,MoraP,Dados,EmUPF,DataEmi,TpEmissao,GravaPendEmi);
//    CalculaDifPagQuit(MacIni,MacFim,DtCorr,Pend,CorrP,MoraP,Dados,EmUPF,DataEmi,TpEmissao,GravaPendEmi);
    if abs(Pend + Corr + MoraP) > zero then begin
      ValorT := ValorT + Pend;
      CorrT  := CorrT + CorrP;
      MoraT  := MoraT + MoraP;
    end;
  end;

  CalculaPendPosTermino(MacIni,MacFim,DtCorr,Pend,CorrP,MoraP,Dados,EmUPF,DataEmi,TpEmissao,GravaPendEmi);
  if abs(Pend + Corr + MoraP) > zero then begin
    ValorT := ValorT + Pend;
    CorrT  := CorrT + CorrP;
    MoraT  := MoraT + MoraP;
  end;
  
  if Not EmUpf then begin
    if Abs(ValorT) > Zero then begin
      if ValorT > Zero then
        ValorT :=  int(    ValorT * 100.0+0.5) / 100.0
      else
        ValorT := -int(Abs(ValorT)* 100.0+0.5) / 100.0;
    end;
    if Abs(CorrT) > Zero then begin
      if CorrT > Zero then
        CorrT  :=  int(    CorrT * 100.0+0.5) / 100.0
      else
        CorrT  := -int(Abs(CorrT)* 100.0+0.5) / 100.0;
    end;
    if Abs(MoraT) > Zero then begin
      if MoraT > Zero then
        MoraT  :=  int(    MoraT * 100.0+0.5) / 100.0
      else
        MoraT  := -int(Abs(MoraT)* 100.0+0.5) / 100.0;
    end;
  end;
end;

function TContrato.CalculaAcertoFinOutros(DataRef, DtInipend, DtFimPend : TData; Dados : TDadosAcertoEvo; CalculaSomenteDifPrest : boolean; DataEmi : TData; TipoEmissao : smallint; GravaPendEmi : boolean) : real;
var
  Valor,
  Corr,
  Mora,
  VMoeda : real;
begin
  Valor := 0;
  Corr := 0;
  Mora := 0;
  if Scciconf.CalcPendAutoPorUPF then begin
    ObtemPendCalcOutros(DtIniPend,DtFimPend,Valor,Corr,Mora,DataRef,Dados,true,CalculaSomenteDifPrest,DataEmi,TipoEmissao,GravaPendEmi);
    if (Abs(Valor) > Zero) or (Abs(Mora) > Zero) then begin
      VMoeda := LE_UPFD(DataRef);
      if VMoeda <= Zero then VMoeda := LE_VRF(mes_int(DataRef.Mesano));
      if VMoeda <= Zero then VMoeda := 1.0;
      if Abs(Valor) > Zero then begin
        Valor := Valor*VMoeda;
        if Valor > Zero then
          Valor :=  int(    Valor * 100.0+0.5) / 100.0
        else
          Valor := -int(Abs(Valor)* 100.0+0.5) / 100.0;
      end;
      if Abs(Mora) > Zero then begin
        Mora := Mora * VMoeda;
        if Mora > Zero then
          Mora  :=  int(    Mora  * 100.0+0.5) / 100.0
        else
          Mora  := -int(Abs(Mora) * 100.0+0.5) / 100.0;
      end;
    end;
  end
  else
    ObtemPendCalcOutros(DtIniPend,DtFimPend,Valor,Corr,Mora,DataRef,Dados,false,CalculaSomenteDifPrest,DataEmi,TipoEmissao,GravaPendEmi);
  result := Valor + Corr + Mora;
end;


function  TContrato.CalculaAcertoFin(    DataRef, DtInipend, DtFimPend, DataEmi : Tdata;
                                         Dados : TDadosAcertoEvo;
                                         Com200 : boolean;
                                         SemLiminar : boolean;
                                         Grava : boolean;
                                         UtilizaJMora : boolean = true;
                                         UtilizaJCont : boolean = false;
                                         TipoJur : integer = 0;
                                         CalculaSomenteDifPrest : boolean = false;
                                         CarregaPagamentosSemDiferenca : boolean = false;
                                         IgnoraPA : boolean = false;
                                         IgnoraTipoDePagamento : boolean = false) : real;
var
  i : integer;
  TipoEmissao : smallint;
  Reg : TValoresPorMac;
  TemRescisao : boolean;
begin
  result := 0;
  Reg := ObtemValoresPorMac(mes_int(DataRef.MesAno));
  if assigned(Reg) then
    TemRescisao := (Reg.Status = 29) and not Reg.CtrAtivo
  else
    TemRescisao := false;
  if Scciconf.PendImplant and ((MutDsk.Financ.PA <> 38) or IgnoraPA) and not TemRescisao then begin
    if Grava then
      LimpaPendEmi(MutDsk.Cad.Ctr,Com200,DataEmi);
    for i := 0 to Series.count-1 do
      result := result + Series[i].CalculaAcertoFin(DataRef,DtInipend, DtFimPend, DataEmi, Dados, Com200, Grava,UtilizaJMora,UtilizaJCont,TipoJur,
                                                    CarregaPagamentosSemDiferenca,IgnoraTipoDePagamento);
    if TemFinancDinamico(MutDsk) then
      result := result + GetSerieFinanciamentoDinamico.CalculaAcertoFin(DataRef,DtInipend, DtFimPend, DataEmi, Dados, Com200, SemLiminar, Grava,
                                                                        UtilizaJMora,UtilizaJCont,TipoJur,CarregaPagamentosSemDiferenca,
                                                                        IgnoraTipoDePagamento);
    if Com200 then TipoEmissao := 1 else TipoEmissao := 2;
    result := result + CalculaAcertoFinOutros(DataRef, DtInipend, DtFimPend, Dados, CalculaSomenteDifPrest,DataEmi,TipoEmissao,Grava);
    if abs(result) < 1.0 then begin // Ignorar qualquer acerto financeiro inferior a 1 sol. 41753
      if assigned(Dados) then
        Dados.clear;
      result := 0;
    end;
    if assigned(Dados) then
      Dados.OrdenaPorVencimentoECodSerie;
  end;
end;

procedure TContrato.LeValoresPorMacRef(Parametros : TParametrosQuitacaoEvo; DadosQuitacao : TDadosQuitacaoEvo);
var
  i : integer;
begin
  DadosQuitacao.RegConsRef := ObtemValoresPorMac(mes_int(Parametros.DataRef.mesano));
  if not assigned(DadosQuitacao.RegConsRef) then
    raise exception.create('Cache de evolu  o n o gerado');

  if TemFinancDinamico(Mutdsk) then
    DadosQuitacao.RegFinancRef := SerieF.ObtemValoresPorMac(mes_int(Parametros.DataRef.mesano));

  SetLength(DadosQuitacao.ArrRegSerieRef,Series.count);

  for i := 0 to Series.count-1 do
    DadosQuitacao.ArrRegSerieRef[i] := Series[i].ObtemValoresPorMac(mes_int(Parametros.DataRef.mesano));
end;

procedure TContrato.DefinePerReajQuit(DadosQuitacao : TDadosQuitacaoEvo);
var
  i : integer;
begin
  DadosQuitacao.MReaj  := 0;
  DadosQuitacao.PerFin := 0;
  if assigned(DadosQuitacao.RegFinancRef) and DadosQuitacao.RegFinancRef.CtrAtivo then begin
    DadosQuitacao.PerFin := DadosQuitacao.RegFinancRef.PerFin;
    DadosQuitacao.MReaj := DadosQuitacao.RegFinancRef.MReaj;
  end;
  for i := 0 to Series.count - 1 do
    if not Series[i].Fin.NaoConsideraSerieCalcQuit then begin
      if DadosQuitacao.ArrRegSerieRef[i].CtrAtivo and
         (DadosQuitacao.ArrRegSerieRef[i].PerFin > 0) and
         ((DadosQuitacao.ArrRegSerieRef[i].PerFin < DadosQuitacao.PerFin) or
          (DadosQuitacao.PerFin = 0)) then begin
        DadosQuitacao.PerFin := DadosQuitacao.ArrRegSerieRef[i].PerFin;
        DadosQuitacao.MReaj := DadosQuitacao.ArrRegSerieRef[i].MReaj;
      end;
    end;
end;

function TContrato.TemRenegPosteriorARef(    DataRef : Tdata;
                                         Var DtReneg : TData): boolean;
var
  i : SmallInt;
begin
  fillchar(DtReneg,sizeof(Tdata),0);
  result := false;
  i := 1;
  while (i <= HistMem[0].Tam) and not result do begin
    if (HistMem[i].Log.CodMov = 53) then
      if Juliano(HistMem[i].Log.Data) > Juliano(DataRef) then begin
        result := true;
        DtReneg := HistMem[i].Log.Data;
      end;
    inc(i);
  end;
end;

function TContrato.TemRenegAnteriorARef(DadosQuitacao : TDadosQuitacaoEvo; Dataref : Tdata) : boolean;
var
  i : smallint;
begin
  result := (DadosQuitacao.RegConsRef.Status = 30) and
            ((DadosQuitacao.RegConsRef.MacStatus < Mes_Int(DataRef.MesAno)) or
             ((DadosQuitacao.RegConsRef.MacStatus = Mes_Int(DataRef.MesAno)) and (byte(DadosQuitacao.RegConsRef.diaLiq) < DataRef.Dia)));
  if result then
    for i := 0 to Series.count-1 do
      if DadosQuitacao.ArrRegSerieRef[i].CtrAtivo and (Series[i].Fin.CompoeSaldo) then
        result := false;
end;

function TContrato.CriticaQuitacao(Parametros : TParametrosQuitacaoEvo; DadosQuitacao : TDadosQuitacaoEvo) : boolean;
var
  DtReneg : TData;
begin
  result := true;
  DtReneg.dia := 0; DtReneg.mes := 0; DtReneg.ano := 0;
  if DadosQuitacao.RegConsRef.TemOpcao(84) then // sol 25297
    DadosQuitacao.Confirmacoes.add('Este contrato encontra-se em condi  o especial de negocia  o '+
                                   'junto ao FCVS, segundo normas da MP 175 e a revelia do mutu rio. '+
                                   'Deseja prosseguir com o c lculo?');
  if MostraAlertaNaQuitacao(MutDsk,Parametros.DataRef) and
     not Parametros.CalculaParaWeb then
    DadosQuitacao.Confirmacoes.add(DescSitAlerta(MutDsk,Parametros.DataRef));

  DadosQuitacao.ContratoTemRenegPosteriorARef := TemRenegPosteriorARef(Parametros.DataRef,DtReneg);
  if not Parametros.IgnoraCriticaRenegPosRef and DadosQuitacao.ContratoTemRenegPosteriorARef then begin
    result := false;
    DadosQuitacao.Error := 'Opera  o n o permitida, contrato renegociado em '+data_str2(DtReneg);
  end;

  if result then begin
    if assigned(DadosQuitacao.RegFinancRef) and not Parametros.ProgAcasaESua and (DadosQuitacao.RegFinancRef.PA = 81) and (not scciconf.PermiteLiquidarOuTransferirPlanoPSH) then
      DadosQuitacao.Error := 'O programa PSH n o permite que seja realizada LAN' // Na rotina antiga setava o erro, mas n o impedia o c lculo. Ajustei a nova para ficar igual
    else if scciconf.PrestAberQuitacao and
            (NumPrstAtrasoEvo(Parametros.DataRef,Parametros.DataRef) > 0) then
      DadosQuitacao.Error := 'Contrato com Prestacao em Aberto'; // Na rotina antiga setava o erro, mas n o impedia o c lculo. Ajustei a nova para ficar igual

    if result then begin
      if DadosQuitacao.RegConsRef.TemQuitAnteriorARef(Parametros.DataRef) and
         not (Parametros.Lei4149 or
              Parametros.ProgACasaESua or
              Parametros.Lei5287) then begin
        if Parametros.CalculaParaWeb then
          raise exception.create('Contrato j  est  liquidado.');
        result := false;
        DadosQuitacao.error := 'C lculo de quita  o n o permitido. Contrato j  liquidado.';
      end
      else if DadosQuitacao.RegConsRef.TemCessaoNaData(Parametros.DataRef) then begin
        result := false;
        DadosQuitacao.error := 'C lculo de quita  o n o permitido. Contrato cedido.';
      end
      else if DadosQuitacao.RegConsRef.TemTermAnteriorARef(Parametros.DataRef) and
              not (Parametros.Lei4149 or
                   Parametros.ProgACasaESua or
                   Parametros.Lei5287) then begin
        if Parametros.CalculaParaWeb then
          raise exception.create('Contrato est  terminado.');
        result := false;
        DadosQuitacao.Error := 'C lculo de quita  o n o permitido. Contrato terminado.';
      end
      else if TemRenegAnteriorARef(DadosQuitacao,Parametros.Dataref) then begin
        if Parametros.CalculaParaWeb then
          raise exception.create('Contrato est  Renegociado.');
        result := false;
        DadosQuitacao.Error := 'C lculo de quita  o n o permitido. Contrato Renegociado.';
      end;
    end;
  end;

  if result then
    if Parametros.TMoraAtr = 199 then
      if ScciConf.ConsultaCartParaLibMoraNaQuit then
        if not CarteiraConcedeIsenMoraAuto(DadosQuitacao.RegConsRef.Carteira) then begin
          result := false;
          DadosQuitacao.Error := 'N o   permitido isen  o de juros de mora para essa carteira';
        end;
end;

function TContrato.CalculaQuitPorPxN(DadosQuitacao : TDadosQuitacaoEvo) : boolean;
var
  RCart : TpCarteira;
begin
  RCart.LiqCalcPorPxN := false;
  fillchar(RCart,sizeof(RCart),0);
  result := false;
  if not DadosQuitacao.RegConsRef.FcvsCobre then begin
    LeCarteira(DadosQuitacao.RegConsRef.carteira,Rcart);
    result := RCart.LiqCalcPorPxN;
  end;
end;

function Tcontrato.RetornaDevolucaoDePrstPagaPosTermino(DataRef : TData): real;
var
  RegParc       : TpParcelas;
  RegAcordo     : TpAcordos;
  MACIni,
  MACPrz        : smallint;
  DtPg          : TData;
  ValorPg       : real;
  Parcela       : TParcela;
begin
  RegAcordo.Ctr := '';
  fillchar(RegAcordo,sizeof(RegAcordo),0);
  RegParc.Codigo := 0;
  fillchar(RegParc,sizeof(RegParc),0);
  ValorPg := 0;
  DtPg.dia := 0; DtPg.Mes := 0; DtPg.Ano := 0;
  result := 0;
  if Scciconf.DevolveNaLANPrstsPagasPosTermino {and
     RPA.Temp6.EDoSFH sol. 29314 }then begin
    MACIni     := Mes_Int(DataRef.MesAno);
    if DataRef.Dia >= byte(RPA.FinRPA.DiaVenc) then inc(MACIni);
    MACPrz := Mes_Int(RPA.FinRPA.DtInFin.MesAno)+RPA.FinRPA.Prazo;
    while MACIni <= MACPrz do begin
      parcela := SerieF.Parcelas.ObtemParcelaPorMac(MacIni);
      if assigned(Parcela) and Parcela.EstaPagaReal then begin
        DtPg := Parcela.DtPg;
        ValorPg := Parcela.ValorPago;
        AjustaMoeda2(mes_int(DtPg.Mesano),Mes_int(Dataref.mesano),ValorPg);
        result := result + ValorPg;
        PegaPrstAcordo(MutDsk.Cad.Ctr,MACIni,RegAcordo,RegParc);
        if RegParc.DtPag.Dia > 0 then begin
          AjustaMoeda2(mes_int(RegParc.DtPag.Mesano),Mes_int(Dataref.mesano),RegParc.ValPg);
          result := result + RegParc.ValPg;
        end;
      end;
      inc(MACIni);
    end;
  end;
end;

function TContrato.TemLiberacaoNaData(DtLib : TData) : boolean;
var
  i : integer;
begin
  result := false;
  for i := 0 to LiberacoesPlanoEmp.count-1 do
    with LiberacoesPlanoEmp[i], LiberacoesPlanoEmp[i].LiberacaoPlanoEmp do begin
      if (TipoLiberacao = 4) and (Juliano(DtLiberacao) = Juliano(DtLib)) then
        result := true;
    end;
end;

procedure TContrato.LimpaSerieFinanciamentoDinamico;
begin
  freeAndNil(FSerieFinanciamentoDinamico);
end;

procedure TContrato.CalculaSimQuitNova(Parametros : TparametrosQuitacaoEvo; DadosQuitacao : TDadosQuitacaoEvo);
var
  RPAComQuit : TpRPA;
  Op : TOpcoesQuitacaoEvoItem;
  MacTpz : integer;
  DtTpz : Tdata;
  ValoresPorMacAux : TValoresPorMac;
  UPFTpz,
  UPFRef : real;
  ProRata : real;
  Dt1Venc : Tdata;
  RPAAux : tpRPA;
  DtAux : Tdata;
  PrstRem : integer;
  ValMoraAux : real;
  CorrAux : real;
  RespMut : real;
begin
// Rotina copiada da quitlib.CalculaQuit. Apesar de copiar toda a l gica, s  foi trabalhada a op  o sem desconto

  RespMut := 0;
  ValMoraAux := 0;
  RPAAux.ctr := '';
  fillchar(RPAAux,sizeof(TpRPA),0);
  DtTpz.dia := 0;
  fillchar(DtTpz,sizeof(Tdata),0);
  
  if Juliano(Parametros.DataRef) < Juliano(MutDsk.Financ.DtAssin) then begin
    DadosQuitacao.ErroQuit := 2;
    exit;
  end;

  if ((Parametros.Lei4149 or Parametros.ProgACasaESua) and (RPAF.FinRpa.Status = 8)) or
     (Parametros.Lei5287 and (RPAF.FinRpa.Status > 1))  then
    MacTpz := RPAF.ValRpa.MacStatus
  else
    MacTpz := 0;

  if DadosQuitacao.ErroQuit = 0 then begin
  
    DadosQuitacao.DevolPrstPaga := RetornaDevolucaoDePrstPagaPosTermino(Parametros.DataRef);

    RPAComQuit := RPAF;
    
    // For ar condicoes da quitacao
    // ExOpc=26 (Quit Sem Desc} DiaLiq
    RPAComQuit.FinRPA.ExOpc := 26;
    RPAComQuit.FinRPA.DiaLiq := Parametros.DataRef.Dia;

    // a LiquidaCTR espera o saldo antes da amortiza  o
    if (RPAComQuit.FinRPA.DiaVenc > RPAComQuit.FinRPA.DiaLiq) then
      RPAComQuit.ValRPA.SaldoDev := RPAComQuit.ValRPA.SaldoDev + RPAComQuit.ValRPA.Amaisj-RPAComQuit.ValRPA.Juro;

    // a liquidaCTR   a rotina que efetivamente calcula dados da quita  o de financ. din mico
    // normalmente, se altera os hist ricos e chama a evolu  o, para obter a simula  o dos c lculos
    // mas aqui estamos for ando o tipo da Lan via altera  o direta no RPA.
    LiquidaCTR(RPAComQuit,1{n});
    
    // Como a evolu  o do m s foi calculada, o seguro foi calculado sem o evento da liquida  o
    // Assim, estou tentando imitar o que a evolu  o faria, zerando o seguro, se for
    // depois do vencimento ou caso ele seja calculado no m s(saldo seria zerado j  que liquidou)
    // essa l gica est  na uevolui3, rotina LiquidaCtr
    if RPAComQuit.FinRPA.DiaLiq < RPAComQuit.FinRPA.DiaVenc then begin
      ValoresPorMacAux := SerieF.ObtemValoresPorMac(RPAComQuit.Mac-1);
      RPAComQuit.Temp8.SeguroLan := ValoresPorMacAux.segfin + ValoresPorMacAux.segimv + ValoresPorMacAux.segcre;
    end
    else if ((ValInt(Scciconf.NSerie) = nsEconomisa) and
             (RPAComQuit.FinRpa.DiaVenc = RPAComQuit.FinRpa.diaLiq)) or
            (RPAComQuit.FinRPA.DiaVenc < RPAComQuit.FinRPA.DiaLiq) or
            FOEvolui3.CalculouSeguroNoMes then
      RPAComQuit.Temp8.SeguroLan := 0;

    Op := DadosQuitacao.Opcoes.add as TOpcoesQuitacaoEvoItem;

    (* DataVenc *)
    if Parametros.DataRef.Dia >= byte(RPAComQuit.FinRPA.DiaVenc) then begin
      Op.DataVenc.Dia := RPAF.FinRpa.DiaVenc;
      Int_Mes(RPAComQuit.MAC,Op.DataVenc.MesAno);
    end
    else begin
      try
        ValoresPorMacAux := SerieF.ObtemValoresPorMac(RPAComQuit.Mac-1);
        Op.DataVenc.Dia := ValoresPorMacAux.DiaVenc;
        Int_Mes(ValoresPorMacAux.MAC,Op.DataVenc.MesAno);
      except
        // eu n o sabia exatamente o que fazer, se n o conseguir achar os dados da evolu  o do m s anterior
        // ent o setei o dia da assinatura com o mac do m s anterior, tentanto imitar o que a rotina j  fazia
        // no c digo logo abaixo
        Op.DataVenc.Dia := RPAF.FinRPA.DtAssin.Dia;
        Int_Mes(RPAComQuit.Mac-1,Op.DataVenc.MesAno);
      end;
    end;

    // Sol. 65597
    if (RPAF.FinRPA.NPC = 0) and // em fase de car ncia
       (RPAF.Mac = mes_int(RPAF.FinRPA.DtAssin.mesano)) and // m s da assinatura
       (byte(RPAF.FinRPA.DiaVenc) < RPAF.FinRPA.DtAssin.dia) then // vencimento anterior a assinatura
      Op.DataVenc.dia := RPAF.FinRPA.DtAssin.dia; // usar o dia da assinatura e n o o dia de vencimento

    (* DataQuit *)
    Op.DataQuit.Dia := RPAComQuit.FinRpa.DiaLiq;
    Int_Mes(RPAF.MAC,Op.DataQuit.MesAno);
    
(*
    dttst := RPAQuit.Temp3.DataLeg;
    if Dttst.Dia=0 then Dttst := RPAQuit.FinRPA.DtAssin;

    if (not NaoConsideraSdPar) then begin
      if (RPAQuit.Temp7.DtLiqSdPar.dia = 0) and
         (abs(SaldoParAnt) > 0) then begin
        if Mes_Int(DtSaldoParAnt.MesAno) > 0 then
          ProRata := Correcao0(DtSaldoParAnt, DataRef, DtSaldoParAnt, SaldoParAnt)
        else
          ProRata := 0;
        RegQuit.SaldoParCorr := SaldoParAnt + ProRata;
      end;
    end;
*)

    (* SaldoProRata *)
    if (Parametros.Lei4149 or Parametros.ProgACasaESua or Parametros.Lei5287) and (MacTpz > 0) then begin
      int_mes(MacTpz,DtTpz.mesano);
      DtTpz.Dia := RPAComQuit.FinRpa.DtInFin.Dia;
      if DtTpz.Dia > Dias_mes(MacTpz) then DtTpz.Dia := Dias_Mes(MacTpz);
      ValoresPorMacAux := SerieF.ObtemValoresPorMac(Mes_int(DtTpz.mesano));
      Op.SaldoDevL := ValoresPorMacAux.SaldoDev;
      if Op.SaldoDevL > zero then begin
        if Parametros.Lei4149 and not RPAComQuit.FinRPA.FCVSCobre then begin
          UPFRef := Le_UPFDComPrecisao(Parametros.DataRef);
          UPFTpz := Le_UPFDComPrecisao(DtTpz);
          Op.IndProSaldo := UPFRef/UPFTpz;
          Op.SaldoProRata := Op.SaldoDevL * Op.IndProSaldo;
        end
        else begin
          if DadosQuitacao.CorrecaoAplicada > zero then ProRata := DadosQuitacao.CorrecaoAplicada
          else begin
            ProRata := Correcao0(DtTpz, Parametros.DataRef, DtTpz, Op.SaldoDevl);
          end;
          AjustaMoeda2(MacTpz,mes_int(Parametros.Dataref.mesano),Op.saldodevl);
          Op.SaldoProrata := Op.SaldoDevl+ProRata;
          if (Abs(Op.SaldoDevl) > Zero) and (Abs(Op.SaldoProRata) > Zero) then
            Op.IndProSaldo  := Op.SaldoProRata / Op.SaldoDevl
          else
            Op.IndProSaldo := 1.0;
        end;
        RPAComQuit.FinRpa2.ValorLA := Op.SaldoProRata;
      end;
    end
    else if (RPAF.FinRPA.Status <> 7) or (Parametros.DataRef.Dia < byte(RPAF.FinRPA.DiaVenc)) then begin
      if DadosQuitacao.CorrecaoAplicada > zero then begin
        Op.SaldoProRata := RPAComQuit.Temp3.SDT-RPAComQuit.FinRpa2.RecProliq + DadosQuitacao.CorrecaoAplicada;
        RPAComQuit.FinRpa2.ValorLA := RPAComQuit.FinRpa2.ValorLA-RPAComQuit.FinRpa2.RecProliq + DadosQuitacao.CorrecaoAplicada;
        RPAComQuit.FinRpa2.RecProliq := DadosQuitacao.CorrecaoAplicada;
      end
      else
        Op.SaldoProRata := RPAComQuit.Temp3.SDT;

      (* SaldoDevl *)
      Op.SaldoDevl := Op.SaldoProRata - RPAComQuit.FinRPA2.RecProliq;
      (* IndProSaldo *)
      if (Abs(Op.SaldoDevl) > Zero) and (Abs(Op.SaldoProRata) > Zero) then
        Op.IndProSaldo  := Op.SaldoProRata / Op.SaldoDevl
      else
        Op.IndProSaldo := 1.0;
    end;
    (* TipoEvento *)
    Op.TipoEvento := RPAComQuit.Temp6.TipoEvento;
    Op.Seguro := 0;
    (* Procedure introduzida para informar prestacao retirando indice de seguro *)
    if Smallint(Parametros.DataRef.Dia) < RPAF.FinRpa.DiaVenc then begin
      RPAComQuit.ValRpa.TotPrest := RPAF.ValRpa.TotPrest;
      RPAComQuit.ValRpa.AmaisJ   := RPAF.ValRpa.AmaisJ;
      RPAComQuit.ValRpa.Juro     := RPAF.ValRpa.Juro;
      RPAComQuit.ValRpa.FCVS     := RPAF.ValRpa.FCVS;
      RPAComQuit.ValRpa.FGTS     := RPAF.ValRpa.FGTS;
      RPAComQuit.ValRpa.SegCre   := RPAF.ValRpa.SegCre;
      RPAComQuit.ValRpa.SegFin   := RPAF.ValRpa.SegFin;
      RPAComQuit.ValRpa.SegImv   := RPAF.ValRpa.SegImv;
      RPAComQuit.ValRpa.Seguro   := RPAF.ValRpa.Seguro;
      RPAComQuit.ValRpa.ValTxAdm := RPAF.ValRpa.ValTxAdm;
     (* Estou preenchendo esses valores para os casos da quitacao PxN e Px5 *)
    end;

    if Op.TipoEvento in [ 1,4,6,9,13,14,19,25,26,27, 28,41] then (* Calculo de Seguro e Juros ProRata*)
    begin                                                        (* Para Sem Desconto, 50%, Nov. 30, 70%, 90% e 100% *)

      (* Seguro *)

      if ((RPAF.temp11.SaldoDevedorDescCada > zero) and
          (RPAF.Temp5.PercDesc > zero)) or Parametros.Lei4149 or RPAF.Temp11.NaoCobraSegUltPrst or
         ((Smallint(Parametros.DataRef.Dia) < RPAComQuit.FinRpa.DiaVenc) and ScciConf.InibeSegNaLanAntesDoVenc) then Op.Seguro := 0
      else
        Op.Seguro := RPAComQuit.Temp8.SeguroLAN;

      (* JurosCont *)
      Dt1Venc := RPAF.FinRpa.DtInFin;
      incMA(Dt1Venc.mesano);
      if Dt1Venc.Dia > Dias_mes(mes_int(Dt1Venc.MesAno)) then
        Dt1Venc.Dia := Dias_Mes(mes_int(Dt1Venc.mesano));
      if (mes_int(Dt1Venc.mesano) - mes_int(RPAF.FinRpa.DtAssin.mesano) <= 1) or  (* se n o tem carencia *)
         ((juliano(Op.DataQuit) >= juliano(Dt1Venc)) or (* se quit. depois da carencia *)
         (not ScciConf.DispensaJurosProRataNaCarencia)) (* n o dispensa juros na carencia *) then begin
        if (Parametros.Lei4149 or Parametros.ProgACasaESua or Parametros.Lei5287) and (MacTpz > 0) then begin
          if not Parametros.Lei4149 or RPAComQuit.FinRPA.FCVSCobre then
            Op.JurosCont := CalcJurosProRata(Op.SaldoProRata,
                                             RPAF.FinRpa.IndJuros,
                                             DtTpz,
                                             Op.DataQuit )
        end
        else if (RPAF.Temp11.DtUltIncorp.dia > 0) and
                (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
                  scciconf.AcumJurosNaFasedeLiberacao or
                  (RPAF.Temp7.TipoCtr = 41)) then begin
          Op.JurosCont := CalcJurosProRata(Op.SaldoProRata,
                                                RPAF.FinRpa.IndJuros,
                                                RPAF.Temp11.DtUltIncorp,
                                                Op.DataQuit);
          Op.JurosCont := Op.JurosCont + RPAF.Temp11.ValAcumJurosIncorp;
        end
        else if (RPAF.Temp12.DtUltIncorpAntesVenc.dia > 0) and (Parametros.DataRef.dia < byte(RPAF.finRPA.DiaVenc)) and
                (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
                 scciconf.AcumJurosNaFasedeLiberacao or
                (RPAF.Temp7.TipoCtr = 41)) then begin
          Op.JurosCont := CalcJurosProRata(Op.SaldoProRata,
                                           RPAF.FinRpa.IndJuros,
                                           RPAF.Temp12.DtUltIncorpAntesVenc,
                                           Op.DataQuit);
          Op.JurosCont := Op.JurosCont + RPAF.Temp11.ValAcumJurosIncorp;
        end
        else
        begin
          Op.JurosCont := CalcJurosProRata(Op.SaldoProRata,
                                           RPAF.FinRpa.IndJuros,
                                           Op.DataVenc,
                                           Op.DataQuit );
        end
      end;
      if DadosQuitacao.JurosAplicado > zero then Op.JurosCont := DadosQuitacao.JurosAplicado;
    end;

    (* VFgtsTr *)
    if not ScciConf.NaoUtilizaFGTSnaQuitacao then begin
  //    RPAComQuit.valrpa.residuo := RPAComQuit.temp11.residuofgtsantesliq;
      Op.VFGTSTR := FGTSTR(RpaComQuit,Op.DataQuit);
    end;

    Op.Nk         := 0;  Op.PrestTot    := 0;
    Op.PrestAtual := 0;  Op.IndProPrest := 0;
    (* PrestTot, IndProPrest, PrestAtual, NK em caso de PXN *)
    if Op.TipoEvento = 41(* ExN *) then begin
      (* NK *)
      Op.NK := RPAF.FinRpa.Prazo - RPAF.FinRpa.NPC;
      If Smallint(RPAF.FinRpa.DiaVenc) > Op.DataQuit.dia then
        inc(Op.NK);

      RpaAux := RPAF;
      RPAAux.ValRpa.MACStatus := RPAComQuit.ValRpa.MACStatus;
      RPAAux.FinRpa.DiaLiq    := RPAComQuit.FinRpa.DiaLiq;
      RPAAux.FinRpa.ExOpc     := RPAComQuit.FinRpa.ExOpc;
      Op.PrestAtual := AtualizaTotPrestUpf(RPAAux);
      Op.PrestTot := RPAComQuit.ValRpa.TotPrest;
      If Op.PrestTot <> 0 then
        Op.IndProPrest := Op.PrestAtual / Op.PrestTot
      else
        Op.IndProPrest := 0;
      if Op.SaldoDevL < (Op.NK*Op.PrestAtual) then
        Op.NK := 0;
    end
    else if Op.TipoEvento in [2,23,24] (* PXN *) then begin
      (* NK *)
      Op.NK := RPAF.FinRpa.Prazo - RPAF.FinRpa.NPC;
      If Smallint(RPAF.FinRpa.DiaVenc) > Op.DataQuit.dia then
        inc(Op.NK);

      (* PrestAtual *)
      if Op.TipoEvento = 24 then begin (* Px5 *)
        RpaAux := RPAF;
        RPAAux.ValRpa.MACStatus := RPAComQuit.ValRpa.MACStatus;
        RPAAux.FinRpa.DiaLiq    := RPAComQuit.FinRpa.DiaLiq;
        RPAAux.FinRpa.ExOpc     := RPAComQuit.FinRpa.ExOpc;
        Op.PrestAtual := AtualizaDiaVencRataTotPrest(RPAAux);
      end
      else if Juliano(Parametros.DataRef) >= Juliano(DadosQuitacao.DataPXNComAmaisJ) then
        Op.PrestAtual := AtualizaDiaVencRata(RPAComQuit)
      else if Op.NK > 0 then
        Op.PrestAtual := RPAComQuit.FinRpa2.ValorLA / Op.NK
      else Op.PrestAtual := 0;

      (* ------ FIM DE BLOCO ------------------------------------------------ *)

      (* PrestTot *)
      if (Juliano(Parametros.DataRef) >= Juliano(DadosQuitacao.DataPXNComAmaisJ)) and
         (Op.TipoEvento <> 24) then (* Px5 *)
           Op.PrestTot := RPAF.ValRpa.Amaisj
      else Op.PrestTot := RPAF.ValRpa.TotPrest+RPAF.ValRpa.FGTS;
      if Tem2065(RPAF) then
        Op.PrestTot := Op.PrestTot-RPAF.ValRPA.AmaisJ+RPAF.Temp3.AmaisJ2045;

      (* IndProPrest *)
      If Op.PrestTot <> 0 then
        Op.IndProPrest := Op.PrestAtual / Op.PrestTot
      else
        Op.IndProPrest := 0;
    end;

    (* ValorLA *)
  (*  if Op.TipoEvento = 9 then Op.ValorLA := Op.SaldoProRata
                              else  *)
    if ((Parametros.Lei4149 or Parametros.ProgACasaESua or Parametros.Lei5287) and
        (((RPAComQuit.ValRPA.MACStatus > 0) and
          (RPAComQuit.ValRPA.MACStatus < Mes_Int(Parametros.DataRef.MesAno))) or
         (RPAComQuit.FinRpa.Status <> 1))) or
       (Parametros.Lei5287 and RPAComQuit.FinRpa.FcvsCobre) then begin
      Op.ValorLA := 0;
      Op.SaldoProRata := 0;
      Op.SaldoDevl := 0;
      Op.IndProSaldo  := 0;
      Op.JurosCont := 0;
    end
    else
      Op.ValorLA := RPAComQuit.FinRpa2.ValorLA;

    DtAux.dia := 01;
    DtAux.mes := 01;
    DtAux.ano := 116;
    if (RPAComQuit.FinRPA.PA=96) and (RPAF.FinRpa.NPC < 60) and (Juliano(RPAComQuit.FinRPA.DtAssin) > Juliano(dtAux)) then begin
      PrstRem := 60-RPAF.FinRPA.NPC;
      Op.DescRestituido := (MutDsk.Cad6.VaBonusFundingFGTS/60)*PrstRem;
      CorrAux := CorrecaoMj(RPAComQuit.FinRPA.DtAssin,Parametros.DataRef,Op.DescRestituido,0,0,ValMoraAux,MutDsk,100);

      AjustaMoeda2(mes_int(RPAComQuit.FinRPA.DtAssin.mesano),mes_int(Parametros.DataRef.mesano),Op.DescRestituido);
      Op.DescRestituido := Op.DescRestituido + CorrAux;
    end;

    (* Calculo do Valor a receber, sem residuo 2045, 2065, dif lim, pend, ats *)
    (* ValorAReceber *)
    Op.ValorAReceber := Op.ValorLA + Op.JurosCont -
                             Op.VFgtsTr + Op.Seguro    +
                             RPAComQuit.Temp10.DifSaldoLei2284 +
                             Op.DescRestituido;
    Op.DifSaldoLei2284 := RPAComQuit.Temp10.DifSaldoLei2284;

    (* Calculo da responsabilidade do FCVS *)
    if (RPAComQuit.FinRPA.ExOpc = 74) or
       (RPAComQuit.FinRPA.ExOpc = 75) or
       (RPAComQuit.FinRPA.ExOpc = 76) or
       (RPAComQuit.FinRPA.ExOpc = 77) then  { Se for Liq. Fut. Aquis. }
      Op.PrejuLiq      := RPAComQuit.FinRPA2.PrejuLiq
    else if not Parametros.Lei5287 then
      RetornaResp(RpaComQuit,MutDsk,Op.FCVS,Op.RespCEF,Op.PrejuLiq,RespMut,Op.RespTNAC);
    if Parametros.Lei4149 or Parametros.ProgACasaESua then begin
      Op.RespTNAC := 0;
      Op.FCVS     := 0;
    end;
    if (Parametros.Lei4149 or Parametros.ProgACasaESua) and
     (((RPAComQuit.ValRPA.MACStatus > 0) and
       (RPAComQuit.ValRPA.MACStatus < Mes_Int(Parametros.DataRef.MesAno))) or
       (RPAComQuit.FinRpa.Status <> 1) or (MacTPz > 0)
     ) then Op.Prejuliq := 0
    else Op.Prejuliq := Op.Prejuliq + Op.RespTNAC;
    if not RPAComQuit.Temp6.EDoSFH and
       (MutDsk.Cad.DtHabit.dia > 0) and
       (Juliano(Parametros.DataRef) <= (Juliano(Mutdsk.Cad.DtHabit)+30)) and
       (DadosQuitacao.RegEmp.PercDescliq > Zero) then begin
      Op.Prejuliq := Op.Prejuliq +
                          Arredonda(Op.ValorLa*DadosQuitacao.RegEmp.PercDescLiq/100) +
                          Arredonda(Op.JurosCont*DadosQuitacao.RegEmp.PercDescLiq/100);
      Op.ValorAReceber := Op.ValorAReceber -
                               (Arredonda(Op.ValorLa*DadosQuitacao.RegEmp.PercDescLiq/100) +
                                Arredonda(Op.JurosCont*DadosQuitacao.RegEmp.PercDescLiq/100));
    end;
    if (RPAComQuit.FinRpa.PA = 94) and (RPAComQuit.finrpa.exopc = 26) and
       (abs(DadosQuitacao.DifLiminar) > zero) then
      Op.PrejuliqDifLiminar := Arredonda(DadosQuitacao.DifLiminar*RPAComQuit.Temp5.PercDesc/100);
    if DadosQuitacao.DescontoAplicado > zero then begin
      Op.ValorAReceber := Op.ValorAReceber+RPAComQuit.FinRPA2.PrejuLiq-DadosQuitacao.DescontoAplicado;
      Op.Prejuliq := DadosQuitacao.DescontoAplicado;
      Op.PrejuliqDifLiminar := 0;
    end;
    Op.DescSegAVista := CalculaDescSegAVista(MutDsk,RPAF,Parametros.DataRef);
    Op.ValorAReceber := Op.ValorAReceber - Op.DescSegAVista;

    { L gica da ValorDaQuitacao
    result1 := Arredonda(RQuit.ValorAReceber + RQuit.SaldoParCorr + RegQuit.Residuo2065 +
               RegQuit.DifLiminar + TotAtraso + TotPend + TotTaxas -
               RegQuit.DevolPrstPaga + RQuit.DifHab + TotSeries -
               PrejuLiqSeries + SeguroSeries - RQuit.PrejuliqDifLiminar - TotVFgtsTrSeries);
    }

    Op.Valor := Op.ValorAReceber;
    Op.Descricao := 'Sem Desconto';
  end;
end;

procedure TContrato.RetornaErroQuit(    ErroQuit   : SmallInt;
                                        Ctr        : TpCtr;
                                    Var Error      : string;
                                        DataRef    : TData);
begin
  case ErroQuit of
    2: Error := 'Data de referencia anterior a data de assinatura de '+CtrStr(Ctr);
    3: Error := 'Ctr '+CtrStr(Ctr)+' nao esta ativo.';
    4: Error := 'N o h  indices para calcular a quita  o para '+data_str(DataRef);
    5: Error := 'A quita  o com benef cio da Lei 4.149/08 n o pode ser concedida p/ este empreend. ou contrato';
    else Error := 'Erro interno';
  end;
end;

function TContrato.CalculaSeguroSeriesQuit(Parametros : TParametrosQuitacaoEvo; DadosQuitacao : TDadosQuitacaoEvo) : real;
var
  i : integer;
  ValoresPormac : TValoresPorMac;
begin
  result := 0;
  for i := 0 to series.count-1 do begin
    ValoresPormac := Series[i].ObtemValoresPorMac(mes_int(Parametros.Dataref.Mesano));
    if (Parametros.DataRef.dia < byte(ValoresPormac.DiaVenc)) and
       not ScciConf.InibeSegNaLanAntesDoVenc then
      result := result + ValoresPorMac.Seguro-ValoresPorMac.DescSeg;
  end;
end;

function CalculaResiduoAcumPorReg(Var MutDsk : TpMutDsk;
                                      Reg : TValoresPorMac;
                                      DataRef : tdata;
                                      DefReaj : byte) : real;
var
  Corr,
  Mora,
  JurosContr : real;
  ResiduoAcum : real;
  DtVenc : TData;
begin
  JurosContr := 0;
  Mora := 0;
  ResiduoAcum := 0;
  Corr := 0;
  if Reg.CtrAtivo then begin
    DtVenc.dia := Reg.DiaVenc;
    int_mes(Reg.MAC,DtVenc.MesAno);
    ResiduoAcum := Reg.ResiduoAcum;
    if DataRef.Dia < byte(Reg.DiaVenc) then
      ResiduoAcum := ResiduoAcum - Reg.CorrecaoResiduo
                                 - Reg.JurosResiduo
                                 - Reg.ResiduoMes;
    Corr := CorrecaoJMJCChaves( MutDsk,
                                ResiduoAcum,
                                DtVenc,
                                DataRef,
                                Reg.IndJuros,
                                Reg.TMora,
                                Mora,
                                JurosContr,
                                Reg.CodTabGPreChvCorr,
                                Reg.CodTabGCorr,
                                false,false,DefReaj);
    AjustaMoeda2(Reg.MAC,Mes_Int(DataRef.MesAno),ResiduoAcum);
  end;
  Result := ResiduoAcum + Corr;
end;

function TContrato.CalculaResiduoAcum(DataRef : TData) : real;
var
  i : integer;
  residuo : real;
  Reg : TValoresPorMac;
begin
  result := 0;
  if TemFinancDinamico(Mutdsk) then begin
    Reg := SerieF.ObtemValoresPorMac(mes_int(DataRef.mesano));
    result := result + CalculaResiduoAcumPorReg(Mutdsk,Reg,Dataref,0);
  end;
  for i := 0 to Series.count - 1 do begin
    Reg := Series[i].ObtemValoresPorMac(mes_int(DataRef.mesano));
    residuo := CalculaResiduoAcumPorReg(Mutdsk,
                                        Reg,
                                        DataRef,
                                        Series[i].Fin.DefReaj);
    result := result + residuo;
  end;
end;

function TContrato.RetornaTotPendManRenegociacao(    DadosAtrasoEvo : TDadosAtrasoEvo;
                                                 var DtCorr    : TData;
                                                     Dttermino : tData;
                                                     DadosPend  : TDadosPendQuit = nil) : real;
var
  TotPend : real;
  i : smallint;
  PendParcPoup: real;
  TotPendParc : real;
  DadosPendAux : TDadosPendQuit;
begin
  PendParcPoup := 0;
  TotPend  := 0;
  if Assigned(DadosPend) then
    DadosPendAux := DadosPend
  else
    DadosPendAux := TDadosPendQuit.create;
  try
    ObtemPendParaRenegociacao(MutDsk,DadosPend.PendMan,DtCorr,DtTermino); // TODO MELHORAR TRATAMENTO DE PENDENCIAS SEM CACHE
    i := 0;
    while i < DadosPend.PendMan.count do begin
      if DadosPend.PendMan[i].Status in [0,1,8] then begin
        TotPend := TotPend + DadosPend.PendMan[i].ValorPendAtu +
                             DadosPend.PendMan[i].Corr +
                             DadosPend.PendMan[i].Mora;
        inc(i);
      end
      else begin
        if not DadosAtrasoEvo.TemAtrasoParaMesAno(DadosPend.PendMan[i].MACCobrado) then begin
          TotPend := TotPend + DadosPend.PendMan[i].ValorPendAtu +
                               DadosPend.PendMan[i].Corr +
                               DadosPend.PendMan[i].Mora;
          inc(i);
        end
        else
          DadosPend.PendMan.Delete(i);
      end;
    end;

    DadosPend.PercHonorarios := ObtemPercHonorariosNotificacaoAcao(Mutdsk);
    if Dadospend.PercHonorarios > Zero then
      TotPend := TotPend + Arredonda(TotPend * Dadospend.PercHonorarios/100);

    TotPendParc := ObtemTotPendParc(MutDsk,DtCorr,PendParcPoup,DadosPend.PendParc);   // TODO MELHORAR TRATAMENTO DE PENDENCIAS SEM CACHE
    TotPend := TotPend + TotPendParc;

    if Dadospend.PercHonorarios > Zero then
      TotPend := TotPend + Arredonda(TotPendParc * Dadospend.PercHonorarios/100);

    RetornaTotPendManrenegociacao := TotPend;
  finally
    if not assigned(DadosPend) then
      DadosPendAux.free;
  end;
end;

procedure TContrato.CalculaTaxasQuitacao(Parametros : TParametrosQuitacaoEvo; DadosQuitacao : TDadosQuitacaoEvo);
begin
  DadosQuitacao.DadosTaxas.clear;
  if (DadosQuitacao.FDadosAtraso.count = 0) and
