function TContrato.GetConfigSituacoesCtb : TConfigSituacoesCtb;
var
  Qry            : TFastSqlQuery;
  RegSituacaoCtb : TpTabSituacaoCtb;
  SitCtb         : TConfigSituacaoCtb;
  Abriu          : boolean;
begin
  if not assigned(FConfigSituacoesCtb) then begin
    FConfigSituacoesCtb := TConfigSituacoesCtb.create(self);
    if assigned(self) and assigned(FConfigSituacoesCtb) then begin
      RegSituacaoCtb.TipoCtb := 0; 
      fillchar(RegSituacaoCtb,sizeof(RegSituacaoCtb),0);
      Abriu := AbriuSituacaoCtb;
      if not Abriu then AbreSituacaoCtb;
      if AbriuSituacaoCtb and assigned(TabSituacaoCtbDsk) then begin
        Qry := TFastSqlQuery.create(niL);
        try
          Qry.SqlConnection := SqlConnectionSituacaoCtb;
          Qry.sql.add('SELECT');
          TabSituacaoCtbDsk.DBRegistro.geraSelectStrings(Qry.Sql);
          Qry.sql.add(' FROM CONFIG_SITUACAOCTB');
          Qry.sql.add(' ORDER BY CO_TIPOCTB,CO_SITUACAOCTB,NU_SEQ DESC');
          Qry.open;
          while not Qry.eof do begin
            TabSituacaoCtbDsk.DBRegistro.QryToReg(Qry,RegSituacaoCtb);
            SitCtb := FConfigSituacoesCtb.add as TConfigSituacaoCtb;
            fillchar(SitCtb.RegSituacaoCtb,sizeof(SitCtb.RegSituacaoCtb),0);
            SitCtb.RegSituacaoCtb := RegSituacaoCtb;
            Qry.next;
          end;
          Qry.close;
        finally
          Qry.free;
        end;
      end;
      if not Abriu then FechaSituacaoCtb;            
    end
    else
      raise exception.create('Tentativa de ler o TContrato sem o objeto estar criado');
  end;
  Result := FConfigSituacoesCtb;
end;



function TContrato.ObtemSituacaoCtb(    DataRef, 
                                        DtAjuizamento      : TData; 
                                    var RAAPTotalNT        : boolean;
                                    var DtEntSituacaoCtb   : TData;
                                    var Regra_2682         : boolean;
                                        DtEntSituacaoCtbAnt: TData;
                                        SaldoBaseCtb       : real = 0;
                                        SituacaoCtbAnt     : smallint = 0;
                                        AtivoProblematico  : boolean = false;
                                        EmPrejuizo         : boolean = false;
                                        TrataRes4966       : boolean = false) : smallint;

var
  PrazoReman,
  QtdDiasAts,
  i                 : integer;
  PegaSituacaoCtbAnt,
  TesteOk           : boolean;
  SaldoContabil     : real;
begin
  Result             := 0;
  PegaSituacaoCtbAnt :=  TrataRes4966 and Regra_2682 and
                        (SituacaoCtbAnt > 0) and 
                        (DtEntSituacaoCtbAnt.Dia > 0);

  DtEntSituacaoCtb.Dia := 0; fillchar(DtEntSituacaoCtb,sizeof(DtEntSituacaoCtb),0);
  RAAPTotalNT  := false;
  if (RPA.FinRPA.NPC = 0) and (RPA.FinRPA.Prazo > RPA.Temp.OldNPC) then 
    PrazoReman := RPA.FinRPA.Prazo - RPA.Temp.OldNPC
  else 
    PrazoReman   := PrestReman(RPA);
  if ((RPA.MAC > RPA.ValRPA.MACStatus) and (RPA.ValRPA.MACStatus > 0)) or
      (PrazoReman < 0)  then
   PrazoReman := 0;
  if RPA.Temp11.DtPrimAtrasoCtb.Dia > 0 then
    QtdDiasAts   := juliano(DataRef)-juliano(RPA.Temp11.DtPrimAtrasoCtb)
  else
    QtdDiasAts   := 0;
  if QtdDiasAts < 0 then QtdDiasAts := 0;
  i := ConfigSituacoesCtb.Count-1;
  if Abs(SaldoBaseCtb) > Zero then
    SaldoContabil := SaldoBaseCtb
  else if RPA.MAC = Mes_Int(DataRef.MesAno) then 
    SaldoContabil := FEncargosEmAbertoCtb+RPA.ValRPA.SaldoDev
  else
    SaldoContabil := FEncargosEmAbertoCtb;
  TesteOk := false;
  while (i >= 0) and (Result = 0) do begin
    TesteOk := true;
    with ConfigSituacoesCtb[i].RegSituacaoCtb do begin
      if IN_PREJUIZO then
        TesteOk := EmPrejuizo;
   
      if TesteOk and In_AtivoProblematico then
        TesteOk := AtivoProblematico;

      if TesteOk and TrataRes4966 and In_Regra_2682 then
        TesteOk := Regra_2682;
      if (not PegaSituacaoCtbAnt) then begin
        if TesteOk and (QtdPrazoRemanFin > 0) then
          TesteOk := (PrazoReman >= QtdPrazoRemanIni) and
                     (PrazoReman <= QtdPrazoRemanFin);
  
        if TesteOk and (QtdDiasAtrasoFin > 0) then 
           TesteOk := (QtdDiasAts >= QtdDiasAtrasoini) and
                      (QtdDiasAts <= QtdDiasAtrasoFin);
        if TesteOk and (QtdDiasAts > 0) then begin
          if QtdDiasAts <= 60 then begin
            DtAjuizamento.Dia := 0;
            fillchar(DtAjuizamento,sizeof(DtAjuizamento),0);
          end;
          if (DtAjuizamento.Dia > 0) and 
             (juliano(DtAjuizamento) <= juliano(DataRef)) then
            TesteOk := ComAjuizamento
          else
            TesteOk := (not ComAjuizamento);
        end;
  
        if TesteOk and (DtDivida.Dia > 0) then 
          TesteOk := (juliano(RPA.Temp11.DtPrimAtrasoCtb) >= juliano(DtDivida));
  
        if TesteOk and ((ValDividaMin > Zero) or 
                        (ValDividaMax > Zero)) then begin
          if ValDividaMin > Zero then 
            TesteOk := (SaldoContabil-ValDividaMin > Zero) or
                       (Abs(SaldoContabil-ValDividaMin) <= Zero);
  
          if TesteOk and (ValDividaMax > Zero) then
            TesteOk := (SaldoContabil-ValDividaMax < Zero) or
                       (Abs(SaldoContabil-ValDividaMax) <= Zero);
        end;
      end
      else if (SituacaoCtb < 8) and PegaSituacaoCtbAnt then begin
        Result           := SituacaoCtbAnt;
        DtEntSituacaoCtb := DtEntSituacaoCtbAnt;
        TesteOk          := false; 
      end;
      if (SituacaoCtb >= 8) and (SituacaoCtb <= 9) and (not TrataRes4966) then
        TesteOk := false;

      if TesteOk and TrataRes4966 and Regra_2682 then begin
        if (SituacaoCtb < 2) or (SituacaoCtb > 7) then 
          Regra_2682 := false //se  estava na regra antiga, vai sair
        else 
          TesteOk    := In_Regra_2682;
      end;
      if TesteOk then begin
        RAAPTotalNT := RAAPNT_TOTAL;
        Result := SituacaoCtb;
        if TrataRes4966 and ((SituacaoCtb = 1) or (SituacaoCtb > 7)) then begin
          if SituacaoCtbAnt <> SituacaoCtb then
            DtEntSituacaoCtb := DataRef;
        end
        else if RPA.Temp11.DtPrimAtrasoCtb.Dia > 0 then 
          J_Data(juliano(RPA.Temp11.DtPrimAtrasoCtb)+QtdDiasAtrasoini,DtEntSituacaoCtb)
        else if SituacaoCtb = 1 then 
          DtEntSituacaoCtb := DataRef;
        if RegCarteira.SemNaturezaCredito and 
          (SituacaoCtb > 3) and (SituacaoCtb < 8) and
         ((MutDsk.Financ3.DtCredPrejuizo.Dia = 0) or 
          (juliano(MutDsk.Financ3.DtCredPrejuizo) > juliano(DataRef))) then begin
          case SituacaoCtb of
            4,7 : Result := 2;
            5,6 : Result := 3;
          end;
          RAAPTotalNT := false;
        end;
      end;
    end; //with
    dec(i);
  end; //while
  if (not TesteOk) and (Result > 0) then
    for i := 0 to ConfigSituacoesCtb.Count-1 do
      if Result = ConfigSituacoesCtb[i].RegSituacaoCtb.SituacaoCtb then
        RAAPTotalNT := ConfigSituacoesCtb[i].RegSituacaoCtb.RAAPNT_TOTAL;
end;

