function TParcelaReneg.DescontoPorTaxa(TaxaOportunidade  : real;
                                       JurosSimples      : boolean;
                                       CalcAntecComoDescComercial : boolean;
                                       DataRef,DtCarenciaDeJuros : Tdata;
                                       JurProRata : boolean;
                                       IncluiFracaoDoMes : boolean;
                                       SemResiduo : boolean = false;
                                       ProRataJurosDiasCorridos : boolean = false;
                                       ProRataJurosDiasUteis: boolean = false) : real;
var
  DtCarenciaLocal,
  DtComCarencia : TData;
begin
  if NaoTemDescPorTaxa then
    result := 0
  else begin
    DtComCarencia := DataRef;
    if DtCarenciaDeJuros.dia > 0 then begin
      DtCarenciaLocal := DtCarenciaDeJuros;
      if not JurProRata then DtCarenciaLocal.Dia := Venc.Dia;
      if Juliano(DtCarenciaLocal) > Juliano(dataref) then
        DtComCarencia := DtCarenciaLocal;
    end;
    if not CalcAntecComoDescComercial then begin
      if SemResiduo then
        Result := VaEncargoSemResiduo - CalculaEncargoAtualizado(EncargoSemResiduo,
                                                                 Venc,
                                                                 DtComCarencia,
                                                                 Taxaoportunidade,
                                                                 JurProRata or ForcaCobJurosProrataNaQuitSerie,
                                                                 IncluiFracaoDoMes,
                                                                 JurosSimples,
                                                                 ProRataJurosDiasCorridos,
                                                                 DiaVencOrig,
                                                                 ProRataJurosDiasUteis)
      else
        Result := VaEncargo - CalculaEncargoAtualizado(Encargo,
                                                       Venc,
                                                       DtComCarencia,
                                                       TaxaOportunidade,
                                                       JurProRata or ForcaCobJurosProrataNaQuitSerie,
                                                       IncluiFracaoDoMes,
                                                       JurosSimples,
                                                       ProRataJurosDiasCorridos,
                                                       DiaVencOrig,
                                                       ProRataJurosDiasUteis);
    end
    else begin
      if SemResiduo then
        Result := CalculaDescComercial(EncargoSemResiduo,
                                       Venc,
                                       DtComCarencia,
                                       Taxaoportunidade,
                                       JurProRata or ForcaCobJurosProrataNaQuitSerie) -
                  (EncargoSemResiduo-VaEncargo)
      else
        Result := CalculaDescComercial(Encargo,
                                       Venc,
                                       DtComCarencia,
                                       TaxaOportunidade,
                                       JurProRata or ForcaCobJurosProrataNaQuitSerie) -
                  (Encargo-VaEncargo);
    end;
    result := Arredonda(result);
  end;
end;

