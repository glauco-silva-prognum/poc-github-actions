begin
  dtind  := data;
  if (mes_int(data.mesano) >= 1035) and
     (mes_int(data.mesano) <= 1046)  then // Congelamento mar/86 a fev/87.
    int_mes(1035,dtind.mesano);
  if indiceMensal(CodTabelaGenerica) or indiceMisto(CodTabelaGenerica) then 
    int_mes(mes_int(dtind.mesano)-defas, dtind.mesano)
  else
    DecData(dtind,defas);
  Indice := serielib.ObtemIndice(CodTabelaGenerica,dtind);
