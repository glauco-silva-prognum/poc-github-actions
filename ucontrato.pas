procedure TContrato.CalculaSeguros;
var
  SerieMaiorPrazoSeguro : integer;
  HSegFin,
  HSegImv : real;
  HFlag : integer;
begin
// guardar valores para uso com arq. presta  es
//  HSegFin := RPAF.ValRPA.SegFin;
//  HSegImv := RPAF.ValRPA.SegImv;
// Sol. 54482 - eu preciso pegar o valor do arqprest e n o o valor calculado na uevolui3
//              pois se valor estiver zerado no arqprest, como no caso de uma reevolu  o
//              eu n o quero voltar com o valor individual calculado do financ. dinamico.
  if Assigned(FOEvolui3) and TemFinancDinamico(Mutdsk) then begin
    HSegFin := FOEvolui3.HSegFin;
    HSegImv := FOEvolui3.HSegImv;
    HFlag := FOEvolui3.HFlag;
  end
  else begin
    HSegFin := 0;
    HSegImv := 0;
    HFlag := 0;
  end;

  TrataContratosContratosCorrelacionados;
  FSerieParaDFI := EscolheSerieParaCobrancadeDFI;
  EscolheSerieParaCobrancadeMIPPorValAVal;
  CalculaValAvalCorr;

  // Se considera atraso no seguro, o valor do financ. din mico foi calculado sem isso
  // ent o preciso refazer o c lculo - Sol.83312
  
  // 95731 - se tem vendedores, pode precisar considerar este saldo, ent o preciso recalcular agora
  //         que o saldo de vendedores j  deve estar calculado.
  
  // precisa recalcular ANTES do c lculo por s rie e do c lculo consolidado
  if ConsideraAtrasoNoSeguro(Rpa,DataAtsEvo) or 
     TemVendedores or TemFgtsApoioAConstrucao then // mesmo teste para decidir chamar a EvoluiSaldoVendedores, na inicrpa
    FOEvolui3.RecalculaSegCampoVBaseMip(RpaF);

  CalculaSeguroPorSerie;

  CalculaReavaliacaoValAvalPorSerie;

  SerieMaiorPrazoSeguro := DeterminaSerieMaiorPrazoSeguro;

  if SerieMaiorPrazoSeguro > -1 then
    CopiaDadosSeguroRPA(Series[SerieMaiorPrazoSeguro].RPAS,RPA)
  else if SerieMaiorPrazoSeguro= -1 then
    CopiaDadosSeguroRPA(RPAF,RPA);

  CalculaSeguroConsolidado(SerieMaiorPrazoSeguro);

  RPA.ValRPA.Seguro := RPA.ValRPA.SegFin + RPA.ValRPA.SegImv + RPA.ValRPA.SegCre;
  RPA.ValRPA.TotPrest := RPA.ValRPA.AmaisJ + RPA.ValRPA.Seguro;
  AtualizaTotPrest(RPA);
  AtualizaDescSeg(RPA);
  
  ForcaVencimentoPrestSeguro;

  if ScciConf.UsaArqPrest then
    ForcaSeguroArqPrest(HSegFin,HSegImv,HFlag);

  TrataSeguroCarencia(HSegFin,HSegImv,HFlag);
end;

function TContrato.EscolheSerieParaCobrancaDeTaxas:Integer;
var
  i: Integer;
  PrazoSerieBase: Integer;
begin
    Result := -1;
    // S  calcula na s rie, se n o houver financ. din mico


    if not Ctr_Ativo(RPAF) then begin
      PrazoSerieBase := 0;
      // Tenta achar a s rie mensal de maior prazo onde possa ser cobrado as taxas
      for i := 0 to series.Count -1 do
      begin
        if (Series[i].Fin.PerParcelas=1) and
           (Series[i].Fin.Prazo>prazoseriebase) and
           Series[i].CalculaTaxasNoMes then begin
          Result := i;
          prazoseriebase := Series[i].Fin.Prazo;
        end;
      end;
      // Se n o achou uma s rie mensal, escolhe uma qualquer onde possa se cobrado o seguro MIP
      if Result < 0 then
        for i := 0 to Series.count-1 do
          if Series[i].CalculaTaxasNoMes then
            Result := i;
      // Se mesmo assim n o achou, desconsidera compoesaldo e compoeentrada
      if Result < 0 then
        for i := 0 to Series.count-1 do
          if Series[i].CalculaTaxasNoMes(true) then
            Result := i;
    end;
end;


procedure TContrato.CalculaTaxas;
var 
  i,
  SerieCobrancaTaxas: Integer;
  JaCobrouTaxaNaSerie : boolean;
begin
  JaCobrouTaxaNaSerie := false;
  SerieCobrancaTaxas := EscolheSerieParaCobrancaDeTaxas;
  Rpa.ValRpa.ValTxAdm := RpaF.ValRpa.ValTxAdm;
  for i := 0 to Series.Count -1 do with Series[i] do begin
    if Rpas.ValRpa.ValTxAdm > zero then begin
      Rpa.valRpa.ValTxAdm := Rpa.ValRpa.ValTxAdm + Rpas.ValRpa.ValTxAdm;
      JaCobrouTaxaNaSerie := true;
    end;
  end;
  if not JaCobrouTaxaNaSerie then begin
    for i := 0 to Series.Count -1 do with Series[i] do begin
    {
      o valtxadm ser  regerado se:
        1 : no m s n o existe parcela e a configura  o manda zerar(ZeraValTxAdmMesSemParc)
        2 : no m s n o existe parcela e em meses anteriores n o foi usado um valor gravado na parcela
        3 : no m s existe parcela, por m o valor gravado   zero
        4 : est  setada a flag de ignorar a parcela
    }
    

      if (not Assigned(ParcelaDoMes) and (not RespeitouTaxaEmi or ScciConf.ZeraValTxAdmMesSemParc)) or
         (Assigned(ParcelaDoMes) and (abs(ParcelaDoMes.TaxaEmi) <= Zero)) or
         DesconsideraParcela then begin
        // se o valtxadm vai ser regerado, ele   zero exceto para a s rie escolhida
        if i = SerieCobrancaTaxas then begin
          case MutDsk.Financ.TTX of
            2 : Rpas.ValRpa.ValTxAdm := Rpa.FinRpa.TxAdm * Rpa.ValRpa.AmaisJ;
            3 : Rpas.ValRpa.ValTxAdm := Rpa.FinRpa.TxAdm / 12 * Rpa.ValRpa.SaldoDev;
           14 : begin
                  if Mutdsk.Cad3.CorrigeTCAFinEstaticos then begin
                    if RPAS.Temp12.CodReajTxAdm > 0 then begin
                      {?Tenho d vida se devo passar o RpaS ou o RPA (consolidado)}
                      RPAS.Temp12.IndTxAdmAcum := CalculaIndAcumulado(RpaS{?},Fin.DataRefReaj,
                                                     RPA.Temp12.CodReajTxAdm,
                                                     RPA.Temp12.DefReajTxAdm,
                                                     RPA.Temp12.PerReajTxAdm,
                                                     false{CalculaTxGestao},
                                                     Fin.PriReajusteIntegral,
                                                     Fin.CorrProRata,
                                                     Fin.RecalculaPrestacao,
                                                     Fin.CorrProRataIniPelaVarDataref,
                                                     false{CalcMes?},
                                                     Mes_Int(Fin.MAPrimReaj));
                      Rpas.ValRpa.ValTxAdm := Arredonda(Rpa.FinRpa.TxAdm*RPAS.Temp12.IndTxAdmAcum);
                    end
                    else
                      Rpas.ValRpa.ValTxAdm := Arredonda(Rpa.FinRpa.TxAdm*Rpas.Temp5.TxPstAcum);
                  end
                  else // sem corre  o
                    Rpas.ValRpa.ValTxAdm := int(Rpa.FinRpa.TxAdm*100+0.5)/100;
                end;
  
          end;
        end
        else
          Rpas.ValRpa.ValTxAdm := 0;
        AtualizaTotPrest(RPAS);
        RespeitouTaxaEmi := false; // Neste m s n o respeitou valor gravado na parcela
      end
      else
        RespeitouTaxaEmi := true; // Neste m s respeitou o valor gravado na parcela
      // Atualiza o rpa consolidado
      if (Fin.CompoeSaldo or Fin.CompoeEntrada) and (Rpa.MAC >= mes_int(fin.DataRef.MesAno)) then
        Rpa.ValRpa.ValTxAdm := Rpa.ValRpa.ValTxAdm + RPAS.ValrPA.ValTxAdm;
    end;
  end;
  AtualizaTotPrest(RPA);
end;
  
