procedure TContrato.EvoluiValAvalCorrPosTermino(var aRpa,aRpaF:TpRpa);
Var
 DtVenc,
 DtVencmenos1mes,
 DtIndInvalido : Tdata;
 IndInvalido : boolean;
 CodSD : integer;
begin
  IndInvalido := false;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  DtVenc.Dia:=0;DtVenc.Mes:=0;DtVEnc.Ano:=0;
  DtVencmenos1mes.Dia:=0;DtVencmenos1mes.Mes:=0;DtVencmenos1mes.Ano:=0;
  with aRpa do begin
//   if ((Temp11.TxSDMes = 0 )or (Temp11.TxSDMes = 1)) and (FinRPA.Status <> 0) then begin
// Linha acima colocada em coment rio e substitu da pela inserida abaixo pelo SCAt 72759 - Deve ser inspecionado.
     if (FinRPA.Status<>0) and (ValRpa.MacStatus < Mac) then begin
      DtVenc.Dia := FinRpa.DiaVenc; int_mes(MAC, DtVenc.MesAno);
      if DtVenc.Dia=0 then DtVenc.Dia := FinRPA.DtInFin.Dia;
      DtVencmenos1mes := DtVenc; DECMA(DtVencmenos1mes.MesAno);
      if (Rpa.finrpa2.SDRata = 128) and (Rpa.FinRpa.CodReaj=23) then CodSD := Rpa.Temp7.CodTabelaGenerica
      else CodSD := Rpa.Temp6.CodReajSD;
      if (CodSD = 0) then CodSD := 100;
      Temp11.TxSDMes := detinddataadata(CodSD,Temp12.DefReajPst, DtVencmenos1mes,
                                       DtVenc, 1.0, false, IndInvalido,DtIndInvalido,false,finrpa.persaldev,
                                       false,Temp12.CmProRataMesAnt,true);
      Temp12.ValAvalCOrr := Temp12.ValAvalCOrr *  Temp11.TxSDMes ;
      AjustaMoeda2(Rpa.MAC-1,Rpa.Mac,RPA.Temp12.ValAvalCorr);
    end;
  end;
  if aRPA.Temp5.MACAval=aRpa.MAC then aRPA.Temp12.ValAvalCorr := aRPA.finRpa.ValAval; 
  aRpaF.Temp11.TxSDMes := aRpa.Temp11.TxSDMes;
  aRpaF.Temp12.ValAvalCOrr := aRpa.Temp12.ValAvalCOrr;
  aRpaF.finrpa.ValAval := aRpa.finrpa.ValAval;
end;


procedure TContrato.CalculaEventoVencimentoIFRS9(Var pRPA : TpRPA);
var
  zerooumeio : real;
begin
  zerooumeio := 0.5;
  if abs((pRPA.Temp12.TxOriginalCtrIFRS9/1200)-pRPA.FinRPA.IndJuros) < zero then begin
    pRPA.Temp12.SaldoIFRS9 := pRpa.ValRpa.SaldoDev;
    pRPA.Temp12.CMIFRS9 := pRpa.Temp.CorrSaldo;
    pRPA.Temp12.JurosIFRS9 := pRPA.ValRPA.Juro;
  end
  else begin
    pRPA.Temp12.CMIFRS9 := int(pRPA.Temp12.SaldoIFRS9 * (pRPA.FinRPA.TXSD - 1.0)*100+Zerooumeio)/100;
    pRPA.temp12.SaldoIFRS9 := pRPA.Temp12.SaldoIFRS9 + pRPA.Temp12.CMIFRS9;
    pRPA.Temp12.JurosIFRS9 := int(pRPA.Temp12.SaldoIFRS9*pRPA.Temp12.TxOriginalCtrIFRS9/1200*100+Zerooumeio)/100;
    pRPA.Temp12.SaldoIFRS9 := pRPA.Temp12.SaldoIFRS9 - (pRPA.ValRPA.Amaisj - pRPA.Temp12.JurosIFRS9);
  end;
end;

function DescrEventosExAmInc(ExAmInc : byte; JaAmortizouECorrigiu : boolean) : ansistring; overload;
var
  St : ansistring;
begin
  if not JaAmortizouECorrigiu then begin
    if ExAmInc = 103 then St := 'Amortiza  o Extraordin ria antes do vencimento'
    else if ExAmInc = 104 then St := 'Libera  o de parcela antes do vencimento'
    else if ExAmInc = 105 then St := 'Repasse de Unidades antes do vencimento'
    else if ExAmInc = 106 then St := 'Libera  o Financiamento antes do vencimento'
    else if ExAmInc = 108 then St := 'Desembolso NF. antes do vencimento'
    else if ExAmInc = 114 then St := 'Amortiza  o s/ abater juros antes do vencimento'
    else if ExAmInc = 118 then St := 'Altera  o de taxa de juros'
    else St := 'Incorpora  o antes do vencimento';
  end
  else begin
    if ExAmInc = 103 then St := 'Amortiza  o Extraordin ria'
    else if ExAmInc = 104 then St := 'Libera  o de parcela'
    else if ExAmInc = 105 then St := 'Repasse de Unidades'
    else if ExAmInc = 106 then St := 'Libera  o Financiamento'
    else if ExAmInc = 108 then St := 'Desembolso NF.'
    else if ExAmInc = 114 then St := 'Amortiza  o s/ abater juros'
    else if ExAmInc = 118 then St := 'Altera  o de taxa de juros'
    else St := 'Incorpora  o';
  end;
  Result := St+'(CA)';
end;

function DescrEventosExAmInc(Evento : TEventoAmInc; JaAmortizouECorrigiu : boolean) : ansistring; overload;
begin
  if Evento.TipoEvento = tipoevento_PagAntecipado then begin
    if JaAmortizouECorrigiu then 
      Result := 'Antecipa  o de pagamento de parcelas'
    else
      Result := 'Antecipa  o de pagamento de parcelas antes do vencimento';
  end
  else if Evento.ExOpc in [35,118] then 
    Result := DescrEventosExAmInc(Evento.ExOpc,JaAmortizouECorrigiu)
  else 
    Result := DescrEventosExAmInc(Evento.ExAmInc,JaAmortizouECorrigiu);
end;

function TContrato.CalculaProratasCA(    pRPA                  : TpRPA;
                                      var JurosProRataCA,
                                          CorrProRataCA         : real;
                                          Dt1, Dt2, DtVencJuros : TData;
                                          SaldoCA               : real = 0;
                                          MesAnterior           : boolean=false;
                                          SobreSaldoCA          : boolean=true;
                                          EAmex                 : boolean=true;
                                          ProrataCM             : boolean=true;
                                          ProrataJuros          : boolean=true) : real;

   function GetIndJuros(var RegSerie : TpSeries;TxJuros : real{;DataRef : TData}) : real;

   var
     RpaBkp : TpRPA;
     DtZero : TData;
   begin
     if RegSerie.CodSerie = 0 then begin
       Result := TxJuros/100;
       if ((pRPA.FinRPA.Plano div 10)= PJF ) and
          (Scciconf.DefasagemDeJurosFlutuantes = 0) then begin
         RpaBkp     := pRPA;
         DtZero.Dia := 0; fillchar(DtZero,sizeof(DtZero),0);
         TxJuros := TxJuros*12; //a TxJuros da fun  o TIR()   mensal, p/FinDin tenho que converter para anual
         RpaBkp.FinRPA.TxJuros := TxJuros;
         Calcula_IndJuros_PJF(RpaBkp,DtZero);
         Result := RPABkp.FinRPA.IndJuros;
       end;
     end
     else begin
       RegSerie.TpJuros := 1; { Mensal pq a TxJuros da TIR()   mensal }
       if RegSerie.JurosSimples then
          Result  := CalculaJuros(RegSerie.TpJuros,TxJuros,RegSerie.PerParcelas,RegSerie.JurosSimples)/100/RegSerie.PerParcelas
       else
          Result  := pot((1+CalculaJuros(RegSerie.TpJuros,TxJuros,RegSerie.PerParcelas,RegSerie.JurosSimples)/100),1.0/RegSerie.PerParcelas)-1;
     end;
   end;

{
   function GetDtUltReajSd(const pRPA         : TpRPA; 
                           var   DtVenc,
                                 DataRefReaj,
                                 DataCorr    : TData) : TData; 
   var
     DtVencCorr   : TData;
     MACCorrSaldo : smallint;
     CalcCorrecao : boolean;
   begin
     if DataCorr.Dia >= byte(pRPA.FinRPA.DiaVenc) then begin
       DtVencCorr.Dia := pRPA.FinRPA.DiaVenc;
       Int_Mes(pRPA.MAC,DtVencCorr.MesAno);
     end
     else begin
       if pRPA.Temp12.DiaVencOrig > 0 then 
         DtVencCorr.Dia := Dia_Venc(pRPA.MAC-1,pRPA.Temp12.DiaVencOrig)
       else
         DtVencCorr.Dia := Dia_Venc(pRPA.MAC-1,pRPA.FinRPA.DtInFin.Dia);
       Int_Mes(pRPA.MAC-1,DtVencCorr.MesAno);
     end;
     DtVenc := DtVencCorr;
     if juliano(DtVenc) < juliano(pRPA.FinRPA.Dtassin) then
       DtVenc := pRPA.FinRPA.Dtassin;

     if pRPA.FinRPA.PerSalDev >= 6 then begin
       if pRPA.Temp11.MAUASD > 0 then 
         MACCorrSaldo := pRPA.Temp11.MAUASD
       else
         MACCorrSaldo := pRPA.Temp.MAUA;
       if MACCorrSaldo = Mes_Int(DataCorr.MesAno) then begin
         if DataCorr.Dia < DtVenc.Dia then 
           MACCorrSaldo := MACCorrSaldo - pRPA.FinRPA.PerSalDev
       end
       else if (MACCorrSaldo = 0) and 
              ((Mes_Int(DataCorr.MesAno)-pRPA.FinRPA.PerSalDev) <= 
               Mes_Int(pRPA.FinRPA.DtAssin.MesAno)) then
              MACCorrSaldo := Mes_Int(pRPA.FinRPA.DtAssin.MesAno);

       if Mes_Int(pRPA.FinRPA.DtAssin.MesAno) >= MACCorrSaldo then
         DtVencCorr := pRPA.FinRPA.DtAssin
       else if (MACCorrSaldo > 0) and (MACCorrSaldo <= Mes_Int(DataCorr.Mesano)) then begin
         Int_Mes(MACCorrSaldo,DtVencCorr.MesAno);
         DtVencCorr.Dia := Dia_Venc(MACCorrSaldo,DtVenc.Dia);
       end;
       if (DataRefReaj.Dia > 0) and 
          (juliano(DtVencCorr) < juliano(DataRefReaj)) then
         DtVencCorr := DataRefReaj;
     end;
     if juliano(DtVencCorr) < juliano(pRPA.FinRPA.Dtassin) then
       DtVencCorr := pRPA.FinRPA.Dtassin;
     Result := DtVencCorr;
   end;
}

var 
  DtVenc                  : TData;
  TemCustoCA,
  CalcCorrecao            : boolean;
  DiasMes,
  IndexSerie              : integer;
  ValorAINoVencto,
  SaldoProRataCA,
  SaldoAnt,
  IndjurosCA,
  IndiceDeJurosProRata,
  IndiceDeCorrecaoProRata : real;
  LegLinkItem             : TLegLinkItem;
  RegSerie                : TpSeries;
begin           { Inicio da CalculaProratasCA }
  Result         := 0;
  LegLinkItem    := nil;
  JurosProRataCA := 0;
  CorrProRataCA  := 0;   
  TemCustoCA     := self.TemCA and (pRPA.Temp7.TipoCtr <> 41{98550});

  if TemCustoCA and
     (Dt1.Dia > 0) and (Dt2.Dia > 0) and
     (juliano(Dt2) > juliano(Dt1)) then begin
    CalcCorrecao := (not ((pRPA.FinRPA.CodReaj = 31) and 
                    (pRPA.FinRPA2.SdRata = 128)));
    CalcCorrecao := CalcCorrecao and ProrataCM;
    IndexSerie := -1;
    RegSerie.CodSerie := 0; fillchar(RegSerie,sizeof(RegSerie),0);
    if pRPA.Temp8.CodSerie > 0 then begin
      IndexSerie := Series.Indexof(pRPA.Temp8.CodSerie);
      if IndexSerie > -1 then RegSerie := Series[IndexSerie].Fin;
    end;
    Int_Mes(pRPA.MAC,DtVenc.MesAno);
    DtVenc.Dia := pRPA.FinRPA.DiaVenc;
    if Abs(SaldoCA) > zero then 
      SaldoProRataCA := SaldoCA
    else begin
      SaldoProRataCA := pRPA.Temp12.SaldoCA;
      if juliano(Dt1) < juliano(DtVenc) then begin
        if (IndexSerie > -1) and (Series[IndexSerie].FSaldoCAAnt > zero) then
          SaldoProRataCA := Series[IndexSerie].FSaldoCAAnt
        else if (pRPA.Temp8.CodSerie = 0) and (FSaldoCAAnt > zero) then 
          SaldoProRataCA := FSaldoCAAnt
        else
          SaldoProRataCA := arredonda(SaldoProRataCA + (pRPA.ValRPA.AmaisJ-pRPA.Temp12.JurosCA) -
                                                        pRPA.Temp12.CMCA);
      end;
    end;
    SaldoAnt := SaldoProRataCA;
    if EAmex and (not SobreSaldoCA) then SaldoProRataCA := -Abs(SaldoProRataCA);
    if not InibeLegLink then 
      LegLinkItem := LegLink.add(pRPA.Temp8.CodSerie,'<P/><b>C lculo de Pro ratas CA</b>');
    if assigned(LegLinkItem) then begin
      if SobreSaldoCA then 
        leglinkItem.Valores['Saldo CA anterior'] := Strgrana(SaldoAnt)
      else
        leglinkItem.Valores['Valor da Amortiza  o'] := Strgrana(SaldoAnt);
    end;
    if DtVencJuros.Dia = 0 then DtVencJuros := Dt1;
    IndiceDeCorrecaoProRata := 0;
    IndiceDeJurosProRata    := 0;
    if CalcCorrecao  then begin
      IndiceDeCorrecaoProRata := CalcIndiceCorrecaoProRata(Dt1,Dt2,pRPA,LegLinkItem,Dt2.Dia < byte(pRPA.finRPA.DiaVenc),false{IRFS9});
      if pRPA.finrpa.persaldev >= 6 then 
        IndiceDeCorrecaoProRata := (IndiceDeCorrecaoProRata * CalcIndiceDesdeMauaSd(pRPA,LegLinkItem,MesAnterior))-1;

      if SobreSAldoCA then begin
        CorrProRataCA  := Arredonda(CorrProRataCA  + (SaldoProRataCA*(IndiceDeCorrecaoProRata-1)));
        SaldoProRataCA := Arredonda(SaldoProRataCA + CorrProRataCA);
      end;
    end;
    IndjurosCA      := GetIndJuros(RegSerie,pRPA.Temp12.TxJurosCA{,Dt2});
    ValorAINoVencto := 0;
    if ProRataJuros then begin
      if (RegSerie.CodSerie > 0) and (RegSerie.CodSerie = pRPA.Temp8.CodSerie) then begin
        if RegSerie.JurProRata then begin
          if (RegSerie.DtCarenciaDeJuros.dia > 0) and
             (Juliano(RegSerie.DtCarenciaDeJuros) > Juliano(DtVencJuros)) then
             DtVencJuros := RegSerie.DtCarenciaDeJuros;
          DiasMes := NoDiasMesProRataJuros(DtVencJuros);
          if DiasMes > 0 then begin 
            if RegSerie.JurosSimples then
              IndiceDeJurosProRata := IndjurosCA*NoDiasProrataJuros(DtVencJuros,Dt2)/DiasMes
            else
              IndiceDeJurosProRata := (1/(pot(1+IndjurosCA, NoDiasProrataJuros(DtVencJuros,Dt2)/DiasMes))-1);

(*-----------------------------SCAT110744 ---------------------------------
            IndiceDeJurosProRata := CalcIndiceJurosProRata(IndjurosCA,DtVencJuros,Dt2,
                                                      RegSerie.JurosSimples{JurosSimples},
                                                      RegSerie.TpJuros=6{ProRataJurosDiasCorridos},
                                                      pRPA.Temp12.DiaVencOrig {DiaVencOrig},
                                                      false{ProRataJurosDiasUteis});
---------------------------------------------------------------------------*)
          end;
        end;
      end
      else if ((pRPA.FinRPA.Plano div 10)= PJF ) and
               (Scciconf.DefasagemDeJurosFlutuantes > 0) then begin
        IndJurosCA := pRPA.Temp12.TxJurosCA/100; //taxa   mensal
        IndiceDeJurosProRata := CalcIndiceJurosProRata(IndjurosCA,
                                                       DtVencJuros,Dt2,false{JurosSimples},
                                                       false{ProRataJurosDiasCorridos},
                                                       pRPA.Temp12.DiaVencOrig,
                                                       false{ProRataJurosDiasUteis},
                                                       pRPA.Temp12.IndJurosFlutuante);
  
      end
      else 
        IndiceDeJurosProRata := CalcIndiceJurosProRata(IndjurosCA,
                                                       DtVencJuros,Dt2,false{JurosSimples},
                                                       false{ProRataJurosDiasCorridos},
                                                       pRPA.Temp12.DiaVencOrig,
                                                       false{ProRataJurosDiasUteis});
    end;
    if (not SobreSaldoCA) and EAmex and 
       (RegSerie.CodSerie > 0) and (RegSerie.Ctr = pRPA.Ctr) then begin
      JurosProRataCA := -Arredonda(-SaldoProRataCa * IndiceDeJurosProRata);
      ValorAiNoVencto := arredonda(SaldoProRataCA+JurosProRataCA);
      if Abs(IndiceDeCorrecaoProRata) > zero then begin
        ValorAiNoVencto := arredonda(ValorAiNoVencto/IndiceDeCorrecaoProRata);
        CorrProRataCA   := -SaldoProrataCa-JurosProRataCA+ValorAINoVencto;
      end;
      JurosProRataCA  := abs(JurosProRataCA);
    end
    else begin
      JurosProRataCA := Arredonda(SaldoProRataCa * IndiceDeJurosProRata);
      if SobreSaldoCA then  SaldoProRataCa := arredonda(SaldoProRataCA + JurosProRataCA);
      ValorAiNoVencto:= SaldoProRataCA;
      if Abs(IndiceDeCorrecaoProRata) > zero then 
        ValorAiNoVencto := arredonda(ValorAiNoVencto/IndiceDeCorrecaoProRata);
    end;
    Result := Abs(ValorAiNoVencto);

    if assigned(LegLinkItem) then begin
      if SobreSaldoCA then begin
        leglinkItem.Valores['Corre  o pro rata CA'] := strgrana(CorrProRataCA);
        leglinkItem.Valores['Saldo pro rata CA'] := StrGrana(SaldoProRataCA);
        leglinkItem.Valores[' ndice mensal de Juros CA'] := formatfloat('0.00000000',IndJurosCA);
        leglinkItem.Valores['Intervalo de datas do prorata de juros CA'] := Data_Str2(DtVencJuros)+'   '+Data_Str2(Dt2);
        leglinkItem.Valores[' ndice de juros pro rata CA'] := formatfloat('0.00000000',IndiceDeJurosProRata);
        leglinkItem.Valores['Juros Pro rata CA'] := StrGrana(JurosPRoRataCA);
        leglinkItem.Valores['Saldo CA prorateado at  '+Data_Str(Dt2)] := StrGrana(SaldoProRataCa+JurosProRataCA);
      end
      else begin
        leglinkItem.Valores['Corre  o pro rata sobre a amortiza  o CA'] := strgrana(CorrProRataCA);
        leglinkItem.Valores[' ndice mensal de Juros CA'] := formatfloat('0.00000000',IndJurosCA);
        leglinkItem.Valores['Intervalo de datas do prorata de juros CA'] := Data_Str2(DtVencJuros)+'   '+Data_Str2(Dt2);
        leglinkItem.Valores[' ndice de juros pro rata CA'] := formatfloat('0.00000000',IndiceDeJurosProRata);
        leglinkItem.Valores['Juros Pro rata sobre a amortiza  o CA'] := StrGrana(JurosPRoRataCA);
        if Abs(ValorAINoVencto) > zero then 
          leglinkItem.Valores['Valor a amortizar no vencimento CA'] := StrGrana(-ValorAiNoVencto);
      end;
    end;
  end;
end;

function ConverteTxJurosParaMensal(const RPA : TpRPA) : real;
begin
  if RPA.Temp8.CodSerie = 0 then 
    Result := RPA.FinRPA.TxJuros/12
  else 
    Result := Rpa.FinRPA.IndJuros*100;
end;

