                                         ValoresPorMac.CO_JUROS_FLUTUANTE,
                                         ValoresPorMac.PERCACRESJURFLUT);                                         
          Corr  := Corr + CorrAc;
          Mora  := Mora + MoraAc;
        end;
      end; { case }
      PrstAtuSemAjuste:= ValPrst;
      if Scciconf.IncluiParcAcPagaNoAcertoFin then PrstAtuSemAjuste := PrstAtuSemAjuste + ValAc;
      AjustaMoeda2(RegPrst.MAC,Mes_Int(DataPg.MesAno),ValAc);
      AjustaMoeda2(RegPrst.MAC,Mes_Int(DataPg.MesAno),ValPrst);
      if (not IsencaoDeMulta(TpPg)) then begin
        Valor := DefineValorPrestAtraso(ValPrst,Seguro,ValTxAdm);
        if (TMora <> 101) then
          Valor := Valor + Corr;
        if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
          Valor := Valor + Mora;
        if (MutDsk.financ.PA = 81) or (TMora = 35) then PercM := 2.0
        else PercM := MutDsk.cad.PercMulta;
        if (TMora in [38..40]) then
          Multa := ValorMulta(DtPrest,DataPg,UF,CodMun,PercM,Valor,MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
        else
          Multa := ValorMulta(DtPrest,DataPg,UF,CodMun,PercM,Valor,MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
      end;
      if ComDesc then begin
        if (PercDescMora > zero) or
           (PercDescCorr > zero) or
           (PercDescMulta > zero) or
           (PercDescJremuneratorios > zero) then begin
           if (PercDescCorr > zero) then
             Corr := int((Corr -(Corr * (PercDescCorr/100)))*100+0.5)/100;
           if (PercDescMulta > zero) then
             Multa := int((Multa -(Multa * (PercDescMulta/100)))*100+0.5)/100;
           JMoratorios := Mora - JurosContr;
           if (PercDescJRemuneratorios > zero) then
             JurosContr := int((JurosContr -(JurosContr * (PercDescJRemuneratorios/100)))*100+0.5)/100;
           if (PercDescMora > zero) then
             JMoratorios := int((JMoratorios -(JMoratorios * (PercDescMora/100)))*100+0.5)/100;
           if (PercDescJRemuneratorios > zero) or (PercDescMora > zero) then
             Mora := JMoratorios + JurosContr;
        end;
      end
      else if Assigned(ValoresPorMAC.ParcelaDoMes) then begin
        { As parcelas de financiamento din mico s o criadas apenas para as parcelas efetivamente pagas.
          No caso de parcelas apenas emitidas, n o   poss vel acessar este parceladomes.
          Este erro foi visto na sol. 38038, tarefa 351181 }
        if (ValoresPorMAC.ParcelaDoMes.PercDescMora > zero) or
           (ValoresPorMAC.ParcelaDoMes.PercDescCorr > zero) or
           (ValoresPorMAC.ParcelaDoMes.PercDescMulta > zero) or
           (ValoresPorMAC.ParcelaDoMes.PercDescjremuneratorios > zero) then begin
         if (ValoresPorMAC.ParceladoMes.PercDescCorr > zero) then
           Corr := int((Corr -(Corr * (ValoresPorMAC.ParcelaDoMes.PercDescCorr/100)))*100+0.5)/100;
         if (ValoresPorMAC.ParceladoMes.PercDescMulta > zero) then
           Multa := int((Multa -(Multa * (ValoresPorMAC.ParcelaDoMes.PercDescMulta/100)))*100+0.5)/100;
         Jmoratorios := Mora - JurosContr;
         if (ValoresPorMAC.ParceladoMes.PercDescJRemuneratorios > zero) then
           JurosContr := int((JurosContr -(JurosContr * (ValoresPorMAC.ParcelaDoMes.PercDescJRemuneratorios/100)))*100+0.5)/100;
         if (ValoresPorMAC.ParceladoMes.PercDescMora > zero) then
           JMoratorios := int((JMoratorios -(Jmoratorios * (ValoresPorMAC.ParcelaDoMes.PercDescMora/100)))*100+0.5)/100;

         if (ValoresPorMAC.ParceladoMes.PercDescJRemuneratorios > zero) or
            (ValoresPorMAC.ParceladoMes.PercDescMora > zero) then
           Mora := JMoratorios + JurosContr;
        end;
        Desconto := ValoresPorMac.ParcelaDoMes.DescontoPagamento;
      end;
      if self.DiasDeAtrasoEntreDatas(DtPrest,DataPg) <= 0 then begin
        Corr      := 0;
        Mora      := 0;
        Multa     := 0;
        JurosContr:= 0;
      end;
      if (Mutdsk.cad5.ValIOF > zero) and (ValoresPorMAC.AmaisJ > zero) and
         (ValoresPorMac.DtAssinOrig.Dia > 0) then begin
        Perc     := (RegPrst.AmaisJ-ValorPagoAntecipado)/ValoresPorMAC.AmaisJ;
        AmortIOF := arredonda(Perc*(ValoresPorMAC.AmaisJ-ValoresPorMAC.Juro)); 
        if (AmortIOF > zero) and 
          ((Abs(Corr + Mora + Multa) > zero) or ApuraIOF) and
           self.SerieF.PrstEmAtrasoAtual(Mes_Int(DtPrest.Mesano),DtPrest.Dia,DataPg,0{lcobr},ValoresPorMac.EParcelaDeSeguro) then
          ValIof := CalculaIOFComplementar(ValoresPorMac.DtAssinOrig,DtPrest,DataPg,
                                           self.Mutdsk,AmortIOF);
      end;
    end;
    if Scciconf.IncluiParcAcPagaNoAcertoFin then ValPrst := ValPrst + ValAc;
    result := int((ValPrst + Corr + Mora + Multa + ValIof - Desconto)*100+0.5)/100;
end;

