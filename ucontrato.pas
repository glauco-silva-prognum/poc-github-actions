procedure TSeries.SetaSeriePrincipal(Marca : boolean = true);
var
  i,
  prazoseriebase : integer;
begin
  for i := 0 to count-1 do Serie[i].fSeriePrincipal := false;
  FNumeroSeriePrincipal := -1; 
  if Marca then begin
    prazoseriebase := 0;
    for i := 0 to count-1 do begin // Tenta achar uma s rie mensal
      if (Serie[i].Fin.PerParcelas=1) and 
         (Ctr_Ativo(Serie[i].RpaS)) and
         (Serie[i].RpaS.Finrpa.Npc+1 <= Serie[i].Rpas.FinRpa.Prazo) and
         (mes_int(Serie[i].Fin.DtInicio.Mesano) <= Serie[i].RpaS.Mac) and 
         (Serie[i].Fin.CompoeSaldo) and 
         ((PrazoSerieBase = 0) or (Serie[i].Fin.Prazo > PrazoSerieBase)) then begin
        FNumeroSeriePrincipal := i;
        PrazoSerieBase := Serie[i].Fin.Prazo;
      end;
    end;
    if FNumeroSeriePrincipal < 0 then begin
      for i := 0 to count-1 do begin // Tenta achar uma s rie mensal, ativa, mesmo que n o componha o saldo
        if (Serie[i].Fin.PerParcelas=1) and 
           (Ctr_Ativo(Serie[i].RpaS)) and
           (Serie[i].RpaS.Finrpa.Npc+1 <= Serie[i].Rpas.FinRpa.Prazo) and
           (mes_int(Serie[i].Fin.DtInicio.Mesano) <= Serie[i].RpaS.Mac) and 
           ((PrazoSerieBase = 0) or (Serie[i].Fin.Prazo > PrazoSerieBase)) then begin
          FNumeroSeriePrincipal := i;
          PrazoSerieBase := Serie[i].Fin.Prazo;
        end;
      end;
    end;
    if FNumeroSeriePrincipal < 0 then begin
      for i := 0 to count-1 do begin // Tenta achar uma s rie ativa, mesmo que n o componha o saldo e n o seja mensal
        if (Ctr_Ativo(Serie[i].RpaS)) and
           (Serie[i].RpaS.Finrpa.Npc+1 <= Serie[i].Rpas.FinRpa.Prazo) and
           (mes_int(Serie[i].Fin.DtInicio.Mesano) <= Serie[i].RpaS.Mac) and 
           ((PrazoSerieBase = 0) or (Serie[i].Fin.Prazo > PrazoSerieBase)) then begin
          FNumeroSeriePrincipal := i;
          PrazoSerieBase := Serie[i].Fin.Prazo;
        end;
      end;
    end;
    if FNumeroSeriePrincipal < 0 then begin
      for i := 0 to count-1 do 
      begin // Tenta achar uma s rie mesmo que n o teinha come ado ainda 
        if (Ctr_Ativo(Serie[i].RpaS)) and
           (Serie[i].RpaS.Finrpa.Npc+1 < Serie[i].Rpas.FinRpa.Prazo) and
           ((PrazoSerieBase = 0) or (Serie[i].Fin.Prazo > PrazoSerieBase)) then 
        begin
          FNumeroSeriePrincipal := i;
          PrazoSerieBase := Serie[i].Fin.Prazo;
        end;
      end;
    end;  
    if (FNumeroSeriePrincipal < 0) and (Count = 1) and
       (Serie[0].Fin.Status = 0) then
      FNumeroSeriePrincipal := 0;
    if FNumeroSeriePrincipal > -1 then Serie[FNumeroSeriePrincipal].FSeriePrincipal := true;
  end;
end;
  
