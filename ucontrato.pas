          end;
          Item.DifAtu := Dif;
          Item.Mora := Mora;
          Item.Corr := Corr;
          Item.CodSerie := 0;
          Dados.add(Item);
        end;
        if Grava then begin
          fillchar(RPendEmi,sizeof(TpPendEmi),0);
          with RPendEmi do begin
