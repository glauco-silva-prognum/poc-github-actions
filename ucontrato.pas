  Parcela : TParcela;
  MACSalvo: smallint; 
  DtAssinSalvo,
  DtAssinOrigSalvo: Tdata;
  CtrSalvo        : TpCtr;
  Acessorios,
  ValJustoSalvo,
  ValPEJurosTJEOProp,
  ValDifPrestSalvo,
  ValAvalCorrSalvo,
  ValAvalSalvo: real;
  ValReavalSalvo : real;
  VFUPC : longint;
begin
  with RPA, RPA.FinRPA, RPA.ValRPA, RPA.Temp, RPA.Sec do begin
    DtPrimAtrasoBkp := RPA.Temp11.DtPrimAtrasoCtb;
    CtrSalvo        := RPA.Ctr;
    MACSalvo        := RPA.MAC;
    DtAssinSalvo    := RPA.FinRPA.DtAssin;
