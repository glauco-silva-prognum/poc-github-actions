          wPagamentoParcial.ValTxAdm := ArrayValPgtoParcial^[pg].ValTxAdm;
          wPagamentoParcial.FCVS  := ArrayValPgtoParcial^[pg].FCVS;
          wPagamentoParcial.FGTS  := ArrayValPgtoParcial^[pg].FGTS;
          wPagamentoParcial.Desc  := ArrayValPgtoParcial^[pg].Desc;
          wPagamentoParcial.DescConcedido := ArrayValPgtoParcial^[pg].DescConcedido;
          wPagamentoParcial.DtPg  := ArrayValPgtoParcial^[pg].DtPg;
          wPagamentoParcial.DtProc:= ArrayValPgtoParcial^[pg].DtProc;
          wPagamentoParcial.TipoPgParcial      := ArrayValPgtoParcial^[pg].TipoPg;
          wPagamentoParcial.TipoPgTotalParcela := SerieF.Parcelas[i].TipoPg;
          wPagamentoParcial.DtPgTotalParcela   := SerieF.Parcelas[i].DtPg;
          wPagamentoParcial.SeqPag             := ArrayValPgtoParcial^[pg].SeqPag;
          wPagamentoParcial.Correcao           := ArrayValPgtoParcial^[pg].Correcao;
          wPagamentoParcial.JurosAbat          := ArrayValPgtoParcial^[pg].JurosAbat;
          wPagamentoParcial.ValIofComplem      := ArrayValPgtoParcial^[pg].ValIofComplem;
          wPagamentoParcial.DataRefCalc        := ArrayValPgtoParcial^[pg].DataRefCalc;
        end;
      end;
    end;
  finally
    FreeMem(ArrayValpgtoParcial);
  end;
end;

function TPagamentosParciaisFinanciamentoDinamico.ObtemEncargoPagamentoParcial(      Mac                   : integer; 
                                                                                     DataRef               : TData;
                                                                                 var RegPgtoParcial        : TpValPgtoParcial;
                                                                                 var AmaisJParcialVencPrst : real;
                                                                                     EmAtrasoCtb           : boolean = false;
                                                                                     SomenteTipoPgParcial  : boolean = false;
                                                                                     DiaVenc               : byte    = 0;
                                                                                     SoPgtoAnteriorDataRef : boolean = false;
                                                                                     ConsideraPgtosAteDataH: boolean = false;
                                                                                     AmaisJ                : real    = 0;
                                                                                     Juro                  : real    = 0;
                                                                                     Seguro                : real = 0;
                                                                                     ValTxAdm              : real = 0;
                                                                                     FCVS                  : real = 0;
                                                                                     FGTS                  : real = 0;
                                                                                     Desc                  : real = 0) : real;

var
  i, j        : integer;
  DtVenc      : Tdata;
  SelecParcela: boolean;
  Parcela     : TParcela;
  PgtoParcial : TPagamentoParcial;
begin
  AmaisJParcialVencPrst := 0; //pgtos parciais antecipados sobre o encargo que venceu
  RegPgtoParcial.codParc:= 0; fillchar(RegPgtoParcial,sizeof(RegPgtoParcial),0);
  PgtoParcial           := TPagamentoParcial.create(nil);
  try
    for i := 0 to Count-1 do begin
      if  (MAC = PagamentoParcial[i].Mac) and 
         ((not SomenteTipoPgParcial) or 
          (PagamentoParcial[i].TipoPgParcial in [51,111,115])) then begin
        PgtoParcial.assign(PagamentoParcial[i]);
        if EmAtrasoCtb then begin
          SelecParcela := juliano(PagamentoParcial[i].DtProc) <= juliano(DataRef);
          if not SelecParcela then begin
            PgtoParcial.clear;
            Parcela := PagamentoParcial[i].GetParcela;
            if assigned(Parcela) and (Parcela.OcorrenciasPagamentos.Count > 0) then begin
              j := Parcela.OcorrenciasPagamentos.Count-1;
              while (j >= 0) and (PgtoParcial.MAC = 0) do begin
                with Parcela.OcorrenciasPagamentos[j] do
                  if (RegOcorrenciasPgtos.DtProc.Dia > 0) and
                     (Juliano(RegOcorrenciasPgtos.DtProc) <= Juliano(DataRef)) and
                     (RegOcorrenciasPgtos.NumParc = PagamentoParcial[i].NumParc) and 
                     (RegOcorrenciasPgtos.SeqPag  = PagamentoParcial[i].SeqPag ) (* and
                     (not (RegOcorrenciasPgtos.TipoPg in NotPg+[0]))*) then begin
                    PgtoParcial.MAC                   := Parcela.MAC;
                    PgtoParcial.DiaVenc               := Parcela.DiaVenc;
                    PgtoParcial.NumParc               := RegOcorrenciasPgtos.NumParc;
                    PgtoParcial.Valor                 := RegOcorrenciasPgtos.Valtot;
                    PgtoParcial.AmaisJ                := RegOcorrenciasPgtos.Amaisj;
                    PgtoParcial.Juro                  := RegOcorrenciasPgtos.Juro;
                    PgtoParcial.Seguro                := RegOcorrenciasPgtos.Seguro;
                    PgtoParcial.ValTxAdm              := RegOcorrenciasPgtos.ValtxAdm;
                    PgtoParcial.FCVS                  := RegOcorrenciasPgtos.FCVS;
                    PgtoParcial.FGTS                  := RegOcorrenciasPgtos.FGTS;
                    PgtoParcial.ValIOFComplem         := RegOcorrenciasPgtos.ValIOFComplem;
                    PgtoParcial.Desc                  := RegOcorrenciasPgtos.Desconto;
                    PgtoParcial.DescConcedido         := RegOcorrenciasPgtos.DescConcedido;
                    PgtoParcial.TipoPgParcial         := RegOcorrenciasPgtos.TipoPg;
    //                PgtoParcial.TipoPgTotalParcela  
    //                PgtoParcial.DtPgTotalParcela 
                    PgtoParcial.DtPg                  := RegOcorrenciasPgtos.DtPg;
                    PgtoParcial.DtProc                := RegOcorrenciasPgtos.DtProc;
                    PgtoParcial.SeqPag                := RegOcorrenciasPgtos.SeqPag;
                    PgtoParcial.DataRefCalc           := RegOcorrenciasPgtos.DataRefCalc;
    //                PgtoParcial.Correcao
    //                PgtoParcial.JurosAbat
                  end;
                dec(j);
              end;       
            end;
            SelecParcela := (PgtoParcial.NumParc = PagamentoParcial[i].NumParc) and 
                            (PgtoParcial.MAC     = PagamentoParcial[i].MAC    ) and
                            (PgtoParcial.SeqPag  = PagamentoParcial[i].SeqPag ) and
                            (not (PgtoParcial.TipoPgParcial in NotPg+[0]))      and  //estornos
                            (juliano(PgtoParcial.DtProc) <= juliano(DataRef));
          end;
        end
        else
          SelecParcela := true;

        if SelecParcela and (PgtoParcial.DtPg.Dia > 0) and 
          (not (PgtoParcial.TipoPgParcial in NotPg+[0])) and
         (
            (ConsideraPgtosAteDataH and (Juliano(PgtoParcial.DtPg) <= Juliano(DataH)))
                             or
          ( (Juliano(PgtoParcial.DtPg) <= Juliano(DataRef)) and
           ((not SoPgtoAnteriorDataRef) or 
            (Juliano(PgtoParcial.DtPg) < Juliano(DataRef))
           )
          )
         )                then begin
          RegPgtoParcial.Amaisj        := RegPgtoParcial.Amaisj  + PgtoParcial.Amaisj;
          RegPgtoParcial.Juro          := RegPgtoParcial.Juro    + PgtoParcial.Juro;
          RegPgtoParcial.Seguro        := RegPgtoParcial.Seguro  + PgtoParcial.Seguro;
          RegPgtoParcial.ValTxAdm      := RegPgtoParcial.ValTxAdm+ PgtoParcial.ValTxAdm;
          RegPgtoParcial.FCVS          := RegPgtoParcial.FCVS    + PgtoParcial.FCVS;
          RegPgtoParcial.FGTS          := RegPgtoParcial.FGTS    + PgtoParcial.FGTS;
          RegPgtoParcial.Desc          := RegPgtoParcial.Desc    + PgtoParcial.Desc;
          RegPgtoParcial.ValIofComplem := RegPgtoParcial.ValIofComplem + PgtoParcial.ValIofComplem;
          Int_Mes(PgtoParcial.MAC,DtVenc.MesAno);
          if DiaVenc > 0 then DtVenc.Dia := DiaVenc
          else if PgtoParcial.DiaVenc > 0 then
            DtVenc.Dia := PgtoParcial.DiaVenc
          else
            DtVenc.Dia := 1; 
          if (juliano(DtVenc) <= juliano(DataRef)) and
            ((Scciconf.ContabDiaria and 
             (juliano(DtVenc) > juliano(PgtoParcial.DtProc))) or
             (PgtoParcial.MAC > Mes_Int(PgtoParcial.DtProc.MesAno))) then
            AmaisJParcialVencPrst := AmaisJParcialVencPrst + PgtoParcial.Amaisj;
        end;
      end;
    end; //for
  finally
    PgtoParcial.free;
  end;                       
  if (AmaisJ > zero) and (AmaisJ - RegPgtoParcial.Amaisj < zero) then 
    RegPgtoParcial.Amaisj := Amaisj;
  if (Seguro > zero) and (Seguro - RegPgtoParcial.Seguro < zero) then
    RegPgtoParcial.Seguro := Seguro;
  if (ValTxAdm > zero) and (ValTxAdm - RegPgtoParcial.ValTxAdm < zero) then
    RegPgtoParcial.ValTxAdm := ValTxAdm;
  if (FCVS  > zero) and (FCVS - RegPgtoParcial.FCVS < zero) then
    RegPgtoParcial.FCVS := FCVS;
  if (FGTS > zero) and (FGTS - RegPgtoParcial.FGTS < zero) then
    RegPgtoParcial.FGTS := FGTS;  
  if (Desc > zero) and (Desc - RegPgtoParcial.Desc < zero) then
    RegPgtoParcial.Desc := Desc;
  Result := arredonda(RegPgtoParcial.Amaisj   +
                      RegPgtoParcial.Seguro   + 
                      RegPgtoParcial.ValTxAdm + 
                      RegPgtoParcial.FCVS     -
                      RegPgtoParcial.FGTS);
end;

function TPagamentosParciaisFinanciamentoDinamico.ObtemSaldoPagamentoParcial(    Mac                   : integer; 
                                                                                 DataRef               : TData;
                                                                             var AmaisJParcialVencPrst : real;
                                                                                 EmAtrasoCtb           : boolean = false;
                                                                                 SomenteTipoPgParcial  : boolean = false;
                                                                                 DiaVenc               : byte    = 0;
                                                                                 SoPgtoAnteriorDataRef : boolean = false;
                                                                                 ConsideraPgtosAteDataH: boolean = false;
                                                                                 SoAmaisJParcial       : boolean = true) : real;
var
  RegPgtoParcial : TpValPgtoParcial;
begin
  AmaisJParcialVencPrst  := 0;
  RegPgtoParcial.CodParc := 0; fillchar(RegPgtoParcial,sizeof(RegPgtoParcial),0);
  Result := self.ObtemEncargoPagamentoParcial(MAC,DataRef,RegPgtoParcial,AmaisJParcialVencPrst,EmAtrasoCtb,SomenteTipoPgParcial,DiaVenc,SoPgtoAnteriorDataRef,ConsideraPgtosAteDataH);
  if SoAmaisJParcial then Result := RegPgtoParcial.AmaisJ;
end;

function TPagamentosParciaisFinanciamentoDinamico.ObtemSaldoPagamentoParcial(Mac : integer; DataRef : TData;
                                                                             DiaVenc : byte = 0;
                                                                             ConsideraPgtosAteDataH : boolean = false) : real;
var
  AmaisJParcialVenc : real;
begin
  AmaisJParcialVenc := 0; //pgtos parciais antecipados sobre o encargo que venceu
  Result            := ObtemSaldoPagamentoParcial(MAC,DataRef,AmaisJParcialVenc,
                                                  false{EmAtrasoCtb},
                                                  false{SomenteTipoPgParcial},
                                                  DiaVenc,
                                                  false{SoPgtoAnteriorDataRef},
                                                  ConsideraPgtosAteDataH);
  
end;

{ TSerieFinanciamentoDinamico }

constructor TSerieFinanciamentoDinamico.create(Owner : TObject);
begin
  inherited create;
  FOwner := Owner;
  FParcelas := TParcelasFinanciamentoDinamico.Create(self);
  FValoresEmitidos := TValoresEmitidos.create;
  FValoresPorMACList := TObjectList.create;
  FValoresPorMACList.ownsobjects := true;
end;

destructor TSerieFinanciamentoDinamico.destroy;
begin
  FValoresEmitidos.free;
  FParcelas.free;
  if assigned(FPagamentosParciais) then
    FPagamentosParciais.free;
  FValoresPorMACList.free;
  inherited;
end;

procedure TSerieFinanciamentoDinamico.ZeraCodErro(inicio : integer = 0);
var
  i : integer;
begin
  if inicio = 0 then
    Inicio := mes_int(Contrato.Mutdsk.Financ.DtAssin.MesAno);
  for i := Inicio to FValoresPorMacList.count-1 do
    if assigned(FValoresPorMacList[i]) then
      TValoresPorMac(FValoresPorMacList[i]).CodErro := 0;
end;

function TSerieFinanciamentoDinamico.GetParcelas : TParcelasFinanciamentoDinamico;
begin
  Result := FParcelas;
end;

function TSerieFinanciamentoDinamico.GetPagamentosParciais : TPagamentosParciaisFinanciamentoDinamico;
begin
  if not Assigned(FPagamentosParciais) then begin
    FPagamentosParciais := TPagamentosParciaisFinanciamentoDinamico.Create(self);
    FPagamentosParciais.le(Self);
  end;
  result := FPagamentosParciais;
end;

function TSerieFinanciamentoDinamico.GetContrato : TContrato;
begin
  result := nil;
  if assigned(FOwner) and (FOwner is TContrato) then
    result := FOwner as TContrato;
end;

