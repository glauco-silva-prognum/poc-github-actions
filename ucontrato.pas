    end
    else if TemFinancDinamico(MutDsk) and //sol.069595 por enquanto s  estamos tratando o financ.dinamico dessa forma, mas segundo Mmr somente estes t rminos tem que zerar os saldos vends
           (RPAF.FinRPA.Status in [20,98]) and (FTemVendedores or FTemFgtsApoioAConstrucao) then begin
      if RPAF.FinRPA.DiaLiq > 0 then 
        DtTermino.Dia := RPAF.FinRPA.DiaLiq
      else
        DtTermino.Dia := RPAF.FinRPA.DiaVenc;
      Int_Mes(RPAF.ValRPA.MACStatus,DtTermino.MesAno);
      if (FDataRefHist.Dia = 0) or DataEMenorOuIgual(DtTermino,FDataRefHist) then 
        ZeraSaldoVendedores(RPAF);
    end;
    if (Faixa=0) and (DtAssin.Dia>0) and (mes_int(DtAssin.MesAno)>768) then begin
      VUPC := OBTEM_MOEDA_REF(DtAssin);
      if VUPC>Zero then T := ValFinanc/VUPC else T := ValFinanc;
      if T < 8000 then VFUPC := trunc(T+0.99) else VFUPC:= 8000;
      case VFUPC of
        0000..2500: Faixa := 1;
        2501..5000: Faixa := 2;
        5001..9999: Faixa := 3;
      end;
    end;
  end; (* with *)
  if (RPA.ValRpa.MacStatus = RPA.Mac) and 
     ((RPA.FinRpa.DiaLiq >= RPA.FinRpa.DiaVenc) or (RPA.FinRpa.DiaLiq = 0)) and
     (RPA.ValRpa.TotPrest > zero) then RPA.Temp12.StatusNoDiaVenc := 0
  else RPA.Temp12.StatusNoDiaVenc := RPA.FinRpa.Status;
  Rpa.Temp12.Diainfin := Rpa.FinRpa.DtInfin.dia;
  RPA.Temp11.PrazoEmMeses := CalculaPrazoEmMeses(Self,true{TerminosAntec});
  for i := 0 to Series.count - 1 do begin
    Salva1Evento(Series[i].RPAS);
    Series[i].AtualizaValoresPorMACList(Series[i].RPAS,RPA.FinRPA.IndJuros);
  end;
  if TemFinancDinamico(Mutdsk) then begin
//    Salva1Evento(RPAF); Passou a ser tratado na uevolui3
    SerieF.AtualizaValoresPorMACList(RPAF,RPA.FinRPA.IndJuros);
  end;
  Salva1Evento(RPA);
  AtualizaValoresPorMacList(RPA);
end; // Fim da ConsolidaRpas

