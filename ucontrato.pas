procedure MontaFiltroSqlDataLocal(    SqlConnection : TsqlConnection;
                                      NomeCampo : ansistring;
                                      DataIni,
                                      DataFim : Tdata;
                                  var sql : ansistring);
begin
  J_Data(Juliano(DataFim)+1,DataFim);
  if (uppercase(SqlConnection.DriverName) = 'INTERBASE') or (uppercase(SqlConnection.DriverName) = 'POSTGRES') then begin
    sql := '(' + NomeCampo + ' >= CAST(' + chr(39) + DataToAAAA_MM_DD(DataIni) + chr(39) + ' AS DATE))';
    sql := sql + ' and (' + NomeCampo + ' < CAST(' + chr(39) + DataToAAAA_MM_DD(DataFim) + chr(39) + ' AS DATE))';
  end
  else if uppercase(SqlConnection.DriverName) = 'ORACLE' then begin
    sql := NomeCampo + '>=to_date(' + Quotedstr(inttostr(DataIni.ano+1900)+'-'+intstr(DataIni.mes)+'-'+intstr(DataIni.dia));
    sql := sql + ','+ quotedStr('YYYY-MM-DD')+') and ' + NomeCampo + '<to_date('+ Quotedstr(inttostr(DataFim.ano+1900)+'-'+intstr(DataFim.mes)+'-'+intstr(DataFim.dia));
    sql := sql + ','+ quotedStr('YYYY-MM-DD')+')';
  end
  else if (uppercase(SqlConnection.DriverName) = 'OPENODBC') or (uppercase(SqlConnection.DriverName) = 'MSSQL') then begin
    sql := '(' + NomeCampo + ' >= CAST(' + chr(39) + DataToAAAA_MM_DD(DataIni) + chr(39) + ' AS DATETIME))';
    sql := sql + ' and (' + NomeCampo + ' < CAST(' + chr(39) + DataToAAAA_MM_DD(DataFim) + chr(39) + ' AS DATETIME))';
  end
  else
    raise exception.create('N o implementado para este database');
end;

function TemPosicaoAtrasoParaData(SqlConnection : TSqlConnection; Ctr : string; Data : Tdata) : boolean;
var
  Qry : TSqlquery;
  sql : ansistring;
begin
  sql := '';
  Qry := TSqlquery.create(nil);
  try
    Qry.sqlConnection := SqlConnection;
    MontaFiltroSqlData(SqlConnection,'DT_POSICAO_ATRASO',Data,Data,sql);
    if uppercase(Qry.SqlConnection.DriverName) = 'ORACLE' then begin
      MontaFiltroSqlDataLocal(SqlConnection,'DT_POSICAO_ATRASO',Data,Data,sql); // Sol. 78521 - o filtro por data com to_char, no oracle estava muito lento
      qry.sql.add('SELECT DT_POSICAO_ATRASO');
      qry.sql.add('FROM');
      Qry.Sql.Add('(SELECT DT_POSICAO_ATRASO,ROW_NUMBER() OVER (ORDER BY DT_POSICAO_ATRASO DESC) R FROM POSICAO_ATRASO ');
      if Ctr > '' then begin
        Qry.sql.add('where CO_CONTRATO = :CO_CONTRATO AND NU_MAC > :NU_MAC');
        Qry.sql.add('and');
      end
      else
        Qry.sql.add('where');
      Qry.sql.add('('+sql+')');
      qry.sql.add(')WHERE R <= 1');
    end
    else if (uppercase(Qry.SqlConnection.DriverName) = 'OPENODBC') or (uppercase(Qry.SqlConnection.DriverName) = 'MSSQL') then begin
      Qry.Sql.add('select top 1 DT_POSICAO_ATRASO from POSICAO_ATRASO');
      if Ctr > '' then begin
        Qry.sql.add('where CO_CONTRATO = :CO_CONTRATO AND NU_MAC > :NU_MAC');
        Qry.sql.add('and');
      end
      else
        Qry.sql.add('where');
      Qry.sql.add('('+sql+')');
      Qry.sql.add('order by DT_POSICAO_ATRASO desc');
    end
    else if (UpperCase(Qry.SqlConnection.DriverName) = 'POSTGRES') then begin
      Qry.Sql.Add('SELECT DT_POSICAO_ATRASO FROM POSICAO_ATRASO');
      if Ctr > '' then begin
        Qry.Sql.Add('WHERE CO_CONTRATO = :CO_CONTRATO AND NU_MAC > :NU_MAC');
        Qry.Sql.Add('AND');
      end
      else
        Qry.Sql.Add('WHERE');
      Qry.Sql.Add('(' + sql + ')');
      Qry.Sql.Add('ORDER BY DT_POSICAO_ATRASO DESC');
      Qry.Sql.Add('LIMIT 1');
    end
    else begin
      Qry.Sql.add('select first 1 DT_POSICAO_ATRASO from POSICAO_ATRASO');
      if Ctr > '' then begin
        Qry.sql.add('where CO_CONTRATO = :CO_CONTRATO AND NU_MAC > :NU_MAC');
        Qry.sql.add('and');
      end
      else
        Qry.sql.add('where');
      Qry.sql.add('('+sql+')');
      Qry.sql.add('order by DT_POSICAO_ATRASO desc');
    end;
    if Ctr > '' then begin
      Qry.ParamByName('CO_CONTRATO').DataType := ftString;
      Qry.ParamByName('NU_MAC').DataType := ftInteger;
      Qry.ParamByName('CO_CONTRATO').asString := ctrtosqlctr(ctr);
      Qry.ParamByName('NU_MAC').asInteger := 0;
    end;
//qry.sql.savetofile('TemPosicaoAtrasoParaData.sql');
    Qry.open;
    result := not Qry.isempty;
    
  finally
    Qry.free;
  end;
end;

procedure TrataIsencaoTaxaEmissao(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados : TDadosAtrasoEvo);
var
  i : integer;
  VaTotCorr : real;
begin
  if CalculoAtrasoParametros.IsentaTaxaRecibo then begin
    VaTotCorr := 0;
    for i := 0 to Dados.count-1 do begin
      if not Dados[i].Esconde then
        VaTotCorr    := VaTotCorr +
                        Dados[i].Correcao +
                        Dados[i].Multa +
                        Dados[i].Mora;
    end;
    if (VaTotCorr <= Zero) and (Dados.NPrest = 1) then
      CalculoAtrasoParametros.CobraTaxa := false;
  end;
end;

