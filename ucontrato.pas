procedure TContrato.CalculaValorTaxaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                           var ValorTaxa,ValorIptu : real);
begin
  ValorTaxa := 0;
  ValorIptu := 0;
  if not CalculoAtrasoParametros.IgnoraTaxas then begin
    if (SisTaxasDiversas(Scciconf.SistemaDeTaxas)) then begin
      if CalculoAtrasoParametros.CobraTaxaWebRecAutoAtend  then begin
        if StripStr(ScciConf.CodTaxaWebRecAutoAtendimento)> '' then begin
          if ValInt(ScciConf.CodTaxaWebRecAutoAtendimento) >=0  then begin
            ValorTaxa := RetornaValorTaxa(MutDsk,CalculoAtrasoParametros.DataRef,
                                          CalculoAtrasoParametros.CobraTodasTaxas,
                                          ValInt(ScciConf.CodTaxaWebRecAutoAtendimento),CalculoAtrasoParametros.ModuloChamador);
          end;
        end;
      end
      else
      if CalculoAtrasoParametros.CobraTaxa2viaAuto and CalculoAtrasoParametros.CobraTaxa then
        ValorTaxa := RetornaValorTaxa(MutDsk,CalculoAtrasoParametros.DataRef,CalculoAtrasoParametros.CobraTodasTaxas,0,CalculoAtrasoParametros.ModuloChamador)
      else
        ValorTaxa := RetornaValorTaxaPorContrato(MutDsk,CalculoAtrasoParametros.DataRef,CalculoAtrasoParametros.CobraTodasTaxas,CalculoAtrasoParametros.ModuloChamador);
    end
    else
      if CalculoAtrasoParametros.CobraTaxa then
        ValorTaxa := RetornaValorTaxa(MutDsk,CalculoAtrasoParametros.DataRef,false,0,CalculoAtrasoParametros.ModuloChamador);
    ValorIptu := RetornaValorTaxaDeIptu(MutDsk.Cad.Ctr,CalculoAtrasoParametros.DataRef,CalculoAtrasoParametros.CobraTodasTaxas,CalculoAtrasoParametros.ModuloChamador);
  end;
  ValorTaxa := Int(ValorTaxa*100+0.5)/100;
  ValorIptu := Int(ValorIptu*100+0.5)/100;
end;


procedure TContrato.CalculaValorTaxaEmissaoAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                  var ValorTaxa : real);
begin
  ValorTaxa := 0;
  if not CalculoAtrasoParametros.IgnoraTaxas then begin
    if (SisTaxasDiversas(Scciconf.SistemaDeTaxas)) then begin
      if not CalculoAtrasoParametros.CobraTaxaWebRecAutoAtend  and
         CalculoAtrasoParametros.CobraTaxa2viaAuto and
         CalculoAtrasoParametros.CobraTaxa then
        ValorTaxa := RetornaValorTaxaEmissao(MutDsk.Cad.Ctr,CalculoAtrasoParametros.DataRef,0)
    end
    else
      if CalculoAtrasoParametros.CobraTaxa then
        ValorTaxa := RetornaValorTaxaEmissao(MutDsk.Cad.Ctr,CalculoAtrasoParametros.DataRef,0);
  end;
  ValorTaxa := Int(ValorTaxa*100+0.5)/100;
end;

procedure TContrato.ExpandeValoresPorMacAteRef(MacRef : smallint; Status : integer);
var
  i : integer;
begin
  Rpa.Temp12.StatusAnt := RPA.FinRpa.Status;
  RPA.FinRPA.Status := status;
  if FValoresPormacList.count <= MacRef then
    FValoresPorMacList.count := MacRef+1;
  for i := 0 to FValoresPorMacList.count-1 do begin
    if not assigned(FValoresPorMacList[i]) then
      FValoresPorMacList[i] := TValoresPorMac.create;
    TValoresPorMac(FValoresPorMacList[i]).CtrAtivo := false;
    TValoresPorMac(FValoresPorMacList[i]).status := status;
  end;
  if TemFinancDinamico(Mutdsk) then begin
    RpaF.Temp12.StatusAnt := RpaF.FinRpa.Status;
    RPAF.FinRPA.Status := status;
    SerieF.ExpandeValoresPorMacAteRef(MacRef,Status);
  end;
  for i := 0 to Series.count-1 do
    Series[i].ExpandeValoresPorMacAteRef(MacRef,Status);
end;

procedure TContrato.EvoluiParaCalculoAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros);

  function EvoPrestVincendaAux(Mac,MacRef : integer; RegLCobr : TpTabLCobr) : boolean;
  var
    Reg : TValoresPorMac;
  begin
    Reg := ObtemValoresPorMac(Mac);
    result := EvoPrestVincenda(CalculoAtrasoParametros,Reg,MacRef,RegLcobr);
  end;

var
  MacRef : smallint;
  CountEvoAtr : integer;
  RegLcobr : TpTabLCobr;
  Reg : TValoresPorMac;
  TempCmTabErr : integer;
  TempCmTabErrData : TData;
begin
  if CalculoAtrasoParametros.PermiteEvoluir then begin
    if FValoresPorMacList.count = 0 then begin
      InicRpa;
    end;
    MacRef := mes_int(CalculoatrasoParametros.DataRef.MesAno);
    if Rpa.Mac > 0 then begin
      CountEvoAtr := 1;
      while (RPA.Mac <= MacRef) and (CountEvoAtr < MaxEvoAtr) do begin
        inc(CountEvoAtr);

        TempCmTabErr := cmTabErr;
        TempCmTabErrData := cmTabErrData;
        Evolui;
        if RPA.Mac > MacRef then begin
          // descarta erros de  ndices posteriores a dataref
          cmTabErr := TempCmTabErr;
          cmTabErrData := TempCmTabErrData;
        end;

      end;
      
      ReglCobr.LCobr := 0;
      fillchar(ReglCobr,sizeof(ReglCobr),0);
      Reg := ObtemValoresPorMac(MacRef);
      if assigned(Reg) then begin
        LeLCobrValoresPorMac(MutDsk,Reg,RegLCobr);
        if (ReglCobr.Lcobr2avia > 0) and not CalculoAtrasoParametros.DebitoCC then
          LeLcobr2aVia(RegLCobr.Lcobr,RegLCobr);
      end;

      CountEvoAtr := 1;
      while ((RPA.Mac <= MacRef) or EvoPrestVincendaAux(RPA.Mac,MacRef,RegLCobr)) and (CountEvoAtr < MaxEvoAtr) do begin
        inc(CountEvoAtr);

        TempCmTabErr := cmTabErr;
        TempCmTabErrData := cmTabErrData;
        Evolui;
        if RPA.Mac > MacRef then begin
          // descarta erros de  ndices posteriores a dataref
          cmTabErr := TempCmTabErr;
          cmTabErrData := TempCmTabErrData;
        end;

      end;

    end
    else begin
      ExpandeValoresPorMacAteRef(MacRef,4);
    end;
  end;
end;

procedure TContrato.EvoluiParaCalculoQuitacao(DataRef : TData);
var
  NumPrst : integer;
  i,
  iSerie : integer;
  SetPgtoNormal : set of byte;
  MacUltimaPaga : integer;
begin

  // Garantir que o cache vai estar preenchido at  o t rmino do contrato
  // Continuar de onde estiver parado, caso j  esteja evoluido(otimiza  o)

  if not Evoluiu then
    InicRPA;

  NumPrst := 0;
  MacUltimaPaga := 0;

  while Ctr_Ativo(RPA) and (NumPrst < 400) do begin
    inc(NumPrst);
    Evolui;
  end;

  // Garantir que o cache vai estar preenchido para o c lculo do saldo de s rie

  SetPgtoNormal := [1,29..30,37,45..47,65,68..71,77..78,81..84,96,100..101,197..199,201..205,214..215,246..247];

  for iSerie := 0 to Series.count-1 do
    for i := 0 to Series[iSerie].Parcelas.count-1 do
      if Series[iSerie].Parcelas[i].EstaPagaReal and
         (Series[iSerie].Parcelas[i].Tipopg in SetPgtoNormal) and //  Considerar todos os pagamentos n o antecipados
         (Series[iSerie].Parcelas[i].Mac > Mes_int(DataRef.MesAno)) and
         (Series[iSerie].Parcelas[i].Mac > MacUltimaPaga) and
         ((mes_int(Series[iSerie].Parcelas[i].DtPg.MesAno) < Series[iSerie].Parcelas[i].Mac) or
          ((mes_int(Series[iSerie].Parcelas[i].DtPg.MesAno) = Series[iSerie].Parcelas[i].Mac) and
           (Series[iSerie].Parcelas[i].DtPg.Dia < Series[iSerie].Parcelas[i].DiaVenc))) then begin
        MacUltimaPaga := Series[iSerie].Parcelas[i].Mac;
      end;

  while RPA.Mac < MacUltimaPaga do
    Evolui;

  // Garantir que o cache vai estar preenchido pelo menos at  a dataref

  while RPA.Mac < mes_int(DataRef.mesano) do
    Evolui;

end;

function Tcontrato.RetornaUltimoMacParaCalcAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                  RegLCobr : TpTabLCobr): integer;
var
  Reg,
  RegAux,
  RegConsRef : TValoresPorMac;
  Mac,
  MAFim : integer;
  CountEvoAtr : integer;
  FaltaIndice : boolean;
  i : integer;
begin
  result := -1; // Limitador para igualar ao c lculo feito pela atrlib
  RegConsRef := ObtemValoresPorMac(Mes_int(CalculoAtrasoParametros.DataRef.MesAno));
  MAFim := Mes_int(CalculoAtrasoParametros.DataRef.MesAno);
  if RegConsRef.MacStatus < MaFim then
    MAFim := RegConsRef.MACStatus;
  Mac := mes_int(RegConsRef.DtAssin.MesAno);
  if Mac < FValoresPorMacList.count then begin
    Reg := ObtemValoresPorMac(Mac);
    CountEvoAtr := 1;
    result := Reg.Mac;
    while (((Reg.Mac <= Mes_int(CalculoAtrasoParametros.DataRef.MesAno)) and (Reg.CtrAtivo or
            (Reg.MAC < MAFim)) and (Reg.CodErro in [0,5])) or
             EvoPrestVincenda(CalculoAtrasoParametros,Reg,Mes_int(CalculoAtrasoParametros.DataRef.MesAno),RegLCobr)) and
            (CountEvoAtr < MaxEvoAtr) {and
            ((CalculoAtrasoParametros.TipoExec <> TipoExec_2avia) or
             (Reg.Mac <= Mes_int(CalculoAtrasoParametros.DataRef.MesAno) + 12)) Sol. 47161}do begin
      result := Mac;
      if not CalculoAtrasoParametros.EvoPrestMesmoSemIndice then
        if (CalculoAtrasoParametros.TipoExec = TipoExec_2avia) and (CalculoAtrasoParametros.MacParcComSegNaoPermitida = 0) then begin
          if TemFinancDinamico(Mutdsk) then begin
            RegAux := SerieF.ObtemValoresPorMac(Reg.Mac);
            FaltaIndice := (RegAux.Coderro > 0) and (RegAux.Coderro <> 5);
          end
          else
            FaltaIndice := false;
          i := 0;
          while not FaltaIndice and (i < Series.count) do begin
            RegAux := Series[i].ObtemValoresPormac(Reg.mac);
            FaltaIndice := FaltaIndice or ((RegAux.Coderro > 0) and (RegAux.Coderro <> 5));
            inc(i);
          end;
          if FaltaIndice then
            CalculoAtrasoParametros.MacParcComSegNaoPermitida := Reg.Mac;
        end;
      inc(CountEvoAtr);
      inc(Mac);
      if Mac < FValoresPorMacList.count then
        Reg := ObtemValoresPorMac(Mac)
      else
        break;
    end;
  end;
end;

procedure TContrato.DistribuiDadosPendCtr(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                              RegConsRef : TValoresPorMac;
                                          var RegLCobr : TpTabLCobr;
                                          var RegCart  : TpCarteira;
                                          var Dados    : TDadosAtrasoEvo;
                                          var DadosPend: TpTotPend;
                                          var TotPend  : TpTotPend;
                                              IndexPrest: smallint;
                                              ConsideraUltVariacao : boolean = false);
  function TotalNPrest(Dados : TDadosAtrasoEvo) : smallint;
  var
    i : smallint;
  begin
    Result := 0;
    with Dados do
      for i := 0 to Dados.count-1 do
        if not Dados[i].Esconde then inc(Result);
  end;
var
  i,QtdePrest,
  UltTit    : SmallInt;
  ValAtu,
  DifMan,
  DifCalc   : real;
  UltRegTit : TPrestacaoAtrasoevo;
  PendDesp  : real;
  VetTpPend : TpArrayTpPend;
begin
  VetTpPend[1] := 0;
  PendDesp := Scciconf.PendDesprezivel;
  if Scciconf.DistribuiPend then Scciconf.PendDesprezivel := 0;
  try
    UltTit := Dados.UltPrestPend;
    if UltTit >= 0 then begin
      UltRegTit := Dados[UltTit];
      DifCalc := DadosPend.PendCalc;
      DifMan := 0;
      QtdePrest:= TotalNPrest(Dados);
      for i := IndexPrest to Dados.count-1 do begin
          Dados[i].LimitouPend:= false;
          Dados[i].ValTit := Dados[i].EncMes    +
                             Dados[i].ValAcordo +
                             Dados[i].ValorSerie +
                             Dados[i].TaxaBanco +
                             Dados[i].ValIOFComplem;
          Dados[i].DifManual   := 0;
          Dados[i].DifCalculada:= 0;
          Dados[i].Diferenca   := 0;
        if (not Dados[i].Esconde) and
          ((MutDsk.Cad.MACIniCobPend <= 0) or (CalculoAtrasoParametros.TipoExec = TipoExec_Quitacao) or
           (Dados[i].MACPrst >= MutDsk.Cad.MACIniCobPend)) then begin
          if (i = UltTit) and (Abs(DadosPend.PendMan) > Zero) then begin
            if (DadosPend.PendMan < Zero) and
               (Abs(DadosPend.PendMan) > (UltRegTit.TotPrest - UltRegTit.Desc)) then begin
              DifMan                := 0;
              DadosPend.CobraPendMan:= false;
            end
            else begin
              DifMan                 := DadosPend.PendMan;
              DadosPend.CobraPendMan := true;
            end;
          end; { if Ult.Prest. }
          (* 98967 - ValAtu e "TotPrest-Desc" passado para DistribuiPend n o consideravam pagamentos
                     parciais. Devido a isso, ao tentar distribuir acerto financeiro na presta  o 
                     com pagamentos parciais, podia calcular uma parcela de acerto financeiro 
                     maior do que a sobra daquela presta  o(  usado um % m ximo a abater ou acrescer 
                     calculado sobre este valor da presta  o), gerando um total negativo a pagar.
                     Assim, a solu  o foi garantir que o valor considerado da presta  o seja realmente
                     o que restou, ap s pagamentos parciais, ao calcular o m ximo a abater ou acrescer. *)
          
          ValAtu := Dados[i].TotPrest-Dados[i].Desc-Dados[i].ValorpagoAntecipado+
                    Dados[i].Correcao+Dados[i].Mora+
                    Dados[i].Multa;
          Dados[i].Diferenca := DistribuiPend(MutDsk,
                                              Dados[i].DifManual,
                                              Dados[i].DifCalculada,
                                              DifMan,DifCalc,
                                              Dados[i].TotPrest-
                                              Dados[i].Desc-
                                              Dados[i].ValorpagoAntecipado,
                                              ValAtu,
                                              true,true,
                                              CalculoAtrasoParametros.DataRef,
                                              (((RegConsRef.Status = 8) and
                                                (RegConsRef.MacStatus=Dados[i].Macprst)) or
                                               ((not RegConsRef.CtrAtivo) and (i = UltTit))) and
                                                (QtdePrest = Dados.count),
                                              ConsideraUltVariacao);

          TotPend.PendMan := TotPend.PendMan  + Dados[i].DifManual;
          TotPend.PendCalc:= TotPend.PendCalc + Dados[i].DifCalculada;
          DadosPend.PendCalc := Dados[i].DifCalculada;
          if i = UltTit then
            DadosPend.PendMan := Dados[i].DifManual;
          if (Abs(Dados[i].DifManual) > Zero) or
             (Abs(Dados[i].DifCalculada) > Zero) then
            if (Abs(Dados[i].DifManual) <= Zero) and
              ((Abs(Dados[i].DifCalculada) > Zero) ) then begin
              Dados[i].CodPend1 := 98;
              if Dados[i].DifCalculada > Zero then
                Dados[i].DescrPend:= 'DIFERENCA A MENOR (PENDENCIA CALCULADA)'
              else
                Dados[i].DescrPend:= 'DIFERENCA A MAIOR (PENDENCIA CALCULADA)'
            end
            else begin
              Dados[i].DescrPend := ObtemDescrUltPend(VetTpPend,MutDsk.Cad.Ctr,1,0);
              Dados[i].CodPend1  := VetTpPend[1];
              Dados[i].CodPend2  := VetTpPend[2];
              Dados[i].CodPend3  := VetTpPend[3];
              Dados[i].CodPend4  := VetTpPend[4];
              Dados[i].CodPend5  := VetTpPend[5];
            end;
          Dados[i].ValorEmi := Dados[i].TotPrest +
                               Dados[i].Diferenca+
                               Dados[i].Correcao +
                               Dados[i].Mora     +
                               Dados[i].Multa;
          if (ValInt(SCCIConf.NSerie) <> nsLetra) and
             (not (ValInt(Scciconf.NSerie) in [5..8])) then
            Dados[i].ValorEmi := Dados[i].ValorEmi - Dados[i].Desc;
          Dados[i].OutRec := 0;
          Dados[i].OutAbat:= 0;
          if Dados[i].Diferenca > Zero then
            Dados[i].OutRec := Dados[i].Diferenca
          else
            Dados[i].OutAbat:= (-1*Dados[i].Diferenca);
          if (ValInt(scciconf.nserie) <> nsLetra) and
             (not (ValInt(Scciconf.NSerie) in [5..8])) then
            Dados[i].OutAbat := Dados[i].OutAbat +
                                Dados[i].Desc;

          Dados[i].ValTit := Dados[i].EncMes    -
                             Dados[i].OutAbat   +
                             Dados[i].OutRec    +
                             Dados[i].ValAcordo +
                             Dados[i].ValorSerie +
                             Dados[i].TaxaBanco +
                             Dados[i].ValIOFComplem;
          if Dados[i].ValTit > Zero then
            Dados[i].ValTit := Int(Dados[i].ValTit*100+0.5)/100;
          DifMan  := DifMan  - Dados[i].DifManual;
          DifCalc := DifCalc - Dados[i].DifCalculada;
        end;
      end;
      if ((Abs(DadosPend.PendCalc) > Zero) and
          (Abs(DifMan) <= Zero) and (Abs(DifCalc) <= Zero)) or
          (Abs(DadosPend.PendCalc) <= Zero) then begin
    {    MutDsk.Cad.DtIniPend.Dia := 01;
        MutDsk.Cad.DtIniPend.Mes := 12;
        MutDsk.Cad.DtIniPend.Ano := 199; n o sei pq sempre alterar o cadmut. Deveria ser alterado s  no momento da emiss o}
      end
      else if (Abs(DadosPend.PendCalc) > Zero) and (UltTit > 0) then
        Dados[UltTit].LimitouPend := true;
      
    end;
  finally
    if Scciconf.DistribuiPend then Scciconf.PendDesprezivel := PendDesp;
  end;
end;

procedure TContrato.IncluiPendenciasNoAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                 RegConsRef : TValoresPorMac;
                                                 Dados : TDadosAtrasoEvo;
                                                 IgnoraPendManual : boolean = false);
var
  IgnoraMACEmissao : boolean;
  IndexPrest : integer;
  LinkPend : integer;
  UltPrestPend : integer;
  UltTitulo : TPrestacaoAtrasoevo;
  DtVenc : Tdata;
  TempDistribuiPend : boolean;
  TempPendImplant : boolean;
  TempPendDesprezivel : real;
begin
  TempDistribuiPend   := Scciconf.DistribuiPend;
  TempPendImplant     := Scciconf.PendImplant;
  TempPendDesprezivel := Scciconf.PendDesprezivel;
  if not CalculoAtrasoParametros.CobraPend then begin
    Scciconf.DistribuiPend  := false;
    Scciconf.PendImplant    := false;
    Scciconf.PendDesprezivel:= 999999999.99;
  end;
  try
    Dados.PrstComPend := Dados.RetornaPrstComPend(Dados.count-1);
    IgnoraMACEmissao := false;
    if (Dados.PrstComPend > -1) and
       Scciconf.ParcelaPendNaEmissaoConsolidada and
       CalculoAtrasoParametros.ParcelaPend and
      (not CalculoAtrasoParametros.IgnoraPendenciaManual) and 
      not IgnoraPendManual then // 99545
      ParcelaPend(MutDsk,Mes_Int(CalculoAtrasoParametros.DataRef.MesAno),CalculoAtrasoParametros.DataRef,
                  Dados[Dados.PrstComPend].TotPrest-
                  Dados[Dados.PrstComPend].Desc,0,IgnoraMACEmissao,
                  Dados[0].MacPrst);
    UltPrestPend := Dados.UltPrestPend;
    if UltPrestPend >= 0 then begin
      UltTitulo := Dados[UltPrestPend];
      DtVenc.Dia := UltTitulo.DiaVenc;
      Int_Mes(UltTitulo.MACPrst,DtVenc.MesAno);
    end
    else begin
      UltTitulo := nil;
      fillchar(DtVenc,sizeof(TData),0);
    end;
    if Assigned(UltTitulo) then
      IncluiDadosPendCtr(self,Dados.RegLCobr,Dados.PendCtr.DadosPendCtr,
                         DtVenc,CalculoAtrasoParametros.DataRef,
                         UltTitulo.TotPrest-UltTitulo.Desc,
                         CalculoAtrasoParametros.IgnoraDtTetoPend,
                         CalculoAtrasoParametros.GravaPendEmi,
                         IgnoraPendManual); // 99545
    if Scciconf.DistribuiPend then
      IndexPrest := 0
    else
      IndexPrest := Dados.PrstComPend;
    if IndexPrest <= -1 then IndexPrest := 0;
    fillchar(Dados.PendCtr.DadosPend,sizeof(TpTotPend),0);
    LinkPend := LinkPendCtr(MutDsk.Cad.Ctr,Dados.PendCtr.DadosPendCtr);
    if IgnoraPendManual then // n o est  limpando o registro, ent o preciso garantir que n o vai reaproveitar o valor.
      Dados.PendCtr.DadosPendCtr[linkpend].DadosPend.pendman := 0;
    DistribuiDadosPendCtr(CalculoAtrasoParametros,RegConsRef,
                          Dados.RegLCobr,RegCarteira,Dados,
                          Dados.PendCtr.DadosPendCtr[LinkPend].DadosPend,
                          Dados.PendCtr.DadosPend,IndexPrest,
                          true{ConsideraUltVariacao});
  finally
    Scciconf.DistribuiPend   := TempDistribuiPend;
    Scciconf.PendImplant     := TempPendImplant;
    Scciconf.PendDesprezivel := TempPendDesprezivel;
  end;
end;

