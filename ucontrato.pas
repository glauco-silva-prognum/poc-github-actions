function TContrato.TemRes3516Evo(DataRef : TData; NaOrigem : boolean = false) : boolean;
var
  i : integer;
  Reg : TValoresPorMac;
begin
  result := false;
  Reg := ObtemValoresPorMac(mes_int(DataRef.MesAno));
  if not assigned(Reg) then
    raise exception.create('Cache de evolu  o n o carregado');
  Reg.DtAssin.DtStr[0] := #3;
  if (Reg.Prazo - Reg.NPC > 12) and
     (Reg.DtAssin.DtStr > #107#12#06) and
     (Reg.DtAssin.DtStr < #114#05#05) and
     (NaOrigem or (juliano(dataref)-juliano(Reg.DtAssin) > 7)) and
     ((Reg.Codreaj <= 0) or ((Reg.CodReaj=23) and (Reg.CodTabelaGenerica <= 0))) then begin
    if RegCarteira.Ctr3516PreFixado and
       MutDsk.Cad6.PreFixado and (RegCarteira.CodSBPE <= 0) then begin
      result := (MutDsk.Cad.FisJur <> 'J') or MutDsk.Cad6.MicroPqEmpresa;
      for i := 1 to arrcomp[0].tam do
        result := Result and ((ArrComp[i].Cad.FisJur <> 'J') or ArrComp[i].Cad.MicroPqEmpresa);
    end;
  end;
end;

// desposiciona o rpa e n o gera erros de  ndices
procedure TContrato.ObtemUltVencPagoAntecipado(DataRef : Tdata; Var DtUltVencPago : Tdata);
var
  i,p : integer;
  DtVenc : Tdata;
  TempCmTabErr : integer;
  TempCmTabErrData : tdata;
begin
  TempCmTabErr := CmTabErr;
  TempCmTabErrData := CmTabErrData;
  try
    DtUltVencPago.dia := 0;
    fillchar(DtUltVencPago,sizeof(Tdata),0);
    if TemFinancDinamico(Mutdsk) then
      for p := 0 to SerieF.parcelas.count-1 do
        if SerieF.parcelas[p].EstaPaga(DataRef) then begin
          while RPA.Mac < SerieF.parcelas[p].Mac do
            Evolui;
          int_mes(SerieF.parcelas[p].Mac,DtVenc.Mesano);
          DtVenc.dia := SerieF.ObtemValoresPormac(SerieF.parcelas[p].Mac).diaVenc;
          if juliano(SerieF.parcelas[p].Dtpg) < juliano(DtVenc) then
            if juliano(DtVenc) > juliano(DtUltVencPago) then
              DtUltVencPago := DtVenc;
        end;
    for i := 0 to Series.count-1 do
      for p := 0 to Series[i].Parcelas.count-1 do
        if Series[i].parcelas[p].EstaPaga(DataRef) then begin
          while RPA.Mac < Series[i].parcelas[p].Mac do
            Evolui;
          int_mes(Series[i].parcelas[p].Mac,DtVenc.Mesano);
          DtVenc.dia := Series[i].ObtemValoresPormac(Series[i].parcelas[p].Mac).diaVenc;
          if juliano(Series[i].parcelas[p].Dtpg) < juliano(DtVenc) then
            if juliano(DtVenc) > juliano(DtUltVencPago) then
              DtUltVencPago := DtVenc;
        end;
  finally
    CmTabErr := TempCmTabErr;
    CmTabErrData := TempCmTabErrData;
  end;
end;

