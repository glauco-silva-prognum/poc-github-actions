procedure CalculaTxPstDataRef(    CodSerie           : longint;
                                  DataRef            : Tdata;
                                  DataRefReaj        : Tdata;
                                  DtAssin            : Tdata;
                                  DtEntregaChaves    : Tdata;
                                  DtVenc             : Tdata;
                                  DiaVencOrig        : byte;
                                  MAC                : smallint;
                                  PerReaj            : byte;
                                  DefReaj            : byte;
                                  defreajprechv      : byte;
                                  codreajprechaves   : smallint;
                                  CodTabelaGenerica  : smallint;
                                  IndSaldoAcum       : real;
                                  CorrSaldoMesAntAcum: real;
                                  CorrSaldoMesAcum   : real;
                                  SalDevAnt,
                                  SaldoDev           : real;
                                  PerSalDev          : byte;
                                  CorrProRata        : boolean;
                                  MACCorrSaldo       : smallint;
                                  CorrProRataIniPelaVarDataRef : boolean;
                                  CmproRatamesAnt    : boolean;
                              var TxPst              : real;
                              var TxPstTabErr        : integer;
                              var TxPstTabErrData    : TData);
var
  MacPrstRef : integer;
  DtVencMesRef,
  Dt1,DtVencCorr :  TData;
  Defas      : integer;
  CmTabErrTemp : integer;
  CmTabErrDataTemp : TData;
  IndInvalido      : boolean;
  DtIndInvalido    : Tdata;
begin
  IndInvalido := false;
  DtIndInvalido.Dia := 0;
  fillchar(DtIndInvalido,sizeof(TData),0);
  DtVencMesRef.MesAno := DataRef.MesAno;
  if DiaVencOrig > 0 then 
    DtVencMesRef.Dia := Dia_Venc(Mes_int(DtVencMesRef.MesAno),DiaVencOrig)
  else
    DtVencMesRef.Dia := Dia_Venc(Mes_int(DtVencMesRef.MesAno),DtVenc.Dia);
  MacPrstRef := mes_int(DataRef.MesAno);
  if DataRef.Dia < DtVenc.Dia then
    dec(MacPrstRef);
  if MAC = MACPrstRef then begin
    int_mes(MacPrstRef,Dt1.MesAno);
    if DiaVencOrig > 0 then Dt1.Dia := DiaVencOrig
    else Dt1.Dia := DtVenc.Dia;
    Dt1.Dia := Dia_Venc(Mes_Int(Dt1.MesAno),Dt1.Dia);
    if juliano(Dt1) < juliano(DtAssin) then Dt1 := DtAssin;
    if (DataRefReaj.Dia > 0) and (juliano(Dt1) < juliano(DataRefReaj)) then 
      Dt1 := DataRefReaj;
    // Indice com c lculo do prorata
    defas := defreaj;
    if not ((Juliano(DtEntregaChaves)>0) and
       (Juliano(DtEntregaChaves)>Juliano(DtAssin)) and  // SCAt 21613
       (Juliano(dtvenc)>Juliano(DtEntregaChaves))) then
      if codreajprechaves > 0 then defas := defreajprechv;

    CmTabErrTemp := CmTabErr;
    CmTabErrDataTemp := CmTabErrData;
    try
      CmTabErr := 0;
      fillchar(CmTabErrData,sizeof(Tdata),0);
      if (PerSalDev >= 6) and (PerReaj > 0) {and CorrProRata} then begin
        if MACCorrSaldo = Mes_Int(DataRef.MesAno) then begin
          if DataRef.Dia < DtVenc.Dia then
            MACCorrSaldo := MACCorrSaldo - PerSalDev
        end
        else if (MACCorrSaldo = 0) and
               ((Mes_Int(DataRef.MesAno)-PerSalDev) <=
                Mes_Int(DtAssin.MesAno)) then
               MACCorrSaldo := Mes_Int(DtAssin.MesAno);
        DtVencCorr := DT1 {DtVenc};
        if Mes_Int(DtAssin.MesAno) >= MACCorrSaldo then
          DtVencCorr := DtAssin
        else if (MACCorrSaldo > 0) and (MACCorrSaldo <= Mes_Int(DataRef.Mesano)) then begin
          Int_Mes(MACCorrSaldo,DtVencCorr.MesAno);
          if DiaVencOrig > 0 then 
            DtVencCorr.Dia := Dia_Venc(MACCorrSaldo,DiaVencOrig)
          else
            DtVencCorr.Dia := Dia_Venc(MACCorrSaldo,DtVenc.Dia);
        end;
        if (DataRefReaj.Dia > 0) and (juliano(DtVencCorr) < juliano(DataRefReaj)) then
          DtVencCorr := DataRefReaj;
        if juliano(DtVencCorr) < juliano(DT1 {DtVenc}) then begin
        { Colocado em coment rio pela sol. 62707
          if (MACCorrSaldo < Mes_Int(DataRef.MesAno)) and
             DataEMaiorOuIgual(DataRef,DtVencMesRef) and (not CmproRatamesAnt) then begin
            if Abs(SaldoDev) > Zero then
              IndSaldoAcum := IndSaldoAcum * ((CorrSaldoMesAcum/SaldoDev)+1);
          end
          else if  (Abs(CorrSaldoMesAntAcum) > Zero) and
                  ((MACCorrSaldo < Mes_Int(DataRef.MesAno)) or
                  ((MACCorrSaldo = Mes_Int(DataRef.MesAno)) and 
                   DataEMenor(DataRef,DtVencMesRef))) then begin
             if Abs(SalDevAnt) > Zero then 
               IndSaldoAcum := IndSaldoAcum * ((CorrSaldoMesAntAcum/SalDevAnt)+1);
          end
          else
        }
            IndSaldoAcum := IndSaldoAcum * (detinddataadata(CodTabelaGenerica,
                                                            Defas, DtVencCorr,
                                                            DT1 {DtVenc},1.0,
                                                            CorrProRata,
                                                            IndInvalido,
                                                            DtIndInvalido,false,1,
                                                            CorrProRataIniPelaVarDataRef,
                                                            CmproRatamesAnt,false{CalcMes}));
        end;
      end;
      if CmProRataMesAnt then
        TxPst := IndSaldoAcum*detinddataadata(CodTabelaGenerica,Defas, 
                                              Dt1,Dataref,1.0,
                                              CorrProRata,
                                              IndInvalido,
                                              DtIndInvalido,false,1,
                                              CorrProRataIniPelaVarDataRef,
                                              CmproRatamesAnt,true{CalcMes})
      else if CorrProRata and (not DatasSaoIguais(Dt1,DataRef))  then
        TxPst := IndSaldoAcum*detIndProRata(CodTabelaGenerica,Defas,Dt1,DataRef,1.0)
      else
        TxPst := IndSaldoAcum;
      TxPstTabErr     := CmTabErr;
      TxPstTabErrData := CmTabErrData;
    finally
      CmTabErr := CmTabErrTemp;
      CmTabErrData := CmTabErrDataTemp;
    end;
  end;
end;

procedure CalculaTxPstDataRefPercentual(
                      DataRef : TData;
                      CodTabelaGenerica: LongInt;
                      defreaj: LongInt;
                      MauaSD: LongInt;
                      DiaMauaSD: Integer;
                      PERC_APLICACAO_IND_CORR: Double;
                      var TxPst:Double;
                      var TxPstTabErr:LongInt;
                      var TxPstTabErrData:TData);
var
  dataUltimoReajuste:tdata;
  indinvalido:boolean;
  CmTabErrTemp : integer;
  CmTabErrDataTemp : TData;
  DtIndInvalido    : Tdata;

begin
  CmTabErrTemp := CmTabErr;
  CmTabErrDataTemp := CmTabErrData;
  try
    dtindinvalido.dia := 0;
    indinvalido:= false;
    dataUltimoReajuste.dia := DiaMauaSD;
    int_mes(MauaSD,dataUltimoReajuste.MesAno);
    TxPst := arredondaDecimais(
             DetIndicePercentual(CodTabelaGenerica,
               defreaj,
               DataUltimoReajuste,
               DataRef,
               PERC_APLICACAO_IND_CORR,
               IndInvalido,
               DtIndInvalido),8);
    TxPstTabErr     := CmTabErr;
    TxPstTabErrData := CmTabErrData;
  except
    CmTabErr := CmTabErrTemp;
    CmTabErrData := CmTabErrDataTemp;
  end;
end;


procedure GuardaTxPstDataRef(SerieObj   : TSerie;
                             DataRef,
                             DtVenc     : Tdata;
                             SerieReneg : TSerieReneg); overload;
var
  MACCorrSaldo : smallint;
  PerSalDevLc  : byte;

begin
  if SerieObj.RPAS.Temp11.MAUASD > 0 then
    MACCorrSaldo := SerieObj.RPAS.Temp11.MAUASD
  else
    MACCorrSaldo := SerieObj.RPAS.Temp.MAUA;
  if SerieObj.Fin.CobraResiduo then 
    PerSalDevLc := 1
  else
    PerSalDevLc := SerieObj.RPAS.FinRPA.PerSalDev;
  if SerieObj.Fin.Indice_Obtido_Dia_Util or (SerieObj.fin.PERC_APLICACAO_IND_CORR <> 0)
     and (SerieObj.fin.PERC_APLICACAO_IND_CORR <> 100) then // scat 65260
    CalculaTxPstDataRefPercentual(DataRef,
                      SerieObj.Rpas.Temp7.CodTabelaGenerica,
                      SerieReneg.Dados.defreaj,
                      SerieObj.Rpas.Temp11.MauaSD,
                      SerieObj.Rpas.Temp12.DiaMauaSD,
                      SerieReneg.Dados.PERC_APLICACAO_IND_CORR, 
                      SerieReneg.TxPst,
                      SerieReneg.TxPstTabErr,
                      SerieReneg.TxPstTabErrData)
  else 
    CalculaTxPstDataRef(SerieReneg.Dados.CodSerie,
                      DataRef,
                      SerieObj.Fin.DataRefReaj,
                      SerieReneg.Dados.DataRef,  //DtAssin
                      SerieObj.Rpas.Temp9.DtEntregaChaves,
                      DtVenc,
                      SerieObj.DiaVencOrig,
                      SerieObj.Rpas.MAC,
                      SerieReneg.Dados.PerReaj,
                      SerieReneg.Dados.defreaj,
                      SerieReneg.Dados.defreajprechv,
                      SerieReneg.Dados.codreajprechaves,
                      SerieObj.Rpas.Temp7.CodTabelaGenerica,
                      SerieObj.Rpas.Temp3.IndSaldoAcum,
                      SerieObj.RpaS.Temp12.CorrSaldoMesAntAcum,
                      SerieObj.RpaS.Temp11.CorrSaldoMesAcum,
                      SerieObj.Rpas.Temp.SaldevAnt,
                      SerieObj.RpaS.ValRPA.SaldoDev,
                      {SerieObj.RPAS.FinRPA.PerSalDev}PerSalDevLc,
                      SerieReneg.Dados.CorrProRata,
                      MACCorrSaldo,
                      SerieObj.Fin.CorrProRataIniPelaVarDataRef,
                      SerieObj.Fin.CmproRatamesAnt,
                      SerieReneg.TxPst,
                      SerieReneg.TxPstTabErr,
                      SerieReneg.TxPstTabErrData);
end;

procedure GuardaTxPstDataRef(ValoresPorMAC  : TValoresPorMAc;
                             DataRef,
                             DtVenc         : Tdata;
                             SerieReneg     : TSerieReneg); overload;
var
  MACCorrSaldo : smallint;
  PerSalDevLc  : byte;
begin
  if ValoresPorMAC.MAUASD > 0 then
    MACCorrSaldo := ValoresPorMAC.MAUASD
  else
    MACCorrSaldo := ValoresPorMAC.MAUA;

  if SerieReneg.Dados.CobraResiduo then  //qdo Serie.cobraResiduo t  marcada, mesmo Per.Reaj.Saldo sendo = 1,
    PerSalDevLc := 1                     //mas se o reajuste da presta  o for diferente de 1, PerSalDev vem <> 1
  else
    PerSalDevLc := ValoresPorMAC.PerSalDev;

  if SerieReneg.dados.Indice_Obtido_Dia_Util or (SerieReneg.dados.PERC_APLICACAO_IND_CORR <> 0)
     and (SerieReneg.dados.PERC_APLICACAO_IND_CORR <> 100) then // scat 65260
    CalculaTxPstDataRefPercentual(DataRef,
                      ValoresPorMAC.CodTabelaGenerica,
                      SerieReneg.Dados.defreaj,
                      ValoresPorMac.MauaSD,
                      ValoresPorMac.DiaMauaSD,
                      SerieReneg.Dados.PERC_APLICACAO_IND_CORR, 
                      SerieReneg.TxPst,
                      SerieReneg.TxPstTabErr,
                      SerieReneg.TxPstTabErrData)
  else
    CalculaTxPstDataRef(SerieReneg.Dados.CodSerie,
                      DataRef,
                      SerieReneg.Dados.DataRefReaj,
                      SerieReneg.Dados.DataRef,  //DtAssin
                      ValoresPorMAC.DtEntregaChaves,
                      DtVenc,
                      ValoresPorMAC.DiaVencOrig,
                      ValoresPorMAC.MAC,
                      SerieReneg.Dados.PerReaj,
                      SerieReneg.Dados.defreaj,
                      SerieReneg.Dados.defreajprechv,
                      SerieReneg.Dados.codreajprechaves,
                      ValoresPorMAC.CodTabelaGenerica,
                      ValoresPorMAC.IndSaldoAcum,
                      ValoresPorMAC.CorrSaldoMesAntAcum,
                      ValoresPorMAC.CorrSaldoMesAcum,
                      ValoresPorMAC.SalDevAnt,
                      ValoresPorMAC.SaldoDev,
                      {ValoresPorMAC.PerSalDev}PerSalDevLc,
                      SerieReneg.Dados.CorrProRata,
                      MACCorrSaldo,
                      SerieReneg.Dados.CorrProRataIniPelaVarDataRef,
                      SerieReneg.Dados.CmproRatamesAnt,
                      SerieReneg.TxPst,
                      SerieReneg.TxPstTabErr,
                      SerieReneg.TxPstTabErrData);
end;


procedure LePagamentosAntecipadosReneg(Ctr : TpCtr;
                                       CodSerie : longint;
                                       ParcOrig : TParcelaSerie;
                                       TxPst : real;
                                       Parcela : TParcelaReneg;
                                       Datacalculo : Tdata;
                                       IndJuros : real;
                                       SerieJurProRata : boolean;
                                       IncluiFracaoDoMes : boolean);

var
  Correcao, Desc,
  Valor, AmaisJ     : real;
  DtPg              : TData;
  TipoPg            : byte;
  Pagamento         : TPagamentoAntecipadoParcelaReneg;
begin
  if AbriuValPgtoParcial and (ParcOrig.ValorPagoAntecipado > zero) then begin
    if not assigned(QuitQryParcelaAntecipada) then begin
      QuitQryParcelaAntecipada := TSqlQuery.create(nil);
      QuitQryParcelaAntecipada.SqlConnection := GetSqlConnection(PegaDirPag);
      QuitQryParcelaAntecipada.Sql.beginUpdate;
      try
        QuitQryParcelaAntecipada.Sql.add('SELECT VALOR, DESC_, AMAISJ, CORRECAO,DTPG, TIPOPG from PAGAMENTOS_PARCIAIS');
        QuitQryParcelaAntecipada.Sql.add('WHERE TIPOCTR=:tipoctr and CO_CONTRATO=:co_contrato and');
        QuitQryParcelaAntecipada.Sql.add('      TIPOPARC=:tipoparc and CODPARC=:codparc and NUMPARC=:numparc');
      finally
        QuitQryParcelaAntecipada.sql.endupdate;
      end;
      QuitQryParcelaAntecipada.parambyname('tipoctr').Datatype := ftInteger;
      QuitQryParcelaAntecipada.parambyname('co_contrato').Datatype := ftString;
      QuitQryParcelaAntecipada.parambyname('tipoparc').Datatype := ftInteger;
      QuitQryParcelaAntecipada.parambyname('codparc').Datatype := ftInteger;
      QuitQryParcelaAntecipada.parambyname('numparc').Datatype := ftInteger;
      QuitQryParcelaAntecipada.prepared := true;
    end;
    QuitQryParcelaAntecipada.parambyname('tipoctr' ).asinteger  := 1;
    QuitQryParcelaAntecipada.parambyname('co_contrato').asstring:= ctrtosqlctr(copy(ctr,1,tamctr));
    QuitQryParcelaAntecipada.parambyname('tipoparc').asinteger  := TpParc_Series;
    QuitQryParcelaAntecipada.parambyname('codparc' ).asinteger  := CodSerie;
    QuitQryParcelaAntecipada.parambyname('numparc' ).asinteger  := ParcOrig.Seq;
    QuitQryParcelaAntecipada.Open;
    try
      while not QuitQryParcelaAntecipada.eof do begin
        Dtpg   := dateTimeToData(QuitQryParcelaAntecipada.Fields[4].asdatetime);
        TipoPg := QuitQryParcelaAntecipada.Fields[5].asinteger;
        if (juliano(DtPg) > 0) and
           (not (TipoPg in NotPg {[8,9,108,110,114]})) and
           ((DataCalculo.dia = 0) or (Juliano(DtPg) <= Juliano(DataCalculo))) then begin
          valor    := QuitQryParcelaAntecipada.Fields[0].asfloat;
          desc     := QuitQryParcelaAntecipada.Fields[1].asfloat;
          AmaisJ   := QuitQryParcelaAntecipada.Fields[2].asfloat;
          Correcao := QuitQryParcelaAntecipada.Fields[3].asfloat;

          Pagamento := Parcela.Pagamentos.add as TPagamentoAntecipadoParcelaReneg;
          Pagamento.Data    := DtPg;
          Pagamento.valor   := Amaisj * TxPst;
          Pagamento.vaValor := CalculaEncargoAtualizado(Pagamento.Valor,Parcela.Venc,
                                                        DataCalculo,IndJuros,
                                                        SerieJurProRata or
                                                        ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                                        IncluiFracaoDoMes);
          Pagamento.Amaisj    := Amaisj;
          Pagamento.Corr      := Correcao;
          Pagamento.Desc      := Desc;
          Pagamento.ValorPago := Valor;
        end;
        QuitQryParcelaAntecipada.next;
      end;
    finally
      QuitQryParcelaAntecipada.close;
    end;
  end;
end;

function CalcSaldoDieValoresPorMac ( ValoresPorMac : TValoresPorMac;DataRef:TData ):real;
var
  DtUltimaIncorporacao : Tdata;
  AuxValAcumJurosIncorp,
  AuxValAcumJurosIncorpAntesVenc : real;
begin
  AuxValAcumJurosIncorp := 0;
  AuxValAcumJurosIncorpAntesVenc := 0;
  with ValoresPorMac do begin
    if juliano(DtUltIncorp) > 0 then DtUltimaIncorporacao := DtUltIncorp else 
