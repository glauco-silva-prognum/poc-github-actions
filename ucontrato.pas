procedure TDadosAgendaPagamento.LeAgendamentos;
var
  ArrTipo,
  ArrParc,
  ArrMac : TSparseObjectArray;
  Obj : TAgendaPagamento;
  Qry : TSqlQuery;
begin
  FLeu := false;
  Clear;
  if assigned(Contrato) then begin

    if FOrdenarPorDtAgendamento then
      Qry := FQryLeAgendamentosPorDtAgendamento
    else
      Qry := FQryLeAgendamentos;

    if not Qry.prepared then
      Qry.prepared := true;
      
    Qry.ParamByName('CTR').asstring := CtrToSqlCtr(Contrato.Mutdsk.Cad.Ctr);
    Qry.open;
    try
      while not Qry.eof do begin
        if not FArrCodSerie.Hasitem(Qry.FieldByname('CO_SERIE').asinteger) then begin
          ArrTipo := TSparseObjectArray.create;
          FArrCodSerie[Qry.FieldByname('CO_SERIE').asinteger] := ArrTipo;
        end
        else
          ArrTipo := FArrCodSerie[Qry.FieldByname('CO_SERIE').asinteger] as TSparseObjectArray;
        if not ArrTipo.HasItem(Qry.FieldByname('NU_TP_PARCELA').asinteger) then begin
          ArrParc := TSparseObjectArray.create;
          ArrTipo[Qry.FieldByname('NU_TP_PARCELA').asinteger] := ArrParc;
        end
        else
          ArrParc := ArrTipo[Qry.FieldByname('NU_TP_PARCELA').asinteger]  as TSparseObjectArray;
        if not ArrParc.HasItem(Qry.FieldByname('NU_PARCELA').asinteger) then begin
          ArrMac := TSparseObjectArray.create;
          ArrParc[Qry.FieldByname('NU_PARCELA').asinteger] := ArrMac;
        end
        else
          ArrMac := ArrParc[Qry.FieldByname('NU_PARCELA').asinteger]  as TSparseObjectArray;
        if not ArrMac.Hasitem(Qry.FieldByname('NU_MAC').asinteger) then begin
          Obj := TAgendaPagamento.create;
          ArrMac[Qry.FieldByname('NU_MAC').asinteger] := Obj;
        end
        else
          Obj := ArrMac[Qry.FieldByname('NU_MAC').asinteger] as TAgendaPagamento;
        Obj.CoSerie := Qry.FieldByname('CO_SERIE').asinteger;
        Obj.TpParcela := Qry.FieldByname('NU_TP_PARCELA').asinteger;
        Obj.Parcela := Qry.FieldByname('NU_PARCELA').asinteger;
        Obj.DtAgendamento := DateTimeToData(Qry.FieldByName('DT_AGENDAMENTO').AsDatetime);
        Obj.PercDescMora := Qry.FieldByname('PERCDESCMORA').asfloat;
        Obj.PercDescJRemuneratorios := Qry.FieldByname('PERCDESCJREMUNERATORIOS').asfloat;
        Obj.PercDescCorr := Qry.FieldByname('PERCDESCCORR').asfloat;
        Obj.PercDescMulta := Qry.FieldByname('PERCDESCMULTA').asfloat;
        Obj.Emitido := Qry.FieldByName('IN_EMITIDO').Asstring = 'v';
        Obj.DtIncAgend := DateTimeToData(Qry.FieldByName('DT_INC_AGENDAMENTO').asDateTime);
        Obj.UserAgend  := Qry.Fieldbyname('CO_USUARIO_INC').asstring;
        Obj.Mac := Qry.FieldByName('NU_MAC').Asinteger;
        Obj.TipoAgendamento := Qry.FieldByName('CO_TIPO_AGENDAMENTO').Asinteger;
        Obj.VA_PGTO_PARCIAL := Qry.FieldByName('VA_PGTO_PARCIAL').asfloat;
        FItems.add(obj);
        Qry.Next;
      end;
    finally
      Qry.close;
    end;
    FLeu := true;
  end;
end;

function TDadosAgendaPagamento.count : integer;
begin
  if not FLeu then
    LeAgendamentos;
  result := FItems.count;
end;

function TDadosAgendaPagamento.GetItems(index : integer) : TAgendaPagamento;
begin
  if not FLeu then
    LeAgendamentos;
  result := FItems[index] as TAgendaPagamento;
end;

procedure TDadosAgendaPagamento.Exclui(index : integer);
var
  ArrTipo,
  ArrParc,
  ArrMac : TSparseObjectArray;
  Obj : TAgendaPagamento;
begin
  Obj := FItems[index] as TAgendaPagamento;

  if not FQryExcluiAgendamento.prepared then
    FQryExcluiAgendamento.prepared := true;

  // exclui na base
  FQryExcluiAgendamento.ParamByName('CTR').asstring := GetContrato.Mutdsk.cad.ctr;
  FQryExcluiAgendamento.ParamByName('CODSERIE').asinteger := Obj.CoSerie;
  FQryExcluiAgendamento.ParamByName('TIPOPARC').asinteger := Obj.TpParcela;
  FQryExcluiAgendamento.ParamByName('NUMPARC').asinteger := Obj.Parcela;
  FQryExcluiAgendamento.ParamByName('NUMAC').asinteger := Obj.Mac;
  FQryExcluiAgendamento.ExecSql;

  // exclui do  ndice em mem ria
  if FArrCodSerie.Hasitem(Obj.CoSerie) then begin
    ArrTipo := FArrCodSerie[Obj.CoSerie] as TSparseObjectArray;
    if ArrTipo.HasItem(Obj.TpParcela) then begin
      ArrParc := ArrTipo[Obj.TpParcela] as TSparseObjectArray;
      if ArrParc.Hasitem(Obj.Parcela) then begin
        ArrMac := ArrParc[Obj.Parcela] as TSparseObjectArray;
        if ArrMac.Hasitem(Obj.Mac) then
          ArrMac.Delete(Obj.Mac);
      end;
    end;
  end;
  
  Obj.free;
  Fitems.delete(index);
end;

function TDadosAgendaPagamento.Le(    CodSerie   : longint;
                                      TipoParc   : smallint;
                                      NumParc    : smallint;
                                  var DataAgenda : TData;
                                  var PercDescMora,
                                      PercDescJRemuneratorios,
                                      PercDescCorr,
                                      PercDescMulta : real;
                                  var Emitiu     : boolean;
                                  var DtIncAgend : Tdata;
                                  var UserAgend  : str20;
                                      MacParc    : smallint) : boolean;
var
  ArrTipo,
  ArrParc,
  ArrMac : TSparseObjectArray;
  Obj : TAgendaPagamento;
begin
  fillchar(DataAgenda,sizeof(Tdata),0);
  Emitiu := false;
  fillchar(DtIncAgend,sizeof(Tdata),0);
  UserAgend := '';
  result := false;
  if not FLeu then
    LeAgendamentos;
  if FArrCodSerie.Hasitem(CodSerie) then begin
    ArrTipo := FArrCodSerie[CodSerie] as TSparseObjectArray;
    if ArrTipo.HasItem(TipoParc) then begin
      ArrParc := ArrTipo[TipoParc] as TSparseObjectArray;
      if ArrParc.Hasitem(NumParc) then begin
        ArrMac := ArrParc[NumParc] as TSparseObjectArray;
        if ArrMac.HasItem(MacParc) then begin
          Obj := ArrMac[MacParc] as TAgendaPagamento;
          DataAgenda := Obj.DtAgendamento;
          PercDescMora := Obj.PercDescMora;
          PercDescJRemuneratorios := Obj.PercDescJRemuneratorios;
          PercDescCorr := Obj.PercDescCorr;
          PercDescMulta := Obj.PercDescMulta;
          Emitiu := Obj.Emitido;
          DtIncAgend := Obj.DtIncAgend;
          UserAgend := Obj.UserAgend;
          result := true;
        end;
      end;
    end;
  end;
end;

function TDadosAgendaPagamento.Le(    CodSerie   : longint;
                                      TipoParc   : smallint;
                                      NumParc    : smallint;
                                  var DataAgenda : TData;
                                  var Emitiu     : boolean;
                                  var DtIncAgend : Tdata;
                                  var UserAgend  : str20;
                                      MacParc    : smallint) : boolean;
var
  PercDescMora,
  PercDescJRemuneratorios,
  PercDescCorr,
  PercDescMulta : real;
begin
  PercDescMora := 0;
  PercDescJRemuneratorios  := 0;
