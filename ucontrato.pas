    else AmJAntAux := 0;
    if (not TemFinancDinamico(MutDsk)) or (Status=30) then // Na renegocia  o zerar txjuros e prazo scat 19706
    begin
      Npc := 0;
      Temp11.NPCCliente := 0;
      TxJuros := 0;
      CodReaj := 0;
      Temp7.CodTabelaGenerica := 0;
