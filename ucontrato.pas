function TSerieReneg.DescontoVincendas(DataRef : Tdata) : real;
var
  i : integer;
begin
  result := 0;
  if TemDescontoAntec then
    for i := 0 to FParcelas.count - 1 do
      if FParcelas[i].Seleciona then begin
        if Dados.IgnoraDiaVencNaQuitacaoEAntec and (DtVencRef.Dia > 0) then
          result := result + FParcelas[i].DescontoPorTaxa(Taxa/100,false{JurosSimples},false{CalcAntecComoDescComercial},
                                                          DtVencRef,Dados.DtCarenciaDeJuros,
                                                          Dados.JurProRata,
                                                          Dados.IncluiFracaoDoMes,
                                                          false{SemResiduo},
                                                         (Dados.TpJuros = 6),
                                                         (Dados.TpJuros = 7))
        else
          result := result + FParcelas[i].DescontoPorTaxa(Taxa/100,false{JurosSimples},false{CalcAntecComoDescComercial},
                                                          DataRef,Dados.DtCarenciaDeJuros,
                                                          Dados.JurProRata,
                                                          Dados.IncluiFracaoDoMes,
                                                          false{SemResiduo},
                                                         (Dados.TpJuros = 6),
                                                         (Dados.TpJuros = 7));
    end;
end;

