function CalculaCETRemanescente(var MutDsk : TpMutDsk;var Hist : TpHistEdit;
                                DataRef : TData; CalcComAMaisJ : boolean = false; MemCalcNode : TpXmlNode = nil) : real;  overload;

var
  RegValores : TpRelCET;
  Contrato : TContrato; 
begin
  Contrato := TContrato.create;
  Contrato.Lemem(MutDsk,Hist);
  RegValores.VlLiberado := 0;
  fillchar(RegValores,sizeof(RegValores),0);
  result := CalculaCETRemanescente(Contrato, Dataref, RegValores, CalcComAMaisJ, MemCalcNode);
  Contrato.free;
end;


