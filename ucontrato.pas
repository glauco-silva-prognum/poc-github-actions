  SeqPagParcial := 0;
  i             := 0;
  while (i < Count) and (SeqPagParcial = 0) do begin
    if (PagamentoParcial[i].Mac = Mac) and
       (PagamentoParcial[i].TipoPgParcial = TipoPg) then
