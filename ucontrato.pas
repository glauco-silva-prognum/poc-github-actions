function TDadosAtrasoEvo.TestaEmissaoAnterior(Ctr : TpCtr; MacPrst : smallint; CodSerie : longint) : boolean;
begin
  if abriuTitSql then
    result := TestaEmissaoAnteriorSql(Ctr,MacPrst,CodSerie)
  else if AbriuTitXdb then
    result := TestaEmissaoAnteriorXdb(Ctr,MacPrst,CodSerie)
  else
