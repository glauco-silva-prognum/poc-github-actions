function TSerie.CarenciaDevidasParaAvisoOk(Reg : TValoresPorMac; DataAtraso : tdata) : boolean;
var
  Carencia : Integer;
  DtCarencia : TData;
begin
  result := true; // a princ pio est  ok.
  
  // verificar se tem car ncia
  if (Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario then
    // como na ucontrato, se for seguro, antes do inicio da presta  o, sempre cobra
    if not ((Reg.NPC = 0) and
            (Reg.MAC > Mes_Int(Fin.DataRef.MesAno)) and
            (Reg.TotPrest-Reg.Desc > Zero)) then begin
      Carencia := TemCarenciaAtrasoFinBancChaves;
      if Carencia > 0 then begin
        if CalcCarenciaFinBancChavesPelaDtInicio(Fin,Contrato.Empreendimento) then
          DtCarencia := Fin.DtInicio
        else
          DtCarencia := Reg.DtHabit;
        if Juliano(DtCarencia) > 0 then begin
          J_Data(Juliano(DtCarencia)+Carencia,DtCarencia);
          // De forma compat vel com a sol. 27520, no  ltimo dia da car ncia, j  cobra
          // na emiss o de avisos
          Result := Juliano(DataAtraso) >= Juliano(DtCarencia);
        end
        else
          result := false;
      end;
    end;
end;

function TSerie.ParcSerieOk(var Mutdsk : TpMutdsk;
                                Reg : TValoresPorMac;
                                DtIsencao : TData;
                                CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                DesconsideraSuspensao : boolean) : boolean;
var
  DtVenc,
  DataAtraso : TData;
  UF : str3;
  CodMun : smallint;
begin
  if CalculoAtrasoparametros.UsaPosicaoAtraso then
    result := (Reg.CodErro = 0) and assigned(Contrato.DadosPosicaoAtraso.ObtemPrest(Fin.CodSerie,Reg.Mac))
  else if (CalculoAtrasoParametros.MacParcComSegNaoPermitida > 0) and
     (Reg.Mac >= CalculoAtrasoParametros.MacParcComSegNaoPermitida) and
     ((Reg.Seguro-Reg.DescSeg) > zero) then
    result := false
  else if (CalculoAtrasoParametros.TipoExec <> TipoExec_Incorporacao) and // N o se incorpora s ries - sol. 39471
          ((CalculoAtrasoParametros.TipoExec <> TipoExec_Acordo) or CalculoAtrasoParametros.AcordoAvancado) and //Sol. 25776
           Reg.CtrAtivo and
         ((Reg.NPC > 0) or  { s. 21058 }
          (Reg.MAC > Mes_Int(Fin.DataRef.MesAno))) and
          ((Reg.TotPrest-Reg.Desc > Zero) or
           ((Reg.TotPrest > zero) and
            ((abs(Reg.ValorDescConcedido-Reg.Desc)<zero) or (abs(Reg.PercDescConcedido-100)<zero)))) and
          assigned(Reg.ParcelaDoMes) then begin
    Int_Mes(Reg.MAC,DtVenc.MesAno);
    if (Reg.DiaVenc1aPrest > 0) and (Reg.NPC = 1) then
      DtVenc.Dia := Reg.DiaVenc1aPrest
    else 
      DtVenc.Dia := Reg.DiaVenc;
    UF := '';
    CodMun := 0;
    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    case CalculoAtrasoParametros.TipoExec of
      TipoExec_Quitacao     : begin  { sol. 9542 }
                         Result := ((Contrato.DiasDeAtrasoEntreDatas(DtVenc,CalculoAtrasoParametros.DataRef) > 0) or
                                    (Juliano(DtVenc) = Juliano(CalculoAtrasoParametros.DataRef)) or
                                   ((Juliano(CalculoAtrasoParametros.DataRef) >= Juliano(DtVenc)) and
                                    (Feriado(DtVenc,UF,CodMun))) ) and
                                    (not EstaPagaRealRpaS(Reg)) and
                                    Reg.CtrAtivo and (Reg.CodErro = 0) and
                                    (Reg.ParcelaDoMes.TipoPg <> 253);
                       end;

      TipoExec_Atraso : begin
                   if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                     DataAtraso := CalculoAtrasoParametros.DataAtr
                   else
                     DataAtraso := CalculoAtrasoParametros.DataRef;
                   Result := not Fin.ParcNaoConsidNoAtraso and
                            EstaEmAtrasoRpaS(Reg,DataAtraso) and
                            (juliano(DataAtraso) > Juliano(DtIsencao)) and
                            (Reg.CodErro <> 2);
                   // Sol. 28821 - Selecionar apenas parcelas realmente vencidas
                   // Sol. 58895 - fazer para o crit rio de atraso tb
                   if Result and CalculoAtrasoParametros.DevidasParaAviso then
                     result := CarenciaDevidasParaAvisoOk(Reg,DataAtraso);
                 end;
      TipoExec_Devidas: begin
                   if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                     DataAtraso := CalculoAtrasoParametros.DataAtr
                   else
                     DataAtraso := CalculoAtrasoParametros.DataRef;
                   Result := (EstaEmAtrasoRpaS(Reg,DataAtraso)) or
                             ((juliano(Dtvenc) <= Juliano(DataAtraso)) and
                              (not EstaPagaRealRpaS(Reg))) and
                              (Reg.CodErro <> 2);
                   // Sol. 28821 - Selecionar apenas parcelas realmente vencidas
                   if Result and CalculoAtrasoParametros.DevidasParaAviso then
                     result := CarenciaDevidasParaAvisoOk(Reg,DataAtraso);
                 end;
      TipoExec_QuitAnual: begin
                   if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                     DataAtraso := CalculoAtrasoParametros.DataAtr
                   else
                     DataAtraso := CalculoAtrasoParametros.DataRef;
                   Result := (EstaEmAtrasoRpaS(Reg,DataAtraso)) or
                             ((juliano(Dtvenc) <= Juliano(DataAtraso)) and
                              (not EstaPagaRealRpaS(Reg))) and
                              (Reg.CodErro <> 2);
                 end;

      TipoExec_Renegociacao: begin
                        if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                          DataAtraso := CalculoAtrasoParametros.DataAtr
                        else
                          DataAtraso := CalculoAtrasoParametros.DataRef;
                        Result := (EstaEmAtrasoRpaS(Reg,DataAtraso)) or
                                  ((juliano(Dtvenc) <= Juliano(DataAtraso)) and
                                   (not EstaPagaRealRpaS(Reg))) and
                                   (Reg.CodErro <> 2) and
                                   (Reg.ParcelaDoMes.TipoPg <> 253);
                      end;

      else begin 
                  Result :=  (  (ScciConf.AcordoCobraPrestMesNaoVencida and
                                (CalculoAtrasoParametros.TipoExec = TipoExec_Acordo) and
                                (Mes_int(Dtisencao.Mesano) = Mes_int(CalculoAtrasoParametros.DataRef.mesano))) or
                               (EstaEmAtrasoRpaS(Reg,CalculoAtrasoParametros.DataRef) and
                              ((CalculoAtrasoParametros.TipoExec <> Tipoexec_Acordo) or ( Juliano(DtIsencao) < Juliano(CalculoAtrasoParametros.DataRef)))) or
                              ((Juliano(DtIsencao) <= Juliano(CalculoAtrasoParametros.DataRef) ) or
                               (CalculoAtrasoParametros.TipoExec in [TipoExec_Aberta,TipoExec_Caixa,TipoExec_2aVia,TipoExec_IsenMoraAuto])) or
                               (CalculoAtrasoParametros.TipoExec in [TipoExec_EmiteAc,TipoExec_Vincendas]))  and
                                Reg.CtrAtivo and ((Reg.CodErro in [0,1]) or CalculoAtrasoParametros.EvoPrestMesmoSemIndice) and
                               (not SitEspSuspPrst(MutDsk,CalculoAtrasoParametros.DataRef,DtVenc) or DesconsideraSuspensao or
                               (not (CalculoAtrasoParametros.TipoExec in [TipoExec_2aVia,TipoExec_Caixa,TipoExec_Vincendas,TipoExec_IsenMoraAuto])) or
                                CalculoAtrasoParametros.EmiteSusp);

                 if (CalculoAtrasoParametros.TipoExec in [TipoExec_Aberta,TipoExec_Acordo,TipoExec_Caixa,TipoExec_2aVia,TipoExec_EmiteAc,
                                  Tipoexec_Vincendas,TipoExec_IsenMoraAuto]) then
                   if EstaPagaRealRpaS(Reg) then ParcSerieOk := false;
      end;
    end;  { case }
    { sol. 22063 }
    if CalculoAtrasoParametros.DesconsideraAtrasoNaCessao and PrestacaoCedida(Reg) then ParcSerieOk := false;
    if result and (abs(Reg.SegFin) > 0) and not CalculoAtrasoParametros.EvoPrestMesmoSemIndice then
      if Reg.SegRecalcSaldo then // recalculo do seguro pelo saldo
        result := Reg.CodErro <> 1  // pode se n o deu erro de falta de  ndice de saldo
      else
        result := Reg.CodErro <> 2; // pode se n o deu erro de falta de  ndice de presta  o
  end
  else Result := false;
end;

procedure TSerie.IdentificaParcela(    Reg : TValoresPorMac;
                                   Var ParcSerieAntec : boolean;
                                   Var TipoParc,
                                       NumParcSerie : integer;
                                   Var TemPgParcial : boolean);
begin
  if assigned(Reg.ParcelaDoMes) and
    (Reg.ParcelaDoMes.TipoPg in PgtoComRedSdDev) and
    (Reg.ParcelaDoMes.DtPg.Dia > 0) then
    ParcSerieAntec:= true;

  if assigned(Reg.ParcelaDoMes) and Reg.TemParcNoMes then begin
    if ParcSerieAntec then
      TipoParc     := 7
    else
      TipoParc     := 6;
    NumParcSerie := TParcelaSerie(Reg.ParcelaDoMes).Seq;
  end
  else begin
    TipoParc     := 7;
    NumParcSerie := reg.mac;
  end;
  
  TemPgParcial := assigned(reg.ParcelaDomes) and
                  Reg.ParcelaDomes.TemPgParcial;
end;

