    MaiorPrazo := 0;

    TemSerieRenegociada := false; MACReneg := 0;

    for i := 0 to Series.Count -1 do begin
      TemSerieRenegociada := TemSerieRenegociada or (Series[i].RPAS.Finrpa.Status=30);
      if (Series[i].FMACStatusReneg>0) then MACReneg := Series[i].FMACStatusReneg;
