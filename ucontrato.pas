              end;
              FinRPA.TxSD := detinddataadata(Temp7.CodTabelaGenerica,defas, Dt1,DtVenc,1.0,
                                             Fin.CorrProRata,IndInvalido,DtIndInvalido,false,finrpa.persaldev,
                                             fin.CorrProRataIniPelaVarDataRef,Temp12.CmProRataMesAnt,true,
                                             LegLinkItem);
             if abs(FinRPA.TxSD - 1.0) > Zero then
             begin
                if assigned(LegLinkItem) then
                  LegLinkItem.valores['Indice'] := formatfloat('0.00000000',FinRPA.TxSD);
             end
             else if assigned(LegLinkItem) then begin
               FreeAndNil(LegLinkItem);
              end;
           end
           else FinRPA.TxSD := 1.0;
           if (Temp3.IndSaldoAcum>Zero) and Temp11.AlterouDiaVenc and 
              (FinRPA.Perfin=1) and (not Temp12.CmProRataMesAnt) then begin // Teste do perfin scat 50233
             DtEntHab := RPAS.Temp9.DtEntregaChaves; // SCAt 29363
             if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then DtEntHab := RPAS.Temp10.DtHabit;
             if (Juliano(DtEntHab)>0) and
               (mes_int(DtEntHab.MesAno)>mes_int(DataRefParaReaj.MesAno)) and  // SCAt 21613
