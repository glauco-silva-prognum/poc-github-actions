procedure TContrato.RetornaDtTetoPend(var DtTetoPend : TData);
var
  DtPrimVenc : TData;
  i : smallint;
begin
  if Juliano(MutDsk.Cad.DtUltRenACFin) > 0 then DtTetoPend := MutDsk.Cad.DtUltRenACFin
  else if Juliano(MutDsk.Cad.DtTetoPendMut) > 0 then DtTetoPend := MutDsk.Cad.DtTetoPendMut
  else if Juliano(Scciconf.DtTetoPend) > 0 then DtTetoPend := Scciconf.DtTetoPend
  else if Juliano(MutDsk.Financ.DtAssin) > 0 then DtTetoPend := MutDsk.Financ.DtAssin
  else begin
    DtTetoPend.Dia := 99; DtTetoPend.Mes := 12; DtTetoPend.Ano := 199;
    for i := 0 to Series.count-1 do
      if Series[i].Fin.Status <> 98 then begin
        if juliano(Series[i].Fin.DataRef) < juliano(DtTetoPend) then
          DtTetoPend := Series[i].Fin.DataRef;
      end;
  end;
  if Juliano(MutDsk.Financ.DtInFin) > 0 then begin
    DtPrimVenc := MutDsk.Financ.DtInFin; IncMA(DtPrimVenc.MesAno);
    if Juliano(DtTetoPend) < Juliano(DtPrimVenc) then DtTetoPend := DtPrimVenc;
  end;
end;

