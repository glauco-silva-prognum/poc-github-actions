procedure TContrato.EvoluiTaxasElegiveisTJEO(RPARef : TpRPA; NoEPosVenc : boolean = false);


  procedure TrataEventosAmIncTaxasElegiveisTJEO(      ListaEventosAmInc  : TListaEventosAmInc; 
                                                const RPARef             : TpRPA;
                                                var   TaxasElegiveisTJEO : real;
                                                      DataRef            : TData;
                                                      NoEPosVenc         : boolean = false);
  var
    VA_TAXAS_ELEGIVEIS_TJEO,
    SaldoAux,
    ValorAmIncAux,
    IndReducao   : real;
    i            : integer;
    DtVenc,
    DtEvento     : TData;
  begin
    if (not Scciconf.MetodologiaDiferenciadaRecReceita) 
                           and
       (Abs(TaxasElegiveisTJEO) > Zero) and
       (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and   //Tem custo Amortizado ?
       (juliano(RPARef.FinRPA.DtAssin) >= juliano(scciconf.DtAssinParaCustoAmortizado)) then begin
      DtVenc.Dia := RPARef.FinRPA.DiaVenc;
      Int_Mes(RPARef.MAC,DtVenc.MesAno);
      if (RPARef.FinRPA.Status <> 0) and (RPARef.ValRPA.MACStatus > 0) and
        (  (DataRef.Dia = 0) or
           (RPARef.ValRPA.MACStatus < Mes_Int(DataRef.MesAno)) or 
          ((RPARef.ValRPA.MACStatus = Mes_Int(DataRef.MesAno)) and 
           (byte(RPARef.FinRPA.DiaLiq) < DataRef.Dia)
          )
        ) then begin
        Int_Mes(RPARef.ValRPA.MACStatus,DataRef.MesAno);
        if RPARef.FinRPA.DiaLiq > 0 then 
          DataRef.Dia := RPARef.FinRPA.DiaLiq
        else
          DataRef.Dia := RPARef.FinRPA.DiaVenc;
      end;
      VA_TAXAS_ELEGIVEIS_TJEO := TaxasElegiveisTJEO;
      Int_Mes(RPARef.MAC,DtEvento.MesAno);
      for i := 0 to ListaEventosAmInc.Count-1 do
        if ListaEventosAmInc[i].MACEvento = RPARef.MAC then begin
          DtEvento.Dia := ListaEventosAmInc[i].DiaEvento;
          if ((ListaEventosAmInc[i].ExAmInc in [21,35,103,105,114]) or //Amex e Sin.Parcial = 35
              (ListaEventosAmInc[i].ExOpc = 35) or
              (ListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado)

             )           and
              (not ListaEventosAmInc[i].MarcaDat) 
                                       and
             (
              (NoEPosVenc and (juliano(DtEvento) >= juliano(DtVenc)))
                                       or
              ((not NoEPosVenc) and (juliano(DtEvento) < juliano(DtVenc)) )
             )
                                      and
             (
              (DataRef.Dia = 0) or (Juliano(DtEvento) <= juliano(DataRef))
                           or
              ((Mes_Int(DtEvento.MesAno) = RPARef.VAlRPA.MACStatus) and
               (ListaEventosAmInc[i].ExAmInc in [103,105,114]) and
               (RPARef.FinRPA.Status = 8))
             )
                                       and
             ((Juliano(DtEvento) > juliano(RPARef.FinRPA.DtAssin)) or
              (RPARef.FinRPA.Status <> 20) or (RPARef.Temp7.TipoCtr <> 45)) then begin
  
            ValorAmIncAux := 0;
            IndReducao    := 0;
            if (ListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado) and
               (RPARef.Temp8.CodSerie > 0) then
              ValorAmIncAux := Arredonda(ListaEventosAmInc[i].ValorAICANoVencto-ListaEventosAmInc[i].ValorAINoVencto)
            else if ((ListaEventosAmInc[i].ExAmInc = 35) or 
                (ListaEventosAmInc[i].ExOpc   = 35)) and { S.Parcial }
                (ListaEventosAmInc[i].PerSin > zero) then
              IndReducao := ListaEventosAmInc[i].PerSin/10000
            else begin
              if //(RPARef.Temp8.CodSerie > 0) and
                 (Abs(ListaEventosAmInc[i].ValorAINoVencto-
                      ListaEventosAmInc[i].ValorAICANoVencto) > zero) then begin
                if (Abs(ListaEventosAmInc[i].ValorAINoVencto  ) > zero) and
                   (Abs(ListaEventosAmInc[i].ValorAICANoVencto) > zero) and
                   (juliano(DtVenc) <> juliano(DtEvento)) then
                  ValorAmIncAux := arredonda(Abs(ListaEventosAmInc[i].ValorAICANoVencto)-Abs(ListaEventosAmInc[i].ValorAINoVencto));
              end
              else if ListaEventosAmInc[i].SaldoDevAntes > zero then
                IndReducao := Abs(ListaEventosAmInc[i].ValorAINoVencto)/ListaEventosAmInc[i].SaldoDevAntes
              else if Abs(ListaEventosAmInc[i].ValorAINoVencto)+ListaEventosAmInc[i].NovoSaldoNoVencto > zero then 
                IndReducao := abs(ListaEventosAmInc[i].ValorAINoVencto)/(ListaEventosAmInc[i].NovoSaldoNoVencto+Abs(ListaEventosAmInc[i].ValorAINoVencto));
            end;
            if (Abs(TaxasElegiveisTJEO) > zero) and
               (Abs(ValorAmIncAux) <= zero) then begin
              SaldoAux      := TaxasElegiveisTJEO;
              ValorAmIncAux := arredonda(TaxasElegiveisTJEO*IndReducao);
              SaldoAux      := arredonda(SaldoAux-ValorAmIncAux);
              if (Abs(SaldoAux) > zero) and (SaldoAux < zero) then begin
                ValorAmIncAux := arredonda(ValorAmIncAux+SaldoAux);
                if Abs(VA_TAXAS_ELEGIVEIS_TJEO) > zero then 
                  IndReducao := ValorAmIncAux/VA_TAXAS_ELEGIVEIS_TJEO;
              end;
            end;
            TaxasElegiveisTJEO := arredonda(TaxasElegiveisTJEO - ValorAmIncAux);
            if Abs(TaxasElegiveisTJEO) <= zero then TaxasElegiveisTJEO := 0;
          end;
        end; //if macevento = RPARef.mac
    end; 
  end;

  
  function JogaResTaxasElegiveisTJEONosJuros(TaxasElegiveisTJEO : real) : boolean;
  begin
    Result := false;
    if (Abs(TaxasElegiveisTJEO) > zero) and
      ((TaxasElegiveisTJEO > zero) or
       (Mutdsk.Cad6.TaxaNaoIncorporadaFinanc < zero)) then
        Result := true;

  end;

//In cio da EvoluiTaxasElegiveisTJEO
var
  DataRef,
  DtVenc,
  DtEventoEv              : TData;
  IndexSerie              : longint;
begin
  if (not Scciconf.MetodologiaDiferenciadaRecReceita) 
                   and 
               Self.TemCA
                   and
     (RPARef.Temp8.CodSerie = GetCodSerieParaTaxaNaoIncorp(Self))
                   and
     (Abs(FTaxasElegiveisTJEO) > zero) then begin
    DtEventoEv.Dia := 0; fillchar(DtEventoEv,sizeof(TData),0);
    DataRef        := DtEventoEv;
    if FDataRefHist.Dia > 0 then DataRef := FDataRefHist;
    if (RPARef.FinRPA.Status <> 0) and (RPARef.ValRPA.MACStatus > 0) then begin
      Int_Mes(RPARef.ValRPA.MACStatus,DtEventoEv.MesAno);
      if RPARef.FinRPA.DiaLiq > 0 then 
        DtEventoEv.Dia := RPARef.FinRPA.DiaLiq
      else
        DtEventoEv.Dia := RPARef.FinRPA.DiaVenc;
    end;
    if RPARef.Temp12.Reestruturada and 
      (RPARef.Temp12.DtEvento.Dia > 0) and
      (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and
      (juliano(RPARef.Temp12.DtEvento) >= juliano(scciconf.DtAssinParaCustoAmortizado)) and
      (juliano(RPARef.Temp12.DtEvento) < juliano(DtEventoEv)) then
      DtEventoEv := RPARef.Temp12.DtEvento;

    if (DtEventoEv.Dia > 0) and (juliano(DtEventoEv) < juliano(DataRef)) then 
      DataRef := DtEventoEv;
    DtVenc.Dia := RPARef.FinRPA.DiaVenc;
    Int_Mes(RPARef.MAC,Dtvenc.MesAno); 
    if (RPARef.MAC > 0) and (RPARef.FinRPA.Prazo > 0) then begin
      if not NoEPosVenc then begin
        if RPARef.Temp8.CodSerie = 0 then begin
          if assigned(Self.OEvolui3.ListaEventosAmInc) then
             TrataEventosAmIncTaxasElegiveisTJEO(self.OEvolui3.ListaEventosAmInc,RPARef,
                                                 FTaxasElegiveisTJEO,DataRef);
        end
        else begin
           IndexSerie := self.Series.IndexOf(RPARef.Temp8.CodSerie);
           if (IndexSerie > -1) and 
               assigned(self.Series[IndexSerie].ListaEventosAmInc) then 
             TrataEventosAmIncTaxasElegiveisTJEO(Self.Series[IndexSerie].ListaEventosAmInc,
                                                 RPARef,FTaxasElegiveisTJEO,DataRef);
        end;
      end
      else if (DataRef.Dia = 0) or (juliano(DataRef) >= juliano(DtVenc)) then begin
        FVA_APROP_CM_TJEO_COMPL := 0;
        FVA_APROP_JR_TJEO_COMPL := 0;
        if (RPARef.FinRPA.Status = 0) or (RPARef.MAC > RPARef.ValRPA.MACStatus) or
          ((DataRef.Dia > 0) and (juliano(DtEventoEv) > juliano(DataRef))
          ) then begin

          if  (RPARef.ValRPA.Juro > zero) and (RPARef.Temp12.JUROSCA > zero) then 
            FVA_APROP_JR_TJEO_COMPL := arredonda(RPARef.ValRPA.Juro - RPARef.Temp12.JUROSCA)
          else
            FVA_APROP_JR_TJEO_COMPL := 0;
          if Abs(RPARef.Temp12.CMCA) > zero then begin
            if Abs(RPARef.Temp.CorrSaldo) > zero then 
              FVA_APROP_CM_TJEO_COMPL := arredonda(RPARef.Temp.CorrSaldo - RPARef.Temp12.CMCA)
            else if Abs(RPARef.Temp11.CorrSaldoMes) > zero then
              FVA_APROP_CM_TJEO_COMPL := arredonda(RPARef.Temp11.CorrSaldoMes - RPARef.Temp12.CMCA)
            else
              FVA_APROP_CM_TJEO_COMPL := 0;
          end;
        end
        else begin
          if JogaResTaxasElegiveisTJEONosJuros(FTaxasElegiveisTJEO) then
            FVA_APROP_JR_TJEO_COMPL := FTaxasElegiveisTJEO
          else 
            FVA_APROP_CM_TJEO_COMPL := FTaxasElegiveisTJEO;
        end;
          
        FTaxasElegiveisTJEO := arredonda(FTaxasElegiveisTJEO-(FVA_APROP_JR_TJEO_COMPL+
                                                              FVA_APROP_CM_TJEO_COMPL));

        if (FDataRefHist.Dia > 0) and (DataRef.Dia > 0) and //se chamado pelo cont bil
           (RPARef.MAC = Mes_Int(DataRef.Mesano)) and 
           (Scciconf.ContabDiaria and (DataRef.Dia < byte(RPARef.FinRPA.DiaVenc))) then begin
        //se execu  o pelo cont bil e DataRef < DiaVenc, somo de volta os valores apropriados de juros e corre  o
          if Mes_Int(RPARef.FinRPA.DtAssin.MesAno) = Mes_Int(DataRef.Mesano) then 
             FTaxasElegiveisTJEO := MutDsk.Cad6.TaxaNaoIncorporadaFinanc
          else 
             FTaxasElegiveisTJEO := arredonda(FTaxasElegiveisTJEO+FVA_APROP_JR_TJEO_COMPL+
                                              FVA_APROP_CM_TJEO_COMPL);
  
           
           FVA_APROP_JR_TJEO_COMPL := 0;
           FVA_APROP_CM_TJEO_COMPL := 0;     
        end
        else begin
          if RPARef.Temp8.CodSerie = 0 then begin
            if assigned(Self.OEvolui3.ListaEventosAmInc) then
               TrataEventosAmIncTaxasElegiveisTJEO(self.OEvolui3.ListaEventosAmInc,
                                                   RPARef,FTaxasElegiveisTJEO,DataRef,
                                                   TRUE{NoEPosVenc});
          end
          else begin
             IndexSerie := self.Series.IndexOf(RPARef.Temp8.CodSerie);
             if (IndexSerie > -1) and 
                 assigned(self.Series[IndexSerie].ListaEventosAmInc) then 
               TrataEventosAmIncTaxasElegiveisTJEO(Self.Series[IndexSerie].ListaEventosAmInc,
                                                   RPARef,FTaxasElegiveisTJEO,DataRef,
                                                   TRUE{NoEPosVenc});
          end;
        end;
      end;  //NoEPosVenc = TRUE
    end; // Prazo > 0
    if (DtEventoEv.Dia > 0) and (Abs(FTaxasElegiveisTJEO) > zero) and
       ((juliano(DataRef) >= juliano(DtEventoEv)) or 
        (RPARef.FinRPA.Status in StatusTermino)
       ) then begin
      if JogaResTaxasElegiveisTJEONosJuros(FTaxasElegiveisTJEO) then 
         FVA_APROP_JR_TJEO_COMPL := arredonda(FVA_APROP_JR_TJEO_COMPL +FTaxasElegiveisTJEO)
      else 
         FVA_APROP_CM_TJEO_COMPL := arredonda(FVA_APROP_CM_TJEO_COMPL+FTaxasElegiveisTJEO);
      FTaxasElegiveisTJEO := 0;
    end;
  end;
end;

procedure TContrato.CalculaEventoCANoVencimento(var pRPA                 : TpRPA;
                                                var DataUltEventoCASerie : Tdata;
                                                var ValAcumJurosIncorpCA,
                                                    CorrSaldoAcumAmIncCA,
                                                    TxJurosCAProxMes     : real;
                                                var IndJurosFixoCA,                            
                                                    IndJurosCA,
                                                    IndJurosProRataCA    : real;
                                                var SaldoCAAnt           : real);



  procedure TrataSaldosEventosAmInc(    ListaEventosAmInc    : TListaEventosAmInc; 
                                    var RPARef               : TpRPA;
                                    var SaldoDevNoEvento     : real;    
                                    var IndCorrProrataCA     : real; 
                                    var TemEventoNoEPosVenc  : boolean;
                                    var EPgtoAntec           : boolean;
                                        JaAmortizouECorrigiu : boolean = false);
  var
    i            : integer;
    DtVencProRata,
    DtVenc,
    DtUltEvento,
    DtEvento     : TData;                                      
    leglinkItem  : TLegLinkItem;
    ProrataDaAmex,
    ComProrataJuros,
    ComProrataCM,
    CalcCorrecao : boolean;
    ValorDevidoNoVencto,
    SaldoAnt,
    JurosProRataCA,
    CorrProRataCA: real;
  begin
    leglinkItem        := nil;
    IndCorrProrataCA   := 0;
    ValorDevidoNoVencto:= 0;
    EPgtoAntec         := false;
    DtUltEvento.dia    := 0; fillchar(DtUltEvento,sizeof(DtUltEvento),0);
    if (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and
       (juliano(self.RPA.FinRPA.DtAssin) >= juliano(scciconf.DtAssinParaCustoAmortizado)) then begin
      CalcCorrecao := (not ((RPARef.FinRPA.CodReaj = 31) and 
                      (RPARef.FinRPA2.SdRata = 128)));
      DtVenc.Dia := RPARef.FinRPA.DiaVenc;
      Int_Mes(RPARef.MAC,DtVenc.MesAno);
      if (RPARef.FinRPA.Status <> 0) and (RPARef.ValRPA.MACStatus > 0) and
        ((RPARef.ValRPA.MACStatus < Mes_Int(DtVenc.MesAno)) or 
        ((RPARef.ValRPA.MACStatus = Mes_Int(DtVenc.MesAno)) and 
         (byte(RPARef.FinRPA.DiaLiq) < DtVenc.Dia))) then begin
        Int_Mes(RPARef.ValRPA.MACStatus,DtVenc.MesAno);
        if RPARef.FinRPA.DiaLiq > 0 then 
          DtVenc.Dia := RPARef.FinRPA.DiaLiq
        else
          DtVenc.Dia := RPARef.FinRPA.DiaVenc;
      end;
      Int_Mes(RPARef.MAC,DtEvento.MesAno);

      for i := 0 to ListaEventosAmInc.Count-1 do 
        if ListaEventosAmInc[i].MACEvento = RPARef.MAC then begin
          DtEvento.Dia := ListaEventosAmInc[i].DiaEvento;
          if ((RPARef.Temp8.CodSerie = 0) or 
              (ListaEventosAmInc[i].ExAmInc in [18,103,104,105,114,121]) or
              (ListaEventosAmInc[i].ExOpc in [17,116,118])  or
              (ListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado)
             )
                                       and
              (not ListaEventosAmInc[i].MarcaDat) 
                                       and
                 
             ((Juliano(DtEvento) > juliano(RPARef.FinRPA.DtAssin)) or
              (RPARef.FinRPA.Status <> 20) or (RPARef.Temp7.TipoCtr <> 45)) then begin

            if (
              (((Juliano(DtEvento) < juliano(DtVenc)) and (not JaAmortizouECorrigiu)) 
                           or
               ((Juliano(DtEvento) >= Juliano(DtVenc)) and JaAmortizouECorrigiu))
  {                         or
              ((Mes_Int(DtEvento.MesAno) = RPARef.VAlRPA.MACStatus) and 
               (ListaEventosAmInc[i].ExAmInc in [103,105,114,121]) and //Amex
               (RPARef.FinRPA.Status = 8))
  }
               ) then begin

              ComProrataJuros := ListaEventosAmInc[i].ComProRataJur;
              ComProrataCM    := CalcCorrecao and (ListaEventosAmInc[i].IncSCorr = 0);
              DtVencProRata := DtVenc;
              if not JaAmortizouECorrigiu then begin
                DecMA(DtVencProRata.MesAno);
                if RPARef.Temp12.DiaVencAnt > 0 then 
                  DtVencProRata.Dia := RPARef.Temp12.DiaVencAnt
                else if RPARef.Temp12.DiaVencOrig > 0 then
                  DtVencProRata.Dia := Dia_Venc(Mes_Int(DtVencProRata.MesAno),RPARef.Temp12.DiaVencOrig)
                else
                  DtVencProRata.Dia := Dia_Venc(Mes_Int(DtVencProRata.MesAno),RPARef.FinRPA.DtInFin.Dia);
              end;
  
              if not FInibeLegLink then begin
                  leglinkItem := LegLink.Add(0,'<br><b>'+DescrEventosExAmInc(ListaEventosAmInc[i],JaAmortizouECorrigiu)+' do CustoCA </b><br>');
(*------------------------------ 111777 --------------------------
                if ListaEventosAmInc[i].ExOpc = 118 then 
                  leglinkItem := LegLink.Add(0,'<br><b>'+DescrEventosExAmInc(ListaEventosAmInc[i].ExOpc,JaAmortizouECorrigiu)+' </b><br>')
                else
                  leglinkItem := LegLink.Add(0,'<br><b>'+DescrEventosExAmInc(ListaEventosAmInc[i].ExAmInc,JaAmortizouECorrigiu)+' </b><br>');
-----------------------------------------------------------------------*)
              end;
    
              if assigned(legLinkItem) then begin
                leglinkItem.Valores['<b>Dia Evento</b>'] := intstr(ListaEventosAmInc[i].DiaEvento);
                leglinkItem.valores['M s/Ano Ref.'] := mac_str(RPARef.mac);
                if (ListaEventosAmInc[i].IncSCorr = 0) and CalcCorrecao then
                  leglinkItem.Valores['Com Corre  o Pro rata'] := 'Sim'
                else
                  leglinkItem.Valores['Com Corre  o Pro rata'] := 'N o';
                if ListaEventosAmInc[i].ComProRataJur then
                  leglinkItem.Valores['Com Juros Pro rata'] := 'Sim'
                else
                  leglinkItem.Valores['Com Juros Pro rata'] := 'N o';
                leglinkItem.Valores['Saldo CA antes do evento'] := strgrana(RPARef.Temp12.SaldoCA);
              end;
              ProrataDaAmex := false;
              if (ListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado) and
                 (RPARef.Temp8.CodSerie > 0) then begin
                RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA-ListaEventosAmInc[i].ValorAICANoVencto);
                EPgtoAntec := true;
                if ListaEventosAmInc[i].DiaEvento > DtUltEvento.Dia then
                  DtUltEvento := DtEvento;

                if assigned(LegLinkItem) then begin
                  leglinkItem.Valores['DataPagamento'] := data_str(DtEvento);
                  leglinkItem.Valores['DiaVencimento'] := intstr(RpaRef.finrpa.diavenc);
                  leglinkItem.Valores['NumeroDeMesesDescapitalizacao'] := formatfloat('0',ListaEventosAmInc[i].NMeses);
                  leglinkItem.valores['MesAnoReferencia'] := mac_str(RPARef.mac);
                  leglinkItem.valores['MesAnoParcelaAntecipada'] := mac_str((ListaEventosAmInc[i].ParcelaObj as TParcelaSerie).Mac);
                  leglinkItem.valores['ValorOriginalParcelaAntecipada'] := Strgrana((ListaEventosAmInc[i].ParcelaObj as TParcelaSerie).Valor);
                  leglinkItem.valores[' ndice de corre  o acumulado'] :=  formatfloat('0.0000000000',ListaEventosAmInc[i].IndCorEv);
                  leglinkItem.valores['ValorPresente'] := strgrana(ListaEventosAmInc[i].ValorAICANoVencto);
                  leglinkItem.valores['SaldoCA Amortizado'] := strgrana(RPARef.Temp12.SaldoCA);
                end;
                if ListaEventosAmInc[i].NovoSaldoNoEvento > zero then 
                  SaldoDevNoEvento := ListaEventosAmInc[i].NovoSaldoNoEvento;

              end
              else if ListaEventosAmInc[i].ExAmInc in [18,102,104,106,108] then begin
                CorrProRataCA := 0; JurosProRataCA := 0;
                if (RPARef.Temp8.CodSerie = 0) and
                   (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
                    scciconf.AcumJurosNaFasedeLiberacao {or
                    ScciConf.CalcularAmortSemAbaterJuros}) and
                   (juliano(DtUltEvento) > juliano(DtVencProRata)) then begin
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtUltEvento,DtEvento,DtUltEvento,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},false{EAmex},ComProRataCM,ComProRataJuros);
                  if not ((ListaEventosAmInc[i].IncSCorr = 0) and CalcCorrecao) then 
                    CorrProRataCA  := 0;
                  if not ListaEventosAmInc[i].ComProRataJur then
                    JurosProRataCA := 0;
                  ValAcumJurosIncorpCA := ValAcumJurosIncorpCA + JurosProRataCA;
                  CorrSaldoAcumAmIncCA := CorrSaldoAcumAmIncCA + CorrProRataCA;
                end
                else
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtVencProRata,DtEvento,DtVencProRata,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},false{EAmex},ComProRataCM,ComProRataJuros);
                SaldoAnt := RPARef.Temp12.SaldoCA;
    (*
                if Abs(RPARef.Temp12.SaldoCA) > zero then 
                  IndCorrProrata := CorrProRataCA/RPARef.Temp12.SaldoCA
                else
                  IndCorrProrata := 0;
    *)
                RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA+CorrProRataCA+JurosProRataCA);
                RPARef.Temp12.SaldoCA := RPARef.Temp12.SaldoCA + ListaEventosAmInc[i].ValorAmInc;
                if ListaEventosAmInc[i].DiaEvento > DtUltEvento.Dia then
                  DtUltEvento := DtEvento;
                if ListaEventosAmInc[i].NovoSaldoNoEvento > zero then 
                  SaldoDevNoEvento := ListaEventosAmInc[i].NovoSaldoNoEvento;
                if assigned(legLinkItem) then begin
                  if Abs(SaldoAnt+CorrProRataCA) > zero then begin
                    if Abs(CorrProRataCA) > zero then begin
                      leglinkItem.Valores['Corre  o pro rata CA'] := strgrana(CorrProRataCA);
                      leglinkItem.Valores['SaldoCA com pro rata'] := strgrana(SaldoAnt+CorrProRataCA);
                    end;
                    if JurosProRataCA > zero then begin
                      leglinkItem.Valores['Juros pro rata CA'] := strgrana(jurosProRataCA);
                      leglinkItem.Valores['SaldoCA c/juros pro rata'] := strgrana(SaldoAnt+CorrProRataCA+JurosProRataCA);
                    end;
                  end;
                  leglinkItem.Valores['Valor da Incorpora  o'] := strgrana(ListaEventosAmInc[i].ValorAmInc);
                  leglinkItem.Valores['Saldo CA Incorporado no evento']  := strgrana(RpaRef.Temp12.SaldoCA);
                end;
              end
              else if ListaEventosAmInc[i].ExAmInc in [21,103,105,114,121] then begin //Amex
                CorrProRataCA := 0; JurosProRataCA := 0;
                if (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
                    scciconf.AcumJurosNaFasedeLiberacao) and
                   (RPARef.Temp8.Codserie = 0) and
                   (juliano(DtUltEvento) > juliano(DtVencProRata)) then
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtUltEvento,DtEvento,DtUltEvento,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},TRUE{EAmex},ComProrataCM,ComProrataJuros)
                else if RPARef.Temp8.CodSerie > 0 then begin
                  ProRataDaAmex := true;
                  ValorDevidoNoVencto := CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtVencProRata,DtEvento,DtVencProRata,Abs(ListaEventosAmInc[i].ValorAmInc),
                                                         (not JaAmortizouECorrigiu),(not ProRataDaAmex){SobreSaldoCA},
                                                         TRUE{EAmex},ComProRataCM,ComProRataJuros);
                  if Abs(ValorDevidoNoVencto) > zero then 
                    ListaEventosAmInc[i].ValorAICANoVencto := ValorDevidoNoVencto;
                end
                else 
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtVencProRata,DtEvento,DtVencProRata,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},TRUE{EAmex},ComProRataCM,ComProRataJuros);
                SaldoAnt       := RPARef.Temp12.SaldoCA;
                if ListaEventosAmInc[i].IndCorEv > zero then 
                  IndCorrProrataCA := ListaEventosAmInc[i].IndCorEv;
    (*
                if Abs(RpaRef.Temp12.SaldoCA) > zero then
                  IndCorrProrata := CorrProRataCA/RPARef.Temp12.SaldoCA
                else
                  IndCorrProrata := 0;
    *)
                if ProRataDaAmex then begin
                  RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA-((Abs(ListaEventosAmInc[i].ValorAmInc)-(CorrProRataCA+JurosProRataCA))) );
                end
                else begin
                  RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA+CorrProRataCA+JurosProRataCA);
                  if ListaEventosAmInc[i].ValorAmInc < zero then 
                    RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA + ListaEventosAmInc[i].ValorAmInc)
                  else
                    RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA - ListaEventosAmInc[i].ValorAmInc);
                end;
  
                if ListaEventosAmInc[i].NovoSaldoNoEvento > zero then 
                  SaldoDevNoEvento := ListaEventosAmInc[i].NovoSaldoNoEvento;
    (*------------------------------ scat093979 -------------------------------
                if ListaEventosAmInc[i].ExAmInc in [103,105,114,121] then begin
                  if ((not SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra) or
                      (RPARef.Temp8.CodSerie > 0)) and
                      (ListaEventosAmInc[i].ValorAmInc      < Zero) and 
                      (Abs(ListaEventosAmInc[i].JurosAmort) > Zero) and
                      (ListaEventosAmInc[i].JurosAmort      < Zero)  then
                    ListaEventosAmInc[i].JurosAmort := Abs(ListaEventosAmInc[i].JurosAmort);
                  RPARef.Temp12.SaldoCA := Arredonda(RPARef.Temp12.SaldoCA + (ListaEventosAmInc[i].ValorAmInc + ListaEventosAmInc[i].CMProrataContabil + ListaEventosAmInc[i].JurosAmort));
                  if assigned(legLinkItem) then
                    leglinkItem.Valores['Valor Amortizado no vencto'] := strgrana(ListaEventosAmInc[i].ValorAmInc+ListaEventosAmInc[i].CMProrataContabil+ListaEventosAmInc[i].JurosAmort);
                end
                else begin
                  RPARef.Temp12.SaldoCA := Arredonda(RPARef.Temp12.SaldoCA - (ListaEventosAmInc[i].ValorAmInc - 
                                                                        ListaEventosAmInc[i].CMProrataContabil));
                  if assigned(legLinkItem) then
                    leglinkItem.Valores['Valor Amortizado no vencto'] := strgrana(ListaEventosAmInc[i].ValorAmInc-ListaEventosAmInc[i].CMProrataContabil);
    
                end;
    -------------------------------------------------------------------------*)
                if assigned(legLinkItem) then begin
                  if Abs(SaldoAnt) > zero then begin
                    if Abs(CorrProRataCA) > zero then begin
                      leglinkItem.Valores['Corre  o pro rata CA'] := strgrana(CorrProRataCA);
                      leglinkItem.Valores['SaldoCA com pro rata'] := strgrana(SaldoAnt+CorrProRataCA);
                    end;
                    if JurosProRataCA > zero then begin
                      leglinkItem.Valores['Juros pro rata CA'] := strgrana(jurosProRataCA);
                      leglinkItem.Valores['SaldoCA c/juros pro rata'] := strgrana(SaldoAnt+CorrProRataCA+JurosProRataCA);
                    end;
                  end;
                  leglinkItem.Valores['Valor da Amortiza  o'] := strgrana(ListaEventosAmInc[i].ValorAmInc);
                  leglinkItem.Valores['Saldo CA Amortizado no evento'] := strgrana(RPARef.Temp12.SaldoCA);
                end;
                if ListaEventosAmInc[i].DiaEvento > DtUltEvento.Dia then
                  DtUltEvento := DtEvento;
              end
              else if (ListaEventosAmInc[i].ExOpc in [17,116,118]) then begin
                CorrProRataCA := 0; JurosProRataCA := 0;
                if (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
                    scciconf.AcumJurosNaFasedeLiberacao) and
                   (RPARef.Temp8.CodSerie = 0) and
                   (juliano(DtUltEvento) > juliano(DtVencProRata)) then
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtUltEvento,DtEvento,DtUltEvento,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},FALSE{EAmex},ComProRataCM,ComProRataJuros)
                else 
                  CalculaProRatasCA(RPARef,JurosProRataCA,CorrProRataCA,DtVencProRata,DtEvento,DtVencProRata,RPARef.Temp12.SaldoCA,(not JaAmortizouECorrigiu),TRUE{SobreSaldoCA},FALSE{EAmex},ComProRataCM,ComProRataJuros);
  
                SaldoAnt := RPARef.Temp12.SaldoCA;
                RPARef.Temp12.SaldoCA := arredonda(RPARef.Temp12.SaldoCA+CorrProRataCA+JurosProRataCA);
                if assigned(legLinkItem) then begin
                  if (Abs(SaldoAnt) > zero) and (Abs(RPARef.Temp12.SaldoCA-SaldoAnt) > zero) then begin
                    leglinkItem.Valores['Saldo CA antes da altera  o da TxJuros']   := strgrana(SaldoAnt);
                    if Abs(CorrProRataCA) > zero then begin
                      leglinkItem.Valores['Corre  o pro rata CA'] := strgrana(CorrProRataCA);
                      leglinkItem.Valores['SaldoCA com pro rata'] := strgrana(SaldoAnt+CorrProRataCA);
                    end;
                    if JurosProRataCA > zero then begin
                      leglinkItem.Valores['Juros pro rata CA'] := strgrana(jurosProRataCA);
                      leglinkItem.Valores['SaldoCA c/juros pro rata'] := strgrana(SaldoAnt+CorrProRataCA+JurosProRataCA);
                    end;
                  end;
                end;
    
                if ListaEventosAmInc[i].DiaEvento > DtUltEvento.Dia then
                  DtUltEvento := DtEvento;
                if juliano(DtEvento) >= juliano(DtVenc) then
                  TemEventoNoEPosVenc := true;
              end;
            end //JaAmortizou ou n o
            else if juliano(DtEvento) >= juliano(DtVenc) then 
              TemEventoNoEPosVenc := true;
          end;
        end; //for
    end; //if tem SaldoCA
    if (DtUltEvento.Dia > 0) and (juliano(DtUltEvento) > juliano(DataUltEventoCASerie)) then
      DataUltEventoCASerie := DtUltEvento;
  end;


var  { CalculaEventoCANoVencimento } 
  EPgtoAntec                    : boolean;
  TemEventoNoEPosVenc,
  TemJurosProrata               : boolean;
  IndexSerie                    : integer;
  DtVenc,
  DtVencAnt,
  DataAnt                       : TData;
  AmortCA,
//  IndiceDeJurosProRata,
  SaldoDevCalcCA,
  IndCorrProrataCA,
  IndiceDeCorrecaoProRata       : real;
begin
  SaldoDevCalcCA  := pRPA.Temp.SalDevAnt;
  DataAnt         := DataUltEventoCASerie;
  IndexSerie      := -1;
  SaldoCAAnt      := pRPA.Temp12.SaldoCA;
  TemJurosProrata := pRPA.Temp9.JurProRata;
  IndCorrProRataCA:= 0;
  TemEventoNoEPosVenc:= false;
  EPgtoAntec      := false;
  if pRpa.Temp8.CodSerie = 0 then
    TrataSaldosEventosAmInc(OEvolui3.ListaEventosAmInc,
                            pRPA,SaldoDevCalcCA,IndCorrProrataCA,
                            TemEventoNoEPosVenc,EPgtoAntec,
                            false{JacorriueAmortizou})
  else begin
    IndexSerie := Series.IndexOf(pRPA.Temp8.CodSerie);
    if IndexSerie > -1 then begin
      TrataSaldosEventosAmInc(Series[IndexSerie].ListaEventosAmInc,
                              pRPA,SaldoDevCalcCA,IndCorrProrataCA,
                              TemEventoNoEPosVenc,EPgtoAntec,false);
      TemJurosProrata := TemJurosProrata or Series[IndexSerie].Fin.JurProRata;
    end;
  end;

  EvoluiTaxasElegiveisTJEO(pRPA);
  if ((Abs(pRPA.Temp12.TxJurosCA) <= zero) and 
//?      (pRPA.ValRPA.Juro > zero) and 
      (pRPA.MAC <= Mes_Int(pRPA.FinRPA.DtInFin.MesAno)+1)
     )
              or 
    (
     ((Abs(pRPA.Temp12.SaldoCA-SaldoCAAnt) > zero) or 
      (juliano(DataAnt) <> juliano(DataUltEventoCASerie)))
                        and 
           (not (TemEventoNoEPosVenc or (EPgtoAntec and (pRPA.Temp8.CodSerie > 0))))
    )
                       or
    ((pRPA.MAC = Mes_Int(pRPA.FinRPA.DtAssin.MesAno)+1) and
     (Abs(pRPa.Temp12.SaldoCA) > zero) and
     (pRPA.Temp7.TipoCtr in EvoPlanoEmpSet)) then begin
    pRPA.Temp12.TxJurosCA := CalculaTxJurosCA(MutDsk,FListTxJurosCA,pRPA.MAC,pRPA.Temp8.CodSerie,DataUltEventoCASerie,TRUE{EventoAntesVenc},ConverteTxJurosParaMensal(pRPA),InibeLegLink,FTaxasElegiveisTJEO,
                                              TRUE{CalcComAMaisJ},false,SaldoDevCalcCA{pRpa.Temp12.SaldoCA});
  end; 
  SaldoCAAnt := pRPA.Temp12.SaldoCA;
  DataAnt    := DataUltEventoCASerie;
  Int_Mes(pRPA.MAC,DtVenc.MesAno);
  DtVenc.Dia:= pRPA.FinRPA.DiaVenc;
  DtVencAnt := DtVenc;
  DecMA(DtVencAnt.MesAno);
  if pRPA.Temp12.DiaVencAnt > 0 then 
    DtVencAnt.Dia := pRPA.Temp12.DiaVencAnt
  else if pRPA.Temp12.DiaVencOrig > 0 then
    DtVencAnt.Dia := pRPA.Temp12.DiaVencOrig
  else
    DtVencAnt.Dia := pRPA.FinRPA.DtInFin.Dia;
  DtVencAnt.Dia := Dia_Venc(Mes_Int(DtVencAnt.MesAno),DtVencAnt.Dia);
  if juliano(DtVencAnt) < juliano(pRPA.FinRPA.DtAssin) then 
    DtVencAnt := pRPA.FinRPA.DtAssin;
  if juliano(DtVenc) < juliano(pRPA.FinRPA.DtAssin) then 
    DtVenc := pRPA.FinRPA.DtAssin;
  if pRPA.Temp12.TxJurosCA > zero then begin
    if pRPA.Temp8.CodSerie = 0 then 
      IndJurosCA := pRPA.Temp12.TxJurosCA/100
    else if IndexSerie > -1 then begin
      if Series[IndexSerie].Fin.PerParcelas = 0 then 
        Series[IndexSerie].Fin.PerParcelas := 1;
      if Series[IndexSerie].Fin.JurosSimples then
        IndJurosCA := CalculaJuros(1{Fin.TpJuros},pRPA.Temp12.TxJurosCA,Series[IndexSerie].Fin.PerParcelas,Series[IndexSerie].Fin.JurosSimples)/100/Series[IndexSerie].Fin.PerParcelas
      else
        IndJurosCA := pot((1+CalculaJuros(1{Fin.TpJuros},pRPA.Temp12.TxJurosCA,Series[IndexSerie].Fin.PerParcelas,Series[IndexSerie].Fin.JurosSimples)/100),1.0/Series[IndexSerie].Fin.PerParcelas)-1;
    end;
    IndJurosFixoCa := IndJurosCA;
  end;
  if ((pRPA.FinRPA.Plano div 10) = PJF) and (pRPA.Temp12.IndJurosFlutuante > zero) then
    IndJurosCA := RetornaIndJurosPJF(IndJurosFixoCA,pRPA.Temp12.IndJurosFlutuante,pRPA.Temp12.CO_JUROS_FLUTUANTE);

  if (SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra or
     (pRPA.FinRPA.PA = 40) or 
      scciconf.AcumJurosNaFasedeLiberacao {or
      ScciConf.CalcularAmortSemAbaterJuros}) and
     (pRPA.Temp8.CodSerie = 0) and
     (Mes_Int(DataUltEventoCASerie.MesAno) >= pRPA.MAC-1) and
     (juliano(DataUltEventoCASerie) > juliano(DtVencAnt)) and
     (juliano(DataUltEventoCASerie) < juliano(DtVenc)) and
      TxJurosCAIgualaTxJuros(self,pRPA.Temp8.Codserie,FTaxasElegiveisTJEO) then begin
    IndiceDeCorrecaoProRata := CalcIndiceCorrecaoProRata(DataUltEventoCASerie,DtVenc,pRPA,nil{LegLinkItem},TRUE,false{IRFS9},pRPA.FinRPA.TxSd);
    pRPA.Temp12.CMCA        := arredonda(pRPA.Temp12.SaldoCA*(IndiceDeCorrecaoProRata-1));
  end
  else if Abs(IndCorrProrataCA) > zero then 
    pRPA.Temp12.CMCA    := Arredonda((pRPA.Temp12.SaldoCA/(1+IndCorrProrataCA))*(pRPA.FinRPA.TXSD - 1.0))
  else
    pRPA.Temp12.CMCA    := Arredonda(pRPA.Temp12.SaldoCA*(pRPA.FinRPA.TXSD - 1.0));
  pRPA.temp12.SaldoCA := pRPA.Temp12.SaldoCA  + pRPA.Temp12.CMCA;


  // Apenas no m s seguinte a assinatura que preciso me preocupar com prorata de juros ??
(*---------------------- scat100062 ------------------------------------*)

//scat108948  if (pRPA.ValRPA.AmaisJ > zero) or (pRPA.ValRPA.Juro > zero) then begin scat108948

    if (
        ((pRPA.MAC <= Mes_Int(pRPA.FinRPA.DtInFin.MesAno)) and 
         (pRPA.Temp8.CodSerie = 0) and
         ((not pRPA.Temp7.AmortizaSaldoComNPC0) or pRPA.Temp12.CobrJurCapPrst1)
        ) 
                      and 
        TxJurosCAIgualaTxJuros(self,pRPA.Temp8.Codserie,FTaxasElegiveisTJEO)
       )
                     or
        (Abs(IndJurosCA) <= zero) or (Abs(pRPA.Temp12.TxJurosCA) <= zero)
                     or
       ((pRPA.MAC = Mes_Int(pRPA.FinRPA.DtAssin.MesAno)) and 
        (pRPA.FinRPA.DtAssin.Dia >= byte(pRPA.FinRPA.DiaVenc))) then 
      pRPA.Temp12.JurosCA := 0
    else if (((pRPA.Mac = mes_int(pRPA.FinRPA.DtAssin.MesAno)) and
              (pRPA.FinRPA.DtAssin.Dia < byte(pRPA.FinRPA.DiaVenc))) 
                         or
             ((pRPA.Mac = succ(mes_int(pRPA.FinRPA.DtAssin.MesAno))) and
              (pRPA.FinRPA.DtAssin.Dia > byte(pRPA.FinRPA.DiaVenc)))
            ) and  TemJurosProrata and
              (not (scciconf.AcumJurosNaFasedeLiberacao and (pRpa.Temp7.TipoCtr in EvoPlanoEmpSet))) 
                             and
              TxJurosCAIgualaTxJuros(self,pRPA.Temp8.Codserie,FTaxasElegiveisTJEO)
     { and Scciconf.ConsideraJurosNaCarenciaNoCalculoDaTJEO}   then begin
      IndJurosProRataCA := CalcIndJurosCAprorata(pRPA);
      pRPA.Temp12.JurosCA := Arredonda(pRPA.Temp12.SaldoCA*IndJurosProRataCA);
    end  
    else  
      pRPA.Temp12.JurosCA  := Arredonda(pRPA.Temp12.SaldoCA*IndJurosCA);
    if (pRPA.MAC <= Mes_Int(pRPA.FinRPA.DtInFin.MesAno)) and
        pRPA.temp12.incCorrSdAmort then
      pRPA.Temp12.SaldoCA  := arredonda(pRPA.Temp12.SaldoCA + pRPA.Temp12.JurosCA)
    else
      pRPA.Temp12.SaldoCA  := arredonda(pRPA.Temp12.SaldoCA - (pRPA.ValRPA.Amaisj - pRPA.Temp12.JurosCA));

  EPgtoAntec           := false;
  ValAcumJurosIncorpCA := 0;
  CorrSaldoAcumAmIncCA := 0;
  SaldoDevCalcCA       := pRPA.Temp12.SaldoVenc;
  SaldoCaAnt           := pRPA.Temp12.SaldoCA;
  IndCorrProrataCA     := 0;
  if pRpa.Temp8.CodSerie = 0 then 
    TrataSaldosEventosAmInc(OEvolui3.ListaEventosAmInc,
                            pRPA,SaldoDevCalcCA,IndCorrProrataCA,
                            TemEventoNoEPosVenc,
                            EPgtoAntec,TRUE{JacorriueAmortizou})
  else begin
    if IndexSerie < 0 then IndexSerie := Series.IndexOf(pRPA.Temp8.CodSerie);
    if IndexSerie > -1 then
      TrataSaldosEventosAmInc(Series[IndexSerie].ListaEventosAmInc,pRPA,
                              SaldoDevCalcCA,IndCorrProrataCA,
                              TemEventoNoEPosVenc,EPgtoAntec,true);
  end;

  if (Abs(pRPA.Temp12.SaldoCA) > zero) and (pRPA.FinRPA.Status > 0) and
     (pRPA.ValRPA.MACStatus = pRPA.MAC) and
     (Abs(pRPA.Temp12.SaldoCA)  > zero) and 
     (Abs(pRPA.VAlRPA.AmaisJ )  > zero) and
     (Abs(pRPA.ValRPA.SAldoDev)<= zero) then begin
    if (IndJurosCA > zero) and (pRPA.Temp12.TxJurosCA > zero) then begin
      AmortCA := pRPA.ValRPA.AmaisJ - pRPA.Temp12.JurosCA;
      AmortCA := AmortCA + pRPA.Temp12.SaldoCA;
      pRPA.Temp12.JurosCA := arredonda(pRPA.ValRPA.AmaisJ - AmortCA);
    end;
    pRPA.Temp12.SaldoCA := 0;
  end;
  EvoluiTaxasElegiveisTJEO(pRPA,TRUE{NoEPosVenc});
  if (( (juliano(DataAnt) <> juliano(DataUltEventoCASerie)) or
        (Abs(pRPA.Temp12.SaldoCA-SaldoCAAnt) > zero)
      ) 
                    and
              (not EPgtoAntec)
     )
                   and
     (not (pRPA.Temp7.TipoCtr in EvoPlanoEmpSet)) and 
     (Abs(pRPA.Temp12.SaldoCA) > zero) then begin
    TxJurosCAProxMes := CalculaTxJurosCA(MutDsk,FListTxJurosCA,pRPA.MAC,pRPA.Temp8.CodSerie,DataUltEventoCASerie,FALSE{EventoAntesVenc},ConverteTxJurosParaMensal(pRPA),InibeLegLink,FTaxasElegiveisTJEO,
                                              TRUE{CalcComAMaisJ},false,SaldoDevCalcCA{pRPA.Temp12.SaldoCA}); 
    if pRPA.Temp8.CodSerie = 0 then 
      IndJurosCA := pRPA.Temp12.TxJurosCA/100
    else if IndexSerie > -1 then begin
      if Series[IndexSerie].Fin.PerParcelas = 0 then 
        Series[IndexSerie].Fin.PerParcelas := 1;
      if Series[IndexSerie].Fin.JurosSimples then
        IndJurosCA := CalculaJuros(1{Fin.TpJuros},pRPA.Temp12.TxJurosCA,Series[IndexSerie].Fin.PerParcelas,Series[IndexSerie].Fin.JurosSimples)/100/Series[IndexSerie].Fin.PerParcelas
      else
        IndJurosCA := pot((1+CalculaJuros(1{Fin.TpJuros},pRPA.Temp12.TxJurosCA,Series[IndexSerie].Fin.PerParcelas,Series[IndexSerie].Fin.JurosSimples)/100),1.0/Series[IndexSerie].Fin.PerParcelas)-1;
    end;
    IndJurosFixoCa := IndJurosCA;
    if ((pRPA.FinRPA.Plano div 10) = PJF) and (pRPA.Temp12.IndJurosFlutuante > zero) then
      IndJurosCA := RetornaIndJurosPJF(IndJurosFixoCA,pRPA.Temp12.IndJurosFlutuante,pRPA.Temp12.CO_JUROS_FLUTUANTE);
  end;
end;

function TContrato.CalcIndJurosCAprorata(var pRPA : TpRPA) : real;
var
  dias : integer;
  DtVenc : TData;
  ll : TLegLinkItem;
begin
  DtVenc.dia := pRpa.FinRPA.DiaVenc;
  int_mes(pRpa.Mac,DtVenc.MesAno);
  Dias := Dias360(pRpa.FinRPA.DtAssin,DtVenc);
  result := pot((pRPA.Temp12.TxJurosCA/100+1),(Dias/30))-1;
  ll := LegLink.Add(pRPA.Temp8.CodSerie,'<b><p>Calculo do  ndice de juros pro-rata do Custo Amortizado</p></b>');
  if assigned(ll) then begin
    ll.valores['Data de assinatura'] := data_str2(pRPA.FinRPA.DtAssin);
    ll.valores['Data de Vencimento'] := data_str2(DtVenc);
    ll.valores['Dias pro rata'] := intstr(dias);
    ll.valores['Taxa de Juros'] := formatfloat('0.000000',pRPA.Temp12.TxJurosCA/100);
    ll.valores[' ndice de juros pro rata ((TxJurosCA/100+1)^(Dias/30))-1'] := formatfloat('0.00000000',result);
  end;
end;
  
procedure TContrato.EvoluiCASerie(var pRPA : TpRPA;
                                  var DataUltEventoCASerie : TData;
                                  var ValAcumJurosIncorpCA,
                                      CorrSaldoAcumAmIncCA,
                                      TxJurosCAProxMes     : real);
var
  TxJurosAnt,
  SaldoCAAnt : real;
  ll         : TLegLinkItem;
//  AmortCA,
  IndJurosFixoCA,
  IndJurosCA : real;
  IndJurosProRataCA : real;
  RegConfigRes : TpConfigRes4966;
  DataRef      : TData;
begin
  if (Scciconf.DtAssinParaCustoAmortizado.Dia > 0) and self.TemCA and
     (pRPA.Temp7.TipoCtr <> 41{98550}) then begin
    if FDataRefHist.Dia > 0 then 
      DataRef := FDataRefHist
    else
      DataRef := pRPA.FinRPA.DtAssin;
    RegConfigRes.Co_Classificacao := 0;
    fillchar(RegConfigRes,sizeof(TpConfigRes4966),0);
    RegConfigRes := ObtemConfigRes4966(DataRef{pRPA.FinRPA.DtAssin},pRPA.Temp5.Carteira,MutDsk.Cad.CodEmpresa);
    if TxJurosCAProxMes > zero then begin
      pRPA.Temp12.TxJurosCA := TxJurosCAProxMes;
      TxJurosCAProxMes := 0;
    end;
    if (pRPA.MAC <= Mes_Int(pRPA.FinRPA.DtAssin.MesAno)) and 
       (not Scciconf.MetodologiaDiferenciadaRecReceita) and
       (Abs(FTaxasElegiveisTJEO) <= zero) and
       (Abs(Self.MutDsk.Cad6.TAXANAOINCORPORADAFINANC) > zero) and
       (GetCodSerieParaTaxaNaoIncorp(self) = pRPA.Temp8.CodSerie) then 
      FTaxasElegiveisTJEO := MutDsk.Cad6.TAXANAOINCORPORADAFINANC;
    if (RegConfigRes.Co_Classificacao <> 2) and        //VJora
       (RegConfigRes.Co_Classificacao <> 3) then begin //Valor_Justo
      ll             := nil;
      IndJurosCA     := 0;
      IndJurosProRataCA := 0;
      IndJurosFixoCA := 0;
      SaldoCAAnt := pRPA.Temp12.SaldoCA;
      TxJurosAnt := pRPA.Temp12.TxJurosCA;
      if (not FInibeLegLink) and (Abs(pRPA.Temp12.SaldoCA) > zero) then 
        ll := LegLink.Add(pRPA.Temp8.CodSerie,'<b><p>Evolu  o do Custo Amortizado '+MAC_Str(pRPA.MAC)+'</b>');
      if (pRPA.finrpa.status > 0) and (pRPA.ValRPA.MACStatus > 0) and
       ( ((pRPA.ValRPA.MACStatus = pRPA.MAC) and (pRPA.FinRPA.DiaLiq < pRPA.FinRPA.DiaVenc)) 
                              or
         (pRPA.MAC > pRPA.ValRPA.MACStatus) {
                              or
         (abs(pRPA.ValRPA.SaldoDev) <= zero) }
       ) then begin
        pRPA.Temp12.VlInicioCA := 0;
        pRPA.Temp12.TxJurosCA  := 0;
        pRPA.Temp12.SaldoCA    := 0;
        pRPA.Temp12.CMCA       := 0;
        pRPA.Temp12.JurosCA    := 0;
      end
      else if (
               ((pRPA.FinRPA.ValorAI > zero) or (pRPA.Temp7.ValorInc > zero))
                                     or
               ((pRPA.Temp12.CoEvento in [1,2,3]) and  // alt. tx juros ou renegociacao
                (Mes_int(pRPA.Temp12.DtEvento.mesano)=pRPA.MAC))
              )                   and
               ((pRPA.Temp12.SaldoCA > zero) or (pRPA.Temp7.TipoCtr in EvoPlanoEmpSet)) then begin
        CalculaEventoCANoVencimento(pRPA,DataUltEventoCASerie,ValAcumJurosIncorpCA,CorrSaldoAcumAmIncCA,
                                    TxJurosCAProxMes,
                                    IndJurosFixoCA,IndJurosCA,IndJurosProRataCA,SaldoCAAnt);

(*
        if (abs(pRPA.ValRPA.SaldoDev) <= zero) and
           (Abs(pRPA.Temp12.SaldoCA ) >  zero) and
           (pRPA.ValRPA.MACStatus >= pRPA.MAC) and
           (Abs(pRPA.Temp12.SaldoCA) > zero) then begin
          if (pRPA.ValRPA.AmaisJ > zero) and
             (pRPA.MAC = pRPA.ValRPA.MACStatus) then begin
            AmortCA := pRPA.ValRPA.AmaisJ - pRPA.Temp12.JurosCA;
            AmortCA := AmortCA + pRPA.Temp12.SaldoCA;
            pRPA.Temp12.JurosCA := arredonda(pRPA.ValRPA.AmaisJ - AmortCA);
          end;
          pRPA.Temp12.SaldoCA := 0;
        end;
*)

        if not FInibeLegLink then 
          ll := LegLink.Add(pRPA.Temp8.CodSerie,'<b><p>C lculo de nova taxa de Juros por custo amortizado(CA)</b>');
        if Assigned(ll) then begin 
          if pRPA.Temp8.CodSerie > 0 then 
            ll.valores['CodSerie'] := inttostr(pRPA.Temp8.CodSerie);
          if Abs(TxJurosAnt-pRPA.Temp12.TxJurosCA) > zero then begin
            ll.valores['TxJurosCA anterior'] := formatfloat('0.000000',TxJurosAnt);
            ll.valores['Nova TxJurosCA'] := formatfloat('0.000000',pRPA.Temp12.TxJurosCA);
          end;
        end;
        if  (pRPA.Temp12.CoEvento in [1,2,3]) and
            (Mes_int(pRPA.Temp12.DtEvento.mesano)=pRPA.MAC) then begin
          if assigned(ll) then begin
            ll.valores['CoEvento'] := inttostr(pRPA.Temp12.CoEvento);
            ll.valores['DtEvento'] := data_str2(pRPA.Temp12.DtEvento);
          end;
        end
        else begin
          if assigned(ll) then
            ll.valores['DiaAMInc'] := inttostr(pRPA.Temp4.DiaAMInc);
        end;
        if assigned(ll) then begin
          ll.valores['Valor Inicial CA'] := strgrana(abs(pRPA.Temp12.VLINICIOCA));
          ll.valores['Saldo CA anterior']:= strgrana(SaldoCAAnt);
          ll.valores['CMCA'] := strgrana(pRPA.Temp12.CMCA);
          ll.valores['Saldo CA anterior + CMCA'] := strgrana(SaldoCAAnt+pRPA.Temp12.CMCA);
          if pRPA.Temp12.IndJurosFlutuante > zero then begin
            ll.valores[' ndice de juros fixo CA']  := formatfloat('0.00000000',IndJurosFixoCA);
            ll.valores[' ndice de juros Flutuante']:= formatfloat('0.00000000',pRPA.Temp12.IndJurosFlutuante);
          end;
          ll.valores[' ndice de juros Mensal CA'] := formatfloat('0.00000000',IndJurosCA);
      
          ll.valores['Juros CA'] := strgrana(pRPA.Temp12.JurosCA);
          ll.valores['Amort.CA'] := strgrana(pRPA.ValRPA.Amaisj-pRPA.Temp12.JurosCA);
          ll.valores['Saldo CA'] := strgrana(pRPA.Temp12.SaldoCA);
        end;
      end
      else if (Abs(SaldoCAAnt) > zero) or (Abs(pRPA.Temp12.VlInicioCA) > zero)  then begin
        CalculaEventoCANoVencimento(pRPA,DataUltEventoCASerie,ValAcumJurosIncorpCA,CorrSaldoAcumAmIncCA,TxJurosCAProxMes,IndJurosFixoCA,IndJurosCA,IndJurosProRataCA,SaldoCAAnt);

        if assigned(ll) then begin
          ll.valores['Valor Inicial CA'] := strgrana(abs(pRPA.Temp12.VLINICIOCA));
          ll.valores['TxJuros CA'] := realstr(pRPA.Temp12.TxJurosCA);
          if pRPA.Temp12.IndJurosFlutuante > zero then begin
            ll.valores[' ndice de juros fixo CA']  := formatfloat('0.00000000',IndJurosFixoCA);
            ll.valores[' ndice de juros Flutuante']:= formatfloat('0.00000000',pRPA.Temp12.IndJurosFlutuante);
          end;
          if abs(IndJurosProRataCA) > 0 then
            ll.valores['Indice de Juros pro-rata CA'] := realstr(IndJurosProRataCA)
          else
            ll.valores['Indice de Juros Mensal CA'] := realstr(IndJurosCA);
          ll.valores[' ndice de Corre  o mensal'] := realstr(pRPA.FinRPA.TXSD);
          ll.valores['Saldo CA anterior'] := strgrana(SaldoCAAnt);
          ll.valores['CMCA'] := strgrana(pRPA.Temp12.CMCA);
          ll.valores['Saldo CA anterior + CMCA'] := strgrana(SaldoCAAnt+pRPA.Temp12.CMCA);
          ll.valores['Juros CA'] := strgrana(pRPA.Temp12.JurosCA);
          ll.valores['Amort.CA'] := strgrana(pRPA.ValRPA.Amaisj-pRPA.Temp12.JurosCA);
          ll.valores['Saldo CA'] := strgrana(pRPA.Temp12.SaldoCA);
        end;
      end;
    end
    else begin
      pRPA.Temp12.VlInicioCA := 0;
      pRPA.Temp12.TxJurosCA  := 0;
      pRPA.Temp12.SaldoCA    := 0;
      pRPA.Temp12.CMCA       := 0;
      pRPA.Temp12.JurosCA    := 0;
    end;
  end
  else begin
    pRPA.Temp12.VlInicioCA := 0;
    pRPA.Temp12.TxJurosCA  := 0;
    pRPA.Temp12.SaldoCA    := 0;
    pRPA.Temp12.CMCA       := 0;
    pRPA.Temp12.JurosCA    := 0;
  end;
end;

procedure TContrato.EvoluiCA; //Custo Amortizado
var
  i : integer;
begin
  if (Scciconf.DtAssinParaCustoAmortizado.Dia > 0){
     (MutDsk.Cad.TipoCtr <> 48)} {Guarda-chuva} then begin
    if TemFinancDinamico(Mutdsk) then
      EvoluiCASerie(RPAF,FDataUltEventoCASerie,FValAcumJurosIncorpCA,FCorrSaldoAcumAmIncCA,FTxJurosCAProxMes);
    for i := 0 to series.count-1 do
      if (Series[i].Fin.CompoeSaldo or Series[i].Fin.CompoeEntrada) and
         (Series[i].Fin.SistAmort <> SisAmFianca) then
        EvoluiCASerie(Series[i].RPAS,
                      Series[i].FDataUltEventoCASerie,
                      Series[i].FValAcumJurosIncorpCA,
                      Series[i].FCorrSaldoAcumAmIncCA,
                      Series[i].FTxJurosCAProxMes);
  end;
end;

procedure TContrato.EvoluiIFRS9Serie(var pRPA : TpRPA);
var
  IndjurosIFRS9 : real;
  zerooumeio : real;
  Dt1,
  Dt2 : Tdata;
  IndJurosProrata : real;
  IndCMProRata : real;
  idx : integer;
  AmaisjMA : real;
  MacMA : integer;
  NpcMA : integer;
  valor : real;
  DtIniProjIFRS9 : TData;
  DiaEvento : integer;
  SaldoIFRS9Ant : real;
//  ValorAIIFRS9 : real; // TODO
  ll : TLegLinkItem;
  CodSD : integer;
  IncrementoPeriodo : integer;
  RARDMA : real;
  zeror : real;
  indj : real;
  CES1 : real;
  lSerie : TSerie;
  DtComCarencia : TData;
  DataCalculo,
  DtUltReajSD : TData;
  DataRefReaj : Tdata;
  CMAcumulada : real;
  IndInvalido : boolean;
  DtIndInvalido : Tdata;
  Mora,
  JurosContr : real;
begin
  IndInvalido := false;
  DtIndInvalido.dia := 0;
  Mora := 0;
  JurosContr := 0;
  ll := nil;
  zerooumeio := 0.5;
//  RARDMA := 0;
  DtIniProjIFRS9 := Mutdsk.Cad6.DtIniProjIFRS9;
  if DtIniProjIFRS9.dia = 0 then
    DtIniProjIFRS9 := ScciConf.DtIniProjIFRS9;
  SaldoIFRS9Ant := pRPA.Temp12.SaldoIFRS9;
  IndjurosIFRS9 := pRPA.Temp12.TxOriginalCtrIFRS9/1200;
  lSerie := nil;
  if pRPA.Temp8.codserie > 0 then begin
    idx := Series.indexof(pRPA.Temp8.codserie);
    if idx >= 0 then
      lSerie := Series[idx];
  end;
  if (pRPA.finrpa.status > 0) and (pRPA.FinRPA.DiaLiq < pRPA.FinRPA.DiaVenc) then begin
    pRpa.Temp12.SaldoIFRS9 := 0;
    pRpa.Temp12.SaldoProRataIFRS9 := 0;
    pRpa.Temp12.ValPresenteEvAditIFRS9 := 0;
    pRpa.Temp12.JurosProRataIFRS9 := 0;
    pRpa.Temp12.CMProRataIFRS9 := 0;
    pRPA.Temp12.JurosIFRS9 := 0;
    pRPA.Temp12.CMIFRS9 := 0;
  end
  else if((pRPA.FinRPA.ValorAi > zero) and  // amortiza  o
          (pRPA.Temp12.SaldoIFRS9 > zero)) or
         ((pRPA.Temp12.CoEvento in [1,2,3]) and  // alt. tx juros ou renegociacao
           (Mes_int(pRPA.Temp12.DtEvento.mesano)=pRPA.MAC) and
         (Mes_int(pRPA.Temp12.DtEvento.mesano)>=mes_int(DtIniProjIFRS9.mesano))) then begin // novo aditamento
    if not FInibeLegLink then 
      ll := LegLink.Add(pRPA.Temp8.CodSerie,'<b><p>C lculo de novo aditamento/Amortiza  o</b>');
    if Assigned(ll) and (pRPA.Temp8.CodSerie > 0) then
      ll.valores['CodSerie'] := inttostr(pRPA.Temp8.CodSerie);

    if ((pRPA.Temp12.CoEvento in [1,2,3]) and
        (Mes_int(pRPA.Temp12.DtEvento.mesano)=pRPA.MAC) and
        (Mes_int(pRPA.Temp12.DtEvento.mesano)>=mes_int(DtIniProjIFRS9.mesano))) then begin
      DiaEvento := pRPA.Temp12.DtEvento.dia;
      if assigned(ll) then begin
        ll.valores['CoEvento'] := inttostr(pRPA.Temp12.CoEvento);
        ll.valores['DtEvento'] := data_str2(pRPA.Temp12.DtEvento);
        ll.valores['DtIniProjIFRS9'] := data_str2(DtIniProjIFRS9);
      end;
    end
    else begin
      DiaEvento := pRPA.Temp4.DiaAMInc;
      if assigned(ll) then
        ll.valores['DiaAMInc'] := inttostr(pRPA.Temp4.DiaAMInc);
    end;
    pRPA.Temp12.SaldoIFRS9 := 0;
    pRpa.Temp12.ValPresenteEvAditIFRS9 := 0;

    if abs((pRPA.Temp12.TxOriginalCtrIFRS9/1200)-(pRPA.FinRPA.TxJuros/1200)) < zero then begin
      pRPA.Temp12.SaldoIFRS9 := pRpa.ValRpa.SaldoDev;
      pRPA.Temp12.JurosIFRS9 := pRpa.ValRpa.Juro;
      pRPA.Temp12.ValPresenteEvAditIFRS9 := pRpa.ValRpa.SaldoDev;
    end
    else begin
      if FDataRefHist.Dia > 0 then 
        DataCalculo := FDataRefHist
      else 
        DataCalculo := pRPA.Temp12.DtEvento;

      if ( pRPA.Temp12.Reestruturada and 
          (juliano(DataCalculo) <= juliano(scciconf.DtTxJurosContrNaApuracaoDoVPDosReestruturados)) 
         ) then 
        pRPA.Temp12.ValPresenteEvAditIFRS9 := pRpa.ValRpa.SaldoDev
      else if assigned(lSerie) then
        pRPA.Temp12.ValPresenteEvAditIFRS9 := lSerie.ObtemValorPresenteVincendas(pRPA,DiaEvento,Series.FTpJurosTxOriginalCtrIFRS9,
                                                                                 Series.FPerParcelasTxOriginalCtrIFRS9,
                                                                                 Series.FJurosSimplesTxOriginalCtrIFRS9)
      else begin
        AmaisjMA := pRPA.ValRPA.Amaisj;
        RARDMA := pRPA.ValRPA.RARD/1000;
        MacMA := pRPA.Mac;
        NpcMA := pRPA.FinRPA.NPC;

        if DiaEvento >= pRPA.FinRPA.DiaVenc then begin

          // como na sccilib.RecalcPst, exceto o prazo-npc
          zeror := 0.0;
          CES1 := 1.0;
          indj := INDICE_JUROS( pRPA.FinRPA.TxJuros );
          AmaisJMA := VAL_AMAISJ (pRPA.FinRPA.Plano,pRPA.FinRPA.PA,pRPA.FinRPA.Prazo-pRPA.FinRPA.NPC,pRPA.ValRPA.SaldoDev, zeror,indj,CES1,pRPA.Temp6.PercRedAmaisJ);
          RARDMA := CES1*RAZAO (pRPA.FinRPA.Plano,pRPA.FinRPA.Prazo-pRPA.FinRPA.NPC,DetKGrad(pRPA),pRPA.ValRPA.SaldoDev,indj,AmaisJMA,pRPA.Temp6.PercRedAmaisJ);

          inc(MacMA);
          inc(NpcMA);
          IncrementoPeriodo := 0;
        end
        else
          IncrementoPeriodo := 1;
        if assigned(ll) then begin
          ll.valores['Amaisj Inicial('+Mac_Str(MacMA)+')'] := strgrana(AmaisjMA);
          ll.valores['NPC Inicial'] := inttostr(NpcMA);
          ll.valores['Prazo'] := inttostr(pRPA.FinRPA.Prazo);
          ll.valores['IndJurosIFRS9'] := realstr(IndJurosIFRS9);
          ll.valores['MacRecorr'] := intstr(pRPA.ValRPA.MacRecorr);
          ll.valores['Plano'] := inttostr(pRPA.FinRPA.Plano);
          ll.valores['RARDMA'] := formatfloat('0.0000000000',RARDMA);
        end;
        while NpcMA <= pRPA.FinRPA.Prazo do begin
          valor := -PresentValue(IndJurosIFRS9,MacMA - pRPA.MAC + IncrementoPeriodo,0,AmaisjMA,ptEndOfPeriod);
  //        if assigned(ll) then
  //          ll.valores[mac_str(macma)] := 'MacMA='+mac_str(macma)+';npcma='+inttostr(npcma)+';IndJurosIFRS9='+realstr(IndJurosIFRS9)+';periodos='+inttostr(MacMA - pRPA.MAC + IncrementoPeriodo)+';AmaisjMA='+realstr(AmaisJMA)+';vp='+realstr(valor);
          valor := int(valor*100+Zerooumeio)/100;
          pRPA.Temp12.ValPresenteEvAditIFRS9 := pRPA.Temp12.ValPresenteEvAditIFRS9 + valor;
          inc(MacMA);
          inc(NpcMA);
          if ((pRPA.FinRPA.Plano mod 10) <> TP) and (MacMA >= pRPA.ValRPA.MacRecorr) then
            AmaisjMA := AmaisjMA-RARDMA;
        end;
      end;
      pRPA.Temp12.SaldoIFRS9 := pRPA.Temp12.ValPresenteEvAditIFRS9;
      if DiaEvento < pRPA.FinRPA.DiaVenc then
        CalculaEventoVencimentoIFRS9(pRPA);
    end;
    if assigned(ll) then begin
      ll.valores['ValPresenteEvAditIFRS9'] := strgrana(pRPA.Temp12.ValPresenteEvAditIFRS9);
      ll.valores['CMIFRS9'] := strgrana(pRPA.Temp12.CMIFRS9);
      ll.valores['JurosIFRS9'] := strgrana(pRPA.Temp12.JurosIFRS9);
      ll.valores['SaldoIFRS9'] := strgrana(pRPA.Temp12.SaldoIFRS9);
    end;
  end
  else if SaldoIFRS9Ant > zero then begin

    if not FInibeLegLink then 
      ll := LegLink.Add(pRPA.Temp8.CodSerie,'<b><p>Evolu  o do IFRS9</b>');
    if assigned(ll) then begin
      ll.valores['IndJurosIFRS9'] := realstr(IndJurosIFRS9);
      ll.valores['TxSD('+mac_str(pRPA.mac)+')'] := realstr(pRPA.FinRPA.TXSD);
      ll.valores['SaldoIFRS9 anterior'] := strgrana(SaldoIFRS9Ant);
    end;

    CalculaEventoVencimentoIFRS9(pRPA);

    if assigned(ll) then begin
      ll.valores['CMIFRS9'] := strgrana(pRPA.Temp12.CMIFRS9);
      ll.valores['SaldoIFRS9 anterior + CMIFRS9'] := strgrana(pRPA.temp12.SaldoIFRS9);
      ll.valores['JurosIFRS9'] := strgrana(pRPA.Temp12.JurosIFRS9);
      ll.valores['Amaisj('+mac_str(pRPA.MAC)+')'] := strgrana(pRPA.ValRPA.Amaisj);
      ll.valores['SaldoIFRS9 (Saldo corrigido - (Amaisj-JurosIFRS9))'] := strgrana(pRPA.Temp12.SaldoIFRS9);
    end;
  end;
  
  if pRPA.Temp12.SaldoIFRS9 <= zero then
    pRPA.Temp12.SaldoIFRS9 := 0;

  if pRPA.Temp12.SaldoIFRS9 > zero then begin
    Dt1 .dia := pRPA.FinRPA.DiaVenc;
    int_mes(pRPA.Mac,Dt1.mesano);
    Dt2 := Dt1;
    Dt2.dia := Diasmes(Dt1.mesano);
    if (pRPA.finrpa2.SDRata = 128) and (pRPA.FinRpa.CodReaj=23) then CodSD := pRPA.Temp7.CodTabelaGenerica
    else CodSD := pRPA.Temp6.CodReajSD;
    if (CodSD = 0) then CodSD := 100;
    if assigned(lSerie) then
      DataRefReaj := lSerie.Fin.DataRefReaj
    else begin
      DataRefReaj.dia := 0;
      fillchar(DataRefReaj,sizeof(Tdata),0);
    end;
    DtUltReajSD := GetDtUltReajSd(pRPA,Dt1,DataRefReaj,Dt1);
    if Juliano(DtUltReajSD) < Juliano(Dt1) then begin
      if pRPA.Temp8.CodSerie > 0 then
        CMAcumulada := Arredonda((detinddataadata(pRPA.Temp7.CodTabelaGenerica,lSerie.Fin.DefReaj, DtUltReajSD,Dt1{DtVenc},1.0,
                                    lSerie.Fin.CorrProRata,IndInvalido,DtIndInvalido)-1)*pRPA.Temp12.SaldoIFRS9)
      else
        CMAcumulada := CorrecaoJMJCChaves(MutDsk,pRPA.Temp12.SaldoIFRS9,
                                          DtUltReajSD,Dt1{DtVenc},1.0,
                                          199,Mora,JurosContr,
                                          pRPA.Temp10.CodTabGPreChvCorr,
                                          pRPA.Temp7.CodTabelaGenerica,false,
                                          RegCarteira.NaoCobraJurosContr,
                                          0{DefReajPreChvCorr},pRPA.Temp12.DefReajPst);

      if assigned(ll) then begin
        ll.valores['Corre  o acumulada'] := strgrana(CMAcumulada);
      end;
    end
    else
      CMAcumulada := 0;
    indCmprorata := CalcIndiceCorrecaoProRata(Dt1,Dt2,pRPA,ll,pRPA.Temp12.DtEvento.dia<byte(pRPA.finRPA.DiaVenc),true{CorrecaoIFRS9});
    if assigned(ll) then
      ll.valores['Tabela'] := inttostr(CodSD);
    pRPA.Temp12.SaldoProRataIFRS9 := pRPA.Temp12.SaldoIFRS9 + CMAcumulada;
    pRPA.Temp12.CMProRataIFRS9 := int((pRPA.Temp12.SaldoProRataIFRS9*indCMProrata-pRPA.Temp12.SaldoProRataIFRS9)*100+Zerooumeio)/100;
    pRPA.Temp12.SaldoProRataIFRS9 := pRPA.Temp12.SaldoProRataIFRS9 + pRPA.Temp12.CMProRataIFRS9;
    pRPA.Temp12.CMProRataIFRS9 := pRPA.Temp12.CMProRataIFRS9 + CMAcumulada;
    if assigned(lserie) then begin
      DtComCarencia := Dt1;
      if lSerie.Fin.DtCarenciaDeJuros.dia > 0 then
        if Juliano(lSerie.Fin.DtCarenciaDeJuros) > Juliano(Dt1) then
          DtComCarencia := lSerie.Fin.DtCarenciaDeJuros;
      IndJurosProRata := CalcIndiceJurosProRata(IndjurosIFRS9,DtComCarencia,Dt2,
                                                lSerie.Fin.JurosSimples{JurosSimples},
                                                lSerie.Fin.TpJuros=6{ProRataJurosDiasCorridos},
                                                0{DiaVencOrig},
                                                false{ProRataJurosDiasUteis});
    end
    else
      IndJurosProRata := CalcIndiceJurosProRata(IndjurosIFRS9,Dt1,Dt2);
    pRPA.Temp12.JurosProRataIFRS9 := int(pRPA.Temp12.SaldoProRataIFRS9 * IndJurosProRata*100+Zerooumeio)/100;
    if assigned(ll) then begin
      ll.valores['CMProRataIFRS9'] := strgrana(pRPA.Temp12.CMProRataIFRS9);
      ll.valores['IndJurosProRata'] := realstr(IndJurosProRata);
      ll.valores['JurosPorRataIFRS9'] := realstr(pRPA.Temp12.JurosProRataIFRS9);
    end;
    pRPA.Temp12.SaldoProRataIFRS9 := pRPA.Temp12.SaldoProRataIFRS9 + pRPA.Temp12.JurosProRataIFRS9;
    if assigned(ll) then
      ll.valores['SaldoProRataIFRS9'] := strgrana(pRPA.Temp12.SaldoProRataIFRS9);
  end;
  
  if (pRPA.finrpa.status > 0) then begin
    pRpa.Temp12.SaldoProRataIFRS9 := 0;
    pRpa.Temp12.ValPresenteEvAditIFRS9 := 0;
    pRpa.Temp12.JurosProRataIFRS9 := 0;
    pRpa.Temp12.CMProRataIFRS9 := 0;
    pRPA.Temp12.SaldoIFRS9 := 0;
  end;
end;

procedure TContrato.EvoluiIFRS9;
var
  i : integer;
begin
  if TemFinancDinamico(Mutdsk) then
    EvoluiIFRS9Serie(RPAF);
  for i := 0 to series.count-1 do
    EvoluiIFRS9Serie(Series[i].RPAS);
end;

function TContrato.Evolui:TpRpa;
var 
  //CtgMem : TpCtgMem;
  FStatusAnt : shortint;
  FDiaLiqAnt : shortint;
  FMacStatusAnt : smallint;
  CtrSemFinancComSaldoFGTS,
  EvoluiuRPAF   : boolean; 
  i : integer;
  MacAnt : integer;
  ControleFinParcADisposicaoBkp : boolean;
begin
    ControleFinParcADisposicaoBkp := scciconf.ControleFinParcADisposicao;
    scciconf.ControleFinParcADisposicao := (not MutDsk.Cad6.IN_INIBE_DISPOSICAO_PARC) and scciconf.ControleFinParcADisposicao;
    try
      EvoluiuRPAF:= false;
      FStatusAnt := Rpa.FinRpa.Status;
      FMacStatusAnt := Rpa.ValRpa.MacStatus;
      FDiaLiqAnt := Rpa.FinRpa.DiaLiq;
      FCodApoliceMesAnt := Rpa.Temp10.CodApolice;
      MsgErro := '';
      TrocouSerieComDFI := false;
      if Rpa.Ctr <> MutDsk.Cad.Ctr then InicRpa
      else begin
        MacAnt := RPAF.Mac;
        RPA.Temp12.IndSegFinAnt := RPA.FinRPA.IndSegFin;
        RPA.temp12.DESP_TJEO_DIF_ANT  := RPA.Temp12.DESP_TJEO_DIF;
        RPA.temp12.REC_TJEO_DIF_ANT   := RPA.Temp12.REC_TJEO_DIF;
        RPAF.temp12.DESP_TJEO_DIF_ANT := RPA.Temp12.DESP_TJEO_DIF;
        RPAF.temp12.REC_TJEO_DIF_ANT  := RPA.Temp12.REC_TJEO_DIF;
        Series.setaSeriePrincipal(false);
        if TemFinancDinamico(MutDsk) or (Series.Count=0) then begin // Para prever o caso de n o ter serie nem financimento
          if MutDsk.Cad.TipoCtr in EvoPlanoEmpSet then begin
            FSaldoCAAnt := RPAF.Temp12.SaldoCA;
            FOEvolui3.AlertaFaltadeIndiceNoSaldoProRata:= self.FAlertaFaltadeIndiceNoSaldoProRata;
            FOEvolui3.DataRefHist := FDataRefHist;
            FOEvolui3.Evolui(FHEvo,RpaF,LiberacoesPlanoEmp,LaudoVistoria,ContratosCorrelacionados(*$IFDEF CONSOLE*),GrupoImv(*$ENDIF*));
            EvoluiuRPAF := true;
            self.FMsgAlertaFaltadeIndiceNoSaldoProRata := FOEvolui3.MsgAlertaFaltadeIndiceNoSaldoProRata;
          end
          else 
          begin
            CtrSemFinancComSaldoFGTS := ((RPA.Temp7.TipoCtr = 42) and
                                        (not TemFinancDinamico(MutDsk)) and
                                        (Series.Count = 0) and
                                        ((RPA.Temp12.SaldoFGTSVendedores > Zero) or
                                        ((RPA.MAC > 0) and (RPA.MAC = RPA.Temp12.MACLiberacaoVend))));
            if not CtrSemFinancComSaldoFGTS then begin
              FOEvolui3.AlertaFaltadeIndiceNoSaldoProRata:= FAlertaFaltadeIndiceNoSaldoProRata;
              FOEvolui3.MsgAlertaFaltadeIndiceNoSaldoProRata := '';
              FOEvolui3.Evolui(FHEvo,RpaF,
                              nil{LiberacoesPlanoEmp},nil{LaudoVistoria},
                              ContratosCorrelacionados
                              (*$IFDEF CONSOLE*),GrupoImv(*$ENDIF*)); //Sol.43773 Evolui3(CtgMem,FHEvo,RPAF);
              EvoluiuRPAF := true;
              self.MsgAlertaFaltadeIndiceNoSaldoProRata := FOEvolui3.MsgAlertaFaltadeIndiceNoSaldoProRata;
            end;
          end;
        end
        else 
          Series.SetaSeriePrincipal;
        // considerar que a composi  o do Financ. Din mica sempre ser  a certa
        for i := 0 to Series.count-1 do
          CopiaComposicaoRPA(RPAF,Series[i].RPAS);
        series.evolui(FHistMem);
        if (TemVendedores or TemFgtsApoioAConstrucao or (RpaF.Temp12.saldoDiferidoComissao > Zero)) and
          not assigned(Series.SeriePrincipal) and
          not TemFinancDinamico(MutDsk) then 
        begin
          if (RpaF.FinRpa.Npc < RpaF.FinRpa.Prazo) or
            ((RPAF.Temp7.TipoCtr = 42) and (MutDsk.Financ.Prazo = 0) and
              TemVendedores and (RPAF.Temp12.SaldoFgtsVendedores > Zero)) then begin
            inc(RpaF.FinRpa.Npc);
            if (RPAF.Temp7.TipoCtr = 42) and (MutDsk.Financ.Prazo = 0) and
              (RPAF.FinRPA.Prazo < RpaF.FinRpa.Npc) then
              RPAF.FinRPA.Prazo := RpaF.FinRpa.Npc;
          end;
          if not EvoluiuRPAF then inc(RpaF.Mac);
        end;
        if TemVendedores or TemFgtsApoioAConstrucao then
        begin
          EvoluiSaldoVendedores(RpaF);
          if not TemFinancDinamico(MutDsk) then
            CopiaSaldoVendedoresNaSeriePrincipal;
        end;
        EvoluiValoresDespesasComercializacao;
        if MutDsk.Financ.PA = 96 then // Funding FGTS
          EvoluiValoresReceitasComercializacao;
        EvoluiValoresReceitaEDespesaTJEODiferenciada;
        EvoluiValorJusto;
        if RPAF.Mac = MacAnt then // Sol. 83079
          inc(RPAF.Mac);
        EvoluiIFRS9;
        EvoluiCA;
        ConsolidaRPAs;
        //-- Scat72408
        EvoluiValAvalCorrPosTermino(Rpa,RpaF);
        // --- at  aqui
        if (Rpa.FinRpa.Status = 98) and (TemVendedores or TemFgtsApoioAConstrucao) then
        begin
          ZeraSaldoVendedores(Rpa);
          ZeraSaldoVendedores(RpaF);
        end;
      end;
      Rpa.Temp12.StatusAnt := FStatusAnt;
      Rpa.Temp12.MacStatusAnt := FMacStatusAnt;
      Rpa.Temp12.DiaLiqAnt := FDiaLiqAnt;
      result := Rpa;
    finally
      scciconf.ControleFinParcADisposicao := ControleFinParcADisposicaoBkp;
    end;
end;

procedure TContrato.TrataInicioFinancVendedores(var aRpa : tpRPA);
var
  MacIni : integer;
  DiaIni : integer;
begin
  // Sol. 93781 - se zerou o saldovendedores, tenho que iniciar o financ. din mico do PA=40
  // Sol. 95832 - se uma libera  o parcial indica o in cio do empr stimo, tamb m quero setar a dtinfin
  //              n o quero reiniciar o contrato, caso a maciniciaemprestimo seja outro mac
  //              evitando assim que a libera  o total ap s uma parcial reinicie a dtinfin
  if (aRpa.FinRPA.PA = 40) and 
     (((aRpa.Temp12.saldoVendedores <= zero) and 
       (aRpa.Temp12.DiaLiberacaoVendedores > 0)) or
       ((aRpa.Temp12.MacIniciaEmprestimo > 0) and 
        (aRpa.Temp12.MacIniciaEmprestimo = aRpa.Mac) and 
        (DiaLiberacaoParcialIniciaEmprestimo > 0))) then begin 
    if (aRpa.Temp12.DtInFinOrig.mes=0) and  // se o usu rio n o informou a dtinfin, eu inicializao ela com a libera  o
       ((aRpa.Temp12.MacIniciaEmprestimo=0) or (aRpa.Temp12.MacIniciaEmprestimo=aRpa.Mac)) then begin
      MacIni := aRpa.Temp12.MACLiberacaoVend;
      DiaIni := aRpa.Temp12.DiaLiberacaoVendedores;
      if (MacIni=0) or ((aRpa.Temp12.MacIniciaEmprestimo>0) and (aRpa.Temp12.MacIniciaEmprestimo<MacIni)) then begin
        MacIni := aRpa.Temp12.MacIniciaEmprestimo;
        DiaIni := DiaLiberacaoParcialIniciaEmprestimo;
      end;  
// 101937 - ajustar o in cio, igual feito na TEvolui3.TrataInicioFLuxoVendedores
//      int_mes(MacIni+aRpa.Temp12.PrzCaramort,aRpa.FinRPA.DtInFin.mesano);
      if (MacIni > 0) and 
        ScciConf.IniciaAmortMin30diasDaLiberacao and
        (DiaIni > aRPA.finrpa.DiaVenc) then // respeitar sol. 97515, se a libera  o for ap s o vencimento, precisa incrementar o m s de in cio
        inc(MacIni);
      int_mes(MacIni,aRpa.FinRPA.DtInFin.mesano);
      aRpa.FinRPA.DtInFin.dia := DiaIni;
      if aRpa.Temp12.DtInFinOrig.dia > 0 then // 93781 - se foi informado um diavenc no cadastro, quero respeitar
        aRpa.FinRPA.DtInFin.dia := aRpa.Temp12.DtInFinOrig.dia;
      if aRpa.FinRPA.DtInFin.Dia > DiasMes(aRpa.FinRPA.DtInFin.MesAno) then
        aRpa.FinRPA.DtInFin.Dia := DiasMes(aRpa.FinRPA.DtInFin.MesAno);
    end;
{$IFDEF FPC}
    FOEvolui3.RedefinePeriodoCarenciaAmort(aRPA); // 108249
{$ENDIF}    
  end;  
end;

function TContrato.DiaLiberacaoParcialIniciaEmprestimo : integer;
var
  i : integer;
begin
  result := 0;
  i := 0;
  while (i < OEvolui3.ListaEventosAmInc.Count) do begin
    if (OEvolui3.ListaEventosAmInc[i].DiaEvento > 0) and
        (OEvolui3.ListaEventosAmInc[i].ExOpc   = 0) and
        (OEvolui3.ListaEventosAmInc[i].ExAmInc = 102) and 
        ((result = 0) or (OEvolui3.ListaEventosAmInc[i].DiaEvento < result)) and
        (OEvolui3.ListaEventosAmInc[i].IniciaEmprestimo) and
      ( (FDataRefHist.Dia = 0) or 
        ((OEvolui3.ListaEventosAmInc[i].MACEvento > 0) and 
      ( (OEvolui3.ListaEventosAmInc[i].MACEvento < Mes_Int(FDataRefHist.MesAno)) or
        ((OEvolui3.ListaEventosAmInc[i].MACEvento=Mes_Int(FDataRefHist.MesAno)) and
        (OEvolui3.ListaEventosAmInc[i].DiaEvento <= FDataRefHist.Dia)) )
        )
      ) then 
      result := OEvolui3.ListaEventosAmInc[i].DiaEvento;
    inc(i);  
  end;    
end;

procedure TContrato.AmortizaSaldoVendedores(var aRpa:TpRpa; JaCalculouJurosECorrecao : boolean = true);
var
  DtVenc     : TData;
  DiaLibAnt,
  i          : integer;
  SaldoAnt,
  ValorAm    : real;
begin
  if Scciconf.UsaLiberacaoIndividualizadaVendedores and
    ((aRpa.Temp12.LibParcialVend > zero) or 
     (aRpa.Temp12.LibParcialFGTSVend > zero)) then begin
    DiaLibAnt := aRpa.Temp12.DiaLiberacaoVendedores;
    for i := 0 to OEvolui3.ListaEventosAmInc.Count-1 do 
      if (OEvolui3.ListaEventosAmInc[i].DiaEvento > 0) and
         (OEvolui3.ListaEventosAmInc[i].ExOpc   = 0) and
         (OEvolui3.ListaEventosAmInc[i].ExAmInc in [0,102]) and // 93781 - a libera  o parcial vem com examinc=102
        ( (FDataRefHist.Dia = 0) or 
         ((OEvolui3.ListaEventosAmInc[i].MACEvento > 0) and 
        ( (OEvolui3.ListaEventosAmInc[i].MACEvento < Mes_Int(FDataRefHist.MesAno)) or
         ((OEvolui3.ListaEventosAmInc[i].MACEvento=Mes_Int(FDataRefHist.MesAno)) and
          (OEvolui3.ListaEventosAmInc[i].DiaEvento <= FDataRefHist.Dia)) )
         )
        ) then begin
        Int_Mes(aRpa.MAC,DtVenc.MesAno);
        DtVenc.Dia := aRpa.FinRPA.DtAssin.Dia;
        if DtVenc.Dia > DiasMes(Mes_Int(DtVenc.MesAno)) then 
          DtVenc.Dia := DiasMes(Mes_Int(DtVenc.MesAno));
        if juliano(DtVenc) < juliano(aRpa.FinRPA.DtAssin) then
          DtVenc := aRpa.FinRPA.DtAssin;
        if OEvolui3.ListaEventosAmInc[i].IniciaEmprestimo then
          aRPA.Temp12.DiaIniciaEmprestimo := OEvolui3.ListaEventosAmInc[i].DiaEvento;
        if (OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores > zero) and
         (
          (JaCalculouJurosECorrecao and (OEvolui3.ListaEventosAmInc[i].DiaEvento >= DtVenc.Dia))
                                  or 
          (not JaCalculouJurosECorrecao and (OEvolui3.ListaEventosAmInc[i].DiaEvento < DtVenc.Dia)) 
         ) then begin
          if OEvolui3.ListaEventosAmInc[i].SomaIOFNaAmVendedor then // 95808 
            ValorAm := Arredonda(OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores - 
                                (OEvolui3.ListaEventosAmInc[i].CMProRataLiberacaoParcialVendedores+
                                OEvolui3.ListaEventosAmInc[i].JurProRataLiberacaoParcialVendedores-
                                OEvolui3.ListaEventosAmInc[i].ValIOFEGI))
          else                      
            ValorAm := Arredonda(OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores - 
                                (OEvolui3.ListaEventosAmInc[i].CMProRataLiberacaoParcialVendedores+
                                OEvolui3.ListaEventosAmInc[i].JurProRataLiberacaoParcialVendedores));
          SaldoAnt := aRpa.Temp12.SaldoVendedores;
          aRpa.Temp12.ValIOFEGI := aRpa.Temp12.ValIOFEGI + OEvolui3.ListaEventosAmInc[i].ValIOFEGI; // 98479
          aRpa.Temp12.SaldoVendedores   := arredonda(aRpa.Temp12.SaldoVendedores - ValorAm);
          aRpa.Temp12.JurProRataVendedor:= OEvolui3.ListaEventosAmInc[i].JurProRataLiberacaoParcialVendedores;
          aRpa.Temp12.CMProRataVendedor := OEvolui3.ListaEventosAmInc[i].CMProRataLiberacaoParcialVendedores;
          if aRpa.Temp12.SaldoVendedores < zero then 
            aRpa.Temp12.SaldoVendedores := 0;         
          if (Abs(aRpa.Temp12.SaldoVendedores) <= DifDesprezivelSdVend) and
             (aRpa.Temp12.DiaLiberacaoVendedores = 0) then begin
            OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores := OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores;
            if (aRpa.Temp12.CMProRataVendedor > zero) or
               (abs(aRpa.Temp12.JurProRataVendedor) <= Zero) then 
              aRpa.Temp12.CMProRataVendedor := arredonda(aRpa.Temp12.CMProRataVendedor - aRpa.Temp12.SaldoVendedores)
            else
              aRpa.Temp12.JurProRataVendedor:= arredonda(aRpa.Temp12.JurProRataVendedor- aRpa.Temp12.SaldoVendedores);
            aRpa.Temp12.SaldoVendedores        := 0;
            aRpa.Temp12.LiberacaoVendedores    := Arredonda(aRpa.Temp12.LiberacaoVendedores+OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores);
            aRpa.Temp12.LibParcialVend         := Arredonda(aRpa.Temp12.LibParcialVend - ValorAm {OEvolui3.ListaEventosAmInc[i].LiberacaoParcialVendedores}); //troquei pq preciso de uma var. com o somat rio de tudo que foi amortizado do saldoVendedor
            aRpa.Temp12.DiaLiberacaoVendedores := OEvolui3.ListaEventosAmInc[i].DiaEvento;
            aRpa.Temp12.MACLiberacaoVend       := aRPA.MAC;
            if JaCalculouJurosECorrecao then begin  // a rotina est  sendo chamada no final da EvoluiSaldoVendedores, onde j  calculou corr e juros do m s. Somo os proratas aqui, do contr rio estes n o ser o apurados
              aRpa.Temp12.CorrecaoVendedores := Arredonda(aRpa.Temp12.CorrecaoVendedores + aRpa.Temp12.CMProRataVendedor);
              aRpa.Temp12.JurosVendedores    := Arredonda(aRpa.Temp12.JurosVendedores + aRpa.Temp12.JurProRataVendedor);
            end
            else 
              aRpa.Temp12.SaldoVendedores    := SaldoAnt; //isso significa que a rotina foi chamada antes de apurar corr e juros dos Saldos Vendedores
          end;                                            //por isso retorno o  ltimo saldo antes da  ltima lib.parcial tratada para que os juros e correcao e proratas
        end;                                              //possam ser apurados na TContrato.EvoluiSaldoVendedores
        if aRPA.Temp12.DtFGTSEntrada.Dia > 0 then begin
          Int_Mes(aRpa.MAC,DtVenc.MesAno);
          DtVenc.Dia := aRPA.Temp12.DtFGTSEntrada.Dia;
          if DtVenc.Dia > DiasMes(DtVenc.MesAno) then
            DtVenc.Dia := DiasMes(DtVenc.MesAno);
          if juliano(DtVenc) < juliano(aRpa.Temp12.DtFGTSEntrada) then
            DtVenc := aRpa.Temp12.DtFGTSEntrada;
 
          if (OEvolui3.ListaEventosAmInc[i].LiberacaoParcialFGTSVendedores > zero) and
         (
          (JaCalculouJurosECorrecao and (OEvolui3.ListaEventosAmInc[i].DiaEvento >= DtVenc.Dia))
                                  or 
          (not JaCalculouJurosECorrecao and (OEvolui3.ListaEventosAmInc[i].DiaEvento < DtVenc.Dia)) 
         ) then begin
            ValorAm := Arredonda(OEvolui3.ListaEventosAmInc[i].LiberacaoParcialFGTSVendedores - 
                                (OEvolui3.ListaEventosAmInc[i].CMProRataLiberacaoParcialFGTSVendedores+
                                 OEvolui3.ListaEventosAmInc[i].JurProRataLiberacaoParcialFGTSVendedores));
            SaldoAnt := aRpa.Temp12.SaldoFGTSVendedores;
            aRpa.Temp12.SaldoFGTSVendedores   := Arredonda(aRpa.Temp12.SaldoFGTSVendedores - ValorAm);
            aRpa.Temp12.JurProRataFGTSVendedor:= OEvolui3.ListaEventosAmInc[i].JurProRataLiberacaoParcialFGTSVendedores;
            aRpa.Temp12.CMProRataFGTSVendedor := OEvolui3.ListaEventosAmInc[i].CMProRataLiberacaoParcialFGTSVendedores;

            if aRpa.Temp12.SaldoFGTSVendedores < zero then 
              aRpa.Temp12.SaldoFGTSVendedores := 0;         
            if (Abs(aRpa.Temp12.SaldoFGTSVendedores) <= DifDesprezivelSdVend) and
               (DiaLibAnt = 0) then begin
              aRpa.Temp12.LiberacaoFGTSVendedores := Arredonda(aRpa.Temp12.LiberacaoFGTSVendedores+OEvolui3.ListaEventosAmInc[i].LiberacaoParcialFGTSVendedores);
              aRpa.Temp12.LibParcialFGTSVend      := Arredonda(aRpa.Temp12.LibParcialFGTSVend - ValorAM{OEvolui3.ListaEventosAmInc[i].LiberacaoParcialFGTSVendedores});
              if aRpa.Temp12.LibParcialFGTSVend <= zero then 
                aRpa.Temp12.LibParcialFGTSVend      := 0;
              if (aRpa.Temp12.CMProRataFGTSVendedor > zero) or
                 (abs(aRpa.Temp12.JurProRataFGTSVendedor) <= Zero) then 
                aRpa.Temp12.CMProRataFGTSVendedor := arredonda(aRpa.Temp12.CMProRataFGTSVendedor - aRpa.Temp12.SaldoFGTSVendedores)
              else
                aRpa.Temp12.JurProRataFGTSVendedor:= arredonda(aRpa.Temp12.JurProRataFGTSVendedor- aRpa.Temp12.SaldoFGTSVendedores);
              aRpa.Temp12.SaldoFGTSVendedores        := 0;

              aRpa.Temp12.DiaLiberacaoVendedores    := OEvolui3.ListaEventosAmInc[i].DiaEvento;
              aRpa.Temp12.MACLiberacaoVend          := aRPA.MAC;
              if JaCalculouJurosECorrecao then begin
                aRpa.Temp12.CorrecaoFGTSVendedores := Arredonda(aRpa.Temp12.CorrecaoFGTSVendedores + aRpa.Temp12.CMProRataFGTSVendedor);
                aRpa.Temp12.JurosFGTSVendedores    := Arredonda(aRpa.Temp12.JurosFGTSVendedores + aRpa.Temp12.JurProRataFGTSVendedor);
              end
              else 
                aRpa.Temp12.SaldoFGTSVendedores := SaldoAnt;
            end;
          end;   
        end;
      end; //if
  end;  
end;

procedure TContrato.PrimeiraFaseVendedores(var aRpa:TpRpa);
var
  i: integer;
  HistMes: TpHistEvo;
begin
  HistMes[0].Tam := 0;
  fillchar(HistMes,sizeof(HistMes),0);
  Obtem_hist_mes(aRPA, HEvo, HistMes);
  for I := 1 to HistMes[0].Tam do 
  begin
    OEvolui3.ListaEventosAmInc.InicializaDadosAmInc(HistMes[i].Ficha);
    with HistMes[I].Ficha do 
    begin
      case Campo of
        283: aRpa.Temp11.ValorAIEmprestimo := ValReal;
        286: aRpa.Temp11.ValorTaxaReneg    := ValReal;
        287: aRpa.Temp11.AplicaLimSobreTotPrest := ValByte;
        288: aRpa.Temp11.DtPagValDifPrest := ValData;
        292: aRpa.Temp12.LiberacaoFGTSVendedores := ValReal;
        293: aRpa.Temp12.LiberacaoVendedores := Arredonda(aRpa.Temp12.LiberacaoVendedores + ValReal);
        294: begin
               aRpa.Temp12.DiaLiberacaoVendedores := ValIntg;
               aRpa.Temp12.MACLiberacaoVend       := aRPA.MAC;
             end;
        300: aRpa.Temp12.IntervenienteQuitante := ValIntg;
        359: begin
               aRpa.Temp12.DiaLiberacaoFGTSConst := ValIntg;
               aRpa.Temp12.MACLiberacaoFGTSConst := aRPA.MAC;
             end;
        362: aRpa.Temp12.LibParcialVend :=  Arredonda(aRpa.Temp12.LibParcialVend + valReal);
        363: aRpa.Temp12.LibParcialFGTSVend := Arredonda(aRpa.Temp12.LibParcialFGTSVend + valReal);
        365, 
        366: aRpa.Temp12.LibParcialVend :=  Arredonda(aRpa.Temp12.LibParcialVend - ValReal);
        367,
        368: aRpa.Temp12.LibParcialFGTSVend := Arredonda(aRpa.Temp12.LibParcialFGTSVend - ValReal);
      end; { case }
    end; { with }
  end; { for }
end;


procedure TContrato.EvoluiValoresDespesasComercializacao;
var
  PrazoDiferimento : smallint;
begin
  RpaF.Temp12.valApropComissao := 0;  
  if RpaF.Temp12.saldoDiferidoComissao > Zero then
  begin
    if not TemFinancDinamico(MutDsk) then
    begin
      if assigned(Series.SeriePrincipal) then
      begin
        RpaF.FinRpa.Npc       := Series.SeriePrincipal.Rpas.FinRpa.Npc;
        RpaF.FinRpa.Prazo     := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
        RPAF.FinRPA.DiaVenc   := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
        RPAF.Temp12.DiaLiqAnt := RPAF.FinRpa.DiaLiq;
        RPAF.FinRPA.DiaLiq    := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
        RPAF.Temp12.MacStatusAnt := RPAF.ValRpa.MacStatus;
        RPAF.ValRPA.MACStatus := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
        RPAF.Temp12.StatusAnt := RPAF.FinRpa.Status;
        RPAF.FinRPA.Status    := Series.SeriePrincipal.RpaS.FinRPA.Status;
        RpaF.Mac              := Series.SeriePrincipal.Rpas.Mac;
      end
      else 
      begin //   necess rio ter um financiamento din mico ou s rie principal 
            // para evolu  o de despesas. Caso n o tenha, deve-se excluir 
            // a despesa de comercializa  o.
            // Alterei para n o atribuir 98 se for no m s do TPZ - solic 55168 
        if RpaF.Finrpa.Prazo-RpaF.FinRpa.NPC > 0 then 
          RpaF.FinRpa.Status := 98
        else RpaF.FinRpa.Status := 8;
      end;
    end;

    PrazoDiferimento := Rpaf.FinRpa.Prazo;
    if (RpaF.FinRpa.DtAssin.ano > 114) and
      ((RpaF.FinRpa.DtAssin.Ano < 117) or 
       (not Scciconf.Difere100PorCentoDasDespesasDeComissao)) then begin
      PrazoDiferimento := min(Rpaf.FinRpa.Prazo,36);
      PrazoDiferimento := PrazoDiferimento - RpaF.FinRpa.Npc + 1;
    end
    else if (scciconf.MACDeRecalculoDeComissaoLegado > 0) and
            (RPAF.MAC >= scciconf.MACDeRecalculoDeComissaoLegado) then 
      PrazoDiferimento := min(Rpaf.FinRpa.Prazo - RpaF.FinRpa.Npc + 1,
                              1440-RpaF.Mac+1) (* 12/2019 *)
    else
      PrazoDiferimento := PrazoDiferimento - RpaF.FinRpa.Npc + 1;
    if (RpaF.FinRpa.Status = 0) and (PrazoDiferimento > 0) then
      RpaF.Temp12.valApropComissao := Arredonda(RpaF.temp12.saldoDiferidoComissao / PrazoDiferimento)
    else
      RpaF.Temp12.valApropComissao := RpaF.temp12.saldoDiferidoComissao;

{---------------c digo anterior, mantive por enquanto---------------------
    PrazoDiferimento := Rpaf.FinRpa.Prazo;
    if RpaF.FinRpa.DtAssin.ano > 114 then PrazoDiferimento := min(PrazoDiferimento,36);
    if (RpaF.FinRpa.Status = 0) and ((PrazoDiferimento - RpaF.FinRpa.Npc + 1) > 0) then
      RpaF.Temp12.valApropComissao := Arredonda(RpaF.temp12.saldoDiferidoComissao / 
        (PrazoDiferimento - RpaF.FinRpa.Npc + 1))
    else
      RpaF.Temp12.valApropComissao := RpaF.temp12.saldoDiferidoComissao;
-------------------------------------------------------------------------}
    RpaF.temp12.saldoDiferidoComissao := 
      Arredonda(RpaF.temp12.saldoDiferidoComissao - RpaF.Temp12.valApropComissao);
    if abs(RpaF.temp12.saldoDiferidoComissao) < Zero then
      RpaF.temp12.saldoDiferidoComissao := 0;
    if RpaF.FinRpa.Status = 98 then RpaF.Temp12.valApropComissao := 0;
  end
  else if (not TemFinancDinamico(MutDsk)) and (DespesasComercializacao.Count > 0) then begin
    if assigned(Series.SeriePrincipal) then begin
      RpaF.FinRpa.Npc       := Series.SeriePrincipal.Rpas.FinRpa.Npc;
      RpaF.FinRpa.Prazo     := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
      RPAF.FinRPA.DiaVenc   := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
      RPAF.Temp12.DiaLiqAnt := RPAF.FinRpa.DiaLiq;
      RPAF.FinRPA.DiaLiq    := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
      RPAF.Temp12.MacStatusAnt := RPAF.ValRpa.MacStatus;
      RPAF.ValRPA.MACStatus := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
      RPAF.Temp12.StatusAnt := RPAF.FinRpa.Status;
      RPAF.FinRPA.Status    := Series.SeriePrincipal.RpaS.FinRPA.Status;
      RpaF.Mac              := Series.SeriePrincipal.Rpas.Mac;
    end
    else if (not TemVendedores) and (not TemFgtsApoioAConstrucao) then begin
      if RpaF.FinRpa.Npc < RpaF.FinRpa.Prazo then inc(RpaF.FinRpa.Npc);
      inc(RpaF.Mac);
    end;
  end;
end;

procedure TContrato.EvoluiValoresReceitasComercializacao;
var
  SaldoSemCorrecao,
  PercDifJuros     : Double;
begin
  if RpaF.Temp3.IndSaldoAcum > 0.5 then // Para n o dar divis o por zero
    SaldoSemCorrecao := RpaF.Temp.SalDevAnt / RpaF.Temp3.IndSaldoAcum
  else
    SaldoSemCorrecao := RpaF.Temp.SalDevAnt;

  // Todo: 2.16   o deferencial de juros e deve ir para o Cadmut.
  if MutDsk.Cad6.PeDifJurosFGTS > zero then
    PercDifJuros := MutDsk.Cad6.PeDifJurosFGTS
  else PercDifJuros := 2.16;
  RpaF.Temp12.ValDifJurosFGTS := arredonda(SaldoSemCorrecao * (PercDifJuros / 1200));

  // Taxa de administra  o funding FGTS
  // Na vari vel ValDescTaxaFGTS o c lculo   com precis o
  if rpa.finrpa.npc > 0 then 
  begin
    FTaxaAdmFundingFgtsMensal := FTaxaAdmFundingFgtsMensal / 
      (1+FTaxaDescaptalizacaoTaxaAdmFundingFgts/1200);
    RpaF.Temp12.ValDescTaxaFGTS := arredonda(FTaxaAdmFundingFgtsMensal);
  end;

  if RpaF.Temp12.SaldoDifJurosFGTS < RpaF.Temp12.ValDifJurosFGTS then
    RpaF.Temp12.ValDifJurosFGTS := RpaF.Temp12.SaldoDifJurosFGTS;
  RpaF.Temp12.SaldoDifJurosFGTS := RpaF.Temp12.SaldoDifJurosFGTS - RpaF.Temp12.ValDifJurosFGTS;
  if  RpaF.Temp12.SaldoDescTaxaFGTS < RpaF.Temp12.ValDescTaxaFGTS then
    RpaF.Temp12.ValDescTaxaFGTS := RpaF.Temp12.SaldoDescTaxaFGTS;
  RpaF.Temp12.SaldoDescTaxaFGTS := RpaF.Temp12.SaldoDescTaxaFGTS - RpaF.Temp12.ValDescTaxaFGTS;

end;

procedure TContrato.EvoluiValoresReceitaEDespesaTJEODiferenciada;

    function GetPrazoRemanAnt : integer;
    var
      ValoresMA : TValoresPorMAC;
      RPAAux    : TpRPA;
    begin
      Result    := 0;
      ValoresMA := nil;
      RPAAux.Ctr := ''; fillchar(RPAAux,sizeof(RPAAux),0);
      if TemFinancDinamico(MutDsk) then begin
        RPAAux := RPAF;
        if (RPAF.FinRPA.NPC <= 1) and 
           (RPAF.MAC-1 <= Mes_Int(RPAF.FinRPA.DtInFin.MesAno)) then
          Result := RPAF.FinRPA.Prazo
        else if assigned(SerieF) then 
          ValoresMA := self.SerieF.ObtemValoresPorMAc(RPAF.MAC-1);

      end else if assigned(Series.SeriePrincipal) then begin
        RPAAux := Series.SeriePrincipal.RPAS;
        if (Series.SeriePrincipal.RPAS.FinRPA.NPC <= 1) and
           (Series.SeriePrincipal.RPAS.MAC-1 <= 
            Mes_Int(Series.SeriePrincipal.RPAS.FinRPA.DtInFin.MesAno)) then
          Result := Series.SeriePrincipal.RPAS.FinRPA.Prazo
        else 
          ValoresMA := Series.SeriePrincipal.ObtemValoresPorMAc(Series.SeriePrincipal.RPAS.MAC-1);
      end;
      if (Abs(Result) <= zero) and assigned(ValoresMA) then begin
         if (ValoresMA.NPC = 0) and 
            (ValoresMA.MAC <= Mes_Int(ValoresMA.DtInFin.MesAno)) then
           Result := ValoresMA.Prazo
         else if (ValoresMA.NPC = 1) or 
                 (ValoresMA.Prazo = RpaAux.FinRPA.Prazo) and
                 (ValoresMA.NPC+1 = RpaAux.FinRPA.NPC  ) then 
           Result := ValoresMA.Prazo - ValoresMA.NPC
         else 
           Result := ValoresMA.PrestReman;
      end;
      if Result  < 0 then Result := 0
    end; // fim da GetPrazoRemanAnt

    procedure TrataEventosAmIncReceitaEDespesa(    ListaEventosAmInc    : TListaEventosAmInc; 
                                               var RPA                  : TpRPA;
                                                   NoEPosVenc           : boolean = false);
    var
      i            : integer;
      DtVenc,
      DtEvento     : TData;
      SaldoAnt,
      IndReducao   : real;
      leglinkItem  : TLegLinkItem;
    begin
      if Scciconf.MetodologiaDiferenciadaRecReceita and
        ((RPA.Temp12.DESP_TJEO_DIF > zero) or 
         (RPA.TEMP12.REC_TJEO_DIF  > Zero)) and
         (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and   //Tem custo Amortizado ?
         (juliano(self.RPA.FinRPA.DtAssin) >= juliano(scciconf.DtAssinParaCustoAmortizado)) then begin
        leglinkItem := nil;
  
        DtVenc.Dia := RPA.FinRPA.DiaVenc;
        Int_Mes(RPA.MAC,DtVenc.MesAno);
        if (RPA.FinRPA.Status <> 0) and (RPA.ValRPA.MACStatus > 0) and
          ((RPA.ValRPA.MACStatus < Mes_Int(DtVenc.MesAno)) or 
          ((RPA.ValRPA.MACStatus = Mes_Int(DtVenc.MesAno)) and 
           (byte(RPA.FinRPA.DiaLiq) < DtVenc.Dia))) then begin
          Int_Mes(RPA.ValRPA.MACStatus,DtVenc.MesAno);
          if RPA.FinRPA.DiaLiq > 0 then 
            DtVenc.Dia := RPA.FinRPA.DiaLiq
          else
            DtVenc.Dia := RPA.FinRPA.DiaVenc;
        end;
        Int_Mes(RPA.MAC,DtEvento.MesAno);
        for i := 0 to ListaEventosAmInc.Count-1 do begin
          DtEvento.Dia := ListaEventosAmInc[i].DiaEvento;
          if ((ListaEventosAmInc[i].ExAmInc in [21,35,103,105,114,121]) or //Amex e Sin.Parcial = 35
              (ListaEventosAmInc[i].ExOpc = 35)) 
                                 and
              (not ListaEventosAmInc[i].MarcaDat) 
                                 and
             (
              (((Juliano(DtEvento) < juliano(DtVenc)) and (not NoEPosVenc))
                           or
               ((Juliano(DtEvento) >= Juliano(DtVenc)) and NoEPosVenc))
             )
                                 and
             ((Juliano(DtEvento) > juliano(RPA.FinRPA.DtAssin)) or
              (RPA.FinRPA.Status <> 20) or (RPA.Temp7.TipoCtr <> 45)) then begin
  
            if not FInibeLegLink then begin
              if ListaEventosAmInc[i].ExOpc = 35 then 
                leglinkItem := LegLink.Add(0,'<br><b>'+DescrEventosExAmInc(ListaEventosAmInc[i].ExOpc,NoEPosVenc)+' </b><br>')
              else
                leglinkItem := LegLink.Add(0,'<br><b>'+DescrEventosExAmInc(ListaEventosAmInc[i].ExAmInc,NoEPosVenc)+' </b><br>');
            end;
  
            if assigned(legLinkItem) then begin
              leglinkItem.Valores['<b>Dia Evento</b>'] := intstr(ListaEventosAmInc[i].DiaEvento);
              leglinkItem.valores['M s/Ano Ref.'] := mac_str(rpa.mac);
              leglinkItem.Valores['Saldo de Receita TJEO Diferenciada antes do evento'] := strgrana(RPA.Temp12.REC_TJEO_DIF);
              leglinkItem.Valores['Saldo de Despesa TJEO Diferenciada antes do evento'] := strgrana(RPA.Temp12.DESP_TJEO_DIF);
            end;
            if ((ListaEventosAmInc[i].ExAmInc in [21,103,105,114,121]) and {Amex}
                (Abs(ListaEventosAmInc[i].ValorAmInc) >  zero))
                                   or
               ((ListaEventosAmInc[i].ExAmInc = 35) or 
                (ListaEventosAmInc[i].ExOpc   = 35)) and { S.Parcial }
                (ListaEventosAmInc[i].PerSin > zero) then begin
              IndReducao := 0;
              if ((ListaEventosAmInc[i].ExAmInc = 35) or 
                  (ListaEventosAmInc[i].ExOpc   = 35)) and { S.Parcial }
                  (ListaEventosAmInc[i].PerSin > zero) then
                IndReducao := ListaEventosAmInc[i].PerSin/10000
              else if ListaEventosAmInc[i].SaldoDevAntes > zero then
                IndReducao := Abs(ListaEventosAmInc[i].ValorAINoVencto)/ListaEventosAmInc[i].SaldoDevAntes
              else if Abs(ListaEventosAmInc[i].ValorAINoVencto)+ListaEventosAmInc[i].NovoSaldoNoVencto > zero then 
                IndReducao := ListaEventosAmInc[i].ValorAINoVencto/ListaEventosAmInc[i].NovoSaldoNoVencto+Abs(ListaEventosAmInc[i].ValorAINoVencto);
              ListaEventosAmInc[i].IndRedDesp := IndReducao;
              ListaEventosAmInc[i].IndRedRec  := IndReducao;
              if RPA.Temp12.DESP_TJEO_DIF > zero then begin
                SaldoAnt := RPA.Temp12.DESP_TJEO_DIF;
                ListaEventosAmInc[i].ValorAmIncDesp := arredonda(RPA.Temp12.REC_TJEO_DIF*IndReducao);
                RPA.Temp12.DESP_TJEO_DIF := arredonda(RPA.Temp12.DESP_TJEO_DIF-ListaEventosAmInc[i].ValorAmIncDesp);
                if RPA.Temp12.DESP_TJEO_DIF < zero then begin
                  ListaEventosAmInc[i].ValorAmIncDesp := arredonda(ListaEventosAmInc[i].ValorAmIncDesp+RPA.Temp12.DESP_TJEO_DIF);
                  if SaldoAnt > zero then 
                    ListaEventosAmInc[i].IndRedDesp := ListaEventosAmInc[i].ValorAmIncDesp/SaldoAnt;
                  RPA.Temp12.DESP_TJEO_DIF := 0;
                end;
              end;
              if RPA.Temp12.REC_TJEO_DIF > zero then begin
                SaldoAnt := RPA.Temp12.REC_TJEO_DIF;
                ListaEventosAmInc[i].ValorAmIncRec := arredonda(RPA.Temp12.REC_TJEO_DIF*IndReducao);
                RPA.Temp12.REC_TJEO_DIF  := arredonda(RPA.Temp12.REC_TJEO_DIF-ListaEventosAmInc[i].ValorAmIncRec);
                if RPA.Temp12.REC_TJEO_DIF <= zero then begin
                  ListaEventosAmInc[i].ValorAmIncRec := arredonda(ListaEventosAmInc[i].ValorAmIncRec+RPA.Temp12.REC_TJEO_DIF);
                  if SaldoAnt > zero then
                    ListaEventosAmInc[i].IndRedRec := ListaEventosAmInc[i].ValorAmIncRec/SaldoAnt;
                  RPA.Temp12.REC_TJEO_DIF := 0;
                end;
              end;
              if assigned(legLinkItem) then begin
                leglinkItem.Valores['Valor da Amortiza  o do Saldo devedor'] := strgrana(ListaEventosAmInc[i].ValorAmInc);
                leglinkItem.Valores['Valor da Amortiza  o do Saldo de Receita TJEO Diferenciada'] := Strgrana(ListaEventosAmInc[i].ValorAmIncRec);
                leglinkItem.Valores['Valor da Amortiza  o do Saldo de Despesa TJEO Diferenciada'] := strGrana(ListaEventosAmInc[i].ValorAmIncDesp);
                leglinkItem.Valores['Valor do  ndice de redu  o'] := formatfloat('0.00000000',IndReducao);
                leglinkItem.Valores['Saldo de Receita TJEO Diferenciada no evento'] := strgrana(RPA.Temp12.REC_TJEO_DIF);
                leglinkItem.Valores['Saldo de Despesa TJEO Diferenciada no evento'] := strgrana(RPA.Temp12.DESP_TJEO_DIF);
              end;
            end
            else if (ListaEventosAmInc[i].ExAmInc = 35) or 
                    (ListaEventosAmInc[i].ExOpc   = 35) and { S.Parcial }
                    (ListaEventosAmInc[i].PerSin > zero) then begin
              IndReducao := ListaEventosAmInc[i].PerSin/10000;
              ListaEventosAmInc[i].IndRedDesp := IndReducao;
              ListaEventosAmInc[i].IndRedRec  := IndReducao;
              if RPA.Temp12.DESP_TJEO_DIF > zero then begin
                SaldoAnt := RPA.Temp12.DESP_TJEO_DIF;
                ListaEventosAmInc[i].ValorAmIncDesp := arredonda(RPA.Temp12.REC_TJEO_DIF*IndReducao);
                RPA.Temp12.DESP_TJEO_DIF := arredonda(RPA.Temp12.DESP_TJEO_DIF-ListaEventosAmInc[i].ValorAmIncDesp);
                if RPA.Temp12.DESP_TJEO_DIF < zero then begin
                  ListaEventosAmInc[i].ValorAmIncDesp := arredonda(ListaEventosAmInc[i].ValorAmIncDesp+RPA.Temp12.DESP_TJEO_DIF);
                  if SaldoAnt > zero then
                    ListaEventosAmInc[i].IndRedDesp := ListaEventosAmInc[i].ValorAmIncDesp/SaldoAnt;
                  RPA.Temp12.DESP_TJEO_DIF := 0;
                end;
              end;
              if RPA.Temp12.REC_TJEO_DIF > zero then begin
                SaldoAnt := RPA.Temp12.REC_TJEO_DIF;
                ListaEventosAmInc[i].ValorAmIncRec := arredonda(RPA.Temp12.REC_TJEO_DIF*IndReducao);
                RPA.Temp12.REC_TJEO_DIF  := arredonda(RPA.Temp12.REC_TJEO_DIF-ListaEventosAmInc[i].ValorAmIncRec);
                if RPA.Temp12.REC_TJEO_DIF < zero then begin
                  ListaEventosAmInc[i].ValorAmIncRec := arredonda(ListaEventosAmInc[i].ValorAmIncRec+RPA.Temp12.REC_TJEO_DIF);
                  if SaldoAnt > zero then
                    ListaEventosAmInc[i].IndRedRec := ListaEventosAmInc[i].ValorAmIncRec/SaldoAnt;
                  RPA.Temp12.REC_TJEO_DIF := 0;
                end;
              end;
            end;
          end;
        end; //for
      end; 
    end;
  
var
  PrazoRem   : smallint;
  IndexSerie : longint;
begin
  RpaF.Temp12.VlAPROP_DESP_TJEO_DIF:= 0;  
  RpaF.Temp12.VlAPROP_REC_TJEO_DIF := 0;  
  RPAF.Temp12.Pe_Juros_Contratuais := 0;
  if Scciconf.CalculaTJEODiferenciadaProporcional and
     Scciconf.MetodologiaDiferenciadaRecReceita   and
     self.TemCA then 
    RPAF.Temp12.Pe_Juros_Contratuais := PercJurosTJEODiferenciadaProporcional(RPAF.MAC);

  if self.TemCA and 
     Scciconf.MetodologiaDiferenciadaRecReceita and
   ((Abs(RpaF.Temp12.DESP_TJEO_DIF) > Zero) or
    (Abs(RpaF.Temp12.REC_TJEO_DIF)  > Zero)) then begin

    if not TemFinancDinamico(MutDsk) then begin
      if assigned(Series.SeriePrincipal) then
      begin
        RpaF.FinRpa.Npc          := Series.SeriePrincipal.Rpas.FinRpa.Npc;
        RpaF.Temp.PrazoAnt       := RPAF.FinRPA.Prazo;
        RpaF.FinRpa.Prazo        := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
        RPAF.FinRPA.DtInFin      := Series.SeriePrincipal.RpaS.FinRPA.DtInFin;
        RPAF.Temp12.DiaVencAnt   := RPAF.FinRPA.DiaVenc;
        RPAF.FinRPA.DiaVenc      := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
        RPAF.Temp12.DiaVencOrig  := Series.SeriePrincipal.RpaS.Temp12.DiaVencOrig;
        RPAF.Temp12.DiaLiqAnt    := RPAF.FinRpa.DiaLiq;
        RPAF.FinRPA.DiaLiq       := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
        RPAF.Temp12.MacStatusAnt := RPAF.ValRpa.MacStatus;
        RPAF.ValRPA.MACStatus    := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
        RPAF.Temp12.StatusAnt    := RPAF.FinRpa.Status;
        RPAF.FinRPA.Status       := Series.SeriePrincipal.RpaS.FinRPA.Status;
        RpaF.Mac                 := Series.SeriePrincipal.Rpas.Mac;
        RpaF.Temp.OldNPC         := Series.SeriePrincipal.RpaS.Temp.OldNPC;
        RpaF.Temp12.Reestruturada:= Series.SeriePrincipal.Rpas.Temp12.Reestruturada;
        RpaF.Temp12.CoEvento     := Series.SeriePrincipal.Rpas.Temp12.CoEvento;
        RpaF.Temp12.DtEvento     := Series.SeriePrincipal.Rpas.Temp12.DtEvento
      end
      else begin                        
        //   necess rio ter um financiamento din mico ou s rie principal 
        // para evolu  o de despesas. Caso n o tenha, deve-se excluir 
        // a despesa de comercializa  o.
        // Alterei para n o atribuir 98 se for no m s do TPZ - solic 55168 
        if RpaF.Finrpa.Prazo-RpaF.FinRpa.NPC > 0 then 
          RpaF.FinRpa.Status := 98
        else RpaF.FinRpa.Status := 8;
      end;
    end;
    if (RPAF.FinRPA.NPC > 0) or Scciconf.CalculaTJEODiferenciadaProporcional then begin
      if (Abs(RPAF.Temp12.PE_JUROS_CONTRATUAIS) > zero) or 
         Scciconf.CalculaTJEODiferenciadaProporcional then
        PrazoRem := 0
      else begin
        PrazoRem := GetPrazoRemanAnt;
(* ----------------------------- scat110345 -------------------------------
      if (RpaF.FinRPA.NPC = 0) and (RpaF.FinRPA.Prazo > RpaF.Temp.OldNPC) then 
        PrazoRem := RpaF.FinRPA.Prazo - RpaF.Temp.OldNPC
      else 
        PrazoRem   := PrestReman(RpaF);
      if ((RpaF.MAC > RpaF.ValRPA.MACStatus) and (RpaF.ValRPA.MACStatus > 0)) or
          (PrazoRem < 0) then PrazoReman := 0;
-------------------------------------------------------------------------*)
      end;
      IndexSerie := -1;
      if TemFinancDinamico(MutDsk) then begin
        if assigned(OEvolui3.ListaEventosAmInc) then
          TrataEventosAmIncReceitaEDespesa(OEvolui3.ListaEventosAmInc,
                                           RpaF,false{NoEPosVenc});
      end
      else if assigned(Series.SeriePrincipal) then begin
       IndexSerie := Series.IndexOf(Series.SeriePrincipal.Fin.CodSerie);
       if (IndexSerie > -1) and assigned(Series[IndexSerie].ListaEventosAmInc) then 
         TrataEventosAmIncReceitaEDespesa(Series[IndexSerie].ListaEventosAmInc,
                                          RpaF,false{NoEPosVenc});
      end;
  
      if (RpaF.FinRpa.Status = 0) and 
  //      ((PrazoRem > 0) or (Abs(RPAF.Temp12.PE_JUROS_CONTRATUAIS) > zero)) and
        ( (not RpaF.Temp12.Reestruturada) or
         ((FDataRefHist.Dia > 0) and 
          (juliano(RpaF.Temp12.DtEvento) > juliano(FDataRefHist)) )
        ) then begin
        if (Abs(RPAF.Temp12.PE_JUROS_CONTRATUAIS) > zero) or
           Scciconf.CalculaTJEODiferenciadaProporcional  then begin
          RpaF.Temp12.VlAPROP_DESP_TJEO_DIF := Arredonda(MutDsk.Cad6.DESPESA_TJEO_DIFERENCIADA*RPAF.Temp12.PE_Juros_Contratuais);
          RpaF.Temp12.VlAPROP_REC_TJEO_DIF  := Arredonda(MutDsk.Cad6.RECEITA_TJEO_DIFERENCIADA*RPAF.Temp12.PE_Juros_Contratuais);
        end
        else if PrazoRem > 0 then begin
          RpaF.Temp12.VlAPROP_DESP_TJEO_DIF := Arredonda(RpaF.temp12.DESP_TJEO_DIF/PrazoRem);
          RpaF.Temp12.VlAPROP_REC_TJEO_DIF  := Arredonda(RpaF.temp12.REC_TJEO_DIF /PrazoRem);
        end;
      end
      else begin
        RpaF.Temp12.VlAPROP_DESP_TJEO_DIF := RpaF.temp12.DESP_TJEO_DIF;
        RpaF.Temp12.VlAPROP_REC_TJEO_DIF  := RpaF.temp12.REC_TJEO_DIF;
      end;
  
      RpaF.temp12.DESP_TJEO_DIF:= Arredonda(RpaF.temp12.DESP_TJEO_DIF- 
                                            RpaF.Temp12.VlAPROP_DESP_TJEO_DIF);
      RpaF.temp12.REC_TJEO_DIF := Arredonda(RpaF.temp12.REC_TJEO_DIF - 
                                            RpaF.Temp12.VlAPROP_REC_TJEO_DIF);
      if (RpaF.temp12.DESP_TJEO_DIF < zero) and
         (abs(RpaF.temp12.DESP_TJEO_DIF) > Zero) then begin
        RpaF.Temp12.VlAPROP_DESP_TJEO_DIF := arredonda(RpaF.Temp12.VlAPROP_DESP_TJEO_DIF+
                                                       RpaF.temp12.DESP_TJEO_DIF);
        RpaF.temp12.DESP_TJEO_DIF := 0;
      end;
  
      if (RpaF.temp12.REC_TJEO_DIF < zero) and
         (abs(RpaF.temp12.REC_TJEO_DIF) > Zero) then begin
        RpaF.Temp12.VlAPROP_REC_TJEO_DIF := arredonda(RpaF.Temp12.VlAPROP_REC_TJEO_DIF+
                                                      RpaF.temp12.REC_TJEO_DIF);
        RpaF.temp12.REC_TJEO_DIF := 0;
      end;
      if TemFinancDinamico(MutDsk) then begin
        if assigned(OEvolui3.ListaEventosAmInc) then
           TrataEventosAmIncReceitaEDespesa(OEvolui3.ListaEventosAmInc,
                                   RpaF,true{NoEPosVenc});
      end
      else if assigned(Series.SeriePrincipal) and (IndexSerie > -1) and
              assigned(Series[IndexSerie].ListaEventosAmInc) then 
         TrataEventosAmIncReceitaEDespesa(Series[IndexSerie].ListaEventosAmInc,
                                          RpaF,true{NoEPosVenc});
  
      if RpaF.FinRpa.Status = 98 then begin
        RpaF.Temp12.VlAPROP_DESP_TJEO_DIF:= 0;
        RpaF.Temp12.VlAPROP_REC_TJEO_DIF := 0;
        RpaF.temp12.DESP_TJEO_DIF        := 0;
        RpaF.temp12.REC_TJEO_DIF         := 0;
      end;
      if (RpaF.temp12.DESP_TJEO_DIF < zero) and
         (abs(RpaF.temp12.DESP_TJEO_DIF) > Zero) then begin
        RpaF.Temp12.VlAPROP_DESP_TJEO_DIF := arredonda(RpaF.Temp12.VlAPROP_DESP_TJEO_DIF+
                                                       RpaF.temp12.DESP_TJEO_DIF);
        RpaF.temp12.DESP_TJEO_DIF := 0;
      end;
      if (RpaF.temp12.REC_TJEO_DIF < zero) and
         (abs(RpaF.temp12.REC_TJEO_DIF) > Zero) then begin
        RpaF.Temp12.VlAPROP_REC_TJEO_DIF := arredonda(RpaF.Temp12.VlAPROP_REC_TJEO_DIF+
                                                      RpaF.temp12.REC_TJEO_DIF);
        RpaF.Temp12.REC_TJEO_DIF := 0;
      end;
    end; //npc > 0
  end
  else if (not TemFinancDinamico(MutDsk)) and 
          (MutDsk.Cad6.DESPESA_TJEO_DIFERENCIADA+
           MutDsk.Cad6.RECEITA_TJEO_DIFERENCIADA > zero) then begin
    if assigned(Series.SeriePrincipal) then begin
      RpaF.FinRpa.Npc           := Series.SeriePrincipal.Rpas.FinRpa.Npc;
      RpaF.Temp.PrazoAnt        := RpaF.FinRpa.Prazo;
      RpaF.FinRpa.Prazo         := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
      RPAF.Temp12.DiaVencAnt    := RPAF.FinRPA.DiaVenc;
      RPAF.Temp12.DiaVencOrig   := Series.SeriePrincipal.RpaS.Temp12.DiaVencOrig;
      RPAF.FinRPA.DiaVenc       := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
      RPAF.FinRPA.DtInFin       := Series.SeriePrincipal.RpaS.FinRPA.DtInFin;
      RPAF.Temp12.DiaLiqAnt     := RPAF.FinRpa.DiaLiq;
      RPAF.FinRPA.DiaLiq        := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
      RPAF.Temp12.MacStatusAnt  := RPAF.ValRpa.MacStatus;
      RPAF.ValRPA.MACStatus     := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
      RPAF.Temp12.StatusAnt     := RPAF.FinRpa.Status;
      RPAF.FinRPA.Status        := Series.SeriePrincipal.RpaS.FinRPA.Status;
      RpaF.Mac                  := Series.SeriePrincipal.Rpas.Mac;
      RpaF.Temp.OldNPC          := Series.SeriePrincipal.RpaS.Temp.OldNPC;
      RpaF.Temp12.Reestruturada := Series.SeriePrincipal.Rpas.Temp12.Reestruturada;
      RpaF.Temp12.DtEvento      := Series.SeriePrincipal.Rpas.Temp12.DtEvento;
      RpaF.Temp12.CoEvento      := Series.SeriePrincipal.Rpas.Temp12.CoEvento;
    end
    else if (not TemVendedores) and (not TemFgtsApoioAConstrucao) then begin
      if RpaF.FinRpa.Npc < RpaF.FinRpa.Prazo then inc(RpaF.FinRpa.Npc);
      inc(RpaF.Mac);
    end;
  end;

end;

procedure TContrato.PrimeiraFaseValorJusto(var aRpa:TpRpa);
var
  i: integer;
  HistMes: TpHistEvo;
begin
  HistMes[0].Tam := 0;
  fillchar(HistMes,sizeof(HistMes),0);
  Obtem_hist_mes(aRPA, HEvo, HistMes);
  for I := 1 to HistMes[0].Tam do 
  begin
    OEvolui3.ListaEventosAmInc.InicializaDadosAmInc(HistMes[i].Ficha);
    with HistMes[I].Ficha do 
    begin
      case Campo of
            378    : begin
                       aRpa.Temp12.ValorJusto := ValReal;
                       aRpa.Temp12.DtEvento   := HistMes[I].Ficha.DtEfetiva;
                       aRpa.Temp12.CoEvento   := 4; // novo para Hist.137 de valor justo
                     end;
            379     : aRpa.Temp12.HIER_VA_JUSTO := ValIntg;

      end; { case }
    end; { with }
  end; { for }
end;

procedure TContrato.EvoluiValorJusto;
begin
  if (RPAF.Temp12.ValorJusto > zero) and (MutDsk.Cad.TipoCtr <> 41) and
     (MutDsk.Cad6.ValorJusto > zero) then begin
    if not TemFinancDinamico(MutDsk) then begin
      if assigned(Series.SeriePrincipal) then
      begin
        RpaF.FinRpa.Npc       := Series.SeriePrincipal.Rpas.FinRpa.Npc;
        RpaF.FinRpa.Prazo     := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
        RPAF.FinRPA.DiaVenc   := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
        RPAF.Temp12.DiaLiqAnt := RPAF.FinRpa.DiaLiq;
        RPAF.FinRPA.DiaLiq    := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
        RPAF.Temp12.MacStatusAnt := RPAF.ValRpa.MacStatus;
        RPAF.ValRPA.MACStatus := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
        RPAF.Temp12.StatusAnt := RPAF.FinRpa.Status;
        RPAF.FinRPA.Status    := Series.SeriePrincipal.RpaS.FinRPA.Status;
        RpaF.Mac              := Series.SeriePrincipal.Rpas.Mac;
        RpaF.Temp.OldNPC      := Series.SeriePrincipal.RpaS.Temp.OldNPC;
        RpaF.Temp12.Reestruturada := Series.SeriePrincipal.Rpas.Temp12.Reestruturada;
        RpaF.Temp12.CoEvento  := Series.SeriePrincipal.Rpas.Temp12.CoEvento;
        RpaF.Temp12.DtEvento  := Series.SeriePrincipal.Rpas.Temp12.DtEvento;
        RpaF.FinRPA.ValFinanc := Series.SeriePrincipal.Rpas.FinRPA.ValFinanc;
        PrimeiraFaseValorJusto(RpaF); 
      end
      else begin
        //   necess rio ter um financiamento din mico ou s rie principal 
        // para evolu  o de despesas. Caso n o tenha, deve-se excluir 
        // a despesa de comercializa  o.
        // Alterei para n o atribuir 98 se for no m s do TPZ - solic 55168 
        if RpaF.Finrpa.Prazo-RpaF.FinRpa.NPC > 0 then 
          RpaF.FinRpa.Status := 98
        else RpaF.FinRpa.Status := 8;
      end;
    end;
//    if RpaF.FinRpa.Status = 98 then RpaF.Temp12.ValorJusto  := 0;
  end
  else if (not TemFinancDinamico(MutDsk)) and 
          (MutDsk.Cad6.ValorJusto > zero) then begin
    if assigned(Series.SeriePrincipal) then begin
      RpaF.FinRpa.Npc       := Series.SeriePrincipal.Rpas.FinRpa.Npc;
      RpaF.FinRpa.Prazo     := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
      RPAF.FinRPA.DiaVenc   := Series.SeriePrincipal.RpaS.FinRPA.DiaVenc;
      RPAF.Temp12.DiaLiqAnt := RPAF.FinRpa.DiaLiq;
      RPAF.FinRPA.DiaLiq    := Series.SeriePrincipal.RpaS.FinRPA.DiaLiq;
      RPAF.Temp12.MacStatusAnt := RPAF.ValRpa.MacStatus;
      RPAF.ValRPA.MACStatus := Series.SeriePrincipal.RpaS.ValRPA.MACStatus;
      RPAF.Temp12.StatusAnt := RPAF.FinRpa.Status;
      RPAF.FinRPA.Status    := Series.SeriePrincipal.RpaS.FinRPA.Status;
      RpaF.Mac              := Series.SeriePrincipal.Rpas.Mac;
      RpaF.Temp.OldNPC      := Series.SeriePrincipal.RpaS.Temp.OldNPC;
      RpaF.Temp12.Reestruturada := Series.SeriePrincipal.Rpas.Temp12.Reestruturada;
      RpaF.Temp12.DtEvento  := Series.SeriePrincipal.Rpas.Temp12.DtEvento;
      RpaF.Temp12.CoEvento  := Series.SeriePrincipal.Rpas.Temp12.CoEvento;
    end
    else if (not TemVendedores) and (not TemFgtsApoioAConstrucao) and
            (Abs(MutDsk.Cad6.Despesa_TJEO_DIFERENCIADA+
                 MutDsk.Cad6.RECEITA_TJEO_DIFERENCIADA) <= zero) then begin
      if RpaF.FinRpa.Npc < RpaF.FinRpa.Prazo then inc(RpaF.FinRpa.Npc);
      inc(RpaF.Mac);
    end;
  end
  else begin
    RpaF.Temp12.ValorJusto   := 0;
    RpaF.Temp12.Hier_VA_Justo:= 0;
  end;
end;

procedure TContrato.EvoluiSaldoVendedores(var aRpa:TpRpa);
var
  NJurosPoup,
  CorrNoVenc,
  JurosNoVenc,
  SaldoPrincNoVenc,
  SaldoVendNoVenc,
  TxSdVendedoresNoVenc,
  TxSdVendedoresProRata,
  TxSdVendedores,
  TxSdFGTSVendedores: Double;
  Dt1,
  DtAniversario,
  Dt2: TData;
  DiasProrata: Integer;
  JurosVendedoresProrata,
  JurosFGTSVEndedoresProrata: Double;
  ParcelaVendedores  : TParcelaVendedores;
  DiaLiberacaoLocal,
  DiaLiberacaoLocalFgts  : byte;
  SaldoBacen,
  TxSdBacen,
  ValorAtuBacen : real;
begin
  // Se n o tiver financiamento din mico n o evoluiu leu os hist ricos
  // Ent o tem que chamar a primeira fase vendedores
  if not TemFinancDinamico(MutDsk) then
  begin
    // Inicializa  es gerais
    aRpa.Temp12.LiberacaoVendedores := 0;
    aRpa.Temp12.LiberacaoFGTSVendedores := 0;
    aRpa.Temp12.DiaLiberacaoVendedores := 0;
    aRpa.Temp12.DiaLiberacaoFGTSConst  := 0;
    if assigned(Series.SeriePrincipal) then begin
      aRpa.Mac := Series.SeriePrincipal.Rpas.Mac;
      aRpa.FinRpa.Npc       := Series.SeriePrincipal.Rpas.FinRpa.Npc;
      aRpa.FinRpa.Prazo     := Series.SeriePrincipal.Rpas.FinRpa.Prazo;
      aRpa.finRpa.DiaVenc   := Series.SeriePrincipal.Rpas.FinRpa.DiaVenc;
    end;
    PrimeiraFaseVendedores(aRpa);
  end;
  aRpa.Temp12.CMProRataVendedor      := 0; //temporariamente sr  cmproratavend
  aRpa.Temp12.JurProRataVendedor     := 0; //JurProRataVend
  aRpa.Temp12.CMProRataFGTSVendedor  := 0; //CmProRataFGTSVend
  aRpa.Temp12.JurProRataFGTSVendedor := 0; //JurProRataFGTSVend
  aRpa.Temp12.CorrecaoVendedores     := 0;
  aRpa.Temp12.JurosVendedores        := 0;
  aRpa.Temp12.CorrecaoFGTSVendedores := 0;
  aRpa.Temp12.JurosFGTSVendedores    := 0;

  if ((aRpa.Temp12.LibParcialVend > zero) or
      (aRpa.Temp12.LibParcialFGTSVend > zero)) 
                     and
      (OEvolui3.ListaEventosAmInc.Count > 0) then 
    AmortizaSaldoVendedores(aRpa,false{JaCalculouJurosECorreca});
  // Evolu  o vendedores financiamento -------------------------------------
  if aRpa.Temp7.TipoCtr <> 49 then begin
    DiaLiberacaoLocal := aRpa.Temp12.DiaLiberacaoVendedores;
    DiaLiberacaoLocalFgts := aRpa.Temp12.DiaLiberacaoVendedores;
  end
  else begin
    DiaLiberacaoLocal := aRpa.Temp12.DiaLiberacaoVendedores;
    DiaLiberacaoLocalFgts := aRpa.Temp12.DiaLiberacaoFgtsConst;
  end;
  if Scciconf.ContabDiaria and (FDataRefHist.Dia > 0) then begin
    if (aRpa.Temp7.TipoCtr <> 49) then begin
      if (aRpa.Temp12.MACLiberacaoVend  = Mes_Int(FDataRefHist.MesAno)) and
         (aRpa.Temp12.DiaLiberacaoVendedores > FDataRefHist.Dia) then begin
//        aRpa.Temp12.DiaLiberacaoVendedores  := 0;
        aRpa.Temp12.LiberacaoVendedores     := 0;
        aRpa.Temp12.LiberacaoFGTSVendedores := 0;
        aRpa.Temp12.IntervenienteQuitante   := 0;
        DiaLiberacaoLocal                   := 0;
        DiaLiberacaoLocalFgts               := 0;
      end;
    end
    else begin
      if (aRpa.Temp12.MACLiberacaoVend  = Mes_Int(FDataRefHist.MesAno)) and
         (aRpa.Temp12.DiaLiberacaoVendedores > FDataRefHist.Dia) then begin
//        aRpa.Temp12.DiaLiberacaoVendedores  := 0;
        aRpa.Temp12.LiberacaoVendedores     := 0;
        aRpa.Temp12.IntervenienteQuitante   := 0;
        DiaLiberacaoLocal                   := 0;
      end;
      if (aRpa.Temp12.MACLiberacaoFgtsConst = Mes_Int(FDataRefHist.MesAno)) and
         (aRpa.Temp12.DiaLiberacaoFgtsConst > FDataRefHist.Dia) then begin
        aRpa.Temp12.LiberacaoFGTSVendedores := 0;
        DiaLiberacaoLocalFgts               := 0;
      end;
    end;
  end;

  SaldoVendNoVenc        := aRpa.Temp12.SaldoVendedores;
  SaldoPrincNoVenc       := aRpa.Temp12.SaldoPrincVend;
  TxSdVendedoresProRata  := 0;
  TxSdVendedoresNoVenc   := 0;
  TxSdVendedores         := 0;
    // Corre  o Vendedores ( Financiamento )
  int_mes(aRpa.Mac,DtAniversario.MesAno); DtAniversario.Dia := aRpa.FinRpa.DtAssin.Dia;
  Dt1 := DtAniversario; Dt2 := DtAniversario;
  Dt2 := Dt1;
  if aRpa.MAC > mes_int(aRpa.FinRpa.DtAssin.MesAno) then
    DecMA(Dt1.MesAno);
  // Se teve libera  o no m s. A corre  o   at  a data de libera  o
  if DiaLiberacaoLocal > 0 then 
    Dt2.Dia :=  DiaLiberacaoLocal;
  if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
    if ((aRpa.Mac > mes_int(aRpa.FinRpa.DtAssin.MesAno)) or
        (aRpa.MAC = aRpa.Temp12.MAcLiberacaoVend)) and
        (aRpa.Temp12.SaldoVendedores > Zero) then 
    begin
      // Se teve libera  o no m s. A corre  o   at  a data de libera  o
      if DiaLiberacaoLocal > 0 then
      begin
        // igual a TEvolui3.DetTxSd
        CmTabErr         := 0;
        CmTabErrData.Dia := 0; fillchar(CmTabErrData,sizeof(CmTabErrData),0);

        Dt2.Dia :=  DiaLiberacaoLocal;

        TxSdVendedores := Correcao0(Dt1,Dt2,AjustaData293031ParaDia1(Dt1),1000000)/1000000;

        // igual a TEvolui3.DetTxSd
        if TxSdVendedores <= zero then
          aRPA.Temp12.CodErroVendedor := 9;

        if DiaLiberacaoLocal > aRpa.FinRpa.DtAssin.Dia then begin
          // igual a TEvolui3.DetTxSd
          CmTabErr         := 0;
          CmTabErrData.Dia := 0; fillchar(CmTabErrData,sizeof(CmTabErrData),0);
          TxSdVendedoresNoVenc := IndiceDiario(AjustaData293031ParaDia1(dt1),AjustaData293031ParaDia1(DtAniversario),0)-1;
          // igual a TEvolui3.DetTxSd
          if TxSdVendedoresNoVenc <= zero then
            aRPA.Temp12.CodErroVendedor := 9;

          // igual a TEvolui3.DetTxSd
          CmTabErr         := 0;
          CmTabErrData.Dia := 0; fillchar(CmTabErrData,sizeof(CmTabErrData),0);
          TxSdVendedoresProRata:= Correcao0(DtAniversario,Dt2,AjustaData293031ParaDia1(DtAniversario),1000000)/1000000;
          // igual a TEvolui3.DetTxSd
          if TxSdVendedoresProRata <= zero then
            aRPA.Temp12.CodErroVendedor := 9;
          CorrNoVenc      := arredonda(aRpa.Temp12.SaldoVendedores * TxSdVendedoresNoVenc);
          SaldoVendNoVenc := Arredonda(SaldoVendNoVenc + CorrNoVenc);
        end;
      end else
      begin
        // igual a TEvolui3.DetTxSd
        CmTabErr         := 0;
        CmTabErrData.Dia := 0; fillchar(CmTabErrData,sizeof(CmTabErrData),0);
        TxSdVendedores := IndiceDiario(AjustaData293031ParaDia1(dt1),AjustaData293031ParaDia1(dt2),0)-1;
        //scat82535 se n o tem o segundo  ndice n o aplica a corre  o
        if (Abs(TxSdVendedores) > zero) and (TxSdVendedores < Zero) and
           (LE_BTNF(AjustaData293031ParaDia1(dt2),0) <= Zero) then begin
          TxSdVendedores := 0;
        end;  
        // igual a TEvolui3.DetTxSd
        if TxSdVendedores <= zero then
          aRPA.Temp12.CodErroVendedor := 9;
      end;
    end;
      // CorrecaoMJSemIsencao(Dt1 ,Dt2, 100000, aRpa.FinRPA.IndJuros,199,MoraAux,aRpa.FinRPA.DtAssin,100)/ 100000; Rotina lenta
    aRpa.Temp12.CorrecaoVendedores     := arredonda(aRpa.Temp12.SaldoVendedores * TxSdVendedores);
    aRpa.Temp12.SaldoVendedores        := aRpa.Temp12.SaldoVendedores +
                                          aRpa.Temp12.CorrecaoVendedores;
    aRpa.Temp12.SaldoPrincVend := aRpa.Temp12.SaldoPrincVend * 
                                  (1+TxSdVendedores);
  end; 
  // C lculo de libera  o antes do vencimento
  if (DiaLiberacaoLocal > 0) and (DiaLiberacaoLocal < aRpa.FinRpa.DtAssin.Dia) then 
  begin
    if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
      if scciconf.CalcEvoVendedoresDias360 then 
        DiasProRata := Dias360(Dt1,Dt2)
      else
        DiasProrata := DiaLiberacaoLocal - aRpa.FinRpa.DtAssin.Dia + 30;
      if aRpa.Mac > mes_int(aRpa.FinRpa.DtAssin.MesAno) then
      begin
        if scciconf.EvoluirSaldoVendedoresComJurosSimples then
          aRpa.Temp12.JurosVendedores := arredonda(aRpa.Temp12.SaldoPrincVend * (NovosJurosPoup(Dt1)*DiasProRata/30))
        else
          aRpa.Temp12.JurosVendedores := arredonda(aRpa.Temp12.SaldoVendedores * (power(1+NovosJurosPoup(Dt1),DiasProRata/30)-1));

        aRpa.Temp12.JurProRataVendedor:= aRpa.Temp12.JurosVendedores;
        aRpa.Temp12.CMProRataVendedor := aRpa.Temp12.CorrecaoVendedores;
  
      // C lculo de juros pro rata se tiver no m s da libera  o
      end;
    end;
    aRpa.Temp12.SaldoVendedores        := aRpa.Temp12.SaldoVendedores -
                                          aRpa.Temp12.LiberacaoVendedores;
  end; 
  // C lculo de juros do m s
  if  (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
    if (aRpa.Mac > mes_int(aRpa.FinRpa.DtAssin.MesAno)) and
       ((DiaLiberacaoLocal = 0) or
        (DiaLiberacaoLocal >= aRpa.FinRpa.DtAssin.Dia)) then
    begin
      NJurosPoup := NovosJurosPoup(Dt1);
      if scciconf.EvoluirSaldoVendedoresComJurosSimples then
        aRpa.Temp12.JurosVendedores := arredonda(aRpa.Temp12.SaldoPrincVend * NJurosPoup{NovosJurosPoup(Dt1)})
      else if Scciconf.EvoluirSaldoVendedoresSemCorrJurParaCtrEmprestimo then // 103023 - n o fizemos para juros simples
        aRpa.Temp12.JurosVendedores := arredonda(aRpa.Temp12.SaldoVendedores * NJurosPoup{NovosJurosPoup(Dt1)})
      else begin  // 103023 - evolui saldo vendedores de acordo com o site do bacen
{
  103023
	data inicial = 17/10/2024
	data final = 17/11/2024
	saldo anterior = 399.000,00
	 ndice TR (17/11/2024) = 1,000709
	 ndice de juros = 1,005
	 ndice de atualiza  o = 1,000709 * 1,005 = 1,005713 (arredondado para 6 casas decimais)
	valor atualiza  o = 399.000,00 * (1,005713 - 1) = 2.279,49
	valor da corre  o = 399.000,00 * (1,000709 - 1) = 282,89
	valor dos juros = 2.279,49 - 282,89 = 1.996,60
	saldo atual = 399.000,00 + 282,89 + 1.996,60 =  401.279,49  
}
        SaldoBacen := aRpa.Temp12.SaldoVendedores-aRpa.Temp12.CorrecaoVendedores;
        TxSdBacen := int((1+TxSdVendedores)*(1+NJurosPoup)*1000000+0.5)/1000000; // arredondado para 6 casas decimais
        ValorAtuBacen := arredonda(SaldoBacen * (TxSdBacen-1));
        aRpa.Temp12.JurosVendedores := ValorAtuBacen-aRpa.Temp12.CorrecaoVendedores;
      end;  
      if DiaLiberacaoLocal > aRpa.FinRpa.DtAssin.Dia then begin
        if scciconf.EvoluirSaldoVendedoresComJurosSimples then begin
          SaldoPrincNoVenc:= SaldoPrincNoVenc * (1+TxSdVendedoresNoVenc);
          JurosNoVenc     := Arredonda(SaldoPrincNoVenc * NJurosPoup);
        end
        else 
          JurosNoVenc     := Arredonda(SaldoVendNoVenc * NJurosPoup);
        SaldoVendNoVenc := Arredonda(SaldoVendNoVenc+JurosNoVenc);
      end;
    end;
    aRpa.Temp12.SaldoVendedores := aRpa.Temp12.SaldoVendedores + aRpa.Temp12.JurosVendedores;
  end;
  // C lculo de libera  o no vencimento e depois do vencimento
  if (DiaLiberacaoLocal > 0) and (DiaLiberacaoLocal >= aRpa.FinRpa.DtAssin.Dia) then
  begin
    JurosVendedoresProrata := 0;
    if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
      if scciconf.CalcEvoVendedoresDias360 and
        (DiaLiberacaoLocal > aRpa.FinRpa.DtAssin.Dia) then begin
        DiasProRata := Dias360(DtAniversario,Dt2);
      end
      else
        DiasProrata :=  DiaLiberacaoLocal - aRpa.FinRpa.DtAssin.Dia;
      if aRpa.Mac >= mes_int(aRpa.FinRpa.DtAssin.MesAno) then
      begin
        if scciconf.EvoluirSaldoVendedoresComJurosSimples then
          JurosVendedoresProrata := arredonda(aRpa.Temp12.SaldoPrincVend * (NovosJurosPoup(DtAniversario)*DiasProRata/30))
        else
          JurosVendedoresProrata := arredonda(aRpa.Temp12.SaldoVendedores * (power(1+NovosJurosPoup(DtAniversario),DiasProRata/30)-1));

        if DiaLiberacaoLocal > DtAniversario.Dia then begin
          aRpa.Temp12.JurProRataVendedor:= JurosVendedoresProrata;
          aRpa.Temp12.CMProRataVendedor := arredonda(SaldoVendNoVenc * TxSdVendedoresProRata);
        end;
      end;
      // C lculo de juros pro rata se tiver no m s da libera  o
      aRpa.Temp12.JurosVendedores := aRpa.Temp12.JurosVendedores + JurosVendedoresProrata;
    end;
    aRpa.Temp12.SaldoVendedores := aRpa.Temp12.SaldoVendedores +
                                   JurosVendedoresProrata -
                                   aRpa.Temp12.LiberacaoVendedores;
  end; 
  // Evolu  o vendedores FGTS -----------------------------------------------

  SaldoVendNoVenc       := aRpa.Temp12.SaldoFGTSVendedores;
  SaldoPrincNoVenc      := aRpa.Temp12.SaldoFGTSPrincVend;
  TxSdVendedoresProRata := 0;
  TxSdFGTSVendedores    := 0;
  TxSdVendedoresNoVenc  := 0;
  // Corre  o FGTS Vendedores, s  se a data da entrada de fgtrs estiver preenchida
  if (aRpa.Temp12.DtFGTSEntrada.Dia > 0) then
  begin
    int_mes(aRpa.Mac,Dt1.MesAno); Dt1.Dia := aRpa.Temp12.DtFGTSEntrada.Dia;
    DtAniversario := Dt1;
    Dt2 := Dt1;
    if DiaLiberacaoLocalFgts > 0 then
      Dt2.Dia :=  DiaLiberacaoLocalFgts;
    if aRpa.MAC > mes_int(aRpa.Temp12.DtFGTSEntrada.MesAno) then 
      DecMA(Dt1.MesAno);
    if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
      if ((aRpa.Mac > mes_int(aRpa.Temp12.DtFGTSEntrada.MesAno)) or
          (aRpa.MAC = aRpa.Temp12.MACLiberacaoVend) or (aRpa.MAC = aRpa.Temp12.MACLiberacaoFgtsConst)) and
          (aRpa.Temp12.SaldoFgtsVendedores > Zero) then
      begin 
        // Se teve libera  o no m s. A corre  o   at  a data de libera  o
        if DiaLiberacaoLocalFgts > 0 then
        begin
          Dt2.Dia :=  DiaLiberacaoLocalFgts;
          if DiaLiberacaoLocalFgts > aRpa.Temp12.DtFGTSEntrada.Dia then begin
            TxSdVendedoresNoVenc := IndiceDiario(AjustaData293031ParaDia1(dt1),AjustaData293031ParaDia1(DtAniversario),0)-1;
            TxSdVendedoresProRata:= Correcao0(DtAniversario,Dt2,AjustaData293031ParaDia1(DtAniversario),1000000)/1000000;
            CorrNoVenc           := arredonda(aRpa.Temp12.SaldoFGTSVendedores * TxSdVendedoresNoVenc);
            SaldoVendNoVenc      := Arredonda(SaldoVendNoVenc + CorrNoVenc);
          end;
          TxSdFGTSVendedores := Correcao0(Dt1,Dt2,AjustaData293031ParaDia1(Dt1),1000000)/1000000;
        end else
        begin 
          TxSdFGTSVendedores := IndiceDiario(AjustaData293031ParaDia1(dt1),AjustaData293031ParaDia1(dt2),0)-1;
          if (Abs(TxSdFGTSVendedores) > zero) and 
             (TxSdFGTSVendedores < zero) and
             (LE_BTNF(AjustaData293031ParaDia1(dt2),0) <= 0) then
            TxSdFGTSVendedores := 0;
        end;
        // Rotina lenta CorrecaoMJSemIsencao(Dt1 ,Dt2, 100000, aRpa.FinRPA.IndJuros,199,MoraAux,aRpa.FinRPA.DtAssin,100)/ 100000;
      end;
      aRpa.Temp12.CorrecaoFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSVendedores * TxSdFGTSVendedores);

      aRpa.Temp12.SaldoFgtsVendedores    := aRpa.Temp12.SaldoFgtsVendedores +
                                           aRpa.Temp12.CorrecaoFgtsVendedores;
      aRpa.Temp12.SaldoFGTSPrincVend := aRpa.Temp12.SaldoFGTSPrincVend * 
                                 (1+TxSdFGTSVendedores);
    end;
    
    // C lculo de libera  o antes do vencimento
    if (DiaLiberacaoLocalFgts > 0) and (DiaLiberacaoLocalFgts < aRpa.Temp12.DtFGTSEntrada.Dia) then
    begin
      if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
        // C lculo de juros pro rata se tiver no m s da libera  o
        if scciconf.CalcEvoVendedoresDias360 then 
          DiasProRata := Dias360(Dt1,Dt2)
        else
          DiasProrata :=  DiaLiberacaoLocalFgts - aRpa.Temp12.DtFGTSEntrada.Dia + 30;
        if (aRpa.Temp12.DtFGTSEntrada.dia > 0) and 
           (aRpa.Mac > mes_int(aRpa.Temp12.DtFGTSEntrada.MesAno)) then
        begin
          if scciconf.EvoluirSaldoVendedoresComJurosSimples then begin
            if FTemFgtsApoioAConstrucao then
              aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * (NovosJurosPoupFgts(Dt1)*DiasProRata/30))
            else
              aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * (NovosJurosPoup(Dt1)*DiasProRata/30));
          end
          else begin
            if FTemFgtsApoioAConstrucao then
              aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSVendedores * (power(1+NovosJurosPoupFgts(Dt1),DiasProRata/30)-1))
            else
              aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSVendedores * (power(1+NovosJurosPoup(Dt1),DiasProRata/30)-1));
          end;
          aRpa.Temp12.JurProRataFGTSVendedor  := aRpa.Temp12.JurosFgtsVendedores;  //JurProRataFgtsVendedor
          aRpa.Temp12.CMProRataFGTSVendedor   := aRpa.Temp12.CorrecaoFgtsVendedores; //CMProRAtaFGTSVendedor
        end;
      end;
      aRpa.Temp12.SaldoFgtsVendedores    := aRpa.Temp12.SaldoFgtsVendedores -
                                           aRpa.Temp12.LiberacaoFGTSVendedores;
    end; 
    // C lculo de juros do m s
    if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
      if (aRpa.Temp12.DtFGTSEntrada.dia > 0) and 
         (aRpa.Mac > mes_int(aRpa.Temp12.DtFGTSEntrada.MesAno)) and 
         ((DiaLiberacaoLocalFgts = 0) or
          (DiaLiberacaoLocalFgts >= aRpa.Temp12.DtFGTSEntrada.Dia)) then
      begin
        if FTemFgtsApoioAConstrucao then
          NJurosPoup := NovosJurosPoupFgts(Dt1)
        else
          NJurosPoup := NovosJurosPoup(Dt1);
        if scciconf.EvoluirSaldoVendedoresComJurosSimples then
          aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * NJurosPoup {NovosJurosPoup(Dt1)})
        else
          aRpa.Temp12.JurosFgtsVendedores := arredonda(aRpa.Temp12.SaldoFGTSVendedores * NJurosPoup{NovosJurosPoup(Dt1)}); 
  
        if DiaLiberacaoLocalFgts > aRpa.Temp12.DtFGTSEntrada.Dia then begin
          if scciconf.EvoluirSaldoVendedoresComJurosSimples then begin
            SaldoPrincNoVenc:= SaldoPrincNoVenc * (1+TxSdVendedoresNoVenc);
            JurosNoVenc     := Arredonda(SaldoPrincNoVenc * NJurosPoup);
          end
          else 
            JurosNoVenc     := Arredonda(SaldoVendNoVenc * NJurosPoup);
          SaldoVendNoVenc := Arredonda(SaldoVendNoVenc+JurosNoVenc);
        end;
      end;
      aRpa.Temp12.SaldoFgtsVendedores    := aRpa.Temp12.SaldoFgtsVendedores +
                                            aRpa.Temp12.JurosFgtsVendedores;
    end;
    // C lculo de libera  o no vencimento e depois do vencimento
    JurosFgtsVendedoresProRata := 0;
    if (DiaLiberacaoLocalFgts > 0) and (DiaLiberacaoLocalFgts >= Rpa.Temp12.DtFGTSEntrada.Dia) then
    begin
      if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
      // C lculo de juros pro rata se tiver no m s da libera  o
        if scciconf.CalcEvoVendedoresDias360 and
          (DiaLiberacaoLocalFgts > Rpa.Temp12.DtFGTSEntrada.Dia) then
          DiasProRata := Dias360(DtAniversario,Dt2)
        else
          DiasProrata :=  DiaLiberacaoLocalFgts - aRpa.Temp12.DtFGTSEntrada.Dia;
        if (aRpa.Mac >= mes_int(aRpa.Temp12.DtFGTSEntrada.MesAno)) then
        begin
          if scciconf.EvoluirSaldoVendedoresComJurosSimples then begin
            if FTemFgtsApoioAConstrucao then
              JurosFgtsVendedoresProRata := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * (NovosJurosPoupFgts(Dt2)*DiasProRata/30))
            else
              JurosFgtsVendedoresProRata := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * (NovosJurosPoup(Dt2)*DiasProRata/30));
          end
          else begin
            if FTemFgtsApoioAConstrucao then
              JurosFgtsVendedoresProRata := arredonda(aRpa.Temp12.SaldoFGTSVendedores * (power(1+NovosJurosPoupFgts(Dt2),DiasProRata/30)-1))
            else
              JurosFgtsVendedoresProRata := arredonda(aRpa.Temp12.SaldoFGTSVendedores * (power(1+NovosJurosPoup(Dt2),DiasProRata/30)-1));
          end;
    
          if DiaLiberacaoLocalFgts > DtAniversario.Dia then begin
            aRpa.Temp12.JurProRataFGTSVendedor:= JurosFgtsVendedoresProRata;  //JurProRataFgtsVendedor
            aRpa.Temp12.CMProRataFGTSVendedor := arredonda(SaldoVendNoVenc * TxSdVendedoresProRata); //CmproratafgtsVendedor
          end;
        end;
        aRpa.Temp12.JurosFgtsVendedores := aRpa.Temp12.JurosFgtsVendedores + JurosFgtsVendedoresProRata;
      end;
      aRpa.Temp12.SaldoFgtsVendedores    := aRpa.Temp12.SaldoFgtsVendedores +
                                           JurosFgtsVendedoresProRata -
                                           aRpa.Temp12.LiberacaoFGTSVendedores;
    end; 
    // Se teve libera  o no m s, zera o saldo
  end;  //aRpa.Temp12.DtFGTSEntrada.Dia > 0

  if ((aRpa.Temp12.LibParcialVend > zero) or
      (aRpa.Temp12.LibParcialFGTSVend > zero)) 
                     and
      (OEvolui3.ListaEventosAmInc.Count > 0) then begin
    AmortizaSaldoVendedores(aRpa,true{JaCalculouJurosECorreca});
    DiaLiberacaoLocal := aRpa.Temp12.DiaLiberacaoVendedores;
    if aRpa.Temp12.DtFGTSEntrada.Dia > 0 then
      DiaLiberacaoLocalFgts := aRpa.Temp12.DiaLiberacaoVendedores;
  end;
  if (aRpa.Temp12.DtFGTSEntrada.Dia > 0) and (DiaLiberacaoLocalFgts > 0) then
  begin
    if (not (RegCarteira.SdVendSemCorrJur or Scciconf.PermiteLiberarSaldoVendedoresPorPartes)) and (not FInibeCorSdVendedor) then begin //ver com Marcus como prever a  ltima libera  o
      if aRpa.Temp12.CorrecaoFgtsVendedores > Zero then begin
        aRpa.Temp12.CorrecaoFgtsVendedores := Arredonda(aRpa.Temp12.CorrecaoFgtsVendedores - aRpa.Temp12.SaldoFgtsVendedores);
        if DiaLiberacaoLocalFgts < aRpa.Temp12.DtFGTSEntrada.Dia then
          aRpa.Temp12.CmProRataFGTSVendedor := aRpa.Temp12.CorrecaoFGTSVendedores;
      end
      else begin
        aRpa.Temp12.JurosFgtsVendedores    := Arredonda(aRpa.Temp12.JurosFgtsVendedores - aRpa.Temp12.SaldoFgtsVendedores);
        if DiaLiberacaoLocalFgts < aRpa.Temp12.DtFGTSEntrada.Dia then
          aRpa.Temp12.JurProRataFGTSVendedor := aRpa.Temp12.JurosFGTSVendedores;
      end;
    end;
    aRpa.Temp12.SaldoFgtsVendedores := 0;      
    aRpa.Temp12.SaldoFgtsPrincVend := 0;
  end;

  if DiaLiberacaoLocal > 0 then 
  begin
    if (not (RegCarteira.SdVendSemCorrJur or Scciconf.PermiteLiberarSaldoVendedoresPorPartes)) and (not FInibeCorSdVendedor) then begin //ver com Marcus com prever a  ltima para jogar a dif. na corr ou juros
      if aRpa.Temp12.CorrecaoVendedores > Zero then begin
        aRpa.Temp12.CorrecaoVendedores := Arredonda(aRpa.Temp12.CorrecaoVendedores - aRpa.Temp12.SaldoVendedores);
        if DiaLiberacaoLocal < aRpa.FinRpa.DtAssin.Dia then 
          aRpa.Temp12.CmProRataVendedor := aRpa.Temp12.CorrecaoVendedores;
      end
      else begin
        aRpa.Temp12.JurosVendedores     := Arredonda(aRpa.Temp12.JurosVendedores - aRpa.Temp12.SaldoVendedores);
        if DiaLiberacaoLocal < aRpa.FinRpa.DtAssin.Dia then
          aRpa.Temp12.JurProRataVendedor := aRpa.Temp12.JurosVendedores;
      end;
    end;
    aRpa.Temp12.SaldoVendedores := 0;
    aRpa.Temp12.SaldoPrincVend := 0;
    TrataInicioFInancVendedores(aRpa); // 93781 - se zerar o saldo, tem que iniciar a fase de financ. (PA=40)
  end
  else if aRpa.Temp12.MacIniciaEmprestimo=aRpa.Mac then
    TrataInicioFInancVendedores(aRpa); // 95832 - se marcou na libera  o parcial para iniciar o empr stimo, preciso tratar tamb m

  if  (not FIgnoraArqPrstVendedoresCtb) and
      (ScciConf.UsaArqPrest) then begin
    // Seta evolu  o vendedores gravada em ArqPrstVendedor
    ParcelaVendedores := ParcelasVendedores.GetParcelaPorMac(aRpa.Mac);
    if assigned(ParcelaVendedores) then
    begin
      aRpa.Temp12.DiaLiberacaoVendedores := ParcelaVendedores.NuDiaLiberacao;
      aRpa.Temp12.SaldoVendedores := ParcelaVendedores.VaSaldoVendedor;
      aRpa.Temp12.CorrecaoVendedores := ParcelaVendedores.VaCorrecaoVendedor;
      aRpa.Temp12.JurosVendedores := ParcelaVendedores.VaJurosVendedor;
      aRpa.Temp12.LiberacaoVendedores := ParcelaVendedores.VaLiberacaoVendedor;
      aRpa.Temp12.SaldoFgtsVendedores := ParcelaVendedores.VaSaldoFgts;
      aRpa.Temp12.CorrecaoFgtsVendedores := ParcelaVendedores.VaCorrecaoFgts;
      aRpa.Temp12.JurosFgtsVendedores := ParcelaVendedores.VaJurosFgts;
      aRpa.Temp12.LiberacaoFGTSVendedores := ParcelaVendedores.VaLiberacaoFGts;
      if Abs(ParcelaVendedores.CorrProRataVendedor) > Zero then 
        aRpa.Temp12.CMProRataVendedor  := ParcelaVendedores.CorrProRataVendedor;
      if Abs(ParcelaVendedores.JurProRataVendedor) > Zero then
        aRpa.Temp12.JurProRataVendedor     := ParcelaVendedores.JurProRataVendedor;
      if Abs(ParcelaVendedores.CorrProRataFGTSVendedor) > Zero then 
        aRpa.Temp12.CMProRataFGTSVendedor  := ParcelaVendedores.CorrProRataFGTSVendedor;
      if Abs(ParcelaVendedores.JurProRataFGTSVendedor) > Zero then 
        aRpa.Temp12.JurProRataFGTSVendedor := ParcelaVendedores.JurProRataFGTSVendedor;
    end;
  end;
  if (aRpa.Temp12.MACLiberacaoVend > 0) and (aRpa.MAC > aRpa.Temp12.MACLiberacaoVend) then begin
    aRpa.Temp12.LibParcialVend     := 0;
    aRpa.Temp12.LibParcialFGTSVend := 0;
  end;
end;

procedure TContrato.TiraHistoricoDeTermino(CodLog : integer = 0);
var 
  i : SmallInt;
  InibiuHist : boolean;
begin
  InibiuHist := false;
  i := 1;
  while (i <= FHistMem[0].Tam) do
  begin
    if (FHistMem[i].Log.CodMov in [1..10,122]) or
      ((CodLog > 0) and (FHistMem[i].Log.CodMov = CodLog)) then begin
      FHistMem[i].Log.MarcaLog := True;
      InibiuHist := true;
    end;
    inc(i);
  end;
  if InibiuHist then Processa_Hist(DataH,FHistMem,FHEvo); 
end;

procedure TContrato.InibeHistEvoDeCodHistLog(ListCodHistLog : THashedStringList; MACRef : smallint = 0);
var
  i : integer;
begin
  if assigned(ListCodHistLog) and (ListCodHistLog.Count > 0) then 
    for i := 1 to FHEvo[0].Tam do begin
      if ((MACRef = 0) or (Mes_Int(FHEvo[i].Ficha.MesAno) >= MACRef)) and
         (ListCodHistLog.IndexOf(IntStr(FHEvo[i].Ficha.CodHistLog)) > -1) then 
        FHEvo[i].Ficha.MarcaDat := true;
    end;
end;

procedure TContrato.SalvaRpa;
begin
    MsgErro := '';
    if Rpa.Ctr <> MutDsk.Cad.Ctr then MsgErro := 'Sem posi  o a ser salva'
    else begin
      if TemFinancDinamico(MutDsk) or TemVendedores or TemFgtsApoioAConstrucao or
        (RpaF.Temp12.saldoDiferidoComissao > Zero) or
        (Series.Count=0) then  // Para prever o caso de n o ter serie nem financimento
        RpaFSalvo := RpaF;
      series.SalvaRpa;
      RpaSalvo := Rpa;
    end;
end;

procedure TContrato.RetornaRpaSalvo;
begin
    MsgErro := '';
    if RpaSalvo.Ctr <> MutDsk.Cad.Ctr then MsgErro := 'Sem posi  o salva'
    else begin
      if TemFinancDinamico(MutDsk) or TemVendedores or TemFgtsApoioAConstrucao or
         (RpaF.Temp12.saldoDiferidoComissao > Zero) or
         (Series.Count=0) then  // Para prever o caso de n o ter serie nem financimento
        RpaF := RpaFSalvo;
      series.RetornaRpaSalvo;
      Rpa := RpaSalvo;
    end;
end;


function TContrato.ObtemRpaEvo(Mac : Integer;NaoReajusta : boolean = false):TpRpa;
begin
  InicRpa(NaoReajusta);
  while RPA.MAC < Mac do Evolui;
  result := Rpa;
end;

procedure TContrato.AtualizaValoresPorMACList(Var pRPA : TpRPA);
begin
  if FIniValoresPorMac < 0 then
    FIniValoresPorMac := pRPA.mac;
  if pRPA.mac >= FValoresPorMacList.count then
    FValoresPorMacList.count := pRPA.mac + 1;
  if not assigned(FValoresPorMacList[pRPA.mac]) then
    FValoresPorMacList[pRPA.mac] := TValoresPorMac.create;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).CodSerie := 0;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).mac := pRPA.mac;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).MACTmp := pRPA.MACTmp;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).MACStatus := pRPA.ValRPA.MacStatus;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).indsaldoacum := pRPA.Temp3.IndSaldoAcum;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).indredprest := pRPA.Temp10.IndRedPrest;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).CodReaj := pRPA.FinRPA.CodReaj;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).CodTabelaGenerica := pRPA.Temp7.CodTabelaGenerica;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).IndJuros := pRPA.FinRPA.IndJuros;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).CodTabGPreChvCorr := pRPA.Temp10.CodTabGPreChvCorr;
  TValoresPorMac(FValoresPorMacList[pRPA.mac]).DefReajPreChvCorr := pRPA.Temp12.DefReajPreChvCorr;
