var
  i : integer;
begin
  if TemFinancDinamico(Mutdsk) then begin
    FOEvolui3.Pagamentos.clear;
    for i := 0 to SerieF.Parcelas.count-1 do
      if SerieF.Parcelas[i].EstaPagaReal then
