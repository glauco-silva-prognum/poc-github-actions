function TSerieFinanciamentoDinamico.PrstPagaReal(Mac : integer; ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
var
  DtInFin : Tdata;
  Parcela : TParcela;
  Valores : TValoresPorMac;
begin
  if Contrato.MutDsk.Financ.Status in StatusTermino then result := true
  else begin
    if (juliano(Contrato.MutDsk.Financ.DtInFin) < juliano(Contrato.Mutdsk.Financ.DtAssin)) and
       ((Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1) < Mes_Int(Contrato.MutDsk.Financ.DtAssin.MesAno)) then begin
      DtInFin := Contrato.MutDsk.Financ.DtAssin;
      DecMA(DtInFin.MesAno);
    end else DtInFin := Contrato.MutDsk.Financ.DtInFin;
    DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),Contrato.MutDsk.Financ.DtInFin.Dia);
    if (Mes_Int(DtInFin.MesAno)+1 = MAC) and
       (Contrato.MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then
      DtInFin.Dia := Dia_Venc(MAC,Contrato.MutDsk.Financ3.DiaVenc1aPrest);

    if Mac <= Mes_Int(DtInFin.MesAno) then
      result := true
    else begin
      Parcela := Parcelas.ObtemParcelaPorMac(Mac);
      if assigned(parcela) then begin
//scat111015        if Parcela.EstaPagaReal and ConsideraPrstSoDeAcessorios then begin
        Result := Parcela.EstaPagaReal;
        if Result or (ConsideraPrstSoDeAcessorios and Parcela.SeguroEstaPagoReal) then begin
          try
            Valores := Contrato.SerieF.ObtemValoresPorMac(Mac);
          except
            on e : exception do begin
              raise exception.create('Erro ao obter a presta  o, na PrstPagaRPA.');
            end;
          end;  
          if {(Parcela.TipoPg in PgtoComRedSdDev)} 
              assigned(Valores) and
              (Valores.TotalAcessorios > Zero) and
              (Valores.AmaisJ-(Valores.Desc-Valores.DescSeg) <= zero) then begin
{----------------------------- scat11015 ---------------------------------
            Result := (Parcela.DtPgSeg.Dia > 0) and
                      (not (Parcela.TipoPgSeg in [8..9,66,74,108,110,114,117,95,121,200,253]))
---------------------------------------------------------------------------}
{
  111312
  Quando a presta  o da car ncia(amaisj=0) tem acess rios(seguo+taxa>0) e tem pagamento normal,
  preciso considerar que os acess rios foram pagos, apesar do tipo de pagamento n o ser 
  compat vel, ou o usu rio ir  reclamar que a presta  o foi paga e o sistema n o acata o pagamento.
}            
            Result := Parcela.SeguroEstaPagoReal or Parcela.EstaPagaReal;
          end
          else
            Result := Result and (Parcela.TipoPg<>65); //para ficar similar a dinamico.PrstPaga()
        end;
{----------------------------- scat11015 ---------------------------------
        else
          result := Parcela.EstaPagaReal;
---------------------------------------------------------------------------}
      end    
      else
        result := false;
    end;
  end;
end;

function TSerieFinanciamentoDinamico.PrstEmAtrasoAtual(MAC     : integer;
                                                       DiaVenc : integer;
                                                       DtRef   : TData;
                                                       LCobr   : integer = 0;
                                                       ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
var DtMac,DtIsen: TData;
  Reg : TValoresPorMac;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  if not (Contrato.MutDsk.Cad.TipoCtr in [1,2]) then begin
    DtMac.Dia := Dia_Venc( MAC, DiaVenc);
    Int_Mes(MAC, DtMac.MesAno ) ;
    DtIsencaoMora(Contrato.Mutdsk.ChaveImv.Empreend,Contrato.Mutdsk.Cad.Ctr,LCobr,
                  DtMac, DtIsen,Contrato.MutDsk.Cad.DiaIsencao );
    if Contrato.DiasDeAtrasoEntreDatas(DtIsen,DtRef) <= 0 then result := False
    else begin
      {
        110593
        Posso ter uma presta  o antecipada que teve ou n o o seguro tamb m pago a parte.
        Preciso verificar os dois cen rios. A PrstPaga n o verifica tudo, ent o
        vou usar a PrstTotalmentePagaAteData que criei para tratar tamb m a antecipa  o e
        verifica  o do seguro.
      }
      Reg := ObtemValoresPorMac(Mac);
      result := not PrstTotalmentePagaAteData(DtRef, Reg, ConsideraPrstSoDeAcessorios);
                //not PrstPaga( DtRef, MAC, ConsideraPrstSoDeAcessorios);
    end;  
  end else result := False;
end;

function TSerieFinanciamentoDinamico.PrstEmAtrasoIsencao(DtRef : TData;
                                                         MAC: SmallInt;
                                                         ConsideraIsencao : boolean;
                                                         LCobr : integer = 0): boolean;
  var dtmac,dtisen: TData;
      diaVenc     : SmallInt;
      RPrest : TpArqPrst;
  begin
    RPrest.ctr := '';
    fillchar(RPrest,sizeof(RPrest),0);
    DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
    (* Sol 8531 - Sidnei/ mmr - Alterado para dar preferencia a DiaVenc do
        cadmut. Hoje no sistema estes dois valores contem o mesmo valor,
        porem no passado existem casos em que o dia do dtinfin esta'
        incorretamente preenchido. Isto tambem mantem compatibilidade com
        outras areas do sistema *)
    if not (Contrato.MutDsk.Cad.TipoCtr in [1,2]) then begin
      if (Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1 = MAC) and
         (Contrato.MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then
        DiaVenc := Contrato.MutDsk.Financ3.DiaVenc1aPrest
      else
        DiaVenc := Contrato.MutDsk.Financ.DtInFin.Dia;
      LePrst(Contrato.Mutdsk.Cad.Ctr,Mac,RPrest);
      if trim(RPrest.ctr) > '' then // Priorizar o arqprst, sol. 49727
        DiaVenc := RPrest.DiaVenc; 
      DtMac.Dia := Dia_Venc(Mac,DiaVenc);
      int_mes( MAC, dtmac.MesAno ) ;
      if ConsideraIsencao then
        DtIsencaoMora( Contrato.Mutdsk.ChaveImv.Empreend,Contrato.Mutdsk.Cad.Ctr,LCobr,
                       dtmac, DtIsen,Contrato.MutDsk.Cad.DiaIsencao )
      else
        DtIsen := DtMac;
     (* if Juliano( DtRef ) <= Juliano( dtmac ) then PrstEmAtraso := false *)
     (* Teste Substituido por DiasDeAtrasoEntreDatas para casos em que o vencimento*)
     (* da prestacao nao eh em dia util. SCAT - SOL. 4.373 ( JCarlos ) ..  *)
      if Contrato.DiasDeAtrasoEntreDatas(DtIsen,DtRef) <= 0 then PrStEmAtrasoIsencao := False
      else PrstEmAtrasoIsencao := not PrstPaga( DtRef, MAC );
    end
    else PrstEmAtrasoIsencao := False;
  end; (* Prst Em Atraso Isencao *)

function TSerieFinanciamentoDinamico.PrstEmAtraso (DtRef : TData; MAC: SmallInt; LCobr : integer = 0): boolean;
begin
  result := PrstEmAtrasoIsencao(DtRef,Mac,true,LCobr);
end;

function TSerieFinanciamentoDinamico.PrstEmAtrasoReal(var RPA     : TpRPA;
                                                          DtRef   : TData;
                                                          ConsideraIsencao : boolean = true;
                                                          ConsideraVencida : boolean = false;
                                                          ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
var DtMac,DtIsen: TData;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  if not (Contrato.MutDsk.Cad.TipoCtr in [1,2]) then begin
    DtMac.Dia := Dia_Venc( RPA.MAC, RPA.FinRPA.DiaVenc);
    Int_Mes(RPA.MAC, DtMac.MesAno ) ;
    if ConsideraIsencao then
      DtIsencaoMora(Contrato.Mutdsk,RPA,DtMac, DtIsen,Contrato.MutDsk.Cad.DiaIsencao )
    else
      DtIsen := DtMac;  
    if ConsideraVencida and (Juliano(DtRef) = Juliano(DtIsen)) then 
      result := not PrstPagaReal( RPA.MAC, ConsideraPrstSoDeAcessorios )
    else if Contrato.DiasDeAtrasoEntreDatas(DtIsen,DtRef) <= 0 then
      Result := False
    else
      Result := not PrstPagaReal( RPA.MAC, ConsideraPrstSoDeAcessorios );
  end else Result := False;
end;

function TSerieFinanciamentoDinamico.PrstEmAtrasoReal(    ValoresPorMac : TValoresPorMac;
                                                          DtRef   : TData;
                                                          ConsideraIsencao : boolean = true;
                                                          ConsideraVencida : boolean = false;
                                                          ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
var DtMac,DtIsen: TData;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  if not (Contrato.MutDsk.Cad.TipoCtr in [1,2]) then begin
    DtMac.Dia := Dia_Venc( ValoresPorMac.MAC, ValoresPorMac.DiaVenc);
    Int_Mes(ValoresPorMac.MAC, DtMac.MesAno ) ;
    if ConsideraIsencao then
      DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,ValoresPorMac,DtMac, DtIsen,Contrato.MutDsk.Cad.DiaIsencao )
    else
      DtIsen := DtMac;  
    if ConsideraVencida and (Juliano(DtRef) = Juliano(DtIsen)) then
      Result := not PrstPagaReal( ValoresPorMac.MAC, ConsideraPrstSoDeAcessorios )
    else if Contrato.DiasDeAtrasoEntreDatas(DtIsen,DtRef) <= 0 then
      Result := False
    else
      Result := not PrstPagaReal( ValoresPorMac.MAC,ConsideraPrstSoDeAcessorios );
  end else Result := False;
end;

function TSerieFinanciamentoDinamico.PrstAntecipada(Reg : TValoresPorMac) : boolean;
begin
  result := false;
  if assigned(Reg.ParcelaDoMes) then begin
    {
      No financiamento din mico, uma parcela s    criada em mem ria, quando a presta  o
      tem pagamento, ent o se n o estiver atribuido, a presta  o nem est  paga.
    }
    result := Reg.ParcelaDoMes.TipoPg = 80; // 80   o tipo gravado na antecipa  o.
  end;
end;

function TSerieFinanciamentoDinamico.SeguroPago(DtRef : TData; Reg : TValoresPorMac) : boolean; 
begin
  result := false;
  if assigned(Reg.ParcelaDoMes) then begin
    {
      No financiamento din mico, uma parcela s    criada em mem ria, quando a presta  o
      tem pagamento, ent o se n o estiver atribuido, a presta  o nem est  paga.
    }
    if DtRef.dia = 0 then
      result := Reg.ParcelaDoMes.SeguroEstaPagoReal
    else begin
      result := Reg.ParcelaDoMes.SeguroEstaPago(DtRef);
    end;
  end;
end;

function TSerieFinanciamentoDinamico.SeguroPago(Reg : TValoresPorMac) : boolean;
Var
  DtRef : TData;
begin
  DtRef.Dia := 0;
  fillchar(DtRef,sizeof(TData),0);
  result := SeguroPago(DtRef,Reg);
end;

function TSerieFinanciamentoDinamico.PrestacaoTotalmenteQuitada(Reg : TValoresPorMac) : boolean;
begin
  {
    110593
    Foi pedido para verificar que uma presta  o antecipada ainda tem seguro a cobrar.
    Assim, testar PrstPagaReal n o   mais suficiente para saber se a presta  o foi realmente paga.
    Agora eu preciso conferir o seguro tamb m, caso haja uma antecipa  o.
  }
  if PrstAntecipada(Reg) then
    result := SeguroPago(Reg)
  else
    result := PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios});
end;

function TSerieFinanciamentoDinamico.PrstTotalmentePagaAteData(DtRef : Tdata; Reg : TValoresPorMac; ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
begin
  {
    110593
    Foi pedido para verificar que uma presta  o antecipada ainda tem seguro a cobrar.
    Assim, testar PrstPaga n o   mais suficiente para saber se a presta  o foi realmente paga.
    Agora eu preciso conferir o seguro tamb m, caso haja uma antecipa  o.
  }
  if PrstAntecipada(Reg) then
    result := SeguroPago(DtRef,Reg)
  else
    result := PrstPaga(DtRef,Reg.Mac,ConsideraPrstSoDeAcessorios);
end;

function TSerieFinanciamentoDinamico.PrstOk(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                            var MutDsk : TpMutDsk;
                                                DtIsencao : TData;
                                                Reg : TValoresPorMac;
                                                TpPg : byte;
                                                DesconsideraSuspensao : boolean): boolean;
var
  DtVenc : TData;
  PosicaoAtraso : TDadosPosicaoAtrasoItem;
  UF : str3;
  CodMun : smallint;
begin
  if CalculoAtrasoParametros.UsaPosicaoAtraso then begin
    PosicaoAtraso := Contrato.DadosPosicaoAtraso.ObtemPrest(0,Reg.Mac);
    result := (Reg.CodErro = 0) and assigned(PosicaoAtraso) and (PosicaoAtraso.Cad.VAL_ATRASO > zero);
  end
  else if (CalculoAtrasoParametros.MacParcComSegNaoPermitida > 0) and
     (Reg.Mac >= CalculoAtrasoParametros.MacParcComSegNaoPermitida) and
     ((Reg.Seguro-Reg.DescSeg) > zero) then begin
    result := false;
  end
  else if (Reg.NPC > 0) and 
          ((Reg.TotPrest-Reg.Desc > Zero) or
           ((Reg.TotPrest > zero) and
            ((abs(Reg.ValorDescConcedido-Reg.Desc)<zero) or (abs(Reg.PercDescConcedido-100)<zero)))) then begin
    Int_Mes(Reg.MAC,DtVenc.MesAno);
    if (Reg.DiaVenc1aPrest > 0) and (Reg.NPC = 1) then
      DtVenc.Dia := Reg.DiaVenc1aPrest
    else
      DtVenc.Dia := Reg.DiaVenc;
    UF := '';
    CodMun := 0;
    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    case CalculoAtrasoParametros.TipoExec of
     TipoExec_Atraso       : begin
                      if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                        result := PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                    CalculoAtrasoParametros.DataAtr,
                                                    RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                    true{ConsideraPrstSoDeAcessorios}) and
                                 (not PrstTotalmentePagaAteData(CalculoAtrasoParametros.DataAtr,Reg,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0)
                      else begin
                        result := PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                    CalculoAtrasoParametros.DataRef,
                                                    RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                    true{ConsideraPrstSoDeAcessorios}) and
                                 (not PrstTotalmentePagaAteData(CalculoAtrasoParametros.DataRef,Reg,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0);
                      end;            
     end;
     TipoExec_Devidas      : if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataAtr,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(dtvenc) <= Juliano(CalculoAtrasoParametros.DataRef)) or
                                   (CalculoAtrasoParametros.CobraDoMes and (Mes_int(DtVenc.MesAno) = Mes_int(CalculoAtrasoParametros.DataRef.MesAno)))) and
                                 (not PrstPaga(CalculoAtrasoParametros.DataAtr,Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0)
                      else
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataRef,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(DtIsencao) <= Juliano(CalculoAtrasoParametros.DataRef)) or
                                   (CalculoAtrasoParametros.CobraDoMes and (Mes_int(DtIsencao.MesAno) = Mes_int(CalculoAtrasoParametros.DataRef.MesAno)))) and
                                 (not PrstPaga(CalculoAtrasoParametros.DataRef,Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0);

     TipoExec_QuitAnual : if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataAtr,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(dtvenc) <= Juliano(CalculoAtrasoParametros.DataRef))) and
                                 (not PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0)
                      else
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataRef,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(DtIsencao) <= Juliano(CalculoAtrasoParametros.DataRef))) and
                                 (not PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0);

     TipoExec_Renegociacao : if CalculoAtrasoParametros.DataAtr.Dia > 0 then
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataAtr,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(dtvenc) <= Juliano(CalculoAtrasoParametros.DataRef)) or
                                   (CalculoAtrasoParametros.CobraDoMes and (Mes_int(DtVenc.MesAno) = Mes_int(CalculoAtrasoParametros.DataRef.MesAno)))) and
                                 (not PrstPaga(CalculoAtrasoParametros.DataAtr,Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0) and
                                 (TpPg <> 253)
                      else
                        result := (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                     CalculoAtrasoParametros.DataRef,
                                                     RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                     true{ConsideraPrstSoDeAcessorios}) or
                                   (Juliano(DtVenc) <= Juliano(CalculoAtrasoParametros.DataRef)) or
                                   (CalculoAtrasoParametros.CobraDoMes and (Mes_int(DtIsencao.MesAno) = Mes_int(CalculoAtrasoParametros.DataRef.MesAno)))) and
                                 (not PrstPaga(CalculoAtrasoParametros.DataRef,Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                  Reg.CtrAtivo and (Reg.CodErro = 0) and
                                 (TpPg <> 253);

     TipoExec_Quitacao     : begin  { sol. 9542 }
                        result := ((Contrato.DiasDeAtrasoEntreDatas(DtVenc,CalculoAtrasoParametros.DataRef) > 0) or
                                   (Juliano(DtVenc) = Juliano(CalculoAtrasoParametros.DataRef)) or
                                  ((Juliano(CalculoAtrasoParametros.DataRef) >= Juliano(DtVenc)) and
                                   (Feriado(DtVenc,UF,CodMun))) ) and
                                   (not PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios}) or (CalculoAtrasoParametros.CalcPagFGTS and PagoPorFGTS(mutDsk,Reg.Mac))) and
                                    Reg.CtrAtivo and (Reg.CodErro = 0) and
                                   (TpPg <> 253);

                        // Sol. 47324
                        if result then
                          if mes_int(CalculoAtrasoParametros.DataRef.MesAno) = mes_int(DataH.mesano) then
                            if Reg.PA = 94 then
                              if mes_int(DtVenc.MesAno) = mes_int(DataH.mesano) then
                                if ScciConf.DiasIgnoraPrestDoMesNaQuit > 0 then
                                  result := Juliano(CalculoAtrasoParametros.DataRef)-Juliano(DtVenc) > ScciConf.DiasIgnoraPrestDoMesNaQuit;

                      end;
     TipoExec_Incorporacao : begin
                        result := ((Contrato.DiasDeAtrasoEntreDatas(DtVenc,CalculoAtrasoParametros.DataRef) > 0) or
                                   (Juliano(DtVenc) = Juliano(CalculoAtrasoParametros.DataRef)) or
                                   ((Juliano(CalculoAtrasoParametros.DataRef) >= Juliano(DtVenc)) and
                                    (Feriado(DtVenc,UF,CodMun))) ) and
                                   (not PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios})) and
                                   Reg.CtrAtivo and (Reg.CodErro = 0);

                        if (not CalculoAtrasoParametros.CalcIncParaIncorporado) and
                           PrstPagaReal(Reg.MAC,true{ConsideraPrstSoDeAcessorios}) then result := false;
                      end;
     else begin
                        result := (  (ScciConf.AcordoCobraPrestMesNaoVencida and
                                      (CalculoAtrasoParametros.TipoExec = TipoExec_Acordo) and
                                      (Mes_int(Dtisencao.Mesano) = Mes_int(CalculoAtrasoParametros.DataRef.mesano))) or
                                     (PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,
                                                        CalculoAtrasoParametros.DataRef,
                                                        RetornaLCobrValoresPorMac(Mutdsk,Reg),
                                                        true{ConsideraPrstSoDeAcessorios}) and
                                    ((CalculoAtrasoParametros.TipoExec <> TipoExec_Acordo) or ( Juliano(DtIsencao) < Juliano(CalculoAtrasoParametros.DataRef)))) or
                                   ( ( Juliano(DtIsencao) <= Juliano(CalculoAtrasoParametros.DataRef) ) or
                                     ( CalculoAtrasoParametros.TipoExec in [TipoExec_Aberta,TipoExec_Caixa,TipoExec_2aVia,TipoExec_IsenMoraAuto])) or
                                     (CalculoAtrasoParametros.TipoExec in [TipoExec_EmiteAc,TipoExec_Vincendas]))  and
                                      Reg.CtrAtivo and
                                  ((Reg.CodErro in [0,1]) or (CalculoAtrasoParametros.TipoExec = TipoExec_Vincendas) or CalculoAtrasoParametros.EvoPrestMesmoSemIndice) and
                                   (not SitEspSuspPrst(MutDsk,CalculoAtrasoParametros.DataRef,DtVenc) or DesconsideraSuspensao or
                                   (not (CalculoAtrasoParametros.TipoExec in [TipoExec_2aVia,TipoExec_Caixa,TipoExec_Vincendas,TipoExec_IsenMoraAuto])) or
                                    CalculoAtrasoParametros.EmiteSusp);
                        if (CalculoAtrasoParametros.TipoExec in [TipoExec_Aberta,TipoExec_Acordo,TipoExec_Caixa,TipoExec_2aVia,Tipoexec_EmiteAc,
                                       TipoExec_Vincendas,TipoExec_IsenMoraAuto]) then
                          if PrestacaoTotalmenteQuitada(Reg) then PrstOk := false;
     end;
    end; { case }
    if CalculoAtrasoParametros.DesconsideraAtrasoNaCessao and PrestacaoCedida(Reg) then PrstOk := false;
  end else Result := false;
end;

procedure TSerieFinanciamentoDinamico.AtribuiIsenMoraZero(Var Mutdsk : TpMutdsk;
                                                              DataRef : TData;
                                                              Mac : integer;
                                                          Var IsenMora : TpIsenMora);
{$IFDEF CONSOLE}
var
  RegIsenMoraZero : TpIsenMora;
{$ENDIF}  
begin
{$IFDEF CONSOLE}
  RegIsenMoraZero.ctr := '';
  fillchar(RegIsenMoraZero,sizeof(TpIsenMora),0);

  if ObtemIsenMoraZero(Mutdsk.cad.ctr,0{codserie},Mac,RegIsenMoraZero) then begin
    if (juliano(RegIsenMoraZero.DataIsen) >= juliano(DataRef)) or (juliano(RegIsenMoraZero.DataIsen) = 0) then begin
      fillchar(IsenMora,sizeof(TpIsenMora),0);
      with IsenMora do begin
        Ctr          := MutDsk.Cad.Ctr;
        CodSerie     := 0;
        Get_Data(Data);
        Get_Hora(Hora);
        User         := PegaUsuario;
        DataIsen     := DataRef;
        IsenCorrecao := false;
        IsenMora     := false;
        IsenMulta    := false;
        CodMot       := 0;
        MACPrst      := MAC;
      end;
      IsenMora.PercDescMora := RegIsenMoraZero.PercDescMora;
      IsenMora.PercDescJRemuneratorios := RegIsenMoraZero.PercDescJRemuneratorios;
      IsenMora.PercDescCorr := RegIsenMoraZero.PercDescCorr;
      IsenMora.PercDescMulta := RegIsenMoraZero.PercDescMulta;
    end;
  end;
{$ENDIF}
end;

procedure TSerieFinanciamentoDinamico.TrataIsenMoraAuto(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                        var Mutdsk : TpMutdsk;
                                                            Reg : TValoresPorMac;
                                                            Dtv : Tdata;
                                                            Prest : TPrestacaoAtrasoEvo);
var
  DataAgenda : TData;
  Emitiu : boolean;
  PercDescMora,
  PercDescJRemuneratorios,
  PercDescCorr,
  PercDescMulta : real;
begin
  DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,Prest.DtVencAtu,Prest.DtIsenMora,MutDsk.Cad.DiaIsencao);
  DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,Dtv,Prest.DtIsencao,MutDsk.Cad.DiaIsencao); // acredito que seja usado pelo remoto apenas

  PercDescMora := 0;
  PercDescJRemuneratorios := 0;
  PercDescCorr := 0;
  PercDescMulta := 0;
  Emitiu := false;
  DataAgenda.dia := 0; DataAgenda.mes := 0; DataAgenda.ano := 0;
  Prest.SeparaACPrest := false; // seta apenas no caso de ser a  ltima e ela ser diferenciada
  if (CalculoAtrasoParametros.PercIsentaDtIsen.dia > 0) then begin
    fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := 0;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.PercIsentaDtIsen;
      IsenCorrecao := false;
      IsenMora     := false;
      IsenMulta    := false;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
    end;
    Prest.IsenMora.PercDescMora := CalculoAtrasoParametros.PercIsentaMora;
    Prest.IsenMora.PercDescMulta := CalculoAtrasoParametros.PercIsentaMulta;
    Prest.IsenMora.PercDescCorr := CalculoAtrasoParametros.PercIsentaCorr;
  end;
  if CalculoAtrasoParametros.AplicaIsenMoraZero then // Sol. 95299
    AtribuiIsenMoraZero(Mutdsk,CalculoAtrasoParametros.DataRef,Reg.Mac,Prest.IsenMora);
  if CalculoAtrasoParametros.ProgAcasaESua then begin
    fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := 0;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.DataRef;
      IsenCorrecao := false;
      IsenMora     := false;
      IsenMulta    := false;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
    end;
    Prest.IsenMora.PercDescMora := ScciConf.PerDescAtrCasaSua;
    Prest.IsenMora.PercDescJRemuneratorios := ScciConf.PerDescAtrCasaSua;
  end
  else if (((CalculoAtrasoParametros.TipoExec = TipoExec_IsenMoraAuto) or CalculoAtrasoParametros.TrataLei9866) and
             ((ScciConf.VencLimiteLibAutoMora.dia=0) or (Juliano(Prest.DtVencAtu)<=Juliano(ScciConf.VencLimiteLibAutoMora)))) or
           ((CalculoAtrasoParametros.TipoExec = TipoExec_Quitacao) and MutDsk.Cad3.IsentadeMoraAtrasoNaQuit and
             CalculoAtrasoParametros.IsentaMoraNaQuitacao) then begin
      fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
      with Prest.IsenMora do begin
        Ctr := MutDsk.Cad.Ctr;
        Get_Data(Data);
        Get_Hora(Hora);
        User         := PegaUsuario;
        DataIsen     := CalculoAtrasoParametros.DataRef;
        if (CalculoAtrasoParametros.TipoExec = TipoExec_IsenMoraAuto) and
           (ScciConf.DataIsenMoraAuto.dia > 0) and
           (Juliano(ScciConf.DataIsenMoraAuto) > Juliano(CalculoAtrasoParametros.DataRef)) then
          DataIsen := ScciConf.DataIsenMoraAuto;
        IsenCorrecao := false;
        if CalculoAtrasoParametros.TrataLei9866 then
          PercDescMora := DefinePerDescMoraPorLei9866(CalculoAtrasoParametros.DtProtocoloLei9866)
        else if ScciConf.UtilizaLei9866 then
          PercDescMora := DefinePerDescMoraPorLei9866(CalculoAtrasoParametros.DataRef)
        else
          IsenMora     := true;
        IsenMulta    := false;
        CodMot       := 0;
        MACPrst      := Reg.Mac;
        CodSerie     := 0;
      end;
    end
  else if CalculoAtrasoParametros.RespeitaAgendaPagamento then begin
    if Contrato.DadosAgendaPagamento.Le(0,TpParc_Series,Reg.NPC,DataAgenda,
                                        PercDescMora,PercDescJRemuneratorios,PercDescCorr,PercDescMulta,
                                        Emitiu,Reg.Mac) then
      if (DataAgenda.dia > 0) then begin
        fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
        with Prest.IsenMora do begin
          Ctr          := MutDsk.Cad.Ctr;
          CodSerie     := 0;
          Get_Data(Data);
          Get_Hora(Hora);
          User         := PegaUsuario;
          DataIsen     := CalculoAtrasoParametros.DataRef;
          IsenCorrecao := false;
          IsenMora     := false;
          IsenMulta    := false;
          CodMot       := 0;
          MACPrst      := Reg.MAC;
        end;
        Prest.IsenMora.PercDescMora := PercDescMora;
        Prest.IsenMora.PercDescJRemuneratorios := PercDescJRemuneratorios;
        Prest.IsenMora.PercDescCorr := PercDescCorr;
        Prest.IsenMora.PercDescMulta := PercDescMulta;
      end;
  end
  else if Prest.UltimaPrestacao and CalculoAtrasoParametros.UltimaPrestacaoDiferenciada then begin
    fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
    with Prest.IsenMora do begin
      Ctr := MutDsk.Cad.Ctr;
      Get_Data(Data);
      Get_Hora(Hora);
      User := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.DataRef;
      IsenCorrecao := true;
      IsenMora     := true;
      IsenMulta    := true;
      CodMot       := 0;
      MACPrst      := Reg.Mac;
    end;
    Prest.SeparaACPrest := true;
  end;

  if (ScciConf.DtMaxAtrIsenMora.dia > 0) and
     (Juliano(Prest.DtVencAtu) > Juliano(ScciConf.DtMaxAtrIsenMora)) then begin // sol. 49556
    Prest.IsenMora.PercDescMora := 0;
    Prest.IsenMora.IsenJM := false;
    Prest.IsenMora.PercDescJRemuneratorios := 0;
    Prest.IsenMora.IsenJC := false;
    Prest.IsenMora.IsenMora := false;
  end;
end;

