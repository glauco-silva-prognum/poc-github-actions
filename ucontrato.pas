procedure TSerie.InitRazao;
var
  J : real;
  MesAnoRef   : TMes_Ano;
  Defasagem : Double;
  IndJurosAoMes : Double;
  DataRefJuros : TData; // Data de referencia para c lculo dos juros
  Dia2 : Integer;
  DtInicio : Tdata;
  RSerie : TpSeries;
  SistAmort : byte;
begin
  RSerie := Fin;

  if RPAS.ValRPA.MACRecorr=0 then RPAS.ValRPA.MACRecorr := Mes_Int( RPAS.FinRPA.DtInFin.MesAno ) + 2;
  SistAmort := RPAS.FinRPA.Plano mod 10;
  if SistAmort = SIMC then
    RPAS.ValRPA.MACRecorr := RPAS.ValRPA.MacRecorr + 23;

  DtInicio := RSerie.DtInicio;
  if RSerie.DiaVenc > 0 then
    DtInicio.Dia := RSerie.DiaVenc;
  if DtInicio.dia > Dias_Mes(Mes_int(DtInicio.MesANo)) then
    DtInicio.dia := Dias_Mes(Mes_Int(DtInicio.MesAno));
  if RSerie.PerParcelas = 0 { Serie A Vista } then
  begin
    RSerie.Prazo := 1;
    RSerie.PerParcelas := 1;
  end;
  J := CalculaJuros(RSerie.TpJuros,RSerie.TxJuros,RSerie.PerParcelas,RSerie.JurosSimples);
  if Juliano(RSerie.DataRef) = 0 then
    RSerie.DataRef := RPAS.FinRPA.DtAssin;
  if (RSerie.DtCarenciaDeJuros.Dia > 0) and
     (Juliano(RSerie.DtCarenciaDeJuros) > Juliano(RSerie.DataRef)) then
    DataRefJuros := RSerie.DtCarenciaDeJuros
  else
    DataRefJuros := RSerie.DataRef;
  MesAnoRef := DataRefJuros.MesAno;
  Defasagem := Mes_Int(DtInicio.MesAno) - Mes_Int(MesAnoRef) - RSerie.PerParcelas;
  if RSerie.JurProRata then // Dever  ser considerado a diferen a de dias na defasagem
  begin
    Dia2 := DIA_VENC(mes_int(DataRefJuros.MesAno),DtInicio.Dia);
    Defasagem := Defasagem + (Dia2 - DataRefJuros.Dia) / 30;
  end
  else if RSerie.IncluiFracaoDoMes then // Se N o tem juros pro-rata ent o verifica se cobra um per odo para fra  o do m s
  begin
    if DataRefJuros.Dia < DtInicio.Dia then Defasagem := Defasagem + 1;
  end;

  if RSerie.PerParcelas = 0 then RSerie.PerParcelas := 1;
  IndJurosAoMes := pot(1 + J/100, 1.0 / RSerie.PerParcelas ) -1 ;

  if RSerie.CobraJurosNaCarencia then
  begin
    Defasagem := 0;
    J := IndJurosAoMes*100;
  end;
  if RSerie.RazaoIni <> 0 then
    RPAS.ValRPA.RARD := RSerie.RazaoIni
  else
    RPAS.ValRPA.RARD := CalculaRazao(RSerie.Valor,J,
                         RSerie.PerParcelas,RSerie.Prazo,
                         RSerie.SistAmort,Defasagem,RSerie.JurosSimples);
  if RPAS.MAC >= 1070 then
    RPAS.ValRPA.RARD := RPAS.ValRPA.RARD * 1000 ;

  if (Rpas.Temp11.planoswap = 0{Igual ao financiamento}) then
    rpas.Temp12.RaRdSwap := RSerie.RazaoIni * (1-Rpas.Sec.PercColateral)*1000;
end;


procedure TSerie.CalcAmaisJAgio;
var
  AmaisjContratual, 
  AmaisjDesconto,
  RazaoJContratual,
  RazaoJDesconto: Double;

begin
  // Se o contrato tem uma car ncia inicial, n o d  para alcular como diferen as entre os amaisj Sol. 73434
  if Rpas.Mac > Mes_Int(RPas.Finrpa.DtAssin.MesAno)  then
  begin
    Rpas.Sec.AmaisjAgio := 
     CalcAmaisJ( RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, RPAS.Sec.SaldoAgio,
                 Fin.TxJurosDesconto/1200 );
    Rpas.Sec.RazaoAgio := 
      Razao(RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, 0, RPAS.Sec.RazaoAgio,
            Fin.TxJurosDesconto/1200, Rpas.Sec.AmaisjAgio, 0);
  end
  else
  begin
    AmaisJContratual := 
     CalcAmaisJ( RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, RPAS.ValRpa.SaldoDev,
                 Rpas.FinRpa.IndJuros );
    RazaoJContratual := 
      Razao(RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, 0, RPAS.ValRpa.SaldoDev,
            Rpas.FinRpa.IndJuros, AmaisJContratual, 0);
    AmaisJDesconto := 
     CalcAmaisJ( RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, RPAS.ValRpa.SaldoDev,
                 Fin.TxJurosDesconto/1200 );
    RazaoJDesconto := 
      Razao(RPAS.FINRpa.Plano, RPAS.FINRPA.Prazo, 0, RPAS.ValRpa.SaldoDev,
            Fin.TxJurosDesconto/1200, AmaisJDesconto, 0);
   RPAS.Sec.RazaoAgio := RazaoJContratual - RazaoJDesconto;
   // Est  sendo somada uma raz o ao amaisjAgio para que n o seja necess rio
   // fazer um teste para s  come ar a descontar a raz o a partir da segunda
   // persta  o.
   if Rpas.Sec.TpCalcDesagio <> 3 then
     RPAS.Sec.AmaisJAgio := AmaisJContratual - AmaisJDesconto + RPAS.Sec.RazaoAgio
   else
   begin
     Rpas.Sec.AmaisJAgio := 0; { Scat 32198 }
     Rpas.Sec.RazaoAgio := 0;  { Scat 75942 }
   end;
  end; 
end;

