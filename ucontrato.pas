                          Prest.Despesas + Prest.ResiduoCobrado-
                          Prest.ValorPagoAntecipado;

    DifAbat   := 0;
    if Prest.Diferenca > Zero then Prest.OutRec := Prest.Diferenca
    else DifAbat := Prest.Diferenca * -1;
    if (ValInt(scciconf.nserie) <> nsLetra) and
       (not (ValInt(Scciconf.NSerie) in [5..8])) then
      Prest.OutAbat := DifAbat + Prest.Desc
    else
      Prest.OutAbat := DifAbat;
    if Prest.DescPagamento > zero then Prest.outAbat := Prest.OutAbat + Prest.DescPagamento;
    Prest.ValTit       := Prest.EncMes - Prest.OutAbat + Prest.TaxaBanco +
                          Prest.OutRec + Prest.ValAcordo + Prest.ValIOFComplem;
  finally
    RegAux.free;
    RegSemReajuste.free;
  end;
end;

procedure TSerie.TrataIsenMoraAuto(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                   var Mutdsk : TpMutdsk;
                                       Reg : TValoresPorMac;
                                       Dtv : Tdata;
                                       UsaIsenSerieDefault : boolean;
                                       Prest : TPrestacaoAtrasoEvo);
var
  DataAgenda : TData;
  Emitiu : boolean;
  PercDescMora,
  PercDescJRemuneratorios,
  PercDescCorr,
  PercDescMulta : real;
begin
  PercDescMora := 0;
  PercDescJRemuneratorios := 0;
  PercDescCorr := 0;
  PercDescMulta := 0;
  Emitiu := false;
  DataAgenda.dia := 0; DataAgenda.mes := 0; DataAgenda.ano := 0;
  if (CalculoAtrasoParametros.PercIsentaDtIsen.dia > 0) then begin
    {
      111576
    }
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := Fin.CodSerie;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.PercIsentaDtIsen;
      IsenCorrecao := false;
      IsenMora     := false;
      IsenMulta    := false;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
      PercDescMora := CalculoAtrasoParametros.PercIsentaMora;
      PercDescMulta := CalculoAtrasoParametros.PercIsentaMulta;
      PercDescCorr := CalculoAtrasoParametros.PercIsentaCorr;
    end;
  end;
  if UsaIsenSerieDefault then
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := Fin.CodSerie;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.DataRef;
      IsenCorrecao := Fin.Isentacorrecao;
      IsenMora     := Fin.IsentaMora;
      IsenMulta    := Fin.IsentaMulta;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
      if IsenCorrecao then PercDescCorr := 100.0;
      if IsenMora  then begin
        PercDescMora            := 100.0;
        PercDescJRemuneratorios := 100.0;
      end;
      if IsenMulta then PercDescMulta   := 100.0;
      if Fin.IsentaHonorario then PercDescHonorarios := 10000;
    end;

  if CalculoAtrasoParametros.ProgAcasaESua then begin
    fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := Fin.CodSerie;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.DataRef;
      IsenCorrecao := false;
      IsenMora     := false;
      IsenMulta    := false;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
    end;
    Prest.IsenMora.PercDescMora := ScciConf.PerDescAtrCasaSua;
    Prest.IsenMora.PercDescJRemuneratorios := ScciConf.PerDescAtrCasaSua;
  end
  else if CalculoAtrasoParametros.TipoExec = TipoExec_IsenMoraAuto then begin
    fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
    with Prest.IsenMora do begin
      Ctr          := MutDsk.Cad.Ctr;
      CodSerie     := Fin.CodSerie;
      Get_Data(Data);
      Get_Hora(Hora);
      User         := PegaUsuario;
      DataIsen     := CalculoAtrasoParametros.DataRef;
      if (CalculoAtrasoParametros.TipoExec = TipoExec_IsenMoraAuto) and
         (ScciConf.DataIsenMoraAuto.dia > 0) and
         (Juliano(ScciConf.DataIsenMoraAuto) > Juliano(CalculoAtrasoParametros.DataRef)) then
        DataIsen := ScciConf.DataIsenMoraAuto;
      IsenCorrecao := false;
      IsenMora     := true;
      IsenMulta    := false;
      CodMot       := 0;
      MACPrst      := Reg.MAC;
    end;
  end
  else if CalculoAtrasoParametros.RespeitaAgendaPagamento then begin
    IdentificaParcela(Reg,Prest.ParcSerieAntec,Prest.TipoParc,Prest.NumParcSerie,Prest.TemPgParcial);
    if Contrato.DadosAgendaPagamento.Le(Fin.CodSerie,Prest.TipoParc,Prest.NumParcSerie,DataAgenda,
                                        PercDescMora,PercDescJRemuneratorios,PercDescCorr,PercDescMulta,
                                        Emitiu,Prest.MacPrst) then
      if (DataAgenda.dia > 0) then begin
        fillchar(Prest.IsenMora,sizeof(TpIsenMora),0);
        with Prest.IsenMora do begin
          Ctr          := MutDsk.Cad.Ctr;
          CodSerie     := Fin.CodSerie;
          Get_Data(Data);
          Get_Hora(Hora);
          User         := PegaUsuario;
          DataIsen     := CalculoAtrasoParametros.DataRef;
          IsenCorrecao := false;
          IsenMora     := false;
          IsenMulta    := false;
          CodMot       := 0;
          MACPrst      := Reg.MAC;
        end;
        Prest.IsenMora.PercDescMora := PercDescMora;
        Prest.IsenMora.PercDescJRemuneratorios := PercDescJRemuneratorios;
        Prest.IsenMora.PercDescCorr := PercDescCorr;
        Prest.IsenMora.PercDescMulta := PercDescMulta;
      end;
  end;
  if Fin.NaoPodeIsentarMora or // sol. 55478
     ((ScciConf.DtMaxAtrIsenMora.dia > 0) and
      (Juliano(Dtv) > Juliano(ScciConf.DtMaxAtrIsenMora))) then begin // sol. 49556
    Prest.IsenMora.PercDescMora := 0;
    Prest.IsenMora.IsenJM := false;
    Prest.IsenMora.PercDescJRemuneratorios := 0;
    Prest.IsenMora.IsenJC := false;
    Prest.IsenMora.IsenMora := false;
  end;
  if Fin.NaoPodeIsentarMulta then begin
    Prest.IsenMora.PercDescMulta := 0;
    Prest.IsenMora.IsenMulta := false;
  end;
  if Fin.NaoPodeIsentarCorr then begin
    Prest.IsenMora.PercDescCorr := 0;
    Prest.IsenMora.IsenCorrecao := false;
  end;
  if Fin.NaoPodeIsentarHonor then
    Prest.IsenMora.PercDescHonorarios := 0;
end;

procedure Tserie.CalcParcSerieMes(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                  Var Mutdsk : TpMutdsk;
                                      Reg,
                                      RegConsRef : TValoresPorMac;
                                      Dados : TDadosAtrasoEvo;
                                      Prest : TPrestacaoAtrasoEvo;
                                      UsaIsenSerieDefault : boolean);
var
  dtv,
  DtIniPend,
  DataRefRecibo : TData;
begin
  DtIniPend.dia := 0; DtIniPend.mes := 0; DtIniPend.ano := 0;
  int_mes(Reg.Mac,dtv.MesAno);
  dtv.Dia := Reg.DiaVenc;
  Prest.DtVencAtu := dtv;
  TrataIsenMoraAuto(CalculoAtrasoParametros,Mutdsk,Reg,Dtv,UsaIsenSerieDefault,Prest);
  Prest.EmAtraso := CalculoAtrasoParametros.UsaPosicaoAtraso or
                    EstaEmAtrasoAtualS(Reg,CalculoAtrasoParametros.DataRef);
  Prest.NDiasAtr := juliano(CalculoAtrasoParametros.Dataref)-juliano(Prest.DtVencAtu);
  if Prest.NDiasAtr < 0 then
    Prest.NDiasAtr := 0;
  if CalculoAtrasoParametros.DtVencRecVincendasNoVencOrig and not Prest.EmAtraso then
    DataRefRecibo := dtv
  else
    DataRefRecibo := CalculoAtrasoParametros.DataRef;
  Prest.EmFaseDeCarenciaFinBancChaves := EstaEmFaseDeCarenciaFinBancChaves(DataRefRecibo);
  Prest.EmCarenciaCobAtraso := EmCarenciaCobAtraso(Reg,DataRefRecibo);
  DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,Dtv,Prest.DtIsencao,MutDsk.Cad.DiaIsencao); // acredito que seja usado pelo remoto apenas
  if Prest.ESeguro then
    CalculaDadosPrestSeguro(CalculoAtrasoParametros,MutDsk,Reg,RegConsRef,
                            Dados,Prest,Dtv,DtIniPend,DataRefRecibo)
  else
    CalculaDadosPrest(CalculoAtrasoParametros,MutDsk,Reg,RegConsRef,
                      Dados,Prest,Dtv,DtIniPend,DataRefRecibo);
  if (Prest.ValTit < Zero) and (Abs(Prest.ValTit) > Zero) then
    Prest.Esconde := true;
end;

procedure MontaPrestatrEvoControverso(Reg : TValoresPorMac;
                                      Prest : TPrestacaoAtrasoEvo);
begin
  Prest.EControverso := TemOpcao(Reg.FezOpc,
                                 Reg.FezOpc2,
                                 Reg.FezOpc3,
                                 Reg.FezOpc4,83);
  Prest.AmaisjControverso := Reg.AmaisjControverso;
end;

procedure Tserie.SelecionaMesAMes(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                  var Mutdsk : TpMutdsk;
                                      Reg,
                                      RegConsRef : TValoresPorMac;
                                      DtIsenMora : TData;
                                      Dados : TDadosAtrasoEvo);
var
  Prest : TprestacaoAtrasoEvo;
begin
  if ParcSerieOk(Mutdsk,Reg,DtIsenMora,CalculoAtrasoParametros,false{DesconsideraSuspensao}) then begin
    if Dados.SeparaSeguro then begin
      Prest := TprestacaoAtrasoEvo.create;
      Prest.Ctr := Fin.Ctr;
      Prest.ESeguro := true;
      Prest.EParcserie := true;
      Prest.TipoCtr := RegConsRef.TipoCtr;
      Prest.SerieAtiva := Reg.CtrAtivo;
      Prest.SerieIsentaHonorario := Fin.IsentaHonorario and not Fin.NaoPodeIsentarHonor;
      MontaPrestAtrEvoControverso(RegConsRef,Prest);
      Dados.Add(Prest);
      CalcParcSerieMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Prest,true{UsaIsenSerieDefault});
    end;

    Prest := TprestacaoAtrasoEvo.create;
    Prest.Ctr := Fin.Ctr;
    Prest.EParcserie := true;
    Prest.TipoCtr := RegConsRef.TipoCtr;
    Prest.SerieAtiva := Reg.CtrAtivo;
    Prest.SerieIsentaHonorario := Fin.IsentaHonorario and not Fin.NaoPodeIsentarHonor;
    MontaPrestAtrEvoControverso(RegConsRef,Prest);
    Dados.Add(Prest);
    CalcParcSerieMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,Dados,Prest,true{UsaIsenSerieDefault});
  end;
end;


procedure TSerie.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                               Var Mutdsk : TpMutDsk;
                                   RegConsRef : TValoresPorMac;
                                   UltimoMac : integer;
                                   Dados : TDadosAtrasoEvo);
var
  Reg : TValoresPorMac;
  i : integer;
  DtVenc : Tdata;
  DtIsenMora : Tdata;
begin
  DtIsenMora.Dia := 0; DtIsenMora.Mes := 0; DtIsenMora.ano := 0;
  i := mes_int(Fin.DataRef.MesAno);
  if UltimoMac < 0 then
    UltimoMac := Mes_int(CalculoAtrasoParametros.DataRef.MesAno);
  while (i <= UltimoMac) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      Int_Mes(Reg.MAC,DtVenc.MesAno);
      if (valInt(ScciConf.Nserie) = NsPiemonte) and (Reg.Npc = 1) then
        DtVenc.Dia := Reg.DiaVenc
      else
        DtVenc.Dia := Reg.DtInFin.Dia;
      DtVenc.Dia := Dia_Venc(Mes_Int(DtVenc.MesAno),DtVenc.Dia);
      DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsenMora,MutDsk.Cad.DiaIsencao);
      SelecionaMesAMes(CalculoAtrasoParametros,Mutdsk,Reg,RegConsRef,DtIsenMora,Dados);
      if (Reg.CodErro = 2) and ((Dados.MACErro2 > Reg.MAC) or (Dados.MACErro2 = 0)) then Dados.MACErro2 := Reg.MAC;
    end;
    inc(i);
  end;
end;

procedure TSerie.CalculaAtrasoSwap( DataRef : Tdata;
                                    Var Amaisj, Juros : real);
var
  Reg : TValoresPorMac;
  i : integer;
  UltimoMac : integer;
begin
  i := mes_int(Fin.DataRef.MesAno);
  UltimoMac := Mes_int(DataRef.MesAno);
  while (i <= UltimoMac) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if assigned(Reg.parcelaDoMes) and not Reg.ParcelaDoMes.EstaPaga(DataRef) then begin
        Amaisj := Amaisj + Reg.AmaisJSwap;
        Juros := Juros + Reg.JuroSwap;
      end;
    end;
    inc(i);
  end;
end;

procedure TSerie.CalculaAtraso(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                               Var Mutdsk : TpMutDsk;
                                   RegConsRef : TValoresPorMac;
                                   UltimoMac : integer;
                               Var NumPrst : integer;
                               Var Total,
                                   TotalJurosMoratorios,
                                   TotalJurosRemuneratorios,
                                   TotalCorrecao,
                                   TotalMulta : real;
                                   Dados : TDadosAtrasoEvo = nil);
var
  DadosAux : TDadosAtrasoEvo;
  i : integer;
begin
  NumPrst := 0;
  Total := 0;
  TotalJurosMoratorios := 0;
  TotalJurosRemuneratorios := 0;
  TotalCorrecao := 0;
  TotalMulta := 0;

  DadosAux := TDadosAtrasoEvo.create;
  try
    CalculaAtraso(CalculoAtrasoParametros,Mutdsk,RegConsRef,UltimoMac,DadosAux);
    NumPrst := DadosAux.count;
    for i := 0 to DadosAux.count-1 do begin
      Total := Total + DadosAux[i].Valtit;
      TotalJurosMoratorios := TotalJurosMoratorios + (DadosAux[i].Mora - DadosAux[i].JurosContr);
      TotalJurosRemuneratorios := TotalJurosRemuneratorios + DadosAux[i].Juroscontr;
      TotalCorrecao := TotalCorrecao + DadosAux[i].Correcao;
      TotalMulta := TotalMulta + DadosAux[i].Multa;
      if Assigned(Dados) then
        Dados.Copy(DadosAux[i]);
    end;
  finally
    DadosAux.free;
  end;
end;

function TSerie.ObtemHonorariosParcelaPaga(    Parcela            : TParcelaSerie; 
                                           var PercHonorarios,
                                               PercDescHonorarios : real;
                                               Seguro : boolean = false) : real;
begin
  Result := 0;
  PercHonorarios := 0;
  PercDescHonorarios := 0;
  if assigned(Parcela) then begin
    if Seguro then begin
      if Parcela.SeguroEstaPagoReal then begin
        Result := Parcela.ValorHonorariosSeg;
        PercHonorarios     := Parcela.PercHonorariosSeg;
        PercDescHonorarios := Parcela.PercDescHonorariosSeg;
      end;
    end
    else begin
      if Parcela.EstaPagaReal then begin
        Result := Parcela.ValorHonorarios;
        PercHonorarios     := Parcela.PercHonorarios;
        PercDescHonorarios := Parcela.PercDescHonorarios;
      end;
    end;  
  end;
end;

function TSerie.ValPagParcSerieDtPg(    Parcela : TParcelaSerie;
                                    var Desconto: real;
                                        SoDescConcedido : boolean = false;
                                        SomenteSeguro : boolean = false) : real;
var
  UltimoPagamentoParcial : TpValPgtoParcial;
  Datazero : Tdata;
begin
  result  := 0;
  Desconto:= 0;
  UltimoPagamentoParcial.DescConcedido := 0;
  fillchar(UltimoPagamentoParcial,sizeof(UltimoPagamentoParcial),0);
  if assigned(Parcela) then begin
      if not SomenteSeguro and Parcela.TemPgParcial then begin
        DataZero.dia := 0;
        fillchar(Datazero,sizeof(Tdata),0);
        ObtemUltimoPagamentoParcial(1,Contrato.Mutdsk.Cad.Ctr,Parcela.TipoParc,
                                    Fin.CodSerie,Parcela.Seq,DataZero,UltimoPagamentoParcial);
        result := UltimoPagamentoParcial.Valor;
        if SoDescConcedido then 
          Desconto := UltimoPagamentoParcial.DescConcedido
        else
          Desconto := UltimoPagamentoParcial.Desc + UltimoPagamentoParcial.DescConcedido;
      end
      else begin
        if SomenteSeguro then begin
          result := Parcela.SeguroPago;
          if SoDescConcedido then 
            Desconto := Parcela.DescConcedidoSeg
          else
            Desconto := Parcela.DescontoPagamentoSeg + Parcela.DescConcedidoSeg;  
        end
        else begin
          result := Parcela.ValorPago;
          if SoDescConcedido then 
            Desconto := Parcela.DescConcedido
          else
            Desconto := Parcela.DescontoPagamento + Parcela.DescConcedido;
        end;    
      end;
  end;
end;

function TSerie.ValDevParcSerieDtPg(    ValoresDoMes : TValoresPorMac;
                                    var PendEmi,
                                        Corr,
                                        Mora,
                                        Multa : real;
                                        SomenteSeguro : boolean = false) : real;
var
  DtVenc       : TData;
  JMoratorios,
  ValorPagoAntecipado,
  JContr,
  ValAux,
  ValParcSerie : real;
  NMeses       : smallint;
  DescRPA : real;
  DtpgAux : TData;
  TipoPgAux : byte;
  PercDescMoraAux : real;
  PercDescCorrAux : real;
  PercDescMultaAux : real;
  PercDescjremuneratoriosAux : real;
begin
  ValAux      := 0;
  JContr      := 0;
  PendEmi     := 0;
  Corr        := 0;
  Mora        := 0;
  Multa       := 0;
  ValParcSerie:= 0;

  if assigned(ValoresDoMes.ParcelaDoMes) then begin
    if SomenteSeguro then begin
      DtPgAux := ValoresDoMes.ParcelaDoMes.DtPgSeg;
      TipoPgAux := ValoresDoMes.ParcelaDoMes.TipoPgSeg;
      PercDescMoraAux := ValoresDoMes.ParcelaDoMes.PercDescMoraSeg;
      PercDescCorrAux := ValoresDoMes.ParcelaDoMes.PercDescCorrSeg;
      PercDescMultaAux := ValoresDoMes.ParcelaDoMes.PercDescMultaSeg;
      PercDescjremuneratoriosAux := ValoresDoMes.ParcelaDoMes.PercDescjremuneratoriosSeg;
    end  
    else begin
      DtPgAux := ValoresDoMes.ParcelaDoMes.DtPg;
      TipoPgAux := ValoresDoMes.ParcelaDoMes.TipoPg;
      PercDescMoraAux := ValoresDoMes.ParcelaDoMes.PercDescMora;
      PercDescCorrAux := ValoresDoMes.ParcelaDoMes.PercDescCorr;
      PercDescMultaAux := ValoresDoMes.ParcelaDoMes.PercDescMulta;
      PercDescjremuneratoriosAux := ValoresDoMes.ParcelaDoMes.PercDescjremuneratorios;
    end;  
    if (Juliano(DtPgAux) >= Juliano(Fin.DataRef)) and
        DataValida(DtPgAux) then begin
      DtVenc.Dia := ValoresDoMes.DiaVenc;
      Int_Mes(ValoresDoMes.MAC,DtVenc.MesAno);
      if assigned(Contrato) then
        PendEmi := Contrato.Pendencias.ValorPendEmi(ValoresDoMes.ParcelaDoMes.MAC,Fin.CodSerie)
      else
        PendEmi := 0;
(*----sol. 054768 - qdo o pgto parcial   antecipado de fato, este estava vindo dobrado, tanto pela var
      VUtilPgParcialAntec qto pela fun  o ObtemSaldoAteDataref.
      if ValoresDoMes.TemParcNoMes and (not (ValoresDoMes.ParcelaDoMes.TipoPg in PgtoComRedSdDev)) then
        ValParcSerie := ValoresDoMes.TotPrest + ValoresDoMes.ResiduoCobrado+
                        PendEmi - ValoresDoMes.VUtilPgParcialAntec
      else
---------------------------------------------------------------------*)
      if SomenteSeguro then begin
        ValParcSerie := ValoresDoMes.seguro + ValoresDoMes.ValTxAdm + PendEmi;
        DescRPA := ValoresDoMes.DescSeg;
        if (ValParcSerie - DescRPA > Zero) or
          (Abs(ValParcSerie-DescRPA) <= Zero) then
          ValParcSerie := ValParcSerie - DescRPA;
      end  
      else begin 
        ValParcSerie := ValoresDoMes.TotPrest + ValoresDoMes.ResiduoCobrado+
                        PendEmi;

        DescRPA := ValoresDoMes.Desc;
        if (ValoresDoMes.ParcelaDoMes.TipoPg in [30,78,102,224..230,247]) then DescRPA := 0
        else if (ValoresDoMes.TipoDesc = 8) and (ValoresDoMes.Desc > Zero) then begin
          NMeses := NMesesAtraso(DtVenc,ValoresDoMes.ParcelaDoMes.DtPg,Contrato.MutDsk.Cad.DiaIsencao);
          DescRPA := DescRPA * (1 - NMeses/24);
          DescRPA := Int(DescRPA*100+0.5)/100;
        end;
        ValoresDoMes.Desc := DescRPA;
        if (ValParcSerie - DescRPA > Zero) or
          (Abs(ValParcSerie-DescRPA) <= Zero) then
          ValParcSerie := ValParcSerie - DescRPA;
        if ((Abs(ValoresDoMes.AmaisJ) <= Zero) and (ValoresDoMes.Seguro > Zero)) or
            (not ValoresDoMes.TemParcNoMes) then
          ValorPagoAntecipado := 0
        else
          ValorPagoAntecipado := int(PagamentosParciais.ObtemSaldoAteDataref(ValoresDoMes.Mac,ValoresDoMes.ParcelaDoMes.DtPg,ValoresDoMes.IndJuros,ValAux,false{AtrasoCtb},true) * ValoresDoMes.TxPstacum *100+0.5)/100;
        if (ValorPagoAntecipado > zero) and (ValoresDoMes.Amaisj > zero) and
          (ValorPagoAntecipado - ValoresDoMes.Amaisj > zero) then
          ValorPagoAntecipado := ValoresDoMes.Amaisj;

        ValParcSerie := ValParcSerie - ValorPagoAntecipado;
      end;  
      case TipoPgAux of
         43,
         44,
        100..101,
        200,
        253,
        202,
        212,
        213,
        228,
        237..238,
        52,
        54 : begin Corr := 0; Mora := 0; Multa := 0;  end;
         41,
        215,
        217,
        199,
        206,
        208,
        209,
        229,
        56,
        233..234
            : begin
                CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                             Corr,Mora,JContr,Multa,
                                             Contrato.RegCarteira.NaoCobraJurosContr,true,
                                             false{AtrasoCtb},True{SomenteTipoPgParcial},
                                             SomenteSeguro);
                Mora   := 0;
                JContr := 0;
              end;
         42,
        205,
        210,
        211,
        219,
        230,
        235..236,
        53,
        62  : begin
                CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                             Corr,Mora,JContr,Multa,
                                             Contrato.RegCarteira.NaoCobraJurosContr,true{ComIsencao},
                                             false{AtrasoCtb},True{SomenteTipoPgParcial},
                                             SomenteSeguro);
                Corr := 0;
              end;
      68..71,
      224,225: begin
                 CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                              Corr,Mora,JContr,Multa,
                                              Contrato.RegCarteira.NaoCobraJurosContr,false,
                                              false{AtrasoCtb},True{SomenteTipoPgParcial},
                                              SomenteSeguro);
                 Mora   := ArredondaPend(Mora - JContr);
                 JContr := 0;
                 if TipoPgAux in [69,70,225] then Corr := 0;
               end;

        81..84,
        226,227: begin
                   CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                                Corr,Mora,JContr,Multa,
                                                Contrato.RegCarteira.NaoCobraJurosContr,false,
                                                false{AtrasoCtb},True{SomenteTipoPgParcial},
                                                SomenteSeguro);
                   Mora := JContr;
                   if TipoPgAux in [81,84,227] then Corr := 0;
                 end;
         220..223,
         239..242,
         58..61 : begin
                   CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                                Corr,Mora,JContr,Multa,
                                                Contrato.RegCarteira.NaoCobraJurosContr,true,
                                                false{AtrasoCtb},True{SomenteTipoPgParcial},
                                                SomenteSeguro);
                   Mora    := int((Mora * 0.2)*100+0.5)/100;
                   if TipoPgAux in [59..60,221,223,240..241] then Corr := 0;
                 end;
        else CalculaCorrecaoMoraMultaRPAS(ValoresDoMes,Contrato.MutDsk,DtPgAux,
                                          Corr,Mora,JContr,Multa,
                                          Contrato.RegCarteira.NaoCobraJurosContr,true,
                                          false{AtrasoCtb},True{SomenteTipoPgParcial},
                                          SomenteSeguro);
      end; { case }
      AjustaMoeda2(ValoresDoMes.ParcelaDoMes.MAC,Mes_Int(DtPgAux.MesAno),ValParcSerie);
      if IsencaoDeMulta(TipoPgAux) then Multa := 0;

      if (PercDescMoraAux > zero) or
         (PercDescCorrAux > zero) or
         (PercDescMultaAux > zero) or
         (PercDescjremuneratoriosAux > zero) then begin
        if (PercDescCorrAux > zero) then
          Corr := int((Corr -(Corr * (PercDescCorrAux/100)))*100+0.5)/100;
        if (PercDescMultaAux > zero) then
          Multa := int((Multa -(Multa * (PercDescMultaAux/100)))*100+0.5)/100;
        JMoratorios := Mora - JContr;
        if (PercDescJRemuneratoriosAux > zero) then
          JContr := int((JContr -(JContr * (PercDescJRemuneratoriosAux/100)))*100+0.5)/100;
        if (PercDescMoraAux > zero) then
          JMoratorios := int((JMoratorios -(JMoratorios * (PercDescMoraAux/100)))*100+0.5)/100;
        if (PercDescJRemuneratoriosAux > zero) or
           (PercDescMoraAux > zero) then
          Mora := JMoratorios + JContr;
      end;
      if Contrato.DiasDeAtrasoEntreDatas(DtVenc,DtPgAux) <= 0 then begin
        Corr   := 0;
        Mora   := 0;
        Multa  := 0;
        JContr := 0;
      end;
    end;
  end;
  result := int((ValParcSerie + Corr + Mora + Multa)*100+0.5)/100;
end;

function AplicaPercHonorarios(Valor : real; PercHonorarios : real) : real;
var
  Honor : real;
begin
  Result := Valor;
  if AbriuPagamentosSql and AbriuTitSql and (PercHonorarios > Zero) then begin
    Honor := Arredonda(Valor*PercHonorarios/100);
    Result := Result + Honor;
  end;
end;

function OrdenaParcsAntecipadasPorPgto(Item1,Item2 : pointer) : integer;
var
  Prest1,
  Prest2 : TParcelaSerie;
//  Prest2 : TObjectList;
begin
  Prest1 := TParcelaSerie(item1);
//  Prest1 := TObjectList(item1);
//  Prest2 := TObjectList(item2);
  Prest2 := TParcelaSerie(item2);
  if Juliano(Prest1.DtPg) < Juliano(Prest2.DtPg) then
    result := -1
  else if Juliano(prest1.DtPg) > Juliano(Prest2.DtPg) then
    result := 1
  else if Prest1.MAC < prest2.MAC then
    result := -1
  else if prest1.MAC > prest2.MAC then
    result := 1
  else
    result := 0;
end;


Procedure TSerie.ObtemPendCalcValorCorrMoraUPF(    DtIni,
                                                   DtFim       : Tdata;
                                                   Com200      : Boolean;
                                               var ValorT,
                                                   MoraT       : Real;
                                                   DtCorr      : TData;
                                                   DataEmi     : TData;
                                                   Dados       : TDadosAcertoEvo;
                                                   Grava       : boolean;
                                                   CarregaPagamentosSemDiferenca : boolean;
                                                   IgnoraTipoDePagamento : boolean);
var
  VMoeda,
  VMoedaVenc,
  PendEmi,  Corr,
  Mora,Pend,Multa,
  MoraP, MultaP  : real;
  i              : SmallInt;
  DataPagoAnt,
  DtTermino,
  DtPgAnt,
  DataCalculo,
  DtPrest        : TData;
  ValPrst        : real;
  iAntec         : integer;
  RParcela       : TParcelaSerie;
  ParcsAntecipadasNoMes : TObjectList;
  MACUltPag,
  SeqPg          : smallint;
  IndCorr,
  ValPrest,
  Desconto       : real;
  MACDaUltima,
  MacIni,
  MacFim         : smallint;
  Honorarios,
  PercDescHonorarios,
  PercHonorarios,
  DescontoAux    : real;
  ValPag         : real;
  ParcEstaPaga   : boolean;
  Reg            : TValoresPorMac;
  Item : TItemAcertoEvo;
  UF : str3;
  CodMun : smallint;
begin        
  UF := '';
  CodMun := 0;
  PendEmi := 0;
  Mora := 0;
  Multa := 0;
  DescontoAux := 0;
  PercHonorarios := 0;
  PercDescHonorarios := 0;
  ValPrst := 0;
  Desconto := 0;
  ParcsAntecipadasNoMes := TObjectList.create(false);
  try
  Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
  MacIni := Mes_int(DtIni.MesAno);
  MacFim := Mes_int(DtFim.MesAno);
  ValorT := 0; MoraT := 0; Corr := 0;
  if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);
  DtTermino.Dia := 0; fillchar(DtTermino,sizeof(DtTermino),0);
  MacUltPag := 0;
  i         := Parcelas.Count-1;

  while (i >= 0) {and (MACUltPag = 0)} do begin
    if (RPAS.FinRPA.Status > 0) and (RPAS.ValRpa.MacStatus > 0) then begin
      if RPAS.FinRPA.DiaLiq > 0 then 
        DtTermino.Dia := RPAS.FinRPA.DiaLiq
      else
        DtTermino.Dia := RPAS.FinRPA.DiaVenc;
    end;
    if  (Parcelas[i].MAC >= MACIni) and (Parcelas[i].MAC <= MACFim) and 
        (Parcelas[i].MAC > MacUltPag) and Parcelas[i].EstaPagaReal and
      ( (RPAS.ValRpa.MacStatus = 0) or 
        (Parcelas[i].MAC <  RPAS.ValRpa.MacStatus) or
       ((Parcelas[i].MAC = RPAS.ValRpa.MacStatus) and
       ((not (RPAS.FinRPA.Status in [1,30])) 
                       or
        (DtTermino.Dia >= byte(RPAS.FinRPA.DiaVenc))
                       or
        (juliano(Parcelas[i].DtProcPg) > juliano(DtTermino))
       )
       )
      ) then 
        MacUltPag := Parcelas[i].MAC;
    dec(i);
  end;
  i := mes_int(Fin.DataRef.MesAno);
  while (i <= MACFim) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if (i >= MACIni) and (i <= MACFim) and
         (Reg.CtrAtivo or ((MacUltPag > 0) and (i <= MacUltpag))) then begin
        SeqPg := 0;
        if (Fin.codclassificacao = serie_AcertoFin) and
           (Mes_Int(Fin.DataRef.MesAno) = i) and
           (Juliano(Fin.DataRef) <= Juliano(DtCorr)) and
           (not Fin.NaoApuraAcertoFinanceiro) and
           (i >= MACIni) and
           (i <= MACFim) and
           ((Juliano(Fin.DataRef) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
            ((Juliano(Fin.DataRef) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
             (Juliano(Fin.DataRef) = Juliano(Fin.DtRenegGeradora)))) and
           (Juliano(Fin.DataRef) >= Juliano(DtIni)) and
           (Juliano(Fin.DataRef) <= Juliano(DtFim)) then begin
          Pend := Fin.Valor;
          VMoeda  := LE_UPFD(Fin.DataRef);
          if VMoeda <= Zero then
            VMoeda := LE_VRF(mes_int(Fin.DataRef.Mesano));
          if VMoeda <= Zero then VMoeda := 1.0;
          VMoedaVenc := VMoeda;
          Pend    := Pend/VMoeda;
          if Scciconf.CobraMoraDif then
            MoraP := MoraRef(Fin.DataRef,DtCorr,UF,CodMun,0,Pend,
                             Contrato.RegCarteira.NaoCobraJurosContr)
          else
            MoraP := 0;
          if (MoraP <= Zero)(* and (not ScciConf.CobraMoraDifADev)*) then
            MoraP := 0;
          if Scciconf.MultaContrEmEncRemuneratoriosNoAcFin and (Abs(MoraP) > Zero) then begin
            if (Reg.TMora in [38..40]) then 
              MultaP := ValorMulta(Fin.DataRef,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
            else
              MultaP := ValorMulta(Fin.DataRef,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta);
          end
          else
            MultaP := 0;
          ValorT := ValorT + Pend;
          MoraT  := MoraT  + MoraP + MultaP;
          if Abs(ValorT*VMoeda) < 0.01 then begin
            ValorT := 0;
            MoraT  := 0;
          end;
          if (abs(Fin.Valor) > zero) or CarregaPagamentosSemDiferenca then begin
            if assigned(Dados) then begin
              Item := TItemAcertoEvo.create;
              Item.AcFinanc := true;
              Item.DtVenc := Fin.DataRef;
              Item.DtPag := Fin.DataRef;
              Item.DifAtu := Pend;
              Item.Mora := MoraP+MultaP;
              Item.CodSerie := Fin.CodSerie;
              Item.VMoeda := VMoeda;
              Item.VMoedaVenc := VMoedaVenc;
              Item.AmortNegMes := Reg.AmortNegMes;
              Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
              Item.CorrSaldoAmortneg := Reg.CorrSaldoAmortNeg;
              Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
              Dados.add(Item);
            end;
            if Grava then begin
              fillchar(RPendEmi,sizeof(TpPendEmi),0);
              with RPendEmi do begin
                Ctr            := Contrato.MutDsk.Cad.Ctr;
                if Com200 then TpEmissao := 1
                else TpEmissao := 2;
                DtEmi          := DataEmi;
                CodSerie       := Fin.CodSerie;
                MAC            := i;
                ValDevido      := Fin.Valor;
                DifAtual       := Pend;
                Atualizacao    := MoraP + MultaP;
                DtVenc         := Fin.DataRef;
                Moeda          := 1;
              end;
              GravaPendEmi(RPendEmi);
            end;
          end;
        end;
        DtPgAnt.dia := 0;
        TotDevido := 0; fillchar(DtPgAnt,sizeof(TData),0);
        DataPagoAnt.Dia := 0; fillchar(DataPagoAnt,sizeof(DataPagoAnt),0);
        if (Reg.Status <> 0) and (not Fin.NaoApuraAcertoFinanceiro) and
           (not Fin.RecalculaPrestacao) and
           (Fin.SistAmort <> 6) { Sacre } and
           (not Fin.FinanciaResiduo)  then begin
          ParcsAntecipadasNoMes.clear;
          ParcsAntecipadasNoMes.assign(Reg.ParcelasAntecipadasNoMes);
          MACDaUltima := MACUltParcelaAntecipada(i);
          if MACDaUltima > 0 then 
            ParcsAntecipadasNoMes.sort({$IFDEF FPC}@{$ENDIF}OrdenaParcsAntecipadasPorPgto);
          for iAntec := 0 to ParcsAntecipadasNoMes.count -1 do begin
            RParcela := ParcsAntecipadasNoMes[iAntec] as TParcelaSerie;
            if ((Juliano(RPArcela.DtPg) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
                ((Juliano(RPArcela.DtPg) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
                 (Juliano(RPArcela.DtPg) = Juliano(Fin.DtRenegGeradora)))) and
               (Mes_Int(RParcela.DtPg.MesAno) >= MACIni) and
               (Mes_Int(RParcela.DtPg.MesAno) <= MACFim) then begin
              DtPrest.Dia := RParcela.DiaVenc;
              Int_Mes(RParcela.Mac,DtPrest.MesAno);
              if DataEMaior(RParcela.DataRefCalc,RParcela.DtPg) and 
                 DataEMenor(RParcela.DataRefCalc,DtPrest) then
                DataCalculo := RParcela.DataRefCalc
              else
                DataCalculo := RParcela.DtPg;

              if ((Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno)) and
                  (
                  (Mes_Int(DataPagoAnt.MesAno) <> Mes_Int(RParcela.DtPg.MesAno)) or
                  ((DataPagoAnt.Dia < RParcela.DiaVenc) and 
                   (RParcela.DtPg.Dia >= RParcela.DiaVenc))
                  )
                 ) 
                                          or
                 ((DtPgAnt.Dia < RParcela.DiaVenc) and (DataCalculo.Dia >= RParcela.DiaVenc)) then
                TotDevido := 0;   

(*---------------------------------------------------------------------
              if (juliano(DtPgAnt) <> juliano(DataCalculo)) and
                ((DtPgAnt.Dia < RParcela.DiaVenc) or 
                 (Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno))) and 
                 (DataCalculo.Dia >= RParcela.DiaVenc) then
                TotDevido := 0;
----------------------------------------------------------------------*)
(*
              if  (Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno)) or
                 ((DtPgAnt.Dia < RParcela.DiaVenc) and (DataCalculo.Dia >= RParcela.DiaVenc)) then
                TotDevido := 0;   
*)

              ObtemValorParcelaAntecipada(Reg,Contrato.MutDsk,RParcela,DataCalculo,
                                          Contrato.RegCarteira.NaoCobraJurosContr,
                                          ValPrst,Desconto);
              DtPgAnt     := DataCalculo;
              DataPagoAnt := RParcela.DtPg;
              Pend   := ValPrst - RParcela.ValorPagoNoUltimoPagamento;
              if (Abs(Pend) > Zero) and
                 (Juliano(RParcela.DtPg) >= Juliano(DtIni)) and
                 (Juliano(RParcela.DtPg) <= Juliano(DtFim)) then begin
                VMoeda  := LE_UPFD(RParcela.DtPg);
                if VMoeda <= Zero then
                  VMoeda := LE_VRF(mes_int(RParcela.DtPg.Mesano));
                if VMoeda <= Zero then VMoeda := 1.0;
                VMoedaVenc := VMoeda;
                Pend    := Pend/VMoeda;
                if Scciconf.CobraMoraDif then
                  MoraP := MoraRef(RParcela.DtPg,DtCorr,UF,CodMun,0,Pend,
                                   Contrato.RegCarteira.NaoCobraJurosContr)
                else
                  MoraP := 0;
                if (MoraP <= Zero)(* and (not ScciConf.CobraMoraDifADev)*) then
                  MoraP := 0;
                if Scciconf.MultaContrEmEncRemuneratoriosNoAcFin and (Abs(MoraP) > Zero) then begin
                  if (Reg.TMora in [38..40]) then 
                    MultaP := ValorMulta(RParcela.DtPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
                  else
                    MultaP := ValorMulta(RParcela.DtPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta);
                end
                else
                  MultaP := 0;
  
                ValorT := ValorT + Pend;
                MoraT  := MoraT  + MoraP + MultaP;
                if Abs(ValorT*VMoeda) < 0.01 then begin
                  ValorT := 0;
                  MoraT  := 0;
                end;
                if (abs(ValPrst - RParcela.ValorPagoNoUltimoPagamento) > Zero) then begin
                  if assigned(Dados) then begin
                    Item := TItemAcertoEvo.create;
                    Item.DtVenc := DtPrest;
                    Item.DtPag := RParcela.DtPg;
                    Item.DifAtu := Pend;
                    Item.Mora := MoraP+MultaP;
                    Item.CodSerie := Fin.CodSerie;
                    Item.VMoeda := VMoeda;
                    Item.VMoedaVenc := VMoedaVenc;
                    Item.AmortNegMes := Reg.AmortNegMes;
                    Item.SaldoAmortneg := Reg.SaldoAmortNeg;
                    Item.CorrSaldoAmortneg := Reg.CorrSaldoAmortNeg;
                    Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                    Dados.add(Item);
                  end;
                  if Grava then begin
                    inc(SeqPg);
                    fillchar(RPendEmi,sizeof(TpPendEmi),0);
                    with RPendEmi do begin
                      Ctr            := Contrato.MutDsk.Cad.Ctr;
                      if Com200 then TpEmissao := 1
                      else TpEmissao := 2;
                      DtEmi          := DataEmi;
                      CodSerie       := Fin.CodSerie;
                      MAC            := RParcela.MAC;
                      Seq            := SeqPg;
                      ValDevido      := ValPrst;
                      ValPago        := RParcela.ValorPagoNoUltimoPagamento;
                      DifAtual       := Pend;
                      Atualizacao    := MoraP + MultaP;
                      DtVenc         := DtPrest;
                      DtPag          := RParcela.DtPg;
                      Moeda          := 1;
                      Parcela        := TParcelaSerie(Reg.ParcelaDoMes).Seq;
                    end;
                    GravaPendEmi(RPendEmi);
                  end;
                end;
              end;
            end;
          end;
        end;
        if assigned(Reg.ParcelaDoMes) then begin
          ParcEstaPaga := Reg.ParcelaDoMes.EstaPagaReal;
          if ((Reg.NPC > 0) or
              (i > Mes_Int(Fin.DataRef.MesAno)))  and
             ((Reg.TotPrest > Zero) or ParcEstaPaga) and
              (not Fin.NaoApuraAcertoFinanceiro) and
              (i >= MACIni) and
              (i <= MACFim) and
              (ParcEstaPaga or
              (Com200 and (Reg.ParcelaDoMes.TipoPg in [200,253]) and
              ((Reg.ParcelaDoMes.DataValidadeTit.Dia = 0) or 
                DataEMenorOuIgual(DataH,Reg.ParcelaDoMes.DataValidadeTit)) //se o titulo ainda   v lido
              )) then begin
            DtPrest.Dia := Reg.DiaVenc;
            Int_Mes(i,DtPrest.MesAno);
            if Reg.ParcelaDoMes.TipoPg in [200,253] then
              Reg.ParcelaDoMes.DtPg := DtPrest; { Nao Foi Paga, so Emitida }
            if (((not (Reg.ParcelaDoMes.TipoPg in NotGerPend) or (IgnoraTipoDePagamento and Reg.ParcelaDoMes.EstaPagaReal)) and
                 (Com200 or (not (Reg.ParcelaDoMes.TipoPg in [200,253])))  and
                 (Juliano(Reg.ParcelaDoMes.DtPg) >= Juliano(Fin.DataRef)) and
                 DataValida(Reg.ParcelaDoMes.DtPg) and
                 ((Juliano(Reg.ParcelaDoMes.DtPg) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
                  ((Juliano(Reg.ParcelaDoMes.DtPg) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
                   (Juliano(Reg.ParcelaDoMes.DtPg) = Juliano(Fin.DtRenegGeradora))))) or CarregaPagamentosSemDiferenca) and
               (Juliano(DtPrest) >= Juliano(DtIni)) and
               (Juliano(DtPrest) <= Juliano(DtFim)) then begin
              Honorarios := ObtemHonorariosParcelaPaga(TParcelaSerie(Reg.ParcelaDoMes),PercHonorarios,PercDescHonorarios);
              ValPag  := ValPagParcSerieDtPg(TParcelaSerie(Reg.ParcelaDoMes),DescontoAux);
              { 
                99785 - quando o usu rio faz uma emiss o antecipada da presta  o do m s, ele pode gerar junto o titulo de
                        acess rios. No momento da baixa, se passar do vencimento, o titulo n o   mais baixado como antecipa  o
                        e nesse caso, a baixa   feita "normal"(no exemplo da sol. era 96).
                        Como esse tipo de baixa prev  que a presta  o tenha sido totalmente paga, o seguro que foi separado acaba virando
                        um valor que o usu rio n o pagou. Para cobrir esta situa  o, eu vou verificar que a presta  o teve sim acess rios pagos
                        (Reg.ParcAcessoriosPaga) e se tiver, eu somo no valor pago. S  devo fazer isso se eu estiver calculando uma presta  o
                        "normal" (not Reg.EParcelaDeSeguro) ou eu poderia dobrar o valor pago, no acerto de um acess rio.
                        Copiei a l gica da ObtemPendCalcValorCorrMora, j  que deveria ser a mesma l gica.
              }          
              if not Reg.EParcelaDeSeguro and Reg.ParcAcessoriosPaga then
                ValPag  := ValPag + ValPagParcSerieDtPg(TParcelaSerie(Reg.ParcelaDoMes),DescontoAux,false{SoDescConcedido},true{SomenteSeguro});

              ValPrst := ValDevParcSerieDtPg(Reg,PendEmi,Corr,Mora,Multa)-DescontoAux;
              if (Abs(Honorarios) > Zero) and (PercHonorarios > Zero) then begin
                Honorarios := arredonda(ValPrst *(PercHonorarios/100));
                if PercDescHonorarios > Zero then
                  Honorarios := Arredonda(Honorarios - (Honorarios * PercDescHonorarios/100));
              end;
              ValPrst := ValPrst + Honorarios + Reg.ParcelaDoMes.ValIOFcomplem;

              Pend := ValPrst - ValPag;
{ Sol. 46012
              VMoeda  := LE_UPFD(Reg.ParcelaDoMes.DtPg);
              if VMoeda <= Zero then                 
                VMoeda := LE_VRF(mes_int(Reg.ParcelaDoMes.DtPg.Mesano));
}
              VMoeda  := LE_UPF(DtPrest);
              if VMoeda <= Zero then VMoeda := LE_VRF(mes_int(DtPrest.MesAno));
              AjMoedaComPrecisao(Mes_Int(DtPrest.MesAno),Mes_Int(Reg.ParcelaDoMes.DtPg.MesAno),VMoeda);
              if VMoeda <= Zero then VMoeda := 1.0;
              VMoedaVenc := VMoeda;
              ValPrest := ValPrst - Corr - Mora - Multa + DescontoAux - Honorarios;
              if ValPrest > Zero then 
                IndCorr := 1 + Corr/ValPrest
              else
                IndCorr := 1.0;
              VMoeda := VMoeda * IndCorr;
              Pend    := Pend/VMoeda;
              if Scciconf.CobraMoraDif then
                MoraP := MoraRef(Reg.ParcelaDoMes.DtPg,DtCorr,UF,CodMun,0,Pend,
                                 Contrato.RegCarteira.NaoCobraJurosContr)
              else
                MoraP := 0;
              if (MoraP <= Zero) and (not ScciConf.CobraMoraDifADev) then
                MoraP := 0;
              if Scciconf.MultaContrEmEncRemuneratoriosNoAcFin and (Abs(MoraP) > Zero) then begin
                if (Reg.TMora in [38..40]) then 
                  MultaP := ValorMulta(Reg.ParcelaDoMes.DtPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
                else
                  MultaP := ValorMulta(Reg.ParcelaDoMes.DtPg,DtCorr,UF,CodMun,Contrato.MutDsk.Cad.PercMulta,Pend,Contrato.MutDsk.Cad.DiaIsencao,Contrato.MutDsk.Cad3.MultaContratualProRata,Contrato.Mutdsk.Cad6.DtIniCobMulta);
              end
              else
                MultaP := 0;

              ValorT := ValorT + Pend;
              MoraT  := MoraT  + MoraP + MultaP;
              if Abs(ValorT*VMoeda) < 0.01 then begin
                ValorT := 0;
                MoraT  := 0;
              end;
              if (abs(ValPrst - Reg.ParcelaDoMes.ValorPago) > zero) or CarregaPagamentosSemDiferenca then begin
                if assigned(Dados) then begin
                  Item := TItemAcertoEvo.create;
                  Item.DtVenc := DtPrest;
                  Item.DtPag := Reg.ParcelaDoMes.DtPg;
                  Item.DifAtu := Pend;
                  Item.Mora := MoraP+MultaP;
                  Item.Honorarios := Honorarios;
                  Item.ValIOFComplem := Reg.ParcelaDoMes.ValIOFcomplem;
                  Item.Desconto   := DescontoAux;
                  Item.CodSerie := Fin.CodSerie;
                  Item.VMoeda := VMoeda;
                  Item.VMoedaVenc := VMoedaVenc;
                  Item.ValPrest := ValPrest;
                  Item.AmortNegMes := Reg.AmortNegMes;
                  Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                  Item.CorrSaldoAmortNeg := Reg.CorrSaldoAmortNeg;
                  Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                  Dados.add(Item);
                end;
                if Grava then begin
                  fillchar(RPendEmi,sizeof(TpPendEmi),0);
                  with RPendEmi do begin
                    Ctr            := Contrato.MutDsk.Cad.Ctr;
                    if Com200 then TpEmissao := 1
                    else TpEmissao := 2;
                    DtEmi          := DataEmi;
                    CodSerie       := Fin.CodSerie;
                    MAC            := i;
                    ValDevido      := ValPrst;
                    ValPago        := Reg.ParcelaDoMes.ValorPago+TParcelaSerie(Reg.ParcelaDoMes).DescConcedido;
                    DifAtual       := Pend;
                    Atualizacao    := MoraP + MultaP;
                    DtVenc         := DtPrest;
                    DtPag          := Reg.ParcelaDoMes.DtPg;
                    Moeda          := 1;
                    Parcela        := TParcelaSerie(Reg.ParcelaDoMes).Seq;
                  end;
                  GravaPendEmi(RPendEmi);
                end;
              end;
            end;
          end; { if }
        end;
      end;
    end;
    inc(i);
  end;
  finally
    ParcsAntecipadasNoMes.free;
  end;
end;

function CalcJurosContratuais(TxJuros:Real; Data,DtBase : TData; Valor : real) : real;
var NDias  : longint;
    TxDia  : Real;
    VMora  : Real;
begin
   NDias   := Juliano(DtBase) - Juliano(Data);
   TxDia   := TxJuros / 36500;
   VMora   := (TxDia * Valor) * NDias;
   CalcJurosContratuais := Arredonda(VMora);
end;

function CalcJurosEspeciais(Tipo:Byte;TxJuros:Real; Data,DtBase : TData; Valor : real) : real;
var NMeses : SmallInt;
    TxMes  : Real;
    VMora  : Real;
begin
   NMeses  := Mes_Int(DtBase.Mesano) - Mes_Int(Data.Mesano);
   TxMes   := TxJuros / 1200;
   Case Tipo Of
     JSimples  : VMora := Valor * TxMes * NMeses;
     JCapital  : VMora := Valor * ( pot(1+TxMes,NMeses)-1 );
     else        VMora := 0.0;
   end;
   CalcJurosEspeciais := Arredonda(VMora);
end;

procedure TSerie.ObtemPendCalcValorCorrMora(    DtIni,
                                                DtFim       : Tdata;
                                                DtCorr      : TData;
                                                Com200      : Boolean;
                                            var ValorT,
                                                CorrT,
                                                MoraT       : Real;
                                                DataEmi     : TData;
                                                Dados       : TDadosAcertoEvo;
                                                Grava       : boolean;
                                                UtilizaJMora,
                                                UtilizaJCont : boolean;
                                                TipoJur : integer;
                                                CarregaPagamentosSemDiferenca : boolean);
var
  PendEmi,Corr,
  Mora,Pend,Multa,
  CorrP,MoraP    : real;
  SEqPg,
  i              : SmallInt;
  DataPagoAnt,
  DtPgAnt,
  DataCalculo,
  DtPrest        : TData;
  ValPrst        : real;
  CodTabelaGenerica : longint;
  iAntec         : integer;
  RParcela       : TParcelaSerie;
  ParcsAntecipadasNoMes : TObjectList;
  DtTermino      : TData;
  Honorarios,
  PercDescHonorarios,
  PercHonorarios : real;
  Desconto       : real;
  MACDaUltima,
  MacIni,
  MacFim         : smallint;
  DescontoAux    : real;
  ValPag         : real;
  Reg : TValoresPorMac;
  Item : TItemAcertoEvo;
  DtIsenMora : Tdata;
  UF : str3;
  MacUltPag,
  CodMun : smallint;
  Defasagem : byte;
  ParcEstaPaga : boolean;
  TipoPgAux : byte;
  DtPgAux : TData;
begin
  PendEmi := 0;
  Corr := 0;
  Multa := 0;
  Mora := 0;
  DescontoAux := 0;
  PercHonorarios := 0;
  PercDescHonorarios := 0;
  ValPrst := 0;
  Desconto := 0;
  DescontoAux := 0;
  ValPrst := 0;
  MoraP := 0;
  Defasagem := 0;
  DtIsenMora.dia := 0; DtIsenMora.mes := 0; DtIsenMora.ano := 0;
  UF := '';
  CodMun := 0;
  ParcsAntecipadasNoMes := TObjectList.create(false);
  try
    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    MacIni := Mes_int(DtIni.MesAno);
    MacFim := Mes_int(DtFim.MesAno);
    ValorT := 0; MoraT := 0; CorrT := 0; 
    if MacFim < MacIni then MacFim := Mes_Int(DtCorr.MesAno);
    DtTermino.Dia := 0; fillchar(DtTermino,sizeof(DtTermino),0);
    MacUltPag := 0;
    i         := Parcelas.Count-1;
    while (i >= 0) {and (MACUltPag = 0)} do begin
      if (RPAS.FinRPA.Status > 0) and (RPAS.ValRpa.MacStatus > 0) then begin
        Int_Mes(RPAS.ValRpa.MacStatus,DtTermino.MesAno);
        if RPAS.FinRPA.DiaLiq > 0 then 
          DtTermino.Dia := RPAS.FinRPA.DiaLiq
        else
          DtTermino.Dia := RPAS.FinRPA.DiaVenc;
      end;
      if  (Parcelas[i].MAC >= MACIni) and (Parcelas[i].MAC <= MACFim) and 
          (Parcelas[i].MAC > MacUltPag) and Parcelas[i].EstaPagaReal and
        ( (RPAS.ValRpa.MacStatus = 0) or 
          (Parcelas[i].MAC <  RPAS.ValRpa.MacStatus) or
         ((Parcelas[i].MAC = RPAS.ValRpa.MacStatus) and
          ((not (RPAS.FinRPA.Status in [1,30])) 
                          or
           (DtTermino.Dia >= byte(RPAS.FinRPA.DiaVenc))
                          or
           (juliano(Parcelas[i].DtProcPg) > juliano(DtTermino))
          )
         )
        ) then 
        MacUltPag := Parcelas[i].MAC;
      dec(i);
    end;
    i := mes_int(Fin.DataRef.MesAno);
    while (i <= MACFim) and (i < FValoresPorMacList.count) do begin
      if assigned(FValoresPorMacList[i]) then begin
        Reg := TValoresPorMac(FValoresPorMacList[i]);
        if (i >= MACIni) and (i <= MACFim) and
           (Reg.CtrAtivo or ((MacUltPag > 0) and (i <= MacUltpag))) then begin
          SeqPg := 0;
          if (Fin.codclassificacao = serie_AcertoFin) and
             (Mes_Int(Fin.DataRef.MesAno) = i) and
             (Juliano(Fin.DataRef) <= Juliano(DtCorr)) and
             (not Fin.NaoApuraAcertoFinanceiro) and
             (i >= MACIni) and
             (i <= MACFim) and
             ((Juliano(Fin.DataRef) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
              ((Juliano(Fin.DataRef) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
               (Juliano(Fin.DataRef) = Juliano(Fin.DtRenegGeradora)))) and
             (Juliano(Fin.DataRef) >= Juliano(DtIni)) and
             (Juliano(Fin.DataRef) <= Juliano(DtFim)) then begin
            Pend := -Fin.Valor;
            // movi o teste para cima
            if (abs(Fin.Valor) > zero) or CarregaPagamentosSemDiferenca then begin
              CodTabelaGenerica := DefineCodTabelaGenericaPorChaves(Contrato.MutDsk.Cad.DtEntregaChaves,
                                                                    Reg.CodTabGPreChvCorr,
                                                                    Reg.CodTabGCorr,
                                                                    Reg.DefReajPreChvCorr,
                                                                    Reg.DefReajCorr,
                                                                    Fin.DataRef,
                                                                    Defasagem);
              if (CodTabelaGenerica = 0) and (Fin.CodReajAtraso > 0) then
                  CodTabelaGenerica := Fin.CodReajAtraso;
              CorrP := CorrPendComDefasagem(Contrato.Mutdsk,UF,CodMun,
                                            Fin.DataRef,DtCorr,Pend,MoraP,
                                            CodTabelaGenerica,Defasagem,
                                            Fin.codclassificacao,
                                            2{TipoCorr},
                                            true{SemCorrCodTGZero});
              AjustaMoeda2(Mes_Int(Fin.DataRef.MesAno),
                           Mes_Int(DtCorr.MesAno),Pend);
              if SCCIConf.CobraMoraDif then begin
                if ((-Fin.Valor) > ZERO) or ScciConf.CobraMoraDifADev then begin
                  if not UtilizaJMora  then MoraP := 0.0;
                  if UtilizaJCont then begin
                    if Not SCCICONF.PedeTipoJurAcertoFin then
                      MoraP := MoraP + CalcJurosContratuais(Contrato.MutDsk.Financ.TxJuros,Fin.DataRef,DtCorr,(Pend + CorrP) )
                    else MoraP := MoraP + CalcJurosEspeciais(TipoJur,Contrato.MutDsk.Financ.TxJuros,Fin.DataRef,DtCorr,(Pend + CorrP) );
                  end;
                end;
              end;
              ValorT := ValorT + Pend;
              CorrT  := CorrT + CorrP;
              MoraT  := MoraT + MoraP;
              if assigned(Dados) then begin
                Item := TItemAcertoEvo.create;
                Item.AcFinanc := true;
                Item.DtVenc := Fin.DataRef;
                Item.DtPag := Fin.DataRef;
                Item.PrstAnt := Fin.Valor;
                Item.PrstAtu := 0;
                Item.ValPrest := 0;
                Item.ValPrestOri := Fin.Valor;
                Item.Dif := -Fin.Valor;
                Item.DifAtu := Pend;
                Item.Mora := MoraP;
                Item.Corr := CorrP;
                Item.CodSerie := Fin.CodSerie;
                Item.AmortNegMes := Reg.AmortNegMes;
                Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                Item.CorrSaldoAmortneg := Reg.CorrSaldoAmortNeg;
                Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                Dados.add(Item);
              end;
              if Grava then begin
                fillchar(RPendEmi,sizeof(TpPendEmi),0);
                with RPendEmi do begin
                  Ctr            := Contrato.MutDsk.Cad.Ctr;
                  if Com200 then TpEmissao := 1
                  else TpEmissao := 2;
                  DtEmi          := DataEmi;
                  CodSerie       := Fin.CodSerie;
                  MAC            := i;
                  ValDevido      := Fin.Valor;
                  DifAtual       := Pend;
                  Atualizacao    := CorrP + MoraP;
                  DtVenc         := Fin.DataRef;
                end;
                GravaPendEmi(RPendEmi);
              end;
            end;
          end;
          if (Reg.Status <> 0) and (not Fin.NaoApuraAcertoFinanceiro) and
             (not Fin.RecalculaPrestacao) and
             (Fin.SistAmort <> 6) {SACRE} and
             (not Fin.FinanciaResiduo)  then begin
            ParcsAntecipadasNoMes.clear;
            ParcsAntecipadasNoMes.assign(Reg.ParcelasAntecipadasNoMes);
            MACDaUltima := MACUltParcelaAntecipada(i);
            if MACDaUltima > 0 then 
              ParcsAntecipadasNoMes.sort({$IFDEF FPC}@{$ENDIF}OrdenaParcsAntecipadasPorPgto);
            DtPgAnt.dia := 0;
            TotDevido := 0; fillchar(DtPgAnt,sizeof(TData),0);
            DataPagoAnt.Dia := 0; fillchar(DataPagoAnt,sizeof(DataPagoAnt),0);
            for iAntec := 0 to ParcsAntecipadasNoMes.count -1 do begin
              RParcela := ParcsAntecipadasNoMes[iAntec] as TParcelaSerie;
  
              if ((Juliano(RParcela.DtPg) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
                  ((Juliano(RParcela.DtPg) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
                   (Juliano(RParcela.DtPg) = Juliano(Fin.DtRenegGeradora)))) and
                  (Mes_Int(RParcela.DtPg.MesAno) >= MACIni) and
                  (Mes_Int(RParcela.DtPg.MesAno) <= MACFim) then begin
  
                DtPrest.Dia := RParcela.DiaVenc;
                Int_Mes(RParcela.Mac,DtPrest.MesAno);
                if DataEMaior(RParcela.DataRefCalc,RParcela.DtPg) and 
                   DataEMenor(RParcela.DataRefCalc,DtPrest) then
                  DataCalculo := RParcela.DataRefCalc
                else
                  DataCalculo := RParcela.DtPg;
                if ((Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno)) and
                   (
                   (Mes_Int(DataPagoAnt.MesAno) <> Mes_Int(RParcela.DtPg.MesAno)) or
                   ((DataPagoAnt.Dia < RParcela.DiaVenc) and 
                    (RParcela.DtPg.Dia >= RParcela.DiaVenc))
                   )
                  ) 
                                           or
                  ((DtPgAnt.Dia < RParcela.DiaVenc) and (DataCalculo.Dia >= RParcela.DiaVenc)) then
                 TotDevido := 0;   

  (*-----------------------------------------------------------------------
                if (juliano(DtPgAnt) <> juliano(DataCalculo)) and
                  ((DtPgAnt.Dia < RParcela.DiaVenc) or 
                   (Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno))) and 
                   (DataCalculo.Dia >= RParcela.DiaVenc) then
                  TotDevido := 0;
    Sol. 48544 - estou zerando o somat rio dos valores descapitalizados das parcelas anteriores 
       ltima, quando este somat rio se refere   parcelas pagas antes do vencimento e a  ltima
    ocorre ap s ou no vencimento, visto que ValorAntecNoVenc+ValorAntecPosVenc n o contemplam
    esses valores anteriores ao vencimento. Por isso n o posso abater do restante do saldo o TotDevido,
    pois d  um resultado negativo. 
  ------------------------------------------------------------------------*)
(*
                if  (Mes_Int(DtPgAnt.MesAno) <> Mes_Int(DataCalculo.MesAno)) or
                   ((DtPgAnt.Dia < RParcela.DiaVenc) and (DataCalculo.Dia >= RParcela.DiaVenc)) then
                   TotDevido := 0;

*)  
                ObtemValorParcelaAntecipada(Reg,Contrato.MutDsk,RParcela,DataCalculo,
                                            Contrato.RegCarteira.NaoCobraJurosContr,
                                            ValPrst,Desconto);
                DtPgAnt     := DataCalculo;
                DataPagoAnt := RParcela.DtPg;
                Pend := ValPrst - RParcela.ValorPagoNoUltimoPagamento;
                // movi o teste para cima
                if (abs(Pend) > Zero) and
                   (Juliano(RParcela.DtPg) >= Juliano(DtIni)) and
                   (Juliano(RParcela.DtPg) <= Juliano(DtFim)) then begin
                  CodTabelaGenerica := DefineCodTabelaGenericaPorChaves( Contrato.MutDsk.Cad.DtEntregaChaves,
                                                                         Reg.CodTabGPreChvCorr,
                                                                         Reg.CodTabGCorr,
                                                                         Reg.DefReajPreChvCorr,
                                                                         Reg.DefReajCorr,
                                                                         RParcela.DtPg,
                                                                         Defasagem);
                  if (CodTabelaGenerica = 0) and (Fin.CodReajAtraso > 0) then
                    CodTabelaGenerica := Fin.CodReajAtraso;
                  CorrP := CorrPendComDefasagem(Contrato.MutDsk,UF,CodMun,
                                                DataCalculo,DtCorr,Pend,MoraP,
                                                CodTabelaGenerica,Defasagem,
                                                0{codclassificacao},
                                                2{TipoCorr},
                                                true{SemCorrCodTGZero});
                  AjustaMoeda2(Mes_Int(RParcela.DtPg.MesAno),
                               Mes_Int(DtCorr.MesAno),Pend);
                  ValorT := ValorT + Pend;
                  CorrT  := CorrT + CorrP;
                  MoraT  := MoraT + MoraP;
  
                  if assigned(Dados) then begin
                    Item := TItemAcertoEvo.create;
                    Item.DtVenc := DtPrest;
                    Item.DtPag := RParcela.DtPg;
                    Item.PrstAnt := RParcela.ValorPagoNoUltimoPagamento;
                    Item.PrstAtu := ValPrst;
                    Item.Desconto := Desconto;
                    Item.ValPrest := ValPrst+Desconto;
                    Item.ValPrestOri := ValPrst+Desconto;
                    Item.Dif := Item.PrstAtu-Item.PrstAnt;
                    Item.DifAtu := Pend;
                    Item.Mora := MoraP;
                    Item.Corr := CorrP;
                    Item.CodSerie := Fin.CodSerie;
                    Item.AmortNegMes := Reg.AmortNegMes;
                    Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                    Item.CorrSaldoAmortNeg := Reg.CorrSaldoAmortNeg;
                    Item.TxSDAmortNeg := Reg.TxSDAmortNeg;
                    Dados.add(Item);
                  end;
                  if Grava then begin
                    inc(SeqPg);
                    fillchar(RPendEmi,sizeof(TpPendEmi),0);
                    with RPendEmi do begin
                      Ctr            := Contrato.MutDsk.Cad.Ctr;
                      if Com200 then TpEmissao := 1
                      else TpEmissao := 2;
                      DtEmi          := DataEmi;
                      CodSerie       := Fin.CodSerie;
                      MAC            := RParcela.MAC;
                      Seq            := SeqPg;
                      ValDevido      := ValPrst;
                      ValPago        := RParcela.ValorPagoNoUltimoPagamento;
                      DifAtual       := Pend;
                      Atualizacao    := CorrP + MoraP;
                      DtVenc         := DtPrest;
                      DtPag          := RParcela.DtPg;
                      Parcela        := RParcela.Seq;
                    end;
                    GravaPendEmi(RPendEmi);
                  end;
                end;
              end;
            end;
          end;
          if assigned(Reg.ParcelaDoMes) then begin
            if Reg.EParceladeSeguro then begin
              ParcEstaPaga := Reg.ParcelaDoMes.SeguroEstaPagoReal;
              TipoPgAux := Reg.ParcelaDoMes.TipoPgSeg;
            end  
            else begin
              ParcEstaPaga := Reg.ParcelaDoMes.EstaPagaReal;
              TipoPgAux := Reg.ParcelaDoMes.TipoPg;
            end;  
            if ((Reg.NPC > 0) or
                (Reg.MAC > Mes_Int(Fin.DataRef.MesAno)))  and
               ((Reg.TotPrest > Zero) or ParcEstaPaga) and
                (not Fin.NaoApuraAcertoFinanceiro) and
                (Reg.MAC >= MACIni) and
                (Reg.MAC <= MACFim) and
                (ParcEstaPaga or
                (Com200 and (TipoPgAux in [200,253]) and
                ((Reg.ParcelaDoMes.DataValidadeTit.Dia = 0) or 
                  DataEMenorOuIgual(DataH,Reg.ParcelaDoMes.DataValidadeTit)) //se o titulo ainda   v lido
                )) then begin
              DtPrest.Dia := Reg.DiaVenc;
              Int_Mes(Reg.MAC,DtPrest.MesAno);
              if Reg.EParcelaDeSeguro then begin
                if Reg.ParcelaDoMes.TipoPgSeg in [200,253] then
                  Reg.ParcelaDoMes.DtPgSeg := DtPrest; { Nao Foi Paga, so Emitida, j  fazia para a presta  o normal, mantive para o seguro tb }
                DtPgAux := Reg.ParcelaDoMes.DtPgSeg;    
              end
              else begin
                if Reg.ParcelaDoMes.TipoPg in [200,253] then
                  Reg.ParcelaDoMes.DtPg := DtPrest; { Nao Foi Paga, so Emitida }
                DtPgAux := Reg.ParcelaDoMes.DtPg;  
              end;  
              if (((not (TipoPgAux in NotGerPend)) and
                   (Com200 or (not (TipoPgAux in [200,253]))) and
                   (Juliano(DtPgAux) >= Juliano(Fin.DataRef)) and
                   DataValida(DtPgAux) and
                   ((Juliano(DtPgAux) > Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) or
                    ((Juliano(DtPgAux) = Juliano(Contrato.MutDsk.Cad.DtUltRenACFin)) and
                     (Juliano(DtPgAux) = Juliano(Fin.DtRenegGeradora))))) or CarregaPagamentosSemDiferenca) and
                 (Juliano(DtPrest) >= Juliano(DtIni)) and
                 (Juliano(DtPrest) <= Juliano(DtFim)) then begin
                Honorarios := ObtemHonorariosParcelaPaga(TParcelaSerie(Reg.ParcelaDoMes),PercHonorarios,PercDescHonorarios,Reg.EParcelaDeSeguro);
                ValPag  := ValPagParcSerieDtPg(TParcelaSerie(Reg.ParcelaDoMes),DescontoAux,false{SoDescConcedido},Reg.EParcelaDeSeguro);
                { 
                  99785 - quando o usu rio faz uma emiss o antecipada da presta  o do m s, ele pode gerar junto o titulo de
                          acess rios. No momento da baixa, se passar do vencimento, o titulo n o   mais baixado como antecipa  o
                          e nesse caso, a baixa   feita "normal"(no exemplo da sol. era 96).
                          Como esse tipo de baixa prev  que a presta  o tenha sido totalmente paga, o seguro que foi separado acaba virando
                          um valor que o usu rio n o pagou. Para cobrir esta situa  o, eu vou verificar que a presta  o teve sim acess rios pagos
                          (Reg.ParcAcessoriosPaga) e se tiver, eu somo no valor pago. S  devo fazer isso se eu estiver calculando uma presta  o
                          "normal" (not Reg.EParcelaDeSeguro) ou eu poderia dobrar o valor pago, no acerto de um acess rio.
                }          
                if not Reg.EParcelaDeSeguro and Reg.ParcAcessoriosPaga then
                  ValPag  := ValPag + ValPagParcSerieDtPg(TParcelaSerie(Reg.ParcelaDoMes),DescontoAux,false{SoDescConcedido},true{SomenteSeguro});
                ValPrst := ValDevParcSerieDtPg(Reg,PendEmi,Corr,Mora,Multa,Reg.EParcelaDeSeguro)-DescontoAux;
                if (Abs(Honorarios) > Zero) and (PercHonorarios > Zero) then begin
                  Honorarios := arredonda(ValPrst *(PercHonorarios/100));
                  if PercDescHonorarios > Zero then
                    Honorarios := Arredonda(Honorarios - (Honorarios * PercDescHonorarios/100));
                end;
                if Reg.EParcelaDeSeguro then
                  ValPrst := ValPrst + Honorarios
                else //#PARCELA DE SEGURO TEM IOFCOMPLEMENTAR?
                  ValPrst := ValPrst + Honorarios + Reg.ParcelaDoMes.ValIOFComplem;
                Pend := ValPrst - ValPag;
                // movi o teste para cima. Estranho s  considerar se for diferente do valor pago da parcela
                // e n o do valpag calculado
                if (abs(ValPrst - Reg.ParcelaDoMes.ValorPago) > zero) or CarregaPagamentosSemDiferenca then begin
                  CodTabelaGenerica := DefineCodTabelaGenericaPorChaves( Contrato.MutDsk.Cad.DtEntregaChaves,
                                                                         Reg.CodTabGPreChvCorr,
                                                                         Reg.CodTabGCorr,
                                                                         Reg.DefReajPreChvCorr,
                                                                         Reg.DefReajCorr,
                                                                         DtPgAux,
                                                                         Defasagem);
                  if (CodTabelaGenerica = 0) and (Fin.CodReajAtraso > 0) then
                    CodTabelaGenerica := Fin.CodReajAtraso;
                  if juliano(DtPgAux) >= juliano(DtPrest) then begin
                    CorrP := CorrPendComDefasagem(Contrato.MutDsk,UF,CodMun,
                                                  DtPgAux,DtCorr,
                                                  Pend,MoraP,CodTabelaGenerica,
                                                  Defasagem,
                                                  0{codclassificacao},
                                                  2{TipoCorr},
                                                  true{SemCorrCodTGZero});
                    AjustaMoeda2(Mes_Int(DtPgAux.MesAno),
                                 Mes_Int(DtCorr.MesAno),Pend);
                  end
                  else begin
                    // n o parece fazer sentido, se a corre  o abaixo   de dtprest para dtcorr
                    // al m de ajustar a moeda de novo, logo depois, de dtprest para dtcorr de novo
                    // achei melhor n o tirar, mas parece errado.
                    AjustaMoeda2(Mes_Int(DtPgAux.MesAno),
                                 Mes_Int(DtPrest.MesAno),Pend);
                    CorrP := CorrPendComDefasagem(Contrato.MutDsk,UF,CodMun,DtPrest,
                                                  DtCorr,Pend,MoraP,
                                                  CodTabelaGenerica,Defasagem,
                                                  0{codclassificacao},
                                                  2{TipoCorr},
                                                  true{SemCorrCodTGZero});
                    AjustaMoeda2(Mes_Int(DtPrest.MesAno),
                                 Mes_Int(DtCorr.MesAno),Pend);
                  end;
  
                  if SCCIConf.CobraMoraDif then begin
                    if ((ValPrst - ValPag) > ZERO) or ScciConf.CobraMoraDifADev then begin
                      if not UtilizaJMora  then MoraP := 0.0;
                      if UtilizaJCont then begin
                        if Not SCCICONF.PedeTipoJurAcertoFin then
                          MoraP := MoraP + CalcJurosContratuais(Contrato.MutDsk.Financ.TxJuros,DtPgAux,DtCorr,(Pend + CorrP) )
                        else MoraP := MoraP + CalcJurosEspeciais(TipoJur,Contrato.MutDsk.Financ.TxJuros,DtPgAux,DtCorr,(Pend + CorrP) );
                      end;
                    end;
                  end;
                  if assigned(Dados) then begin
                    Item := TItemAcertoEvo.create;
                    Item.DtVenc := DtPrest;
                    Item.DtPag := DtPgAux;
                    Item.PrstAnt := Valpag;
                    Item.PrstAtu := ValPrst;
                    Item.Multa   := Multa;
                    Item.Desconto := DescontoAux;
                    Item.Honorarios := Honorarios;
                    Item.ValIOFComplem := Reg.ParcelaDoMes.ValIOFComplem;
                    Item.CorrPrest := Corr;
                    Item.MoraPrest := Mora;
                    if Reg.TemParcNoMes and (not (TipoPgAux in PgtoComRedSdDev)) then
                      Item.ValPrest := Reg.TotPrest+Reg.ResiduoCobrado-Reg.VUtilPgParcialAntec
                    else
                      Item.ValPrest := Reg.TotPrest+Reg.ResiduoCobrado;
                    Item.ValPrest := Item.ValPrest - Reg.Desc + PendEmi;
                    Item.ValPrestOri := Item.ValPrest;
                    AjustaMoeda2(Mes_Int(DtPrest.MesAno),Mes_Int(DtPgAux.MesAno),Item.ValPrest);
                    DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,Item.DtVenc,DtIsenMora,Contrato.Mutdsk.Cad.DiaIsencao);
                    Item.Dif := Item.PrstAtu - Item.PrstAnt;
                    Item.DifAtu := Pend;
                    Item.Mora := MoraP;
                    Item.Corr := CorrP;
                    Item.CodSerie := Fin.CodSerie;
                    Item.AmortNegMes := Reg.AmortNegMes;
                    Item.SaldoAmortNeg := Reg.SaldoAmortNeg;
                    Item.CorrSaldoAmortNeg := Reg.CorrSaldoAmortNeg;
                    Item.TxSDAmortNeg := Reg.TXSDAmortNeg;
                    Item.EParcelaDeSeguro := Reg.EParcelaDeSeguro;
                    Dados.add(Item);
                  end;
                  if Grava then begin
                    fillchar(RPendEmi,sizeof(TpPendEmi),0);
                    with RPendEmi do begin
                      Ctr            := Contrato.MutDsk.Cad.Ctr;
                      if Com200 then TpEmissao := 1
                      else TpEmissao := 2;
                      DtEmi          := DataEmi;
                      CodSerie       := Fin.CodSerie;
                      MAC            := Reg.MAC;
                      DifAtual       := Pend;
                      Atualizacao    := CorrP + MoraP;
                      DtVenc         := DtPrest;
                      if Reg.EParcelaDeSeguro then begin
                        ValPago        := Reg.ParcelaDoMes.SeguroPago;
                        if Abs(Pend) > zero then 
                          ValDevido    := ValPrst
                        else
                          ValDevido    := ValPago;
                        DtPag          := Reg.ParcelaDoMes.DtPgSeg;
                        Parcela        := Reg.ParcelaDoMes.Mac;
                      end
                      else begin
                        ValPago        := Reg.ParcelaDoMes.ValorPago+TParcelaSerie(Reg.ParcelaDoMes).DescConcedido;
                        if Abs(Pend) > zero then 
                          ValDevido    := ValPrst
                        else
                          ValDevido    := ValPago;
                        DtPag          := Reg.ParcelaDoMes.DtPg;
                        Parcela        := TParcelaSerie(Reg.ParcelaDoMes).Seq;
                      end;  
                    end;
                    GravaPendEmi(RPendEmi);
                  end;
                end
                else begin
                  Pend := 0; CorrP := 0; MoraP := 0;
                end;
              end
              else begin
                Pend := 0; CorrP := 0; MoraP := 0;
              end;
              ValorT := ValorT + Pend;
              CorrT  := CorrT + CorrP;
              MoraT  := MoraT + MoraP;
            end; { if }
          end;
        end;
      end;
      inc(i);
    end;
    if Abs(ValorT) > Zero then begin
      if ValorT > Zero then
        ValorT :=  int(    ValorT * 100.0+0.5) / 100.0
      else
        ValorT := -int(Abs(ValorT)* 100.0+0.5) / 100.0;
    end;
    if Abs(CorrT) > Zero then begin
      if CorrT > Zero then
        CorrT  :=  int(    CorrT * 100.0+0.5) / 100.0
      else
        CorrT  := -int(Abs(CorrT)* 100.0+0.5) / 100.0;
    end;
    if Abs(MoraT) > Zero then begin
      if MoraT > Zero then
        MoraT  :=  int(    MoraT * 100.0+0.5) / 100.0
      else
        MoraT  := -int(Abs(MoraT)* 100.0+0.5) / 100.0;
    end;
  finally
    ParcsAntecipadasNoMes.free;
  end;
end;

procedure TSerie.ExpandeValoresPorMacAteRef(MacRef : smallint; Status : integer);
var
  i : integer;
