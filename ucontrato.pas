{$IFDEF CONSOLE}
// Esta l gica foi movida da evopglib.TotAtrasoEvoContrato para c 
// O TContrato j  tem que est  evolu do at  onde for necess rio
// e qualquer tratamento de simula  o j  tem que ter sido feito
function CalculaAtrasoEvoContrato(SeparaUltimaPrestacao : boolean;
                                  NIsen : integer;
                                  ArrIsen : TpArrIsen;
                                  Contrato : TContrato;
                                  Dados : TDadosAtrasoEvo;
                                  DataRef : TData;
                              var IsenAtraso : TpIsenAtraso;
                                  DtProtocoloLei9866 : TData;
                                  Tmora : integer  = 0;
                                  TipoQuit : smallint = 0;
                                  Devidas : boolean  = false;
                                  NaoPodeCobrarTaxaBancaria : boolean = false;
                                  IgnoraTaxas : boolean = false;
                                  IgnoraAcordos : boolean = false;
                                  CobraPrestMesNaoVencida : boolean = false;
                                  EhQuitacaoDeDebito : boolean = false;
                                  CobraHonorarios : boolean = false;
                                  TipoIsencao : integer = 0;
                                  ParamsIsenRenegFinanc : TParamsIsenRenegFinanc = nil;
                                  CalcPagFGTS : boolean = false;
                                  ProgACasaESua : boolean = false;
                                  TrataLei9866 : boolean = false;
                                  ModuloChamador : integer = 0;
                                  CobraTodasTaxas : boolean = true;
                                  IgnoraDtTetoPend : boolean = false;
                                  PermiteEvoluir : boolean = false;
                                  Selecao : TSelecaoAtrasoEvo = nil) : real;
var
  i : SmallInt;
  DtAux           : TData;
  Parametros : TCalculoAtrasoParametros;
  TempDtIsenMora : Tdata;
  TempPendImplant : boolean;
  TempPendDesprezivel : real;
  Prestacao : TPrestacaoAtrasoEvo;
  DtVenc : Tdata;
  Dias : integer;
  Alcadas : TAlcadasDesconto;
  Alcada : TAlcadaDesconto;
  HoraAux : THora;
begin
  Alcada := nil;
  result := 0;

  TempDtIsenMora := Scciconf.DtIsenMora;
  TempPendImplant := Scciconf.PendImplant;
  TempPendDesprezivel := Scciconf.PendDesprezivel;

  Parametros := TCalculoAtrasoParametros.create;
  try
    StdDtPgto.Ctr := '';
    Scciconf.PendImplant := false;
    Scciconf.PendDesprezivel:= 999999999.99;

    Parametros.DataRef := DataRef;
    if CobraPrestMesNaoVencida then Parametros.DataAtr := DataRef;
//    Parametros.PendUltPrst := (not Scciconf.DistribuiPend);
    Parametros.IgnoraAcordos := IgnoraAcordos;
    Parametros.TMora := TMora;
//    Parametros.UltimaPrestacaoDiferenciada := SeparaUltimaPrestacao;
    Parametros.IsentaMoraNaQuitacao := (TipoQuit = Quit_Novacao30) or
                                       (TipoQuit = Quit_Novacao100);
    Parametros.CobraTodasTaxas := CobraTodasTaxas;
    Parametros.IgnoraTaxas := IgnoraTaxas;
    Parametros.CobraDoMes := CobraPrestMesNaoVencida;
    Parametros.CobraPend := false;
    Parametros.IgnoraDtTetoPend := IgnoraDtTetoPend;
    Parametros.PermiteEvoluir := PermiteEvoluir;

{    if NaoPodeCobrarTaxaBancaria then
      Parametros.PodeCobrarTaxaBancaria := false;}
    if Devidas then
      Parametros.TipoExec := TipoExec_Renegociacao
    else
      Parametros.TipoExec := TipoExec_Quitacao;
    Parametros.CobraHonorarios := CobraHonorarios;
    if Scciconf.IgnoraIsencaoDeMoraNaQuitacao then
      Scciconf.DtIsenMora.Dia := 0;

    Parametros.CalcPagFGTS := CalcPagFGTS;
    Parametros.ProgACasaESua := ProgACasaESua;
    Parametros.EhQuitacaoDeDebito := EhQuitacaoDeDebito;
    Parametros.AplicaIsenMoraZero := EhQuitacaoDeDebito; // na quita  o sempre considerar a isenmorazero
    if (Parametros.TipoExec = TipoExec_Renegociacao) and
       EhQuitacaoDeDebito and Scciconf.AgrupaCtrNoCalculoDoAtrasoDaReneg and
       (Contrato.Grupo.Count > 1) then begin
      for i := 0 to Contrato.Grupo.Count -1 do begin
        if not Contrato.grupo[i].contrato.evoluiu then
          Contrato.Grupo[i].Contrato.ObtemRpaEvo(Mes_Int(DataRef.MesAno));
      end;
      Contrato.Grupo.CalculaAtraso(Parametros,Dados);
    end
    else
      Contrato.CalculaAtraso(Parametros,Dados);

    if assigned(Selecao) then begin
      for i := 0 to Dados.count-1 do
        Dados[i].Esconde := true;

      for i := 0 to Selecao.count-1 do
        if Mes_Int(Selecao[i].MA) > 0 then begin
          Prestacao := Dados.PrestacaoPorCodSerieEMac[Selecao[i].CodSerie,Mes_Int(Selecao[i].MA)];
          if assigned(Prestacao) then
            Prestacao.esconde := false;
        end;
    end;    

    IsenAtraso.DiasEmAtraso := 0;

    IsenAtraso.JMTot := 0;
    IsenAtraso.JCTot := 0;
    IsenAtraso.CorrecaoTot := 0;
    IsenAtraso.MultaTot := 0;
    IsenAtraso.HonorariosTot := 0;

    IsenAtraso.PercDescMoraMax := 100;
    IsenAtraso.PercDescJremuneratoriosMax := 100;
    IsenAtraso.PercDescCorrMax := 100;
    IsenAtraso.PercDescMultaMax := 100;
    IsenAtraso.PercDescHonorariosMax := 100;
    IsenAtraso.PercDescQuitacaoMax := 100;

    IsenAtraso.Permissao := 0;
    IsenAtraso.DiasEmAtrasoAlcada := 0;
    IsenAtraso.DiasEmAtrasoIsencao := 0;

    // preencher pelo menos codserie e macprst ou a montagem da isen  o
    // n o ser  feita corretamente na rotina UAtrasolib.LeDadosAtrasoEvo

    for i := 0 to Dados.Count-1 do begin
// Sol. 78206
// ao limpar o registro isenmora e tentar emitir, causa erro na grava  o do campo DATAHORA, que n o pode ser nulo
// al m disso, o c lculo de atraso carrega estes registros com condi  es pr -configuradas, que n o deveriam
// ser perdidas. Assim, eu mantive a l gica de garantir que a chave do registro esteja preenchida, mas n o
// estrago os valores carregados pelo calculo do atraso
//      fillchar(Dados[i].IsenMora,sizeof(TpIsenMora),0);
      with Dados[i].IsenMora do begin
        Ctr := Contrato.MutDsk.Cad.Ctr;
        CodSerie := Dados[i].CodSerie;
        MACPrst := Dados[i].MacPrst;
      end;

      // preparar o registro IsenAtraso, igual   feito para rotina antiga de atraso
      DtVenc.dia := Dados[i].DiaVenc;
      int_mes(Dados[i].MacPrst,DtVenc.MesAno);
      Dias := DiasDeAtrasoEntreDatas(DtVenc,DataRef);
      if (IsenAtraso.DiasEmAtraso <= 0) or (Dias > IsenAtraso.DiasEmAtraso) then
        IsenAtraso.DiasEmAtraso := Dias;

      if Dados[i].EmAtraso then
        Dias := dados[i].NDiasAtr
      else
        Dias := 0;
      if (IsenAtraso.DiasEmAtrasoIsencao <= 0) or (dados[i].NDiasAtr > IsenAtraso.DiasEmAtrasoIsencao) then
        IsenAtraso.DiasEmAtrasoIsencao := Dias;
      if not Dados[i].esconde then begin
        IsenAtraso.JMTot := IsenAtraso.JMTot + Dados[i].Mora-
                                               Dados[i].Juroscontr;
        IsenAtraso.JCTot := IsenAtraso.JCTot + Dados[i].Juroscontr;
        IsenAtraso.CorrecaoTot := IsenAtraso.CorrecaoTot + Dados[i].Correcao;
        IsenAtraso.MultaTot := IsenAtraso.MultaTot + Dados[i].Multa;
        IsenAtraso.HonorariosTot := IsenAtraso.HonorariosTot + Dados[i].Honorarios;
      end;
    end;

    if IsenAtraso.AlcadaDescontoModulo > 0 then begin
      Alcadas := TAlcadasDesconto.create(nil);
      try
        Alcadas.le(IsenAtraso.AlcadaDescontoModulo,GetSqlConnection(pegaDirTab));
        for i := Alcadas.count-1 downto 0 do
          if IsenAtraso.DiasEmAtraso >= Alcadas[i].Cad.NU_DIAS_ATS then begin
            Alcada := Alcadas[i];
            break;
          end;
        if assigned(Alcada) then begin
          IsenAtraso.PercDescMoraMax := Alcada.Cad.PE_DESC_MORA;
          IsenAtraso.PercDescJremuneratoriosMax := Alcada.Cad.PE_DESC_JREM;
          IsenAtraso.PercDescCorrMax := Alcada.Cad.PE_DESC_CORRECAO;
          IsenAtraso.PercDescMultaMax := Alcada.Cad.PE_DESC_MULTA;
          IsenAtraso.PercDescQuitacaoMax := Alcada.Cad.PE_DESC_QUITACAO;
          IsenAtraso.Permissao := Alcada.Cad.CO_PERMISSAO;
          IsenAtraso.DiasEmAtrasoAlcada := Alcada.Cad.NU_DIAS_ATS;
        end;
      finally
        Alcadas.free;
      end;

      if (IsenAtraso.PercDescMoraMax-IsenAtraso.PercDescMora) < 0 then
        raise exception.create('Desc. juros morat rios m ximo de '+format('%.2f%%',[IsenAtraso.PercDescMoraMax]));
      if (IsenAtraso.PercDescJremuneratoriosMax-IsenAtraso.PercDescJremuneratorios) < 0 then
        raise exception.create('Desc. juros remunerat rios m ximo de '+format('%.2f%%',[IsenAtraso.PercDescJremuneratoriosMax]));
      if (IsenAtraso.PercDescCorrMax-IsenAtraso.PercDescCorr) < 0 then
        raise exception.create('Desc. corre  o m ximo de '+format('%.2f%%',[IsenAtraso.PercDescCorrMax]));
      if (IsenAtraso.PercDescMultaMax-IsenAtraso.PercDescMulta) < 0 then
        raise exception.create('Desc. multa m ximo de '+format('%.2f%%',[IsenAtraso.PercDescMultaMax]));
    end;

    if (NIsen > 0) or (IsenAtraso.DtIsen.dia > 0) then begin
      Get_Hora(HoraAux);
      if IsenAtraso.DtIsen.dia > 0 then begin
        for i := 0 to Dados.count-1 do begin
          fillchar(Dados[i].Isenmora,sizeof(TpIsenMora),0);
          Dados[i].IsenMora.Ctr := Contrato.Mutdsk.cad.ctr;
          Dados[i].IsenMora.Data := DataH;
          Dados[i].IsenMora.Hora := HoraAux;
          Dados[i].IsenMora.User := PegaUsuario;
          Dados[i].IsenMora.DataIsen := IsenAtraso.DtIsen;
          Dados[i].IsenMora.CodMot := IsenAtraso.CodMot;
          Dados[i].IsenMora.MACPrst := Dados[i].MacPrst;
          Dados[i].IsenMora.CodSerie := Dados[i].CodSerie;
          Dados[i].IsenMora.PercDescMora := IsenAtraso.PercDescMora;
          Dados[i].IsenMora.PercDescJRemuneratorios := IsenAtraso.PercDescJRemuneratorios;
          Dados[i].IsenMora.PercDescCorr := IsenAtraso.PercDescCorr;
          Dados[i].IsenMora.PercDescMulta := IsenAtraso.PercDescMulta;
          Dados[i].IsenMora.PercDescHonorarios := trunc(IsenAtraso.PercDescHonorarios/100);
        end
      end
      else for i := 1 to Nisen do begin
        Prestacao := Dados.PrestacaoPorCodSerieEMac[ArrIsen[i].CodSerie,ArrIsen[i].MacPrst];
        if assigned(prestacao) then
          Prestacao.IsenMora := ArrIsen[i];
      end;
      Contrato.RecalculaDadosAtraso(Parametros,Dados);
    end
    else if assigned(ParamsIsenRenegFinanc) then begin
      for i := 0 to Dados.Count-1 do begin
        fillchar(Dados[i].IsenMora,sizeof(TpIsenMora),0);
        with Dados[i].IsenMora do begin
          Ctr          := Contrato.MutDsk.Cad.Ctr;
          CodSerie     := Dados[i].CodSerie;
          Get_Data(Data);
          Get_Hora(Hora);
          User         := PegaUsuario;
          DataIsen     := ParamsIsenRenegFinanc.DtIsen;
          CodMot       := ParamsIsenRenegFinanc.Motivo;
          MACPrst      := Dados[i].MacPrst;
          PercDescCorr := ParamsIsenRenegFinanc.PercCorr;
          PercDescjremuneratorios := ParamsIsenRenegFinanc.PercJC;
          PercDescMora := ParamsIsenRenegFinanc.PercJM;
          PercDescMulta := ParamsIsenRenegFinanc.PercMulta;
          PercDescHonorarios := trunc(ParamsIsenRenegFinanc.PercHonorarios*100);
        end;
      end;
      Contrato.RecalculaDadosAtraso(Parametros,Dados);
    end
    else if TipoIsencao = Isen_RenegComRepasse then begin
      for i := 0 to Dados.Count-1 do begin
        fillchar(Dados[i].IsenMora,sizeof(TpIsenMora),0);
        with Dados[i].IsenMora do begin
          Ctr          := Contrato.MutDsk.Cad.Ctr;
          CodSerie     := Dados[i].CodSerie;
          Get_Data(Data);
          Get_Hora(Hora);
          User         := PegaUsuario;
          DataIsen     := Parametros.DataRef;
          CodMot       := 0;
          MACPrst      := Dados[i].MacPrst;
          PercDescMora := 100.0;
          PercDescMulta := 100.0;
          PercDescHonorarios := 10000;
        end;
      end;
      Contrato.RecalculaDadosAtraso(Parametros,Dados);
    end;

    for i := 0 to Dados.count-1 do
     result := result + Dados[i].ValTit - Dados[i].DifManual;
  finally
    Parametros.free;
    Scciconf.PendImplant := TempPendImplant;
    Scciconf.PendDesprezivel := TempPendDesprezivel;
    Scciconf.DtIsenMora := TempDtIsenMora;
  end;
end;

function ClassificaValoresPorMac(var MutDsk : TpMutDsk; ValoresPorMac : TValoresPorMac; DataRef : Tdata) : SmallInt;
var
  RegImv : TpCadImv;
  conta : smallint;
  ComCoobrigacao : boolean;
begin
  RegImv.Empreend := 0; fillchar(RegImv,sizeof(RegImv),0);

  conta := ValoresPorMac.conta;
  if conta = 0 then
    conta := MutDsk.Cad.ContaVel;
  if DataRef.Dia > 0 then
    ComCoobrigacao := (ValoresPorMac.DtTermCoobrigacao.Dia > 0) and
                      DataMaior(ValoresPorMac.DtTermCoobrigacao,DataRef)
  else
    ComCoobrigacao := false;
  Result := Cla0(Conta, ValoresPorMac.donocred,
                 ValoresPorMac.cauccred, MutDsk.Cad.CodRegiao,
                 0, ValoresPorMac.status, ValoresPorMac.codsusp,
                 ValoresPorMac.lcobr,
                 MutDsk.ChaveImv.Empreend,
                 ValoresPorMac.Plano,
                 ValoresPorMac.FCVSCobre,
                 MutDsk.Cad.SuregCef,
                 MutDsk.Cad.CadFin.OrigCred,
                 MutDsk.Cad.ContaVel,
                 MutDsk.Cad.CodAdvG,
                 MutDsk.Cad.LcEntrega,
                 ValoresPorMac.Carteira,
                 MutDsk.Cad.AgencCC,
                 MutDsk.Cad.SitCobJ,
                 0{MutDsk.Cad.SitEsp1},
                 0{MutDsk.Cad.SitEsp2},
                 0{MutDsk.Cad.SitEsp3},
                 0{MutDsk.Cad.SitEsp4},
                 0{MutDsk.Cad.SitEsp5},
                 0,0,0,0,0,0,0,0,
                 MutDsk.Cad.TipoCtr,1,
                 MutDsk.Financ3.Gestor,
                 0,
                 ComCoobrigacao,
                 UpCase(RegImv.ImovelNovo) = 'S',
                 0{SituacaoCtb});
end;

procedure DeterminaTerminoValoresPorMac(    ValoresPorMac : TValoresPorMac;
                                        Var DtTerminoContratual : TData;
                                            TerminosAntec : boolean = false;
                                            ConsiderarPrazoOrig : boolean = false);
begin
  DeterminaTermino(ValoresPorMac.Status,ValoresPorMac.MacStatus,ValoresPorMac.MAC,
                   ValoresPorMac.DiaLiq,ValoresPorMac.DiaVenc,ValoresPorMac.DtInFin,
                   ValoresPorMac.DesconsideraPrstNoDiaSin,ValoresPorMac.StatusAnt,
                   ValoresPorMac.MacStatusAnt,ValoresPorMac.DiaLiqAnt,
                   ValoresPorMac.CodSerie,ValoresPorMac.Periodicidade,
                   ValoresPorMac.PrazoOrig,ValoresPorMac.Prazo,
                   ValoresPorMac.DiaVencOrig,
                   DtTerminoContratual,
                   TerminosAntec,
                   ConsiderarPrazoOrig);
end;

