      ParcAtuFGTS := RPAQuit.Mac - RPAQuit.ValRPA.PstInFG + 1;
      result1 := true;
    end
    else begin
      result1 := false;
      RetornaErroQuit(ErroQuit,MutMem.MutDsk.Cad.Ctr,Error,Controle.DataRef);
    end;
  *)

    if DadosQuitacao.ErroQuit = 0 then begin
      result := true;
      if DadosQuitacao.Opcoes.count > 0 then
        DadosQuitacao.Opcoes[0].Valor := Arredonda(  DadosQuitacao.Opcoes[0].Valor
                                                   + DadosQuitacao.Residuo2065
                                                   + DadosQuitacao.DifLiminar
                                                   + DadosQuitacao.TotAtraso
                                                   + DadosQuitacao.TotPend
                                                   + DadosQuitacao.TotTaxas
                                                   - DadosQuitacao.DevolPrstPaga
                                                   + DadosQuitacao.Opcoes[0].DifHab
                                                   + DadosQuitacao.TotSeries
                                                   - DadosQuitacao.PrejuLiqSeries
                                                   + DadosQuitacao.SeguroSeries
                                                   - DadosQuitacao.Opcoes[0].PrejuliqDifLiminar
                                                   {- DadosQuitacao.TotVFgtsTrSeries});
    end
    else begin
      result := false;
      RetornaErroQuit(DadosQuitacao.ErroQuit,MutDsk.Cad.Ctr,DadosQuitacao.Error,Parametros.DataRef);
    end;
  end;

  if result then try
    VerificaCmTabErr;
    if GeraMsgCmTabErr > '' then
      DadosQuitacao.Avisos.add(GeraMsgCmTabErr);
  except
    on e : exception do begin
      result := false;
      DadosQuitacao.Error := e.message;
    end;
  end;
end;

procedure DefinePadroesAcertoFin(Var UtilizaJmora, UtilizaJCont : boolean; Var TipoJur : integer);
begin
  UtilizaJMora := true;
  if ScciConf.MoraSimplesJurContCap then begin
    TipoJur      := JCapital;
    UtilizaJCont := true;
  end
  else begin
    TipoJur      := JSimples;
    UtilizaJCont := false;
  end;
end;

function  TContrato.CalculaAcertoFinPadrao(DataRef, DtInipend, DtFimPend, DataEmi : Tdata;
                                           Dados : TDadosAcertoEvo;
                                           Com200 : boolean;
                                           SemLiminar : boolean;
                                           Grava : boolean;
                                           CalculaSomenteDifPrest : boolean = false;
                                           CarregaPagamentosSemDiferenca : boolean = false;
                                           IgnoraPA : boolean = false) : real;
var
  UtilizaJMora,
  UtilizaJCont  : boolean;
  TipoJur       : integer;
begin
  TipoJur := 0;
  UtilizaJMora := false;
  UtilizaJCont := false;
  DefinePadroesAcertoFin(UtilizaJMora,UtilizaJCont,TipoJur);
  result := CalculaAcertoFin(DataRef,DtIniPend,DtFimPend,Dataemi,Dados,Com200,SemLiminar,Grava,UtilizaJMora,UtilizaJCont,TipoJur,CalculaSomenteDifPrest,CarregaPagamentosSemDiferenca,IgnoraPA);
end;

function  TContrato.CalculaAcertoFin(    DataRef, DtInipend, DtFimPend : Tdata;
                                         Dados : TDadosAcertoEvo = nil;
                                         Com200 : boolean = false;
                                         SemLiminar : boolean = false) : real;
begin
  result := CalculaAcertoFinPadrao(DataRef,DtIniPend,DtFimPend,DataRef{Dataemi},Dados,Com200,SemLiminar,false{gravar});
end;

procedure PreenchePrest(Ctr : TpCtr; ValoresPorMac : TValoresPorMac; Var RPrest : TpArqPrst);
begin
  fillchar(RPrest,sizeof(TpArqPrst),0);
  RPrest.Ctr      := Ctr;
  RPrest.MAC      := ValoresPorMac.MAC;
  RPrest.NPC      := ValoresPorMac.NPC;
  RPrest.DiaVenc  := ValoresPorMac.DiaVenc;
  RPrest.TAC      := ValoresPorMac.TAC;
  RPrest.AmaisJ   := ValoresPorMac.AmaisJ;
  RPrest.Juro     := ValoresPorMac.Juro;
  RPrest.Seguro   := ValoresPorMac.Seguro;
  RPrest.ValTxAdm := ValoresPorMac.ValTxAdm;
  RPrest.FCVS     := ValoresPorMac.FCVS;
  RPrest.FGTS     := ValoresPorMac.FGTS;
  if ValoresPorMac.Status > 0 then RPrest.SaldoDev := 0
  else RPrest.SaldoDev := ValoresPorMac.SaldoDev;
  RPrest.Desc     := ValoresPorMac.Desc;
  RPrest.SegImv   := ValoresPorMac.SegImv;
  RPrest.SegFin   := ValoresPorMac.SegFin;
  if (RPrest.SegImv>Zero) or (RPrest.SegFin>Zero) then
    RPrest.SegCre   := RPrest.Seguro-RPrest.SegImv-RPrest.SegFin
  else RPrest.SegCre := 0;
  RPrest.Flag     := 100;
  RPrest.ResFGTS  := ValoresPorMac.Residuo;
  RPrest.RARD     := ValoresPorMac.RARD;
  RPrest.AmaisJPar:= ValoresPorMac.AmaisJPar;
  RPrest.CorrPar  := ValoresPorMac.CorrPar;
  RPrest.SaldoPar := ValoresPorMac.SaldoPar;
end;

procedure TContrato.ObtemPrest (DtRPA: TData;  var RPrst: TpArqPrst);
var
  ValoresPorMac : TValoresPorMac;
begin
  LePrst(Mutdsk.Cad.Ctr,Mes_Int(DtRPA.MesAno),RPrst);
  if RPrst.Ctr = '' then begin
    try
      ValoresPorMac := FSerieFinanciamentoDinamico.ObtemValoresPorMAC(Mes_int(DtRPA.MesAno));
    except
      on e : exception do
        raise exception.create('O contrato n o foi evoluido para '+Ma_Str2(DtRPA.MesAno));
    end;
//  ObtemRPAFinancDinamicoEvo(Ctr,DtRPA,RPA); Trocar pelos valores por data
    PreenchePrest(Mutdsk.Cad.Ctr,ValoresPorMac,RPrst);
  end;
end;
