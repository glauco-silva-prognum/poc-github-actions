begin
  if ( Rpas.Temp12.PagAntecNoVenc +  Rpas.Temp12.PagAntecPosVenc) > 0 then
  begin
    if abs(RPAS.ValRPA.Juro) < Zero then begin
      // forcei voltar os valores antecipados para ficar igual a antes
      //RPAS.Valrpa.saldodev := RPAS.Valrpa.saldodev + Rpas.Temp12.PagAntecNoVenc + Rpas.Temp12.PagAntecPosVenc;
