      if not EstaPaga(DataRef) then Result := Result + Valor;
end;
           
function TSerie.ObtemValoresPorMAC(Mac : integer) : TValoresPorMAC;
begin
  if mac < FValoresPorMacList.count then
    if assigned(FValoresPorMacList[Mac]) then
      result := TValoresPorMac(FValoresPorMacList[Mac])
    else if mes_int(Fin.DataRef.MesAno) < FValoresPorMacList.count then
      if assigned(FValoresPorMacList[mes_int(Fin.DataRef.MesAno)]) then
        result := TValoresPorMac(FValoresPorMacList[mes_int(Fin.DataRef.MesAno)])
      else
        raise exception.create(' ndice n o calculado para '+MAC_Str(MAC)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
    else
        raise exception.create(' ndice n o calculado para '+MA_Str2(Fin.DataRef.MesAno)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1))
  else
    raise exception.create(' ndice n o calculado para '+MAC_Str(MAC)+',  ltimo obtido : '+MAC_Str(FValoresPorMacList.count-1));
end;

function TSerie.ObtemValoresPorMACInicial : TValoresPorMAC;
begin
