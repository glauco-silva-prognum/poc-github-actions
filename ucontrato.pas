    SerieMaiorPrazoComAmaisJCompoeSd := -2;
    SerieMaiorPrazoComAmaisJ := -2;
    SerieMaiorPrazoReajCompoeSd := -2;
    SerieMaiorPrazoReaj := -2;

    MenorDataRef := 1e100;
