        t := '00';
      end;
      Node := DadosXml.addChild('CodPref');
      Node.attributes['valor'] := '('+s+'.'+t+')';

      MontaDetalhesStatusCtr(RPA,SitStr,Hint);
      Node := DadosXml.AddChild('Status');
      Node.attributes['valor'] := SitStr;
      Node.attributes['Hint'] := hint;
      MontaDetalhesSituacaoCtr(Contrato.Mutdsk,Contrato.MutdskC,RPA,SitStr,Detalhes,SubDetalhe);
      Node := DadosXml.addChild('Situacao');
      Node.attributes['valor'] := SitStr;
      if Detalhes.count > 0 then begin
        Node := Node.AddChild('DetalhesGrid');
        Node.attributes['Title'] := 'Situa  es do Contrato';
        Node.attributes['valor'] := Detalhes.text;
        Node.attributes['subdetalhe'] := SubDetalhe.text;
      end;

      Node := DadosXml.AddChild('isencao');
      if ContratoTemAlgumaIsencao(Contrato) then
        Node.attributes['valor'] := 'Sim'
      else
        Node.attributes['valor'] := 'N o';

      Node := DadosXml.addchild('Desconto');
      Detalhes.clear;
      if TemDesconto(RPA,Contrato.MutDsk,DataH) then begin
        Node.attributes['valor'] := DescStr[0];
        if Rpa.FinRpa.FCVSCobre then
          Detalhes.add('Com cobertura do FCVS')
        else
          Detalhes.add('Sem cobertura do FCVS');
        Detalhes.add('');
        if Rpa.Temp6.EdoSFH then 
          Detalhes.add('Contrato pertence ao SFH')
        else Detalhes.add('Contrato fora do SFH');
        Node := Node.AddChild('Detalhes');
        Node.Attributes['Title'] := 'Desconto';
        Node.Attributes['Valor'] := Detalhes.text;
      end
      else begin
        Node.attributes['valor'] := DescStr[1];
        if NaoTemDescPorMotNegCobFCVS(Contrato.MutDsk.Cad.MotNegCobFCVS) or
           NaoTemDescPorMotNegCobFCVS(Contrato.MutDsk.Cad2.MotNegCobFCVS2) then begin
          TavaAbertoMotNegCobFCVS := AbriuMotNegCobFCVS;
          if not TavaAbertoMotNegCobFCVS then
            AbreMotNegCobFCVS;
          Detalhes.clear;
          Detalhes.add('Motivo(s) de negativa de cobertura:');
          contMotivo := 0;
          if NaoTemDescPorMotNegCobFCVS(Contrato.MutDsk.Cad.MotNegCobFCVS) then begin
            inc(contMotivo);
            Detalhes.add('Motivo '+inttostr(contMotivo)+': '+
                         DescMotNegCobFCVS(Contrato.MutDsk.Cad.MotNegCobFCVS));
          end;
          if NaoTemDescPorMotNegCobFCVS(Contrato.MutDsk.Cad2.MotNegCobFCVS2) then begin
            inc(contMotivo);
            Detalhes.add('Motivo '+inttostr(contMotivo)+': '+
                         DescMotNegCobFCVS(Contrato.MutDsk.Cad2.MotNegCobFCVS2));
          end;

          if not TavaAbertoMotNegCobFCVS then
            FechaMotNegCobFCVS;
        end;
        if Rpa.FinRpa.FCVSCobre then
          Detalhes.add('Com cobertura do FCVS')
        else
          Detalhes.add('Sem cobertura do FCVS');
        Detalhes.add('');
        if Rpa.Temp6.EdoSFH then 
          Detalhes.add('Contrato pertence ao SFH')
        else Detalhes.add('Contrato fora do SFH');
        Node := Node.AddChild('Detalhes');
        Node.Attributes['Title'] := 'Desconto';
        Node.Attributes['Valor'] := Detalhes.text;
      end;

      if (FinRPA2.Evoluido > 4) then
        FinRPA2.Evoluido := 0;
      if ScciConf.ControlaContribAVistaAoFCVS and (FinRPA2.Evoluido = 3) and
         not Contrato.MutDsk.Cad2.TemPendenciasDeFCVS then begin
        Node := DadosXml.addChild('Evoluido');
        Node.attributes['valor'] := 'TEF';
      end
      else begin
        Node := DadosXml.Addchild('Evoluido');
        if (FinRPA2.Evoluido = 3) then begin
          MontaDetalhesLogReevoCtr(Contrato.MutDsk.Cad.Ctr,Detalhes);
          Node.attributes['valor'] := EvoStr[FinRPA2.Evoluido];
          if Detalhes.count > 0 then begin
            Node := Node.addchild('Detalhes');
            Node.attributes['Title'] := 'Log Reevolu  o';
            Node.attributes['valor'] := Detalhes.text;
          end;
        end
        else
          Node.attributes['valor'] := EvoStr[FinRPA2.Evoluido];
        if FinRPA2.Evoluido = 4 then
          Node.attributes['Hint'] := 'Evolu  o Manual';
      end;
    end;
  finally
    Detalhes.free;
    SubDetalhe.free;
    if not TavaAbertoArea then
      FechaArea;  end;
end;

