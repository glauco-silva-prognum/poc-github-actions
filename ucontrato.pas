function TParcelas.GetContrato : TContrato;
begin
  result := nil;
  if assigned(FOwner) then begin
    if FOwner is TSerie then
      result := (FOwner as TSerie).Contrato
    else if FOwner is TSerieFinanciamentoDinamico then
      result := (FOwner as TSerieFinanciamentoDinamico).Contrato
    else if FOwner is TSerieFinanciamentoConsolidado then
      result := (FOwner as TSerieFinanciamentoConsolidado).Contrato;
  end;
end;

function TParcelas.GetDataProcPgRef : TData;
begin
  Result.Dia := 0;
  fillchar(Result,sizeof(TData),0);
  if assigned(FOwner) then begin
    if FOwner is TSerie then
      result := (FOwner as TSerie).Contrato.FDataProcPgRef
    else if FOwner is TSerieFinanciamentoDinamico then
      result := (FOwner as TSerieFinanciamentoDinamico).Contrato.FDataProcPgRef
    else if FOwner is TSerieFinanciamentoConsolidado then
      result := (FOwner as TSerieFinanciamentoConsolidado).Contrato.FDataProcPgRef
  end;
end;

function TParcelas.GetSerie : TSerie;
begin
  result := nil;
  if assigned(FOwner) and (FOwner is TSerie) then
    result := FOwner as TSerie;
end;

function TParcelas.ObtemParcelaPorMAC(MAC:integer):TParcela;
var i : integer;
begin
  if FIndicePorMac.HasItem(Mac) then
    result := FIndicePorMac[Mac] as Tparcela
  else begin
    Result := nil;
    for i := 0 to Count-1 do
      if Parcela[i].MAC = MAC then begin
        Result := Parcela[i];
        break;
      end;
  end;
end;

procedure TParcelas.clear;
begin
  FIndicePorMac.clear;
  FIndiceSeguroPorMac.Clear;
  inherited clear;
end;

procedure TParcelas.LeParcelasDaMemoria(ParcelasOrigem : TParcelas);
var
  i : integer;
  Parc : TParcelaSerie;
begin
  clear;
  for i := 0 to ParcelasOrigem.count-1 do begin
    Parc := add as TParcelaSerie;
    Parc.assign(ParcelasOrigem[i] as TParcelaSerie);
  end;
end;

