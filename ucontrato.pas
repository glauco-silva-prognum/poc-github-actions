procedure TSerie.CalculaReavaliacaoValAval(var RPACons : TpRPA);
var
  MACUltReaval : smallint;
  NuPerValAval : integer;
  ValReavaliacaoAnt : real;
  Indice : real;
  RegApoliceDFI : TpApolice;
  leglinkitem : TLegLinkItem;
  DtIni,
  DtFim : TData;
begin
  RegApoliceDFI.CodApolice := '';
  fillchar(RegApoliceDFI,sizeof(TpApolice),0);

  {
    111500
    o Valor de reavalia  o estava implementado dentro do c lculo de seguro das s ries,
    por m, quando a s rie n o tinha c lculo no m s, o valor n o era atualizado como esperado,
    ent o resolvi mov -lo para depois do c lculo de seguro, resolvendo assim a ap lice 
    primeiro, para depois calcular o valor de reavalia  o. Para s ries, j  estava considerando
    a ap lice DFI, ent o mantive.
  }

  if scciconf.PeriodicidadeDeReavaliacaoDaGarantia > 0 then
    NuPerValAval := scciconf.PeriodicidadeDeReavaliacaoDaGarantia
  else begin
    if trim(RPAS.Temp11.CodApoliceDFI) > '' then begin
      LeApolice(RPAS.Temp11.CodApoliceDFI,RegApoliceDFI);
    end;
    if RegApoliceDFI.Nu_PerValAval > 0 then
      NuPerValAval := RegApoliceDFI.Nu_PerValAval
    else
      NuPerValAval := 0;
  end;
  if (NuPerValAval > 0) then begin
    if RPAS.Temp12.MACReavaliacao > 0 then
      MACUltReaval := RPAS.Temp12.MACReavaliacao
    else
      MACUltReaval := Mes_Int(RPAS.FinRPA.DtAssin.MesAno);
    if ((MACUltReaval + NuPerValAval) = RPAS.MAC) and
        (RPAS.Temp12.TabGenReavaliacao > 0) then begin
      if RPAS.Temp12.MACReavaliacao <= 0 then
        MACUltReaval := Mes_Int(RPACons.FinRPA.DtAssin.MesAno);
      RPAS.Temp12.MACReavaliacao := RPAS.MAC;
      Int_Mes(MACUltReaval,DtIni.MesAno);
      DtIni.Dia := 1;
      Int_Mes(RPAS.MAC,DtFim.MesAno);
      DtFim.Dia := 1;
      ValReavaliacaoAnt := RPAS.Temp12.ValReavaliacao;
      RPAS.Temp12.ValReavaliacao := RPAS.Temp12.ValReavaliacao
                                  + CorrecaoTabGenerica(DtIni,DtFim,RPAS.Temp12.ValReavaliacao,
                                                        RPAS.Temp12.TabGenReavaliacao,true,0);
      if ValReavaliacaoAnt > 0 then
        Indice := RPAS.Temp12.ValReavaliacao/ValReavaliacaoAnt
      else
        Indice := 0;

      LeglinkItem := Leglink.add(RPAS.Temp8.CodSerie,'Rec lculo do valor de reavalia  o');
      if assigned(LegLinkItem) then begin
        leglinkitem.valores[' ltima Reavalia  o'] := Mac_str(MACUltReaval);
        if scciconf.PeriodicidadeDeReavaliacaoDaGarantia > 0 then
          leglinkitem.valores['Periodicidade(Configura  o)'] := intstr(NuPerValAval);
        if trim(RegApoliceDFI.CodApolice) > '' then
          leglinkitem.valores['Periodicidade(Ap lice '+RegApoliceDFI.CodApolice+')'] := intstr(NuPerValAval);
        leglinkitem.valores['Valor anterior'] := strgrana(ValReavaliacaoAnt);
        leglinkitem.valores['Data Inicial'] := data_str2(DtIni);
        leglinkitem.valores['Data Final'] := data_str2(DtFim);
        leglinkitem.valores['UF'] := Contrato.Imovel.RegImv.UF;
        leglinkitem.valores['Indexador'] := intstr(RPAS.Temp12.TabGenReavaliacao);
        leglinkitem.valores[' ndice'] := formatfloat('0.000000000000',Indice);
        leglinkitem.valores['Novo Valor'] := strgrana(RPAS.Temp12.ValReavaliacao);
      end;                                                              
    end;
  end;
end;

