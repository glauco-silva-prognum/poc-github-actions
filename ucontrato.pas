function TSerie.SaldoPgParcialAntec(DataRef : Tdata; PegaDoProprioMes : boolean = false) : real;
var
  i : integer;
  DtUtilizacao : TData; // Vencto da parcela ou do pgto com red/de saldo dev, o que ocorrer antes
  MAC : integer;
  ValoresAnt,
  ValoresRef : TValoresPorMac;
  IndInvalido : boolean;
  DtIndInvalido : Tdata;
  IndC : real;
  DtVenc : TData;
  DtVencComCarencia : Tdata;
  JurosContr : real;
  DtVencAnt : TData;
begin
  IndInvalido := false;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  Result := 0;
  ValoresRef := ObtemValoresPorMac(Mes_int(DataRef.Mesano));
  if assigned(ValoresRef) then begin
    DtVenc.MesAno := DataRef.MesAno;
    if ValoresRef.DiaVencOrig in [1..31] then
      DtVenc.Dia := ValoresRef.DiaVencOrig
    else
      DtVenc.dia := ValoresRef.diaVenc;
    if juliano(DtVenc) < juliano(Fin.DataRef) then
      DtVenc := Fin.DataRef;
    if (DataRef.dia < DtVenc.dia) then begin
      MAC := mes_int(DataRef.MesAno)-1;
      decMA(DtVenc.MesAno);
      ValoresAnt := ObtemValoresPorMac(MAC);
      if assigned(ValoresAnt) then begin
        DtVenc.Dia := ValoresAnt.DiaVenc;
        if juliano(DtVenc) < juliano(Fin.DataRef) then
          DtVenc := Fin.DataRef;
        for i := 0 to PagamentosParciais.Count -1 do begin
          if juliano(PagamentosParciais[i].DtPg) <= juliano(DataRef) then begin
            if PagamentosParciais[i].TipoPgTotalParcela in PgtoComRedSdDev then
              DtUtilizacao := PagamentosParciais[i].DtPgTotalParcela
            else begin
              DtUtilizacao.Dia := PagamentosParciais[i].DiaVenc;
              Int_Mes(PagamentosParciais[i].MAC,DtUtilizacao.MesAno);
            end;
            if (MAC < Mes_Int(DtUtilizacao.MesAno)) or
              ((MAC = Mes_Int(DtUtilizacao.MesAno)) and PegaDoProprioMes) then begin
              Result := Result + PresentValue(ValoresAnt.IndJuros,PagamentosParciais[i].MAC-MAC,0,-PagamentosParciais[i].AmaisJ,ptEndOfPeriod);
            end;
          end;
        end;
        if (result > zero) then begin
          if Fin.PerReaj = 0 then
            IndC := 1
          else begin
            // Calcular respeitando a evolu  o, pois pode ter havida altera  o de vencimento - sol. 50136
            if Fin.CorrProrata then begin
              try
                IndC := ValoresAnt.IndSaldoAcum;
                int_mes(ValoresAnt.Mac,DtVencAnt.MesAno);
                DtVencAnt.dia := ValoresAnt.diaVenc;
                if juliano(DtVencAnt) < juliano(Fin.DataRef) then
                  DtVencAnt := Fin.DataRef;
                IndC := IndC *
                        detinddataadata(ValoresRef.CodTabelaGenerica,Fin.DefReaj,DtVencAnt,DataRef,1.0,
                                        Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                                        Fin.CorrProRataIniPelaVarDataRef,fin.CmProRataMesAnt,false{UtlPst});
              except
                IndC := 1;
              end;
            end
            else
              IndC := ValoresRef.IndSaldoAcum;
          end;

          result := arredonda(result * IndC);
          
          if Fin.JurProRata then begin
            if (fin.DtCarenciaDeJuros.dia > 0) and (Juliano(Dtvenc) < Juliano(fin.DtCarenciaDeJuros)) then
              DtVencComCarencia := fin.DtCarenciaDeJuros
            else
              DtVencComCarencia := DtVenc;
            if Juliano(DataRef) > Juliano(DtVencComCarencia) then
              JurosContr := CalcJurosProRata(result,
                                             ValoresRef.IndJuros,
                                             DtVencComCarencia,
                                             DataRef,
                                             Fin.JurosSimples,
                                             (Fin.TpJuros = 6){ProRataJurosDiasCorridos})
            else
              JurosContr := 0;
            result := result + JurosContr;
          end;

        end;
      end;
    end
    else 
      result := ValoresRef.SaldoPgParcialAntec
  end;
end;

function Tserie.SaldoPgDesdeUltimoVenc(DataRef : TData; PgtosEmMARef : boolean = false) : real;
var
  ValoresRef,
  ValoresMes : TValoresPorMac;
  UltMac : smallint;
  DtUltVenc : TData;
  i : integer;
  Pago,
  Corr,
  Mora,
  Juroscontr : real;
  DtVencComCarencia : Tdata;
begin
  Mora := 0;
  Juroscontr := 0;
  // totaliza valores pagos ap s o  ltimo vencimento com redu  o de saldo devedor
  // at  a dataref, que n o foram considerados no saldo ainda
  // e os corrige at  dataref
  Result := 0;
  ValoresRef := ObtemValoresPorMac(Mes_int(DataRef.Mesano));
  if assigned(ValoresRef) then begin
    if PgtosEmMARef then begin  //s  interessam pgtos antec's ocorridos em MARef.
      DtUltVenc.MesAno := DataRef.MesAno;
      DecMA(DtUltVenc.MesAno); 
      DtUltVenc.Dia := Dias_Mes(Mes_Int(DtUltVenc.MesAno));
      ValoresMes    := ObtemValoresPormac(Mes_Int(DataRef.MesAno));
    end
    else begin
      if ValoresRef.persaldev = 1 then
        UltMac := Mes_int(DataRef.MesAno)-1
      else
        UltMac := ValoresRef.mac - ((ValoresRef.MAC-Mes_Int(ValoresRef.DtAssin.MesAno)) mod ValoresRef.persaldev);
      int_mes(UltMac,DtUltVenc.mesano);
      ValoresMes := ObtemValoresPormac(UltMac);
    end;
    if assigned(ValoresMes) then begin
      if not PgtosEmMARef then DtUltVenc.dia := ValoresMes.diaVenc;
      for i := 0 to Parcelas.Count-1 do
        if (Parcelas[i].DtPg.Dia > 0) and (Parcelas[i].DtPg.Dia <= 31) and
           (Juliano(Parcelas[i].DtPg) > Juliano(DtultVenc)) and
           (Juliano(Parcelas[i].DtPg) <= Juliano(DataRef)) and
           (Parcelas[i].TipoPg in PgtoComRedSdDev) then begin

          Pago := Parcelas[i].ValorPago + Parcelas[i].DescConcedido;//scat081735 desfazendo scat46249 + Parcelas[i].DescontoPagamento;
          if Fin.PerReaj = 0 then Corr := 0
          else Corr  := CorrecaoJMJCChaves(Contrato.MutDsk,Pago,Parcelas[i].DtPg,DataRef,ValoresRef.IndJuros,
                                           0,Mora,JurosContr,ValoresRef.CodTabGPreChvCorr,
                                           ValoresRef.CodTabGCorr,false,
                                           Contrato.RegCarteira.NaoCobraJurosContr,
                                           ValoresRef.DefReajPreChvCorr,
                                           ValoresRef.DefReajCorr{Fin.DefReaj});
          AjustaMoeda2 (mes_int(Parcelas[i].DtPg.mesano), mes_int(DataRef.mesano), Pago);
          Pago := Pago + Corr;
          JurosContr := 0;
          if Fin.JurProRata then begin
            if (fin.DtCarenciaDeJuros.dia > 0) and (Juliano(Parcelas[i].DtPg) < Juliano(fin.DtCarenciaDeJuros)) then
              DtVencComCarencia := fin.DtCarenciaDeJuros
            else
              DtVencComCarencia := Parcelas[i].DtPg;
            if Juliano(DataRef) > Juliano(DtVencComCarencia) then
              JurosContr := CalcJurosProRata(Pago,
                                             ValoresRef.IndJuros,
                                             DtVencComCarencia,
                                             DataRef,
                                             Fin.JurosSimples,
                                             (Fin.TpJuros = 6){ProRataJurosDiasCorridos});
          end
          else
            JurosContr := 0;
            
          Pago := Pago + JurosContr;
          
          result := result + Pago;
        end;
    end;
  end;
end;

procedure TSerie.ZeraCodErro(Inicio : integer = 0);
var
  i : integer;
begin
  if Inicio = 0 then
    Inicio := mes_int(Fin.DataRef.MesAno);
  for i := Inicio to FValoresPorMacList.count-1 do
    if assigned(FValoresPorMacList[i]) then
      TValoresPorMac(FValoresPorMacList[i]).coderro := 0;
end;

function TSerie.ObtemTxPst(DataRef,DtVenc : Tdata) : real;
var
  MacPrstRef : integer;
  Dt1 : tdata;
  defas : integer;
  Reg : TValoresPorMac;
begin
  MacPrstRef := mes_int(DataRef.MesAno);
  if DataRef.Dia < DtVenc.Dia then
    dec(MacPrstRef);

  Reg := ObtemValoresPorMac(MacPrstRef);

  int_mes(MacPrstRef,Dt1.MesAno);
  Dt1.Dia := DtVenc.Dia;

  // Indice com c lculo do prorata
  defas := Fin.defreaj;
  if not ((Juliano(Reg.DtEntregaChaves)>0) and
     (Juliano(Reg.DtEntregaChaves)>Juliano(Fin.DataRef)) and  // SCAt 21613
     (Juliano(dtvenc)>Juliano(Reg.DtEntregaChaves))) then
    if Fin.codreajprechaves > 0 then defas := Fin.defreajprechv;
  result := Reg.IndSaldoAcum *
            detIndProRata(Reg.CodTabelaGenerica,Defas,Dt1,DataRef,1.0);
end;

function TSerie.CalculaValAntecipacao(Mac : integer; DataRef : TData) : real;
var
  Reg : TValoresPorMac;
  enc : real;
  ValorAtu,
  ValorPagoAntecipadoAtu : real;
  ParcOrig : TParcelaSerie;
  DtVenc : TData;
  DtComCarencia,
  DtCarenciaLocal : TData;
  IndJuros : real;
  TxPst : real;
  CmTabErrTemp : integer;
  CmTabErrDataTemp : TData;
begin
  result := 0;
  CmTabErrTemp := CmTabErr;
  CmTabErrDataTemp := CmTabErrData;
  try
    Reg := ObtemValoresPorMac(Mac);
    if assigned(Reg) and
       assigned(Reg.ParcelaDoMes) and
       not Fin.RecalculaPrestacao and
       (Fin.SistAmort <> 6{Sacre}) and
       (fin.perreaj <> 12) and
       not Reg.ParcelaDoMes.EstaPagaReal and
       Reg.CtrAtivo then begin

      Int_Mes(Reg.ParcelaDoMes.Mac,DtVenc.MesAno);
      DtVenc.dia := Reg.ParcelaDoMes.diavenc;

      // S  considera parcela se n o estiver vencida
      if (Juliano(DtVenc) > Juliano(DataRef)) and
         (juliano(Fin.DataRef) <= juliano(DataRef)) then begin
    
        TxPst := ObtemTxPst(Dataref,DtVenc);

        ParcOrig := Reg.ParcelaDoMes as TParcelaSerie;

        ValorAtu := ParcOrig.Valor;
        ValorPagoAntecipadoAtu := ParcOrig.ValorPagoAntecipado;

        enc := ValorAtu * TxPst * (1-Reg.IndRedPrest) - (ValorPagoAntecipadoAtu * TxPst);
        AjustaMoeda2(mes_int(Fin.DataRef.MesAno),Mes_int(DataRef.MesAno),enc);
        if enc < zero then
          enc := 0;
        enc := Arredonda(enc);

        IndJuros := Reg.IndJuros;

        DtComCarencia := DataRef;
        if Fin.DtCarenciaDeJuros.dia > 0 then begin
          DtCarenciaLocal := Fin.DtCarenciaDeJuros;
          if not Fin.JurProRata then DtCarenciaLocal.Dia := DtVenc.Dia;
          if Juliano(DtCarenciaLocal) > Juliano(dataref) then
            DtComCarencia := DtCarenciaLocal;
        end;

        if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then { Scat 41461 }
          result := CalculaValorAtualEncargoJurosSimplesSCP(Enc,DtVenc,DtComCarencia,Reg.RaRd)
        else
          result := CalculaEncargoAtualizado(Enc,DtVenc,
                                             DtComCarencia,IndJuros,
                                             Fin.JurProRata or
                                             ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                             Fin.IncluiFracaoDoMes,
                                             Fin.JurosSimples,
                                             (Fin.TpJuros = 6),
                                             DiaVencOrig,
                                             (Fin.TpJuros = 7));
      end;
    end;
  finally
    CmTabErr := CmTabErrTemp;
    CmTabErrData := CmTabErrDataTemp;
  end;
end;

