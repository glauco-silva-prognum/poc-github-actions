end;

procedure TContrato.CalculaSeguroPorSerie;
var
  i : integer;
begin
  for i := 0 to Series.count-1 do
    if Series[i].CalculaSeguroNoMes then
      Series[i].CalculaSeguro(SaldoParaCalculoDeSeguroDeApolice,RPA,
                              FSerieParaMIPPorValAVal=Series[i].Fin.CodSerie)
    else with Series[i].RPAS do begin
      ValRPA.Seguro := 0;
      ValRPA.SegFin := 0;
      ValRPA.SegCre := 0;
      ValRPA.SegImv := 0;
      Temp7.DescSeg := 0;
      if Series[i].CalculaSeguroDFINoMes then
        Series[i].CalculaSeguroDFI(RPA);
      if Temp11.GrupoApolice > 0 then begin
        Temp10.CodApolice := '';
        Temp11.CodApoliceDFI := '';
        Temp11.IdadeIniGrupoApolice := 0;
      end;
      AtualizaTotPrest(Series[i].RpaS);
    end;

  // caso alguma s rie tenha precisado de ap lice de grupo e n o tenha achado, seta o consolidado
  i := 0;
  while (i < Series.count) and (RPA.Temp11.SemApoliceVigenteNoGrupo) do begin
    RPA.Temp11.SemApoliceVigenteNoGrupo := Series[i].RPAS.Temp11.SemApoliceVigenteNoGrupo;
    inc(i);
  end;

end;

function TContrato.DeterminaSerieMaiorPrazoSeguro : integer;
var
  i : integer;
begin
  if not Ctr_Ativo(RPAF) and (Series.count = 1) then
    result := 0 // se for s rie  nica, usar os dados dela. Sol.53125
  else 
    result := -2;
  for i := 0 to Series.Count -1 do begin
    if (Series[i].RPAS.Temp11.UltApoliceVencida > '') then
      RPA.Temp11.UltApoliceVencida := Series[i].RPAS.Temp11.UltApoliceVencida;
    with Series[i] do begin
      if ConsolidaSeguroSerie(Fin,RPA.MAC) then begin
        RPA.ValRPA.SegFin   := RPA.ValRPA.SegFin + RPAS.ValRPA.SegFin;
        RPA.ValRPA.SegImv   := RPA.ValRPA.SegImv + RPAS.ValRPA.SegImv;
        RPA.ValRPA.Seguro   := RPA.ValRPA.Seguro + RPAS.ValRPA.Seguro;
        RPA.Temp7.DescSeg   := RPA.Temp7.DescSeg + RPAS.Temp7.DescSeg;
        RPA.ValRPA.Desc     := RPA.ValRPA.Desc   + RPAS.Temp7.DescSeg;
      end;
      if {(Series[i].RPAS.Temp11.GrupoApolice = 0) and}
         not ctr_Ativo(RPAF) and  // 106007 s  deveria considerar alguma s rie, se o financ. din mico n o estiver ativo.
         Series[i].CalculaSeguroNoMes and
         ((result = -2) or
          ((Series[i].RPAS.ValRPA.Amaisj > zero) and
           ((Series[i].RPAS.FinRPA.Prazo >
             Series[result].RPAS.FinRPA.Prazo) or
            ((Series[i].RPAS.FinRPA.Prazo > 0) and
             (abs(Series[result].RPAS.ValRPA.AmaisJ) < zero) ))))  then begin
        result := i;
      end;  
    end;
  end;
  if Ctr_Ativo(RPAF) then
    if {(RPAF.Temp11.GrupoApolice = 0) and}
       ((result = -2) or
        ((RPAF.ValRPA.Amaisj > zero) and
         ((RPAF.FinRPA.Prazo > Series[result].RPAS.FinRPA.Prazo) or
          ((RPAF.FinRPA.Prazo > 0) and
           (abs(Series[result].RPAS.ValRPA.AmaisJ) < zero))))) then
      result := -1;
end;

procedure TContrato.DeterminaMaiorTermino(Var DtTermino : Tdata; ConsideraTerminosAntecipados : boolean = false);
var
  DtTerminoAux : Tdata;
  i : integer;
begin
  DtTermino.dia := 0;
  fillchar(DtTermino,sizeof(Tdata),0);
  DtTerminoAux := DtTermino;

  if TemFinancDinamico(Mutdsk) then
    DeterminaTermino(RPAF,DtTermino,ConsideraTerminosAntecipados);
  
  for i := 0 to Series.count-1 do begin
    DeterminaTermino(Series[i].RPAs,DtTerminoAux,ConsideraTerminosAntecipados);
    if juliano(DtTerminoAux)>juliano(DtTermino) then
      DtTermino := DtTerminoAux;
  end;  
end;

procedure TContrato.CalculaSeguroConsolidado(SerieMaiorPrazoSeguro : integer);
var
  DtMac : TData;
  QtdSeries : integer;
  RegApolice : TpApolice;
  indapolice : real;
  SegFinApolice : real;
  i : integer;
  indSegFinAnt : real;
  SaldoCalcSeg : real;
  PrazoEmMesesAssinatura : integer;
  PercIof : real;
  Iof : real;
  DtTermino : TData;
  leglinkItem : TLegLinkItem;
begin
  leglinkItem := nil;
  PercIof := 0;
  Iof := 0;
  SegFinApolice := 0;
  SaldoCalcSeg := 0;
  RegApolice.CampoVbaseMip := 0;
  fillchar(RegApolice,sizeof(RegApolice),0);
  int_mes(RPA.MAC, DtMAC.MesAno);
  DtMAC.Dia := RPA.FinRPA.DiaVenc;

  QtdSeries := Series.count;
  if TemFinancDinamico(Mutdsk) then
    inc(QtdSeries);
  if ((RPA.Temp12.GrupoApoliceMista > 0) or
      ((StripStr(RPA.Temp10.CodApolice) > '') and (SerieMaiorPrazoSeguro > -2) and
       ((RPA.MAC>Mes_int(RPA.FinRPA.DtAssin.MesAno)) or (RPA.FinRPA.NPC>0)) and
       (Juliano(DtMAC) >= Juliano(RPA.Temp10.DtAssinPropSeguro)) and
       (RPA.MAC >= RPA.Temp11.MacIniSeguro))) and
     (QtdSeries > 1) and
     (RPA.Temp5.MACSuspSeg = 0) and
     not RPA.Temp12.MantemValorMIP then begin
    
    if not FInibeLegLink then begin
      leglinkItem := LegLink.Add(0,'<br><b>C lculo do Seguro Consolidado</b><br>');
      if assigned(leglinkItem) then
        leglinkItem.Consolidado := true;
    end;  

    indSegFinAnt := RPA.FinRPA.IndSegFin;

    // Mesmo crit rio da consolidarpa para determinar o prazoemmeses do rpaconsolidado
    // mas respeitando valores da assinatura(ignorar terminos e usar o prazo original)
    PrazoEmMesesAssinatura := CalculaPrazoEmMeses(Self,false{TerminosAntec},true{ConsiderarPrazoOrig});

    CalculaValBaseLimiteSegMip(RPA,RPA.FinRPA.DtAssin{DtAssinContrato},PrazoEmMesesAssinatura);
    
    if RPA.Temp12.GrupoApoliceMista > 0 then begin
      { Ap lice mista n o considera as faixas de idade para obter o indsegfin, n o importando assim
        as configura  es de mudan a de faixa }
      if Assigned(ApolicesMistas) then
        indapolice := ApolicesMistas.RetornaIndSegFin(RPA.mac)
      else
        indapolice := 0;
      SaldoCalcSeg := SaldoParaCalculoDeSeguroDeApolice;
      SegFinApolice := SaldoCalcSeg * IndApolice;
      // TODO: como respeitar o ValBaseLimiteSegMip no caso de ap lice mista?
    end
    else begin

      LeApolice(RPA.Temp10.CodApolice,RegApolice);

      IndApolice := 0;

      if RegApolice.ALIQUODOTACONTRATO then
        IndApolice := Mutdsk.Financ.IndSegFin;

      Rpa.Temp5.AliquotaDoContrato := RegApolice.ALIQUODOTACONTRATO and (Abs(IndApolice) > zero) and not RPA.ForcouIndSegFin{111863};

      if assigned(LegLinkItem) then begin
        LegLinkItem.valores['Ap lice'] := RegApolice.CodApolice;
        if Rpa.Temp5.AliquotaDoContrato then begin
          LegLinkItem.valores['Respeita Al quota do Contrato'] := 'Sim';
          LegLinkItem.valores['Al quota MIP do contrato'] := formatfloat('0.00000000',IndApolice);
        end;  
      end;

      if not Rpa.Temp5.AliquotaDoContrato then begin
        DtTermino.dia := 0;
        fillchar(DtTermino,sizeof(Tdata),0);
        DeterminaMaiorTermino(DtTermino);
        indapolice := RetornaIndSegFinApolice(Rpa,DtTermino,SaldoParaCalculoDeSeguroDeApolice(LegLinkItem),false,FDetalhesSeguro,PrazoEmMesesAssinatura,LegLinkItem);
        if abs(IndApolice) <= Zero then begin
          IndApolice := RPA.FinRPA.IndSegFin;
          if assigned(LegLinkItem) then
            LegLinkItem.valores['N o consegui obter Al quota MIP da ap lice, usando do contrato'] := formatfloat('0.00000000',IndApolice);
        end  
        else if assigned(LegLinkItem) then
          LegLinkItem.valores['Al quota MIP da ap lice'] := formatfloat('0.00000000',IndApolice);
      end;
      
      if CobraIOFApolice(RegApolice,RPA) then
        PercIof := RegApolice.PercIOFMip;

      if RegApolice.SeguroAVista then begin
        SegFinApolice := 0;
        for i := 0 to FDetalhesSeguro.count-1 do
          FDetalhesSeguro[i].segfin := 0;
      end
      else if IndApolice > zero then begin
        SegFinApolice := int(CalculaSegFinApolice(SaldoParaCalculoDeSeguroDeApolice(LegLinkItem),IndApolice,RPA,RegApolice,SaldoCalcSeg,LegLinkItem)*100+0.5)/100;
      end;
      TrataPercIof(RPA.Temp6.EdoSFH,ObtemTipoAliquotaIof(Rpa,1{MIP}),
                   PercIof,SegFinApolice,Iof);
    end;

    if (abs(IndSegFinAnt+1) < 0) and (FCodApoliceMesAnt=RPA.Temp10.CodApolice) then begin
      IndApolice := IndSegFinAnt;
      SegFinApolice := 0;
      Iof := 0;
    end;

    // zerar o segfin em todas as s ries
    RPAF.ValRPA.Seguro := RPAF.ValRPA.Seguro - RPAF.ValRPA.SegFin;
    RPAF.ValRPA.SegFin := 0;
    RPAF.Temp11.SaldoCalcSeg := 0;
    RPAF.Temp12.ValbaseLimiteSegMip := 0;
    AtualizaTotPrest(RPAF);
    AtualizaDescSeg(RPAF);

    for i := 0 to Series.count-1 do begin
      Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro -
                                      Series[i].RPAS.ValRPA.SegFin;
      Series[i].RPAS.ValRPA.SegFin := 0;
      Series[i].RPAS.Temp11.SaldoCalcSeg := 0;
      Series[i].RPAS.Temp12.ValbaseLimiteSegMip := 0;
      AtualizaTotPrest(Series[i].RPAS);
      AtualizaDescSeg(Series[i].RPAS);
    end;
    
    // jogar o valor total apenas na s rie escolhida. Sol.
    if SerieMaiorPrazoSeguro = -1 then begin
      RPAF.ValRPA.SegFin := SegFinApolice;
      RPAF.ValRPA.Seguro := RPAF.ValRPA.SegFin + RPAF.ValRPA.SegImv + RPAF.ValRPA.SegCre;
      RPAF.FinRPA.IndSegFin := IndApolice;
      RPAF.Temp11.SaldoCalcSeg := SaldoCalcSeg;
      RPAF.Temp12.ValBaseLimiteSegMip := RPA.Temp12.ValBaseLimiteSegMip;
      RPAF.Temp12.IOFMip := Iof;
      RPAF.Temp12.PercIOFMip := PercIof;
      
      AtualizaTotPrest(RPAF);
      AtualizaDescSeg(RPAF);

      if assigned(LegLinkItem) then
        LegLinkItem.valores['S rie de maior prazo, para cobran a do seguro'] := 'Finac. Din mico';
    end
    else if SerieMaiorPrazoSeguro >= 0 then begin
      Series[SerieMaiorPrazoSeguro].RPAS.ValRPA.SegFin := SegFinApolice;
      Series[SerieMaiorPrazoSeguro].RPAS.ValRPA.Seguro := Series[SerieMaiorPrazoSeguro].RPAS.ValRPA.SegFin +
                                                          Series[SerieMaiorPrazoSeguro].RPAS.ValRPA.SegImv +
                                                          Series[SerieMaiorPrazoSeguro].RPAS.ValRPA.SegCre;
      Series[SerieMaiorPrazoSeguro].RPAS.FinRPA.IndSegFin := IndApolice;
      Series[SerieMaiorPrazoSeguro].RPAS.Temp11.SaldoCalcSeg := SaldoCalcSeg;
      Series[SerieMaiorPrazoSeguro].RPAS.Temp12.ValBaseLimiteSegMip := RPA.Temp12.ValBaseLimiteSegMip;
      Series[SerieMaiorPrazoSeguro].RPAS.Temp12.IOFMip := Iof;
      Series[SerieMaiorPrazoSeguro].RPAS.Temp12.PercIOFMip := PercIof;

      AtualizaTotPrest(Series[SerieMaiorPrazoSeguro].RPAS);
      AtualizaDescSeg(Series[SerieMaiorPrazoSeguro].RPAS);

      if assigned(LegLinkItem) then
        LegLinkItem.valores['S rie de maior prazo, para demonstra  o do seguro'] := DescrSerie(Series[SerieMaiorPrazoSeguro].Fin.TipoSerie);

    end;
    
    RPA.ValRPA.SegFin := SegFinApolice;
    RPA.Temp11.SaldoCalcSeg := SaldoCalcSeg;
    RPA.Temp12.IofMip := IOF;
    RPA.Temp12.PercIofMip := PercIof;
  end;
end;

procedure TContrato.ForcaVencimentoPrestSeguro;
var
  i : integer;
begin
  // Forca dia de vencimento de presta  es apenas de seguro (sol. 22413)
  for i := 0 to Series.Count -1 do
//      if (abs(Series[i].RPAS.ValRPA.TotPrest - Series[i].RPAS.ValRPA.Seguro - Series[i].RPAS.ValRPA.Desc) < zero)
    if (abs(Series[i].RPAS.ValRPA.TotPrest - Series[i].RPAS.ValRPA.Seguro) <= zero) and
       (abs(Series[i].RPAS.ValRPA.AmaisJ) <= Zero) and
       (abs(Series[i].RPAS.ValRPA.Seguro) > zero) and
       (Series[i].Fin.ConsolidaDataVenc) then
      Series[i].RPAS.FinRPA.DiaVenc := RPA.FinRPA.DiaVenc;
end;

procedure TContrato.ForcaSeguroArqPrest(HSegFin, HSegImv : real; HFlag : integer);
var
  i : integer;
  Parcela : TParcelaserie;
begin
  RPA.ValRPA.SegFin := 0;
  RPA.ValRPA.SegImv := 0;

  if TemFinancDinamico(Mutdsk) then begin
    if (abs(HSegFin) > 0) or (HFlag=102) then begin
      if (abs(RPAF.ValRPA.seguro-HSegFin-HSegImv) > zero) then
        RPAF.ValRPA.Seguro := RPAF.ValRPA.Seguro -
                              RPAF.ValRPA.SegFin +
                              HSegFin;
    end;

    if (abs(HSegImv) > 0) or (HFlag=102) then begin
      if (abs(RPAF.ValRPA.seguro-HSegFin-HSegImv) > zero) then
        RPAF.ValRPA.Seguro := RPAF.ValRPA.Seguro -
                              RPAF.ValRPA.SegImv +
                              HSegImv;
    end;
    if (abs(HSegImv) > 0) or (abs(HSegFin) > 0) or (HFlag=102) then begin
      RPAF.ValRPA.SegFin := HSegFin;
      RPAF.ValRPA.SegImv := HSegImv;
    end;
    AtualizaTotPrest(RPAF);
    AtualizaDescSeg(RPAF);
  end;

  RPA.ValRPA.SegFin := RPA.ValRPA.SegFin + RPAF.ValRPA.SegFin;
  RPA.ValRPA.SegImv := RPA.ValRPA.SegImv + RPAF.ValRPA.SegImv;

  for i := 0 to Series.count-1 do begin
    Parcela := Series[i].ParcelaDomes;
    if Assigned(parcela) then begin

      if ((abs(parcela.SegFinEmi) > 0) or (parcela.Flag=102)) then begin
        Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro -
                                        Series[i].RPAS.ValRPA.SegFin +
                                        parcela.SegFinEmi;
        Series[i].RPAS.ValRPA.SegFin := parcela.SegFinEmi;
      end;

      if ((abs(parcela.SegImvEmi) > 0) or (parcela.Flag=102)) then begin
        Series[i].RPAS.ValRPA.Seguro := Series[i].RPAS.ValRPA.Seguro -
                                        Series[i].RPAS.ValRPA.SegImv +
                                        parcela.SegImvEmi;
        Series[i].RPAS.ValRPA.SegImv := parcela.SegImvEmi;
      end;

      AtualizaTotPrest(Series[i].RPAS);
      AtualizaDescSeg(Series[i].RPAS);
    end;

    if ConsolidaSeguroSerie(Series[i].Fin,Series[i].RPAS.MAC) then begin
      RPA.ValRPA.SegFin := RPA.ValRPA.SegFin + Series[i].RPAS.ValRPA.SegFin;
      RPA.ValRPA.SegImv := RPA.ValRPA.SegImv + Series[i].RPAS.ValRPA.SegImv;
    end;

  end;

  RPA.ValRPA.Seguro := RPA.ValRPA.SegFin + RPA.ValRPA.SegImv + RPA.ValRPA.SegCre;
  AtualizaTotPrest(RPA);
  AtualizaDescSeg(RPA);

 end;
 
