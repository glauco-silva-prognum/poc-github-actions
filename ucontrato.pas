    RPA.Temp11.DtPrimAtrasoCtb := DtPrimAtrasoBkp;

    if (RPAF.Temp11.GrupoApolice > 0) and MutDsk.Cad2.TemSerie then begin
      RPA.Temp10.CodApolice := '';
      RPA.Temp11.CodApoliceDFI := '';
