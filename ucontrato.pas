procedure MontaDetalhesSituacaoCtr(Var Mutdsk : TpMutDsk;
                                       MutDskC : TpMutDskC;
                                   Var RPA : TpRPA;
                                   Var SitStr : ansistring;
                                       Detalhes : TStrings;
                                       SubDetalhe : TStrings);
var
  i : integer;
  sit : Tstringlist;
  RegHab : TpHabilf;
  TavAberto : boolean;
  RegSpc : TpSpc;
  st : string;
  Sitcompleto : string;
  RegSerasa : TpSerasa;
  indice : integer;
  Situacoes : TSitespCtr;
  Max : integer;
  XmltabSit,
  XmlTabSitCj : TpXml;
  CodClienteSitEsp : integer;
  Stream : TMemoryStream;
  Status : Smallint;
  DtStatus : TData;
begin
  Status := 0;
  DtStatus.dia:=0;DtStatus.mes:=0;DtStatus.ano:=0;
  RegSerasa.Ctr := '';
  fillchar(RegSerasa,sizeof(RegSerasa),0);
  RegHab.Ctr := '';
  fillchar(RegHab,sizeof(RegHab),0);
  RegSpc.Ctr := '';
  fillchar(RegSpc,sizeof(RegSpc),0);
  XmlTabSit := TpXml.create;
  XmlTabSitCj := TpXml.create;
  Sit := Tstringlist.create;
  try
    Stream := TMemoryStream.create;
    try
      if not LeArqsXml(GetSqlConnection(PegaDirTab),'tabsit.xml','xmltabelas',Stream) then 
        XmlTabSit.XMLParseFile(PegaDirArqs + PathDelim+ 'xmltabelas'+PathDeLim+'tabsit.xml')
      else 
        XmlTabSit.XMLParseStream(Stream);
    finally
      Stream.free;
    end;
    
    Stream := TMemoryStream.create;
    try
      if not LeArqsXml(GetSqlConnection(PegaDirTab),'tabsitcj.xml','xmltabelas',Stream) then 
        XmlTabSitCj.XMLParseFile(PegaDirArqs + PathDelim+ 'xmltabelas'+PathDeLim+'tabsitcj.xml')
      else  
        XmlTabSitCj.XMLParseStream(Stream);
    finally
      Stream.free;
    end;
    with MutDsk,RPA do begin
      SitStr := '';
      Detalhes.clear;
      SubDetalhe.clear;
      Detalhes.add('C digo;Abv;Descric o;Data;Detalhe');
      if Cad.DtCausaJ.Dia > 0 then begin
        Sit.add('CJU');
        Detalhes.add('  ;CJU;'+Compstr('Causa Julgada')+';'+Data_str2(Cad.DtCausaJ)+';');
        SubDetalhe.add('');
      end
      else if TemOpcao( RPA, 14 ) then begin
        Sit.add('LIM');
        Detalhes.add('  ;LIM;'+Compstr('Com Liminar')+';  INDEFINIDA'+';');
        SubDetalhe.add('');
      end
      else begin
        Sit.add('NLM');
        Detalhes.add('  ;NLM;'+CompStr('Sem Liminar')+';  INDEFINIDA'+';');
        SubDetalhe.add('');
      end;
      if MutDskC.Cad6.FaseCobranca > 0 then begin
        Sit.add('F'+intstr2(MutdskC.Cad6.faseCobranca,2));
        Detalhes.add('  ;F'+intstr2(MutdskC.Cad6.faseCobranca,2)+';Fase de Cobran a '+intstr2(MutdskC.Cad6.faseCobranca,2)+';'+data_str2(MutDskC.Cad6.DtFaseCobranca)+';');
        SubDetalhe.add('');
      end;
      LeHabilf(MutDsk.Cad.Ctr,RegHab);
      if (RegHab.Ctr = MutDsk.Cad.Ctr) and
         (juliano(RegHab.DataHomologacao) > 0) then begin
        Sit.add('HOM');
        Detalhes.add('  ;HOM;'+Compstr('Homologado no FCVS')+';'+Data_str2(RegHab.DataHomologacao)+';');
        SubDetalhe.add('');
      end;
      if Cad2.Terceirizado then begin
        Sit.add('TER');
        Detalhes.add('  ;TER;'+CompStr('Terceirizado')+';  INDEFINIDA'+';');
        SubDetalhe.add('');
      end;
      TavAberto := AbriuSpc;
      if not TavAberto then AbreSpc;
      LeOcorrAtualCtrSpc(MutDsk.Cad.Ctr,RegSpc);
      if not TavAberto then FechaSpc;
      if RegSpc.Ctr > '' then begin
        if StatusDeIncluidoNoSpc(RegSpc) then begin
          St := 'SPC';
          Detalhes.add('  ;SPC;'+Compstr(StatusSpc2[RegSpc.Status])+';'+ data_str2(RegSpc.DtEnvio)+';');
          SubDetalhe.add('');
        end
        else if RegSPC.Status = 15 then begin
          St := 'CSP';
          Detalhes.add('  ;CSP;'+Compstr(StatusSPC2[RegSpc.Status])+';'+data_str2(RegSpc.DtExclusao)+';');
          SubDetalhe.add('');
        end else begin
          St := 'XSP';
          Detalhes.add('  ;XSP;'+CompStr(StatusSPC2[RegSpc.Status])+';'+data_str2(RegSpc.DtExclusao)+';');
          SubDetalhe.add('');
        end;
        Sit.add(St);
      end;
      TavAberto := AbriuSerasa;
      if not TavAberto then AbreSerasa;
      LeOcorrAtualCtrSerasa(Mutdsk.Cad.Ctr,RegSerasa);
      if not TavAberto then FechaSerasa;
      if RegSerasa.Ctr > '' then begin
        if StatusdeIncluidoNoSerasa(RegSerasa) then begin
          Sit.Add('SER');
          Detalhes.add('  ;SER;'+Compstr(StatusSerasa[RegSerasa.Status])+';'+data_str2(RegSerasa.DataStatus)+';');
          SubDetalhe.add('');
        end else begin
          Sit.add('XSE');
          Detalhes.add('  ;XSE;'+Compstr(StatusSerasa[RegSerasa.Status])+';'+data_str2(RegSerasa.DataStatus)+';');
          SubDetalhe.add('');
        end;
      end;
      LeStatusCadin(MutDsk.Cad.Ctr,Status,DtStatus);
      if Status = 2 then begin
        Sit.Add('CIN');
        Detalhes.add('  ;CIN;'+Compstr(StatusCadin[Status])+';'+data_str2(DtStatus)+';');
        SubDetalhe.add('');
      end
      else if Status >= 3 then begin
        Sit.Add('XIN');
        Detalhes.add('  ;XIN;'+Compstr(StatusCadin[4])+';'+data_str2(DtStatus)+';');
        SubDetalhe.add('');
      end;
      if Temp4.CodSusp > 0 then
        if (not (Cad.SitCobJ in [6,7,8])) and (not (Cad.SitCobJ2 in [6,7,8])) and
           (not SitEspSuspPrst(MutDsk,datah,datah)) then begin
          indice := Sit.add(OcorrStr[Temp4.CodSusp]);
          Detalhes.add('  ;'+Sit[indice]+';'+Compstr('Suspenso por '+Sit[indice])+';'+data_str2(MutDsk.Cad.DtSitCobJ)+';');
          SubDetalhe.add('');
        end;
      if (Cad.SitCobJ > 0) then begin
        indice := Sit.add(AbvSitCj(Cad.SitCobj));
        sitcompleto := DescSitCj(Cad.SitCobj);
        Detalhes.add('  ;'+Sit[indice]+';'+Compstr(sitcompleto)+';'+data_str2(MutDsk.Cad.DtSitCobJ)+';link');
        SubDetalhe.add(EnviaTagsSitCj(Cad.SitCobJ,XmlTabSitCj));
      end;
      if (Cad.SitCobJ2 > 0) then begin
        indice := Sit.add(AbvSitCj(Cad.SitCobj2));
        sitcompleto := DescSitCj(Cad.SitCobj2);
        Detalhes.add('  ;'+Sit[indice]+';'+CompStr(sitcompleto)+';'+data_str2(MutDsk.Cad.DtSitCobJ2)+';link');
        SubDetalhe.add(EnviaTagsSitCj(Cad.SitCobJ2,XmlTabSitCj));
      end;

      Situacoes := TSitEspCtr.create;
      try
        Situacoes.LeSituacoes(Mutdsk.Cad.Ctr);
        for i := 0 to Situacoes.count-1 do
          if (Situacoes[i].SitEsp > 0) and sitlib.DataOk(Situacoes[i].DtExpSitEsp,DataH) then begin
            CodClienteSitEsp := CodClienteSit(Situacoes[i].SitEsp);           
            if (CodClienteSitesp = 0) then  CodClienteSitEsp := Situacoes[i].SitEsp;
            indice := sit.add(AbvSit(Situacoes[i].SitEsp));
            SitCompleto := DescSit(Situacoes[i].SitEsp);
            Detalhes.add(intStr(CodClienteSitEsp)+';'+Sit[indice]+';'+Compstr(SitCompleto)+';'+data_str2(Situacoes[i].DtSitEsp)+';link');
            SubDetalhe.add(EnviaTagsSitEsp(Situacoes[i].Sitesp,XmlTabSit));
          end;
      finally
        Situacoes.free;
      end;

      if Sit.Count > 7 then
        max := 6
      else
        max := Sit.count;
      for i := 0 to Max-1 do
        SitStr := SitStr + space(3-length(sit[i]))+sit[i]+'-';
      SitStr := trim(SitStr);
      if Sit.Count > 7 then
        SitStr := SitStr + '...';
      if SitStr[length(SitStr)] = '-' then
        delete(SitStr,length(SitStr),1);
  end;
  finally
    XmlTabSit.free;
    XmlTabSitCj.free;
    Sit.free;
  end;
end;

function TemTermAnteriorARef(DataRef : Tdata; MacStatus,Status,DiaLiq,DiaVenc : integer): boolean;
var
//  i : SmallInt;
  DtEvento : TData;
begin
  result := false;
  if Status in [2..5,7,9,10,94] then begin
    int_mes(MacStatus,DtEvento.mesano);
    DtEvento.dia := dialiq;
    if DtEvento.dia = 0 then
      DtEvento.dia := diavenc;
    result := Juliano(DtEvento) <= Juliano(DataRef);
  end;
{ sol. 44793
  i := 1;
  while (i <= Contrato.HistMem[0].Tam) and not result do begin
    if (Contrato.HistMem[i].Log.CodMov in [2..5,7,9,10,96]) then
      if Juliano(Contrato.HistMem[i].Log.Data) < Juliano(DataRef) then
        result := true;
    inc(i);
  end;
}
end;

