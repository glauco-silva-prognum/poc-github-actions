procedure TSerie.CalculaSaldosPagNormalAntecipado(Var RPA : TpRPA; PagamentosNormaisNoMes : TObjectList);
var
  Parcela : TParcelaSerie;
  i : integer;
begin
  for i := 0 to PagamentosNormaisNoMes.count-1 do begin
    Parcela := PagamentosNormaisNoMes[i] as TParcelaSerie;
    if Parcela.mac > rpa.mac then begin
      RPA.Temp12.BaixaPgAntecAmaisJ := RPA.Temp12.BaixaPgAntecAmaisJ + RPA.ValRPA.Amaisj;
      RPA.Temp12.BaixaPgAntecAdqAmaisJ := RPA.Sec3.AmaisjAdquirido;
      RPA.Temp12.BaixaPgAntecColAmaisJ := RPA.Sec.AmaisjColateral;
    end;
  end;
end;

procedure TSerie.AdicionaEventoPagAntecipado(Parcela : TParcelaSerie);
var
  Ind : integer;
  DataDePgto : TData;
begin
  Ind := FListaEventosAmInc.Add;
  FListaEventosAmInc[Ind].TipoEvento := tipoevento_PagAntecipado;
  with Parcela do begin
    if (DataRefCalc.Dia > 0) and (DtPg.Dia > 0) and
        (juliano(DataRefCalc) > juliano(DtPg)) and
        (DataRefCalc.Mes = DtPg.Mes) and (DataRefCalc.Ano = DtPg.Ano) then
      DataDePgto := DataRefCalc
    else
      DataDePgto := DtPg;
  end;    
  FListaEventosAmInc[Ind].DiaEvento  := DataDePgto.Dia;
  FListaEventosAmInc[Ind].MACEvento  := Mes_Int(DataDePgto.MesAno);
  FListaEventosAmInc[Ind].ParcelaObj := Parcela;
  FListaEventosAmInc[Ind].MacParcela := Parcela.Mac;
end;

procedure TSerie.GeraEventosPorAntecipacao(ParcelasAntecipadas : TObjectList);
var
  i : integer;
begin
  for i := 0 to ParcelasAntecipadas.Count-1 do
    AdicionaEventoPagAntecipado(ParcelasAntecipadas[i] as TParcelaSerie);  
end;

procedure TSerie.CalculaAntecipacoes;
var PgtosporDia : TValoresporDia;
    i : integer;
begin
  Rpas.Temp12.PagAntecAntesVenc := 0;  Rpas.Temp12.PagAntecNoVenc := 0;  Rpas.Temp12.PagAntecPosVenc := 0;
  FValorAntecAntesVencPrincipal := 0; FValorAntecNoVencPrincipal := 0; FValorAntecPosVencPrincipal := 0;
  FValorAntecDaUltima  := 0; FUltDiaPgAntec    := 0;
  FPagamentoAntecipadoNoMes := 0;
  PgtosporDia := Parcelas.ObtemPagamentosAntecipadosporMAC( RPAS.MAC, FParcelasAntecipadasNoMes, FPagamentosNormaisNoMes );
  CalculaSaldosPagNormalAntecipado(RPAS,FPagamentosNormaisNoMes);
  if PgtosporDia[0] > Zero then begin
    GeraEventosPorAntecipacao(FParcelasAntecipadasNoMes);
    for i := 1 to 31 do
      FPagamentoAntecipadoNoMes := FPagamentoAntecipadoNoMes + PgtosPorDia[i];
    with RPAS do
      FinRPA.Prazo := FinRPA.Prazo -
          Parcelas.ObtemPrazoaReduzir(MAC,FinRpa.Prazo,mes_int(FinRpa.DtInFin.MesAno)+1,Fin.PerParcelas);
  end;
end;

