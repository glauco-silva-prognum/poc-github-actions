procedure TContrato.TrataContratosContratosCorrelacionados;
var
  DtVenc : TData;
  i : integer;
  idx : integer;
begin
  // s  tratar no consolidado, se n o tiver financ. din mico
  if not TemFinancDinamico(Mutdsk) then
    if assigned(FContratosCorrelacionados) then begin
      int_mes(RPA.Mac,DtVenc.MesAno);
      DtVenc.Dia := RPA.FinRPA.DiaVenc;

      idx := FContratosCorrelacionados.ObtemUltimoContratoPorDtVenc(DtVenc);
      if idx < FContratosCorrelacionados.count then
        AtribuiPercPartSeguro(RPAF,FContratosCorrelacionados[idx]);
    end;

  // considerar que a composi  o do Financ. Din mica sempre ser  a certa
  for i := 0 to Series.count-1 do
    CopiaComposicaoRPA(RPAF,Series[i].RPAS);

  // j  passou dessa parte na consolida, ent o copio para o consolidado tamb m
  CopiaComposicaoRPA(RPAF,RPA);
end;

procedure TContrato.TrataSeguroCarencia(HSegFin, HSegImv : real; Hflag : integer);
var
  RegApolice : TpApolice;
begin
  RegApolice.codapolice := '';
  fillchar(RegApolice,sizeof(TpApolice),0);
  
  if RPAF.FinRPA.NPC < 1 then begin
    LeApolice(RPA.Temp10.CodApolice,RegApolice);
    if RegApolice.COBRASEGCARPRIPRES and (RPAF.MAC >= Mes_int(RPAF.FinRPA.DtAssin.MesAno)) then begin
      RPAF.Temp12.VALSEGFINCAR := RPAF.Temp12.VALSEGFINCAR + RPAF.ValRpa.SegFin;
      RPA.Temp12.VALSEGFINCAR := RPA.Temp12.VALSEGFINCAR + RPAF.ValRpa.SegFin;
      RPA.Temp12.VALIofMipCAR := RPA.Temp12.VALIofMipCAR + Rpa.Temp12.IofMip;
      RPAF.Temp12.VALIofMipCAR := RPAF.Temp12.VALIofMipCAR + RpaF.Temp12.IofMip;
    end;
    LeApolice(RPA.Temp11.CodApoliceDFI,RegApolice);
    if RegApolice.COBRASEGCARPRIPRES and (RPAF.MAC >= Mes_int(RPAF.FinRPA.DtAssin.MesAno)) then begin
      RPAF.Temp12.VALSEGIMVCAR := RPAF.Temp12.VALSEGIMVCAR + RPAF.ValRpa.SegImv;
      RPA.Temp12.VALSEGIMVCAR := RPA.Temp12.VALSEGIMVCAR + RPAF.ValRpa.SegImv;
      RPAF.Temp12.VALIofDfiCAR := RPAF.Temp12.VALIofDfiCAR + RpaF.Temp12.IofDfi;
      RPA.Temp12.VALIofDfiCAR := RPA.Temp12.VALIofDfiCAR + Rpa.Temp12.IofDfi;
    end;
  end
  else if RPAF.FinRPA.NPC = 1 then begin
    { S  deve descarregar o seguro quando est  reevoluindo.
      Quando estiver respeitando o arqprest, ele j  esta estar  gravado corretamente}
    if (not scciconf.UsaArqPrest or
        (not ((abs(HSegImv) > 0) or (abs(HSegFin) > 0) or (HFlag=102)))) and
       (abs(RPAF.Temp12.VALSEGFINCAR+RPAF.Temp12.VALSEGIMVCAR) > zero) then begin
      Rpaf.Temp12.IofDfi := RpaF.Temp12.IofDfi + RPAF.Temp12.VALIofDfiCAR;
      Rpaf.Temp12.IofMip := RpaF.Temp12.IofMip + RPAF.Temp12.VALIofMipCAR;
      RPAF.ValRpa.SegFin := RPAF.ValRpa.SegFin + RPAF.Temp12.VALSEGFINCAR;
      RPAF.ValRpa.SegImv := RPAF.ValRpa.SegImv + RPAF.Temp12.VALSEGIMVCAR;
      RPAF.ValRPA.Seguro := RPAF.ValRPA.SegFin +
                            RPAF.ValRPA.SegCre +
                            RPAF.ValRPA.SegImv;
      AtualizaTotPrest(RPAF);

      Rpa.Temp12.IofDfi := Rpa.Temp12.IofDfi + RPAF.Temp12.VALIofDfiCAR;
      Rpa.Temp12.IofMip := Rpa.Temp12.IofMip + RPAF.Temp12.VALIofMipCAR;
      RPA.ValRPA.SegFin := RPA.ValRPA.SegFin + RPAF.Temp12.VALSEGFINCAR;
      RPA.ValRPA.SegImv := RPA.ValRPA.SegImv + RPAF.Temp12.VALSEGIMVCAR;
      RPA.ValRPA.Seguro := RPA.ValRPA.SegFin +
                           RPA.ValRPA.SegImv +
                           RPA.ValRPA.SegCre;
      AtualizaTotPrest(RPA);
    end;
  end
  else begin
    RPAF.Temp12.VALSEGFINCAR := 0;
    RPAF.Temp12.VALSEGIMVCAR := 0;
    RpaF.Temp12.VALIofDfiCAR := 0;
    RpaF.Temp12.VALIofMipCAR := 0;

    RPA.Temp12.VALSEGFINCAR := 0;
    RPA.Temp12.VALSEGIMVCAR := 0;
    Rpa.Temp12.VALIofDfiCAR := 0;
    Rpa.Temp12.VALIofMipCAR := 0;
  end;
end;

