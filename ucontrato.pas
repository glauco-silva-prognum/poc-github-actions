function CompStr(Str : String):string;
const Tam = 50;
begin
     while length(Str) < tam do str:= Str+' ';
     Result := str;

end;

function DefineCodTabGPreChv(Contrato : TContrato;CodReajAtv : shortint) : integer;
var
  i,
  MaiorPrazo : integer;
begin
  MaiorPrazo := Contrato.MutDsk.Financ.Prazo;
  if CodReajAtv = 23 then
    result := Contrato.MutDsk.Financ3.CodTabGPreChaves
  else
    result := 0;
  for i := 0 to Contrato.Series.Count -1 do
    if (Contrato.Series[i].Fin.CompoeSaldo or Contrato.Series[i].Fin.CompoeEntrada) then
      if (Contrato.Series[i].RPAS.FinRPA.Prazo > MaiorPrazo) and
         (Contrato.Series[i].Fin.CodReajPreChaves > 0) then begin
        MaiorPrazo := i;
        result := Contrato.Series[i].Fin.CodReajPreChaves;
      end;
end;

function DefineCodTabG(Contrato : TContrato;CodReajAtv : shortint; CodTabelagenericaAtv : integer) : integer;
var
  i,
  MaiorPrazo : integer;
begin
  MaiorPrazo := Contrato.MutDsk.Financ.Prazo;
  if CodreajAtv = 23 then
    result := CodtabelaGenericaatv
  else
    result := 0;
  for i := 0 to Contrato.Series.Count -1 do
    if (Contrato.Series[i].Fin.CompoeSaldo or Contrato.Series[i].Fin.CompoeEntrada) then
      if (Contrato.Series[i].RPAS.FinRPA.Prazo > MaiorPrazo) and
         (Contrato.Series[i].Fin.CodReaj > 0) then begin
        MaiorPrazo := i;
        result := Contrato.Series[i].Fin.CodReaj;
      end;
end;

function ContratoTemAlgumaIsencao(Contrato : TContrato): boolean;
var
  i : integer;
begin
  result := false;
  i := 0;
  while not result and (i < Contrato.series.count) do begin
    result := result or Contrato.series[i].Fin.IsentaMulta or
                        Contrato.series[i].Fin.IsentaCorrecao or
                        Contrato.series[i].Fin.IsentaMora;
    inc(i);
  end;
end;



function EnviaTagsSitCj(Sit : byte; Xml : TpXml):ansistring;
var
  DbRegistrotabSitCj : TDbRegistroTabSitCj;
  buffer : TpMemory;
  RegSit : TptabSitCj;
  i : smallint;
begin
  RegSit.Desc := '';
  fillchar(RegSit,sizeof(RegSit),0);
  result := '';
  Buffer := TpMemory.create;
  DbRegistrotabSitCj := TDbRegistroTabSitCj.create;
  try
    LeTabSitCj(Sit,RegSit);
    DBRegistrotabSitCj.RegToMemory (RegSit, '', Buffer,true);
    for i := 0 to Xml.DocumentElement['Detalhe'].count-1 do begin
      if (Xml.DocumentElement['Detalhe'][i].Attributes['Valor'] = 'P') or
         (Xml.DocumentElement['Detalhe'][i].Attributes['Valor'] = 'N') then begin
        if Buffer.readval(Xml.DocumentElement['Detalhe'][i].NodeName) = 'T' then
         result := result+Xml.DocumentElement['Detalhe'][i].Attributes['Caption']+';';
      end;
    end;
  finally
    Buffer.free;
    DbRegistrotabSitCj.free;
  end;
end;


