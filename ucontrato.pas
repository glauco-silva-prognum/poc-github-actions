    int_mes(Rpas.Mac,DtEvento.MesAno);
    MudouJuros := (Abs(Rpas.FinRpa.IndJuros- INDICE_JUROS(Rpas.FinRPa.TxJuros)) > Zero);
    if (Rpas.Temp12.DtEvento.Dia = 0) or (Juliano(RPas.Temp12.DtEvento)<Juliano(DtEvento)) then
    begin
      // Se o contrato teve Renegocia  o (ExOpc 17) com altera  o de taxa de juros ou de prazo
      if ((TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc in [17]) or
          (TEventoAmInc(FListaEventosAmInc.Items[i]).ExOpc in [17,116])) and
         (not TEventoAmInc(FListaEventosAmInc.Items[i]).RenegSemRisco) and
        (Rpas.Temp12.AlterouPrazo or (Rpas.ValRPa.NovoPrazo > 0) or
         MudouJuros) then
      begin
        Rpas.Temp12.CoEvento := 1;
        Rpas.Temp12.DtEvento := DtEvento;
      end
      // Se o contrato teve Incorpora  o (ExOpc 18)
      else if (TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc in [18,102]) then
      begin
        Rpas.Temp12.CoEvento := 2;
        Rpas.Temp12.DtEvento := DtEvento;
      end
      // Se o contrato teve Renegocia  o (ExOpc 17) E Incorpora  o
      else if ((TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc in [17]) or
          (TEventoAmInc(FListaEventosAmInc.Items[i]).ExOpc in [17,116])) and
         (TEventoAmInc(FListaEventosAmInc.Items[i]).ValorAmInc > 0) then
      begin
        Rpas.Temp12.CoEvento := 3;
        Rpas.Temp12.DtEvento := DtEvento;
      end
      else if AlterouTxJur and
             (not TEventoAmInc(FListaEventosAmInc.Items[i]).RenegSemRisco) then begin
        Rpas.Temp12.CoEvento := 1;
        DtEvento.Dia := Rpas.FinRPA.DiaLiq;
        Rpas.Temp12.DtEvento := DtEvento;
      end
      else if Rpas.Temp8.CodSerie=Contrato.Series.SerieMaiorPrazoCriadaNaReneg(DtEvento) then begin
        if TEventoAmInc(FListaEventosAmInc.Items[i]).SomaValoresReneg > zero then begin
          Rpas.Temp12.CoEvento := 2; // j  que   uma renegocia  o que considera-se como incopora  o de atraso
          Rpas.Temp12.DtEvento := DtEvento;
        end;
        if (abs(Rpas.Temp12.TxoriginalCtrIFRS9-fin.TxJuros) > zero) or
           HouveAumentoDePrazoIFRS9(DtEvento,Rpas) then begin
          if Rpas.Temp12.CoEvento > 0 then
            Rpas.Temp12.CoEvento := 3
          else
            Rpas.Temp12.CoEvento := 1;
          Rpas.Temp12.DtEvento := DtEvento;
        end;
      end;
      if (Rpas.Temp12.CoEvento >= 1) and
         (Rpas.Temp12.CoEvento <= 3) and (RpaS.MAC >= 1501) and
         (Mes_Int(Rpas.Temp12.DtEvento.MesAno) >= 1501) and 
         ( (TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc in [17,18,102]) 
                                       or
           (TEventoAmInc(FListaEventosAmInc.Items[i]).ExOpc in [17,116])
         ) and 

//scat104057          TEventoAmInc(FListaEventosAmInc.Items[i]).AchouDat348 and
         (not TEventoAmInc(FListaEventosAmInc.Items[i]).EhHist133) then
        Rpas.Temp12.Reestruturada := Rpas.Temp12.Reestruturada or 
        (not (TEventoAmInc(FListaEventosAmInc.Items[i]).RenegSemRisco or
              TEventoAmInc(FListaEventosAmInc.Items[i]).IniciaEmprestimo)
        );
    end;
    if TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc in [17,18,102] then
      MarcaFezOPC( Rpas.Temp2.FezOpc, Rpas.Temp3.FezOpc2,Rpas.Temp7.FezOpc3,Rpas.Temp7.FezOpc4,
                   TEventoAmInc(FListaEventosAmInc.Items[i]).ExAmInc);
    if TEventoAmInc(FListaEventosAmInc.Items[i]).ExOpc in [17,116] then
      MarcaFezOPC( Rpas.Temp2.FezOpc, Rpas.Temp3.FezOpc2,Rpas.Temp7.FezOpc3,Rpas.Temp7.FezOpc4,
                   TEventoAmInc(FListaEventosAmInc.Items[i]).ExOpc);
  end;
  FListaEventosAmInc.InicializaComEventos(ArrEventos,RPAS.Temp8.CodSerie);
end;

procedure DeterminaTxSdSwap(Dt1,Dt2:TData);
var
  IndInvalido : boolean;
  DtIndInvalido : Tdata;
begin
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  fillchar(DtIndInvalido,sizeof(Tdata),0);
  IndInvalido := false;
  if (RPAS.Temp12.CodReajSwap=0) or 
     ((RPAS.Temp12.CodreajSwap=RpaS.Temp6.CodReajSD) and (fin.Defreaj=RPAS.Temp12.DefSwap)
      and (smallint(RPAS.Temp12.PerReajSwap) = Rpas.Finrpa.persaldev ) ) then 
  begin
    rpas.sec.TxSDSwap := rpas.finrpa.TxSD;
  end
  else
  begin
    if (rpas.Temp10.NaoReajusta) or
       (Fin.PerReajSwap=0) and (Rpas.FinRpa.TxSD = 1.0) then // Se o periodo de reajuste de swap   igual ao do contrato, e n o teve reajuste no saldo do contrato ent o tamb m n o reajusta o swap 
    begin
      rpas.sec.TxSDSwap := 1.0;
    end
    else
    begin
      rpas.sec.TxSDSwap:= detinddataadata(RPAS.Temp12.CodreajSwap,RPAS.Temp12.defswap,Dt1,Dt2,1.0,
                                 Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                                 fin.CorrProRataIniPelaVarDataRef,RPAS.Temp12.CmProRataMesAnt,true);
      if IndInvalido then MarcaErroRPAS(RPAS,1,RPAS.Temp12.CodreajSwap,DtIndInvalido);
    end;
  end
end;

procedure SegundaFase(FParceladoMes:TParcelaSerie; DataRefCtb : TData);

  procedure DIV_NS (var RPA : TpRPA; n: real);
  var zerooumeio, valoremitido : real;
    begin
     if (RPA.MAC > mes_int(RPA.FinRPA.DtAssin.MesAno)) then
      with RPA, RPA.FinRPA, RPA.ValRPA, RPA.Temp, RPA.FinRPA2,RPA.Temp2, RPA.Temp6 do begin
        zerooumeio := 0.5;
        RARD     := RARD / n;
        ValTxAdm := int(100*ValTxAdm  / n + zerooumeio) / 100;
        if  ((Fin.RecalculaPrestacao or FDesconsideraParcela) and (NPC>1)) then begin
            if assigned(ParceladoMes) then ValorEmitido := ParceladoMes.Valoremitido
            else ValorEmitido := 0;
          if assigned(ParceladoMes) and (ValorEmitido<=Zero) then
              AmaisJ:= int(100*Amaisj  / n + zerooumeio) / 100;
        end;
        AmaisJAnt:= int(100*AmaisjAnt  / n + zerooumeio) / 100;
        SaldoDev := int(100*SaldoDev  / n + zerooumeio) / 100;
        Rpas.Temp11.SaldoAmortNeg := int(100*Rpas.Temp11.SaldoAmortNeg/n +zerooumeio)/ 100;
        PrejuLiq := int(100*PrejuLiq  / n + zerooumeio) / 100;
        ValorLA  := int(100*ValorLA   / n + zerooumeio) / 100;
        SalDevAnt:= int(100*SalDevAnt / n + zerooumeio) / 100;
        CorrSaldo:= SaldoDev-SaldevAnt;
        Temp4.Renda    := int( 100*Temp4.Renda/n + zerooumeio) / 100;
        Seguro   := int(100*Seguro    / n + zerooumeio) / 100;
        SegImv   := int(100*SegImv    / n + zerooumeio) / 100;
        SegCre   := int(100*SegCre    / n + zerooumeio) / 100;   
        SegFin := int( ( Seguro - SegImv - SegCre ) * 100 + zerooumeio) / 100;
        Temp9.ResiduoAcum    := int(100*Temp9.ResiduoAcum    / n + zerooumeio) / 100;
        Temp9.ResiduoCobrado := int(100*Temp9.ResiduoCobrado / n + zerooumeio) / 100;
        Temp11.SldDevCorr    := int(100*Temp11.SldDevCorr / n + zerooumeio) / 100;
      end; (* with *)
    end; (* DIV NS *)
  
  
  procedure TrataMoeda( var RPAS: TpRPA);
  begin
    Case RPAS.MAC of
      1035,1070,1124 : DIV_NS (RPAS,1000.0);
      1135      : DIV_NS(RPAS,2750.0);
    end;
  end;

// Scat 21249
procedure CalcCorrSaldoMes(var Rpas : TpRpa; RegSerie : TpSeries);

var
  lsaldo,
  lamaisj,
  lamortizacao,
  ljuro : double;
  LMauaSd,
  lmac: integer;
  MacProxReajuste : Integer;
  PerSalDevAjustado : Integer;
  RPASalvo  : TpRPA;
  DtMaua,
  DtIniJuros: TData;
begin
  if (Rpas.Mac > mes_int(Rpas.FinRpa.DtAssin.MesAno)) then
  begin
    if Fin.CobraResiduo then
      PerSalDevAjustado := 1
    else
      PerSalDevAjustado := Rpas.FinRpa.PerSalDev;
                             
    if PerSaldevAjustado <> 1 then 
    begin
      if (abs(Rpas.Temp.CorrSaldo)<Zero) then 
      begin
        RPASalvo := RPAS;
        DtIniJuros := RPAS.FinRpa.DtAssin;
        if (Fin.DtCarenciaDeJuros.Dia > 0) and
           (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
           DtIniJuros := Fin.DtCarenciaDeJuros;
      
        LMauaSd := RpaS.temp11.Mauasd;
        if RpaS.temp11.Mauasd = 0 then
        begin
          DtMaua     := RpaS.FinRpa.DtAssin;
          DtMaua.Mes := RpaS.FinRPa.MReaj;
          LMauaSd    := mes_int(DtMaua.MesAno);
          if LMauaSd > mes_int(RpaS.FinRpa.DtAssin.MesAno) then
            LMauaSd := LMauaSd - RpaS.FinRpa.PerSalDev;
        end;
        MacProxReajuste := LMauaSD + RpaS.FinRpa.PerSalDev;
        if MacProxReajuste < mes_int(RegSerie.DataRefReaj.MesAno) then
          MacProxReajuste := mes_int(RegSerie.DataRefReaj.MesAno);

(* --------O c digo acima foi colado da uevolui3.pas. Abaixo, c digo anterior 
           que tinha erro 
        MacProxReajuste :=   	Rpas.mac - ((Rpas.MAC-Mes_Int(Rpas.FinRpa.DtAssin.MesAno)) mod persaldevAjustado) + persaldevAjustado;
-----------------------------------------------------------------------*)
        lSaldo  := Rpas.ValRpa.SaldoDev;
        lAmaisJ := Rpas.ValRpa.AmaisJ;
        lmac := Rpas.mac;
        // Evolui at  o m s antes do pr ximo reajuste para calcular a corre  o
        // com base o saldo devedor antes do pr ximo reajuste.
        while (lmac <= MacProxReajuste-1) and (LSaldo > Zero) do
        begin
          lAmaisJ := lAmaisJ + Rpas.Valrpa.Recorr; 
          if RPAS.MAC > mes_int(DtIniJuros.MesAno) then begin
            lJuro := int(RpaS.FinRPA.IndJuros * lSaldo*100 +0.5)/100;
            if LMac = RPAS.MAC then begin //a CalcJuro j  prev  DtCarenciaJuros, etc. sol. 62752
              CalcJuro(RPAS.FinRPA.DiaVenc);
              LJuro        := RPAS.ValRPA.Juro;
              LAmaisJ      := Rpas.ValRpa.AmaisJ;
              RPAS         := RPASalvo;
            end;
          end
          else lJuro := 0;
          lAmortizacao := lAmaisJ - lJuro;          
          lSaldo := lSaldo - lAmortizacao;

          inc(lmac);
        end;
        RPAS := RPASalvo;

        if LSaldo < Zero then Lsaldo := 0;
        Rpas.Temp11.CorrSaldoMes := R2((Rpas.Temp11.TxSDMes-1)*
                               (lSaldo+Rpas.Temp11.CorrSaldoMesAcum));
        Rpas.Temp11.CorrSaldoMesAcum := Rpas.Temp11.CorrSaldoMesAcum + Rpas.Temp11.CorrSaldoMes;
      end
      else 
      begin
        RpaS.Temp11.MAUASd       := RpaS.MAC;
        Rpas.Temp12.DiaMauaSD    := Rpas.FinRpa.DiaVenc;
        Rpas.Temp11.CorrSaldoMes := Rpas.Temp.CorrSaldo - Rpas.Temp11.CorrSaldoMesAcum;
        Rpas.Temp11.CorrSaldoMesAcum := 0;
      end;
    end
    else 
    begin
      Rpas.Temp11.CorrSaldoMes := Rpas.Temp.CorrSaldo;
      Rpas.Temp11.CorrSaldoMesAcum := Rpas.Temp.CorrSaldo;
{??}  if RpaS.FinRPA.TxSd <> 1.0 then RpaS.Temp11.MAUASd := RPAS.MAC;
    end
  end
  else
  begin 
    Rpas.Temp11.CorrSaldoMes := 0;
    Rpas.Temp11.CorrSaldoMesAcum := 0;
  end;
end;

var
  IndInvalido         : boolean;
  PersalDevAjustado,
  PerReajSwapAjustado,
  m                   : integer;
  DataReajPst, 
  DtEntHab,
  DtIndInvalido       : Tdata;
  DataRefParaReaj     : TData;
  TempCmTabErr : integer;
  TempCmTabErrData : Tdata;
  MACMA: TMes_Ano;
  LegLinkItem: TLegLinkItem;
  DtIniJuros,
  Dt1swap: TData;
  DataRefParaReajSwap: TData;
  lPeriodicidade : integer;
begin { Segunda fase }
  LegLinkItem := nil;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
  int_mes(RPAS.MAC,MACMA);
  
  TempCmTabErr := CmTabErr;
  TempCmTabErrData := CmTabErrData;

  DataRefParaReaj := fin.DataRefReaj;
  DataRefParaReajSwap := DataRefParaReaj;
  if RPAS.Temp12.MacAcumIndOrigem>0 then begin
    int_mes(RPAS.Temp12.MacAcumIndOrigem {-Fin.DefReaj 62992 Scat na consulta do  ndice j  considera a defasagem}, DataRefparaReaj.MesAno);
    DataRefparaReaj.Dia := Fin.DataRef.Dia;
  end;
  if DataRefParaReaj.dia = 0 then
    DataRefParaReaj := Fin.DataRef;
  if DataRefParaReajSwap.dia = 0 then
    DataRefParaReajSwap := Fin.DataRef;

  FUsandoAmaisJPeloValorEmitido := false;
  FUsandoJurosPeloValorEmitido := false;
  IndInvalido := false;
  fillchar(DtIndInvalido,sizeof(Tdata),0);
  with RPAS do begin
      TrataMoeda( RPAS ); // Antecipada pelo scat 39994
      DiaVencAnt := FinRPA.DiaVenc;
      if ((MAC=1135) and Fin.RecalculaPrestacao) then begin
        FinRPA.PerFin := 12; FinRPA.MReaj := 7;
      end;
      if (fin.DiaVencParcPeloUsuario or (Fin.SistAmort=SisAmFianca)) and assigned(FParcelaDoMes) then begin
        FinRpa.DiaVenc := FParcelaDoMes.DiaVenc;
        FDiaVencOrig   := FinRPA.DiaVenc;
        Temp12.DiaVencOrig:= FDiaVencOrig;
      end
      else
        if FinRPA.DtInFin.Dia>0 then 
          FinRPA.DiaVenc := DIA_VENC(MAC,FinRPA.DtInFin.Dia);
      Dt1.Dia := FDiaVencOrig; // SCAt 44395
      if Dt1.Dia=0 then Dt1.Dia := FinRPA.DtInFin.Dia;
      if Dt1.Dia=0 then Dt1.Dia := DataRefParaReaj.Dia;
//      int_mes(pred(MAC), Dt1.MesAno);   SCAt 21249
      if Fin.CobraResiduo then 
        PerSalDevAjustado := 1
      else
        PerSalDevAjustado := FinRpa.PerSalDev;
      if Fin.PerReajSwap = 0 then
        PerReajSwapAjustado := PerSalDevAjustado
      else
        PerReajSwapAjustado := Fin.PerReajSwap;
      int_mes(MAC-PerSaldevAjustado, Dt1.MesAno);
//      int_mes(MAC-PerSaldevAjustado-Fin.DefReaj, Dt1.MesAno);
      DtVenc.Dia := FDiaVencOrig; int_mes(RpaS.MAC, DtVenc.MesAno); //SCAt 44395
      if DtVenc.Dia=0 then DtVenc.Dia := FinRPA.DtInFin.Dia;
      if DtVenc.Dia=0 then DtVenc.Dia := Fin.DataRef.Dia;

      // Contratual
      DtVencmenos1mes := DtVenc; DECMA(DtVencmenos1mes.MesAno);
      if Juliano(DtVencmenos1mes) < Juliano(DataRefParaReaj) then
         DtVencmenos1mes := DataRefParaReaj;

      //Swap
      Dt1Swap := DtVenc; DECMA(Dt1Swap.MesAno);
      if Juliano(Dt1Swap) < Juliano(DataRefParaReajSwap) then
         Dt1Swap := DataRefParaReajSwap;

      if Juliano(DtVenc)<(Juliano(Fin.DataRef)) then DtVenc := Fin.DataRef;
      defas := fin.defreaj;
      if (Juliano(Dt1)<=(Juliano(DataRefParaReaj))) or
         (MAC=mes_int(Fin.MaPrimReaj)) or    // SCAt 39021
         (((mes_int(Dt1.MesAno) = mes_int(DataRefParaReaj.MesAno)) and (PerSalDevAjustado>1))) or // Scat 80295
         (MAC=mes_int(DataRefParaReaj.MesAno)) or
         ((MAC-PersaldevAjustado)<=Temp12.MacAcumIndOrigem) then begin
           Dt1 := DataRefParaReaj;
      end;
      if (Juliano(Dt1Swap)<=(Juliano(DataRefParaReaj))) or
         (MAC=mes_int(Fin.MaPrimReaj)) or    // SCAt 39021
         (MAC=mes_int(DataRefParaReaj.MesAno)) or
         ((MAC-PerReajSwapAjustado)<=Temp12.MacAcumIndOrigem) then begin
           Dt1Swap := DataRefParaReaj;
      end;

      if ScciConf.IncorporaaoSaldoDevJurosContratnaMudancaVenc and
         RPAS.Temp11.AlteroudiaVenc then begin
        DtVencmenos1mes.Dia := DiaVencAnt;
        Dt1Swap.Dia := DiaVencAnt;
        Dt1.Dia := DiaVencAnt;
      end;

      if SCCIConf.ReajSDIndice1 then begin // SCAT 31958
        Dt1.Dia := 1; DtVenc.Dia := 1; DtVencmenos1mes.Dia := 1;
      end;
      if RPAS.Temp11.DiaCorrecaoSaldo > 0 then begin //SCAt 45991
        Dt1.Dia := RPAS.Temp11.DiaCorrecaoSaldo; 
        DtVenc.Dia := Dt1.Dia; DtVencmenos1mes.Dia := Dt1.Dia;
      end;
      DtEntHab := RPAS.Temp9.DtEntregaChaves; // SCAt 29363
      if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then DtEntHab := RPAS.Temp10.DtHabit;
      if (Juliano(DtEntHab)>0) and
         (MAC>mes_int(DtEntHab.MesAno)) then begin
        FinRpa.CodReaj := 23; // Tabela Generica
        Temp7.CodTabelaGenerica := Fin.CodReaj;
        Temp6.CodReajSD := Fin.CodReaj;
      end
      else  
        if Fin.codreajprechaves > 0 then defas := fin.defreajprechv;
      DataReajPst := DataRefParaReaj;
      if (FinRPA.MReaj > 0) and (byte(FinRPA.MReaj)<>DataRefParaReaj.Mes) then begin
         if byte(FinRPA.MReaj) > DataRefParaReaj.Mes then Dec(DataReajPst.Ano);
         DataReajPst.Mes := FinRPA.MReaj;
      end;
      m := succ(MAC - Mes_int(DataReajPst.MesAno));  //SCAt 22854
     // Determina TxSd. Tem que ser antes a DefineAmaisjParcela, pois ser  usado.
     if (fin.Indice_Obtido_Dia_Util) and (Juliano(Dt1) < Juliano(DtVenc)) then
     // Para cr ditos usando o CDI ajusta o dia do vencimento aterior para
     // o dia do vencimento no m s anterior
     begin
       dt1.dia := DiaVencAnt;
       DtIniJuros := RPAS.FinRpa.DtAssin;
       if (Fin.DtCarenciaDeJuros.Dia > 0) and
         (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
         DtIniJuros := Fin.DtCarenciaDeJuros;
       if juliano(Dt1) < juliano(DtIniJuros) then Dt1 := DtIniJuros;
     end;
     if MAC>=mes_int(Fin.MAPrimReaj) then
     begin
       if fin.Indice_Obtido_Dia_Util or (fin.PERC_APLICACAO_IND_CORR <> 0) 
          and (fin.PERC_APLICACAO_IND_CORR <> 100) then // scat 59802
       begin
         if Juliano(FDataUltimoReajuste) < Juliano(DataRefParaReaj) then
           FDataUltimoReajuste := DataRefParaReaj;
         if (not Temp10.NaoReajusta) 
            // O teste do mac ser posterior a primeira presta  o foi retirado na sol. 61369 e recolocado na 
            // solicita  o 67201 somente se cobra a corre  o na presta  o.
            // N o faz sentido cobrar a corre  o antes de iniciar as parcelas
            and ((MAC>=succ(mes_int(FinRPA.DtInfin.MesAno))) or not fin.IN_COBRACORR ) 
            and ((PerSaldevAjustado=1) or (pred(m mod PerSaldevAjustado)=0) ) 
            and  (Juliano(FDataUltimoReajuste) < Juliano(DtVenc)) then 
         begin
           FinRPA.TxSD := arredondaDecimais(DetIndicePercentual(Temp7.CodTabelaGenerica,Defas,FDataUltimoReajuste,DtVenc,fin.PERC_APLICACAO_IND_CORR,IndInvalido,DtIndInvalido),8);
           if abs(FinRPA.TxSD - 1.0) > Zero then
           begin
             if not Contrato.FInibeLegLink then 
               LegLinkItem := LegLink.Add(CodSerie,'<b><P/>C lculo  ndice do saldo devedor por pencentual</b>');
             if assigned(LegLinkItem) then
             begin
               LegLinkItem.valores['C digo da tabela'] := inttostr(Temp7.CodTabelaGenerica);
               LegLinkItem.valores['Defasagem'] := inttostr(defas);
               LegLinkItem.valores['Data inicial'] := data_str2(FDataUltimoReajuste);
               LegLinkItem.valores['Data final'] := data_str2(DtVenc);
               LegLinkItem.valores['Percentual'] := formatfloat('0.00',fin.PERC_APLICACAO_IND_CORR);
               //LegLinkItem.valores['Periodo de corre  o do saldo'] := inttostr(finrpa.persaldev);
               LegLinkItem.valores['Indice'] := formatfloat('0.00000000',FinRPA.TxSD);
             end;
           end;
           FDataUltimoReajuste := DtVenc;
           Rpas.Temp11.MauaSD := mes_int(FDataUltimoReajuste.MesAno);
           Rpas.Temp12.DiaMauaSD := DtVenc.dia;
         end
         else
           FinRpa.TxSD := 1.0;         
       end
       else    
       case MAC of // SCAT 23166
         1035 : FinRPA.TxSD := 1.3292081;
         1036 : FinRPA.TxSD := 1.0;
         1047 : FinRPA.TxSD := 1.706860;
         1048 : FinRPA.TxSD := 1.145152
       else begin
       if ((FinRPA.Plano mod 10)=SACR) and not(fin.REPACTUA_SACRE_JUROS_0) and (MAC<=succ(mes_int(FinRPA.DtInfin.MesAno))) then FinRPA.TxSD := 1.0
         else
           if (not Temp10.NaoReajusta) and 
