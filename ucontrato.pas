procedure TSerie.CalculaJurosSCPPorDiasCorridosOuUteis;
var
  Dt1, Dt2,
  DtIniJuros: TData;
  IndJuros: Extended;
begin
  IndJuros := 0;
  DtIniJuros := RPAS.FinRpa.DtAssin;
  if (Fin.DtCarenciaDeJuros.Dia > 0) and
     (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
     DtIniJuros := Fin.DtCarenciaDeJuros;
  int_mes(RPAS.MAC,Dt2.Mesano);
  Dt2.Dia := Dia_Venc(RPAS.MAC,byte(RPAS.FinRPA.DiaVenc));
  Dt1 := Dt2;
  DECMA(Dt1.MesAno);
  if Fin.DiaVenc > 0 then Dt1.Dia := Fin.DiaVenc;
  Dt1.Dia := Dia_Venc(mes_int(Dt1.MesAno),Dt1.Dia);
  if Juliano(DtIniJuros) > Juliano(Dt1) then
    Dt1 := DtIniJuros;
  if Juliano(Dt2) > Juliano(Dt1) then
  begin
    if (Fin.TpJuros = 7) then begin // Dias  teis
      TestaProxDiaUtil(Dt1);  // Estava fora do tpjuros=7 at  scat 50225
      TestaProxDiaUtil(Dt2);
      if Fin.JurosSimples then
        IndJuros := RPAS.FinRPA.TxJuros/100 * DiasUteis(Dt1,Dt2)/252
      else
        IndJuros :=  pot(1+RPAS.FinRPA.TxJuros/100,DiasUteis(Dt1,Dt2)/252)-1
    end
    else // Dias corridos modificado para taxa mensal pelo scat 50225
    begin
      if Fin.JurosSimples then
        IndJuros :=  RPAS.FinRPA.TxJuros/100 * (Juliano(Dt2)-Juliano(dt1))/360
      else
        IndJuros :=  pot(1+RPAS.FinRPA.TxJuros/100,(Juliano(Dt2)-Juliano(dt1))/360)-1;
    end
  end;
  if (Fin.JurosSimples) then
    Rpas.ValRpa.Juro := int(IndJuros * RpaS.Temp12.SaldoPrincipal*100+0.5)/100
  else
    Rpas.ValRpa.Juro := int(IndJuros * RpaS.ValRpa.SaldoDev*100+0.5)/100;
  FIndJurosPorDiasCorridosOuUteis := IndJuros;
end;


procedure TSerie.CalculaJurosSimplesSCP(DtIniJuros:TData);
begin
  if (RPAS.MAC>mes_int(DtIniJuros.MesAno)) then
  begin
    if abs(fin.razaoIni) < Zero then
      Rpas.ValRpa.Juro := int(RPAS.FinRPA.IndJuros * RpaS.Temp12.SaldoPrincipal*100+0.5)/100
    else
    begin
      Rpas.ValRpa.Juro := arredonda2(abs(Rpas.valrpa.rard * (1-Rpas.Temp10.IndRedPrest)) / 1000 * Parcelas.ObtemNumeroParcelasRemanescentes(Rpas.Mac) / Rpas.Temp7.Periodicidade);
      if (Rpas.Sec.SaldoDevSwap>0) then
      begin
        Rpas.Sec.JuroSwap :=  arredonda2(abs(rpas.Temp12.RaRdSwap * (1-Rpas.Temp10.IndRedPrest)) / 1000 * Parcelas.ObtemNumeroParcelasRemanescentes(Rpas.Mac) / Rpas.Temp7.Periodicidade);
      end;
    end;
  end;
end;

procedure TSerie.CalculaJurosSimples;
var
  SaldoParaCalculoJuros: Double;
begin
  SaldoParaCalculoJuros := (RpaS.ValRPA.SaldoDev - Rpas.Temp11.SaldoAmortNeg);
  if SaldoParaCalculoJuros < 0 then SaldoParaCalculoJuros := 0;
  RpaS.ValRPA.Juro := int(RpaS.FinRPA.IndJuros * (SaldoParaCalculoJuros) *100 +0.5)/100;
end;

procedure TSerie.CalculaJurosSisAmFianca(DiaVencAnt : byte);
var
  SaldoParaCalculoJuros: Double;
  Dias : integer;
  Dt,
  DtAnt : TData;
  ll : TLegLinkItem;
begin
  if rpas.mac > mes_int(rpas.finrpa.dtassin.mesano) then begin // n o tem juros na assinatura
    {
      seria bom pegar o valaval do pr prio rpa da s rie,
      no entanto, os tratamentos para o valaval s o feitos apenas 
      na consolidarpa, onde os seguros s o tratados, ent o 
      aqui a  nica forma certa de pegar o valor de avalia  o   buscar
      diretamente no cadmut.
    }
    SaldoParaCalculoJuros := Contrato.Mutdsk.Financ.ValAval;
    if SaldoParaCalculoJuros < 0 then SaldoParaCalculoJuros := 0;

    if rpas.mac = succ(mes_int(rpas.finrpa.dtassin.mesano)) then 
      DtAnt.dia := rpas.finrpa.dtassin.dia
    else
      DtAnt.dia := DiaVencAnt;
    int_mes(Rpas.Mac-1,DtAnt.MesAno);

    Dt.dia := Rpas.FinRpa.DiaVenc;
    int_mes(Rpas.Mac,Dt.MesAno);
    Dias := Juliano(Dt)-Juliano(DtAnt);
    
    Rpas.FinRPA.IndJuros := Rpas.FinRPA.TxJuros/360*Dias/100;
    RpaS.ValRPA.Juro := arredonda(SaldoParaCalculoJuros * Rpas.FinRPA.IndJuros);  
    
    ll := LegLink.add(CodSerie,'<P/><b>C lculo de juros de Fian a</b>');
    if assigned(ll) then
    begin
      ll.valores['Saldo base(Valor de avalia  o)'] := strgrana(SaldoParaCalculoJuros);
      if rpas.mac = succ(mes_int(rpas.finrpa.dtassin.mesano)) then 
        ll.valores['Vencimento Anterior(Data de Refer ncia)'] := data_str2(DtAnt)
      else
        ll.valores['Vencimento Anterior'] := data_str2(DtAnt);
      ll.valores['Vencimento'] := data_str2(Dt);
      ll.valores['Dias'] := intstr(Dias);
      ll.valores['Taxa de juros'] := formatfloat('0.00000000',Rpas.FinRPA.TxJuros);
      ll.valores[' ndice de juros(TxJuros/360*Dias/100)'] := formatfloat('0.000000000000',Rpas.FinRPA.IndJuros);
      ll.valores['Juros'] := strgrana(RpaS.ValRPA.Juro);
    end;
  end;  
end;

Procedure Tserie.CalculaJurosCompostos(DiaVencAnt:byte;DtIniJuros:TData);
var Dt1, Dt2 : TData; 
    indjurosprorata:double;
    LegLinkItem : TLegLinkItem;
    UltimoDiaMes : boolean;
    SaldoParaCalculoDeJuros: Double;
begin
  LegLinkItem := nil;
  if not( fin.REPACTUA_SACRE_JUROS_0 or fin.IN_COBRACORR) then
  { Este flag foi criado na solicita  o 59454 para um plano igual ao SACRE mas
    com a difere a que o c lculo da presta  o   com juros zero. Este plano
    tamb m tinha como caracter stica o c lulo dos juros antes da corre  o.
    No futuro, devemos criar uma flag espec fica para o c lculo de juros
    antes da corre  o }
    SaldoParaCalculoDeJuros := RpaS.ValRPA.SaldoDev
  else
    SaldoParaCalculoDeJuros := RpaS.ValRPA.SaldoDev - Rpas.Temp.CorrSaldo;
        if (RPAS.MAC>mes_int(DtIniJuros.MesAno)) then
        begin
          RpaS.ValRPA.Juro := int(RpaS.FinRPA.IndJuros * SaldoParaCalculoDeJuros*100 +0.5)/100;
          if not Contrato.FInibeLegLink then 
            LegLinkItem := LegLink.Add(CodSerie,'<P/><b>C lculo de juros do m s.</b>');
          if assigned(LegLinkItem) then 
          begin
            if fin.REPACTUA_SACRE_JUROS_0 or fin.IN_COBRACORR then begin
              LegLinkItem.Valores['Saldo base inicial'] := strgrana(RpaS.ValRPA.SaldoDev);
              LegLinkItem.Valores['Corre  o do saldo'] := strgrana(Rpas.Temp.CorrSaldo);
              LegLinkItem.Valores['Saldo sem corre  o'] := strgrana(SaldoParaCalculoDeJuros);
            end;  
            LegLinkItem.Valores['Saldo base para c lculo de juros'] := strgrana(SaldoParaCalculoDeJuros);
            LegLinkItem.Valores['Ind Juros'] := formatfloat('0.00000000',RpaS.FinRPA.IndJuros);
            LegLinkItem.Valores['Juros'] := strgrana(RpaS.ValRpa.Juro);
          end;
        end
        else RPAS.ValRPA.Juro := 0.0;
        if Fin.JurProRata or Fin.IncluiFracaodoMes then
        begin
          if {ScciConf.IncorporaaoSaldoDevJurosContratnaMudancaVenc and}
             scciconf.CalculaJurosProRataAlteracaoVencimento and
             (RPAS.Temp11.AlterouDiaVenc) then begin
             int_mes(RPAS.MAC,Dt2.Mesano); 
             Dt2.Dia := byte(RPAS.FinRPA.DiaVenc);
             Dt1:=Dt2; Dt1.Dia := DiaVencAnt; //DECMA(Dt1.MesAno);
             IndJurosProrata := pot(1+RPAS.FinRPA.IndJuros,(Juliano(Dt2)-Juliano(dt1))/30)-1;
             RPAS.Temp12.JurProRataPRoxVenc := int(IndJurosProrata * RpaS.ValRpa.SaldoDev*100 +0.5)/100;
             if not Contrato.FInibeLegLink then 
               LegLinkItem := LegLink.Add(CodSerie,'<P/><b>C lculo de juros pro rata na altera  o de vencimento</b>');
             if assigned(LegLinkItem) then 
             begin
               LegLinkItem.Valores['Dt1'] := Data_Str2(Dt1);
               LegLinkItem.Valores['Dt2'] := Data_Str2(Dt2);
               LegLinkItem.Valores[' ndice de juros pro rata'] := formatfloat('0.0000000',IndJurosProrata);
               LegLinkItem.Valores['Juros pro rata'] := strgrana(RPAS.Temp12.JurProRataPRoxVenc);
             end;
             if ScciConf.IncorporaaoSaldoDevJurosContratnaMudancaVenc then
             begin
               RpaS.ValRpa.Juro := RPAS.ValRPA.Juro + RPAS.Temp12.JurProRataPRoxVenc;
               RPAS.Temp12.JurProRataPRoxVenc := 0;
             end;
          end
          else
          begin
            if  (RpaS.Mac = mes_int(DtIniJuros.MesAno)) then 
            with RPAS.FinRPA do begin
              if not Contrato.FInibeLegLink then 
                LegLinkItem := LegLink.Add(CodSerie,'<P/><b>C lculo de Juros Pro Rata</b>');
              UltimoDiaMes :=  (DtIniJuros.Dia>=DIAS_MES(mes_int(DtIniJuros.MesAno))) and
                               (Fin.DtInicio.Dia>=DIAS_MES(mes_int(DtIniJuros.MesAno)));

              Dt1 := DtIniJuros;
              Dt2 := Dt1;
              Dt2.dia := DIA_VENC(mes_int(Dt1.MesAno),Fin.DtInicio.Dia);
              if assigned(LegLinkItem) then
              begin
                LegLinkItem.Valores['DataInicial']:= Data_Str(Dt1);
                LegLinkItem.Valores['DataFinal']  := Data_Str(Dt2);
              end;
              if (Fin.JurProRata) and (Dt2.Dia > Dt1.Dia) and (not UltimoDiaMes) then begin
                  IndJurosProrata := pot(1+IndJuros,(Dt2.Dia - Dt1.Dia)/30)-1;
                  if assigned(LegLinkItem) then
                    LegLinkItem.Valores['Indice Juros Prorata'] := formatfloat('0.0000000000',IndJurosProrata);
                  RpaS.ValRpa.Juro := int(IndJurosProrata * RpaS.ValRpa.SaldoDev*100 +0.5)/100;
              end
              else begin
                if Fin.IncluiFracaodoMes then IndJurosProRata := IndJuros
                else IndJurosProrata := 0;
                RpaS.ValRpa.Juro := int(IndJurosProrata * RpaS.ValRpa.SaldoDev*100 +0.5)/100;
              end;
            end  
            else
            begin
              if  (RpaS.Mac = mes_int(DtIniJuros.MesAno)+1) then begin
                 if (Fin.DtInicio.Dia < DtIniJuros.Dia) and 
                   // Scat 75721 n o calcula pro rata se a data de in cio   no  ltimo dia do m s 
                   // e o dia de ref ncia de juros   maior que o dia da data de in cio.
                   not ((Fin.DtInicio.Dia=DIASMES(Fin.DtInicio.MesAno)) and ((DtIniJuros.Dia >= Fin.DtInicio.Dia))) then begin
                   Dt2 := DtIniJuros; Dt2.Dia := Fin.DtInicio.Dia; INCMA(Dt2.MesAno);
                   if not Contrato.FInibeLegLink then 
                     LegLinkItem := LegLink.Add(CodSerie,'<P/><b>C lculo de Juros Pro Rata</b>');
                   if Fin.ProRataJurosDiasCorridos then
                     IndJurosProrata := pot(1+RpaS.FinRpa.IndJuros,((Juliano(Dt2) - Juliano(DtIniJuros))/30))-1
                   else 
                     IndJurosProrata := pot(1+RpaS.FinRpa.IndJuros,(30+(Fin.DtInicio.Dia - DtIniJuros.Dia))/30)-1;
                   
                   if assigned(LegLinkItem) then begin
                     if Fin.ProRataJurosDiasCorridos then begin
                       LegLinkItem.Valores['DataInicial'] :=Data_Str(DtIniJuros);
                       LegLinkItem.Valores['DataFinal'] := Data_Str(Dt2);
                     end
                     else begin
                       LegLinkItem.Valores['DiaInicial'] :=inttostr(Fin.DtInicio.Dia);
                       LegLinkItem.Valores['DiaFinal'] := inttostr(DtIniJuros.Dia);
                     end;
                     LegLinkItem.Valores['N mero de dias numerador (30+(Dia Inicial - Dia Vencimento)'] := inttostr(30+(Fin.DtInicio.Dia - DtIniJuros.Dia));
                     LegLinkItem.Valores['N mero de dias denominador'] := inttostr(30);
                     LegLinkItem.Valores['IndProrata'] := formatfloat('0.00000000',IndJurosProrata);
                   end;
                   RpaS.ValRpa.Juro := int(IndJurosProrata * RpaS.ValRpa.SaldoDev*100 +0.5)/100;
                 end;
              end;
            end;
          end;
        end;
end;

procedure Tserie.CalculaJurosAnuais;
var
  MA:TMes_Ano;
  EMesRecalculo: Boolean;
  N: Integer;
begin
  int_mes(Rpas.MAC,MA);
  if fin.mreaj > 0 then
    EMesRecalculo := fin.mreaj = MA.Mes
  else 
    EMesRecalculo := ((Rpas.Mac - Mes_Int(Fin.DataRef.MesAno)-1) mod 12) = 0;
  if (Rpas.FinRpa.npc>1) and (EMesRecalculo) then
  begin
    if fin.perparcelas > 0 then
      N := (12 div fin.perparcelas)
    else
      N := 1;
    if fin.perparcelas > 1 then N := N -1;

    Rpas.ValRpa.Juro := Int(Rpas.FinRpa.IndJuros * 12 * (Rpas.Temp.SalDevAnt+AmaisJAnt*N) *100+0.5)/100
  end
  else 
    Rpas.ValRpa.Juro := 0
end;

procedure TSerie.CalcJuro(DiaVencAnt:byte);
var 
  dtvenc,DtIniJuros : TData; 
begin
  RPAS.Temp.ValTmp1 := 0;
  if not fin.JurosParcPeloUsuario then // Os juros s o calculados pelo sistema
  begin
    dtvenc.dia := RPAS.FinRPA.DiaVenc; int_mes(RPAS.MAC, dtvenc.MesAno); dtvenc.DtStr[0]:=#3;
    DtIniJuros := RPAS.FinRpa.DtAssin;
    if (Fin.DtCarenciaDeJuros.Dia > 0) and 
       (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtIniJuros)) then
      DtIniJuros := Fin.DtCarenciaDeJuros;
    if (mes_int(DtVenc.MesAno) > mes_int(Fin.DtCarenciadeJuros.MesAno)) or
       ((Fin.JurProRata or Fin.IncluiFracaoDoMes) and (Juliano(DtVenc) > Juliano(Fin.DtCarenciadeJuros))) then begin
        if Fin.SistAmort = SisAmFianca then
          CalculaJurosSisAmFianca(DiaVencAnt)
        else if Rpas.Temp11.CalculaJurosAnuais then
          CalculaJurosAnuais // scat 39894
        else if (Fin.TpJuros = 6) or (Fin.TpJuros = 7) then 
        begin
          if (Fin.SistAmort = 7 {SCP}) then
            CalculaJurosSCPPorDiasCorridosOuUteis // scat 52810
          else
            CalculaJurosPorDiasCorridosOuUteis(DiaVencAnt) // scat 34325
        end
        else if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then { Scat 41461 } CalculaJurosSimplesSCP(DtIniJuros)
        else if (Fin.JurosSimples) then { Scat 49369 } CalculaJurosSimples
        else CalculaJurosCompostos(DiaVencAnt,DtiniJuros);
    end;
  end 
  else begin //* Juros definidos  pelo usu rio
    if assigned(FParcelaDoMes) then
      if fin.IN_COBRACORR then
        Rpas.ValRpa.Juro := FParcelaDoMes.Juros
      else
        Rpas.ValRpa.Juro := int(FParcelaDoMes.Juros*RpaS.Temp3.IndSaldoAcum*(1-Rpas.Temp10.IndRedPrest)*100+0.5)/100
    else
      Rpas.ValRpa.Juro := 0;
  end;
  if assigned(FParceladoMes) then
  begin
    if ScciConf.UsaArqPrest and (FParceladoMes.JurosEmi>Zero) or (FParceladoMes.Flag=102) or (FParceladoMes.Flag=103) then 
    begin
      FUsandoJurosPeloValorEmitido := true;
      RPAS.ValRPA.Juro := FParceladoMes.JurosEmi;
    end;
  end;
end;

procedure TSerie.CriaParcelaDoMesDeSeguro;
