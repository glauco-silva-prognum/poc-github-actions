function CtrJaTemPrest(Contrato : TContrato;     DtRef: TData): boolean;
  var DtAux : TData;
      i     : smallint;
  begin
    DtAux.Dia := 0;
    fillchar(DtAux,sizeof(TData),0);
    if TemFinancDinamico(Contrato.MutDsk) then begin
      DtAux := Contrato.MutDsk.Financ.DtInFin;
      incMA(DtAux.MesAno);
      DtAux.Dia := Dia_Venc(Mes_Int(DtAux.MesAno),DtAux.Dia);
    end;
    if Contrato.MutDsk.Cad2.TemSerie then 
      for i := 0 to Contrato.Series.Count-1 do begin
        if (DtAux.Dia = 0) or 
        (juliano(Contrato.Series[i].Fin.DtInicio) < juliano(DtAux)) then
        DtAux := Contrato.Series[i].Fin.DtInicio;   
      end;
    Result := (Juliano(DtAux) <= Juliano(DtRef));
end;

function CalcRataAss( dt1: TData; Ctabgen: smallint;defas:byte;var IndInvalido:Boolean;var DtIndInvalido:TData ) : real;
var dt3,dt11 : TData; i1,ic1:real;
begin                  
   dt11 := dt1; INCMA(dt11.MesAno);
   Dt3:=Dt1; Dt3.Dia := Dias_Mes(mes_int(Dt3.MesAno));

   ic1 := IndiceTabGenerica(Dt1,Dt11,CTabGen,false,false{UsaD2},succ(defas),IndInvalido,DtIndInvalido);
   i1 := pot(ic1,(Juliano(dt3)-Juliano(Dt1))/Dias_Mes(mes_int(Dt1.MesAno)));
//       i1 := IndiceTabGenerica(Dt1,Dt3,CodTabelaGenerica,false,false{UsaD2},succ(defas),IndInvalido,DtIndInvalido);
   if i1>1 then result := int(i1*10000000000+0.5)/10000000000
   else result := int(i1*10000000000-0.5)/10000000000;

end;


function detindProrata( CodTabelaGenerica:smallint;defas:byte;dt1,dt2: TData; TxProj : Real ) : real;
var dt3,DtIndInvalido : TData; IndInvalido : boolean;
begin
  IndInvalido := false;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
//SCat 21402 - Esta rotina foi refeita para ficar compat vel com a calculadora
  dt3.dia := 0;
  fillchar(dt3,4,0); dt3.dummy := 3;
  dt3 := dt1; dt3.dia := dt2.dia;
  if dt3.dia < dt1.dia then INCMA(dt3.mesano);

  {
    Sol. 32256
    esta rotina foi copiada da findrata, e n o pode usar a serie do dia da segunda data,
    pq essa rotina s    usada para calculos de quita  o, e neste caso a segunda data  
    uma dataref e n o uma data de vencimento da parcela, como na findrata
  }

  if CodTabelaGenerica > 0 then begin
    if CodTabelaGenerica <> 100 then
        result := IndiceTabGenerica(Dt1,Dt3,CodTabelaGenerica,true,false{UsaSerieD2},defas,IndInvalido,DtIndInvalido)
    else
      result := indicecmd( dt1,dt3,dt1);
  end
  else
    result := 1;
