{ TPagamentosParciaisSerie }

procedure TPagamentosParciaisSerie.Le( CodCtr   : string;
                                       Serie    : TSerie);
 var
  wPagamentoParcial  : TPagamentoParcial;
  i,pg              : integer;
  ArrayValPgtoParcial : ^TpArrayValPgtoParcial;
begin
  GetMem(ArrayValPgtoParcial,sizeof(TpArrayValpgtoParcial));
  try
    Clear;
    for i := 0 to Serie.Parcelas.Count -1 do
      if Serie.Parcelas[i].TemPgParcial then begin
        LeArrValPgtoParcial(1{TipoCtr},
                            CodCtr,
                            Serie.Parcelas[i].TipoParc{TipoParc},
                            Serie.CodSerie{CodParc},
                            Serie.Parcelas[i].Seq{NumParc},
                            ArrayValPgtoParcial^);
        for pg := 1 to ArrayValPgtoParcial^[0].tam do begin
          wPagamentoParcial                     := Add as TPagamentoParcial;
          wPagamentoParcial.Mac                 := Serie.Parcelas[i].MAC;
          wPagamentoParcial.DiaVenc             := Serie.Parcelas[i].DiaVenc;
          wPagamentoParcial.NumParc             := ArrayValPgtoParcial^[pg].NumParc;
          wPagamentoParcial.Valor               := ArrayValPgtoParcial^[pg].Valor;
          wPagamentoParcial.AmaisJ              := ArrayValPgtoParcial^[pg].AmaisJ;
          wPagamentoParcial.Juro                := ArrayValPgtoParcial^[pg].Juro;
          wPagamentoParcial.Seguro              := ArrayValPgtoParcial^[pg].Seguro;
          wPagamentoParcial.ValTxAdm            := ArrayValPgtoParcial^[pg].ValTxAdm;
          wPagamentoParcial.FCVS                := ArrayValPgtoParcial^[pg].FCVS;
          wPagamentoParcial.FGTS                := ArrayValPgtoParcial^[pg].FGTS;
          wPagamentoParcial.Desc                := ArrayValPgtoParcial^[pg].Desc;
          wPagamentoParcial.DescConcedido       := ArrayValPgtoParcial^[pg].DescConcedido;
          wPagamentoParcial.DtPg                := ArrayValPgtoParcial^[pg].DtPg;
          wPagamentoParcial.DtProc              := ArrayValPgtoParcial^[pg].DtProc;
          wPagamentoParcial.TipoPgParcial       := ArrayValPgtoParcial^[pg].TipoPg;
          wPagamentoParcial.TipoPgTotalParcela  := Serie.Parcelas[i].TipoPg;
          wPagamentoParcial.DtPgTotalParcela    := Serie.Parcelas[i].DtPg;
          wPagamentoParcial.SeqPag              := ArrayValPgtoParcial^[pg].SeqPag;
          wPagamentoParcial.Correcao            := ArrayValPgtoParcial^[pg].Correcao;
          wPagamentoParcial.JurosAbat           := ArrayValPgtoParcial^[pg].JurosAbat;
          wPagamentoParcial.ValIofComplem       := ArrayValPgtoParcial^[pg].ValIofComplem;
          wPagamentoParcial.DataRefCalc         := ArrayValPgtoParcial^[pg].DataRefCalc;
        end;
      end;
  finally
    FreeMem(ArrayValpgtoParcial);
  end;
end;

function TPagamentosParciaisSerie.ObtemSaldoDia(    DataRef          : TData;
                                                    Mac              : Integer;
                                                    Taxa             : Double;
                                                var UtilizacaoNoDia,
                                                    AmaisJParcialVenc:Double;
                                                    DescapitalizaParaDataRef : boolean = false):Double;

procedure RetornaDataDiaUtilNoMes(var Data : TData; Proxima : boolean);
var
  MACMes    : smallint;
  DtVencIni,
  DtVencMax : TData;
begin
  MACMes        := Mes_Int(Data.MesAno);
  DtVencIni     := Data;
  DtVencIni.Dia := 01;
  DtVencMax     := Data;
  DtVencMax.Dia := Dias_Mes(Mes_Int(Data.MesAno));
  while Feriado(Data) and {(Juliano(Data) < Juliano(DataH)) and}
        (Data.Dia > 0) and (Mes_Int(Data.MesAno) = MACMes) do begin
    if Proxima then IncData(Data,1) else DecData(Data,1);
  end;
  if Mes_Int(Data.MesAno) > MACMes then
    while (Feriado(Data) or (Mes_Int(Data.MesAno) > MACMes)) and
          (juliano(Data) > juliano(DtVencIni)) do DecData(Data,1);
  if Mes_Int(Data.MesAno) < MACMes then
    while (Feriado(Data) or (Mes_Int(Data.MesAno) < MACMes)) and
          (juliano(Data) < juliano(DtVencMax)) do IncData(Data,1);


end;

var
  i            : integer;
  DtVenc,
  DtUtilizacao : TData; // Vencto da parcela ou do pgto com red/de saldo dev, o que ocorrer antes
begin
  Result := 0;
  UtilizacaoNoDia  := 0;
  AmaisJParcialVenc:= 0;
  for i := 0 to Count -1 do
  begin
    Int_Mes(PagamentoParcial[i].MAC,DtVenc.MesAno);
    DtVenc.Dia := PagamentoParcial[i].DiaVenc;
    if (MAC >= mes_int(PagamentoParcial[i].DtPg.MesAno)) and
       (juliano(PagamentoParcial[i].DtPg) < juliano(DtVenc)) and
       (juliano(PagamentoParcial[i].DtProc) <= juliano(DataRef)) and
       (juliano(PagamentoParcial[i].DtPg)   <= juliano(DataRef)) then begin
      if PagamentoParcial[i].TipoPgTotalParcela in PgtoComRedSdDev then
        DtUtilizacao := PagamentoParcial[i].DtPgTotalParcela
      else begin
        DtUtilizacao.Dia := PagamentoParcial[i].DiaVenc;
        Int_Mes(PagamentoParcial[i].MAC,DtUtilizacao.MesAno);
        RetornaDataDiaUtilNoMes(DtUtilizacao,true);
      end;
      if (MAC < Mes_Int(DtUtilizacao.MesAno)) or
         (Scciconf.ContabDiaria and DataEMenor(DataRef,DtUtilizacao)) then
      begin
        Result := Result + PresentValue(Taxa,PagamentoParcial[i].MAC-MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod);
      end
      else if (MAC = Mes_Int(DtUtilizacao.MesAno)) and
             ((juliano(DtUtilizacao) <= juliano(DataRef)) or
              (not Scciconf.ContabDiaria)) then begin
//         UtilizacaoNoDia := UtilizacaoNoDia + PagamentoParcial[i].AmaisJ;
         UtilizacaoNoDia:= UtilizacaoNoDia + PresentValue(Taxa,PagamentoParcial[i].MAC-MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod);
         if (PagamentoParcial[i].MAC <= MAC) and 
            (PagamentoParcial[i].TipoPgParcial <> 115) then begin
           AmaisJParcialVenc := AmaisJParcialVenc + PagamentoParcial[i].AmaisJ;
         end;
      end;
    end;
  end;
end;

function TPagamentosParciaisSerie.ObtemSaldoRef(Serie : TSerie; var UtilizacaoNoMes, PagamentoParcialNoMes:Double;
                                                InibeLegLink : boolean = false):Double;
var
  MACUtilizacao,
  i : integer;
  ll: TLegLinkItem;
  ValorPresente : Double;
  DtVencPgParcial,
  DtVenc   :  TData;
begin
  ll     := nil;
  Result := 0;
  UtilizacaoNoMes := 0;
  PagamentoParcialNoMes := 0;
  for i := 0 to Count -1 do
  begin
    if (Serie.RPAS.MAC >= mes_int(PagamentoParcial[i].DtPg.MesAno)) {and
       (PagamentoParcial[i].TipoPgParcial <> 115)} then
    begin
      if PagamentoParcial[i].TipoPgTotalParcela in PgtoComRedSdDev then
        MACUtilizacao := Mes_Int(PagamentoParcial[i].DtPgTotalParcela.MesAno)
      else
        MACUtilizacao := PagamentoParcial[i].MAC;
      if (Serie.RPAS.MAC = mes_int(PagamentoParcial[i].DtPg.MesAno)) then
        PagamentoParcialNoMes := PagamentoParcialNoMes + PagamentoParcial[i].Valor;
      if (Serie.RPAS.MAC < MACUtilizacao) then
      begin
        if not InibeLegLink then 
          ll := LegLink.add(Serie.RPAS.Temp8.CodSerie,'<P/><b>C lculo do saldo de pagamento parcial antecipado</b>');
        DtVenc.Dia := Serie.RPAS.FinRPA.DiaVenc;
        Int_Mes(Serie.RPAS.MAC,DtVenc.MesAno);
        if DataEMaiorOUIgual(DtVenc,Serie.Fin.DataRef) then
          ValorPresente:= PresentValue(Serie.RPAS.FinRPA.IndJuros,PagamentoParcial[i].MAC-Serie.RPAS.MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod)
        else begin
          DtVenc              := Serie.Fin.DataRef;
          DtVencPgParcial.Dia := PagamentoParcial[i].DiaVenc;
          Int_Mes(PagamentoParcial[i].MAC,DtVencPgParcial.MesAno);
          ValorPresente:= CalculaEncargoAtualizado(PagamentoParcial[i].AmaisJ,
                                              DtVencPgParcial,
                                              DtVenc,Serie.RPAS.FinRPA.IndJuros,
                                              Serie.Fin.JurProRata or
                                              ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                              Serie.Fin.IncluiFracaoDoMes,
                                              Serie.fin.JurosSimples,
                                             (Serie.Fin.TpJuros = 6),
                                              Serie.DiaVencOrig,
                                             (Serie.Fin.TpJuros = 7));
        end;
        Result := Result + ValorPresente;
        if assigned(ll) then
        begin
          ll.valores['Mes ano antecipacao'] := mac_str(PagamentoParcial[i].MAC);
          ll.valores['AmaisJ antecipado'] := strgrana(PagamentoParcial[i].AmaisJ);
          ll.valores['Valor corre  o antecipado'] := strgrana(PagamentoParcial[i].Valor - PagamentoParcial[i].AmaisJ);
          ll.valores['Total antecipado'] := strgrana(PagamentoParcial[i].Valor);
          ll.valores['Meses antecipacao'] := inttostr(PagamentoParcial[i].MAC-Serie.RPAS.MAC);
          ll.valores['Taxa'] := formatfloat('0.0000000',Serie.RPAS.FinRPA.IndJuros);
          ll.valores['Valor presente parcela'] := strgrana(ValorPresente);
          ll.valores['Soma parcial'] := strgrana(Result);
        end;
      end
      else if (Serie.RPAS.MAC = MACUtilizacao) then begin
        DtVenc.Dia := Serie.RPAS.FinRPA.DiaVenc;
        Int_Mes(Serie.RPAS.MAC,DtVenc.MesAno);
        if DataEMaiorOUIgual(DtVenc,Serie.RPAS.FinRPA.DtAssin) then
          UtilizacaoNoMes:= UtilizacaoNoMes + PresentValue(Serie.RPAS.FinRPA.IndJuros,PagamentoParcial[i].MAC-Serie.RPAS.MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod)
        else begin
          DtVenc              := Serie.RPAS.FinRPA.DtAssin;
          DtVencPgParcial.Dia := PagamentoParcial[i].DiaVenc;
          Int_Mes(PagamentoParcial[i].MAC,DtVencPgParcial.MesAno);
          UtilizacaoNoMes:= UtilizacaoNoMes +CalculaEncargoAtualizado(PagamentoParcial[i].AmaisJ,
                                              DtVencPgParcial,
                                              DtVenc,Serie.RPAS.FinRPA.IndJuros,
                                              Serie.Fin.JurProRata or
                                              ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                              Serie.Fin.IncluiFracaoDoMes,
                                              Serie.fin.JurosSimples,
                                             (Serie.Fin.TpJuros = 6),
                                              Serie.DiaVencOrig,
                                             (Serie.Fin.TpJuros = 7));
        end;
      end;
    end;
  end;
end;

function TPagamentosParciaisSerie.ObtemSaldo(const CodSerie:Integer;
                                                   Mac:Integer;Taxa : Double; var UtilizacaoNoMes, PagamentoParcialNoMes:Double;
                                                   InibeLegLink : boolean = false):Double;
var
  MACUtilizacao,
  i : integer;
  ll: TLegLinkItem;
  ValorPresente : Double;
begin
  ll     := nil;
  Result := 0;
  UtilizacaoNoMes := 0;
  PagamentoParcialNoMes := 0;
  for i := 0 to Count -1 do
  begin
    if (MAC >= mes_int(PagamentoParcial[i].DtPg.MesAno)) then
    begin
      if PagamentoParcial[i].TipoPgTotalParcela in PgtoComRedSdDev then
        MACUtilizacao := Mes_Int(PagamentoParcial[i].DtPgTotalParcela.MesAno)
      else
        MACUtilizacao := PagamentoParcial[i].MAC;
      if (MAC = mes_int(PagamentoParcial[i].DtPg.MesAno)) then
        PagamentoParcialNoMes := PagamentoParcialNoMes + PagamentoParcial[i].Valor;
      if (MAC < MACUtilizacao) then
      begin
        if not InibeLegLink then 
          ll := LegLink.add(CodSerie,'<P/><b>C lculo do saldo de pagamento parcial antecipado</b>');
        ValorPresente:= PresentValue(Taxa,PagamentoParcial[i].MAC-MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod);
        Result := Result + ValorPresente;
        if assigned(ll) then
        begin
          ll.valores['Mes ano antecipacao'] := mac_str(PagamentoParcial[i].MAC);
          ll.valores['AmaisJ antecipado'] := strgrana(PagamentoParcial[i].AmaisJ);
          ll.valores['Valor corre  o antecipado'] := strgrana(PagamentoParcial[i].Valor - PagamentoParcial[i].AmaisJ);
          ll.valores['Total antecipado'] := strgrana(PagamentoParcial[i].Valor);
          ll.valores['Meses antecipacao'] := inttostr(PagamentoParcial[i].MAC-MAC);
          ll.valores['Taxa'] := formatfloat('0.0000000',Taxa);
          ll.valores['Valor presente parcela'] := strgrana(ValorPresente);
          ll.valores['Soma parcial'] := strgrana(Result);
        end;
      end
      else if (MAC = MACUtilizacao) then
//        UtilizacaoNoMes := UtilizacaoNoMes + PagamentoParcial[i].AmaisJ; Sol. 38896
        UtilizacaoNoMes := UtilizacaoNoMes + PresentValue(Taxa,PagamentoParcial[i].MAC-MAC,0,-PagamentoParcial[i].AmaisJ,ptEndOfPeriod);
    end;
  end;

end;


function TPagamentoParcial.GetParcela : TParcela;
var
  SerieF : TSerieFinanciamentoDinamico;
  Serie  : TSerie;
begin
  Result := nil;
  if Assigned(Collection) then begin
     if (Collection is TPagamentosParciaisFinanciamentoDinamico) then begin
       SerieF := (Collection as TPagamentosParciaisFinanciamentoDinamico).FOwner as TSerieFinanciamentoDinamico;
       if assigned(SerieF) then 
         Result := SerieF.Parcelas.ObtemParcelaPorMAC(MAC);
