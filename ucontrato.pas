function TParcela.EstaPagaCtb(var TemBaixaProcEmDataRef : boolean;
                                  DataRef : TData;
                                  IgnoraOcorrenciasPgtos : boolean = false;
                                  Acessorios : real = 0) : boolean; 

var                                     
  Achou : boolean;
  i     : integer;
begin
  TemBaixaProcEmDataRef := false;
  if assigned(self) then begin
    if (not IgnoraOcorrenciasPgtos) and (DataRef.Dia > 0) and
      ((juliano(DtProcPg) > juliano(DataRef)) or 
      ((DtProcPg.Dia = 0) and (TipoPg <> 200)) ) and 
       (OcorrenciasPagamentos.Count > 0) and
       (OcorrenciasPagamentos.QtdeOcorrPgtosTotais > 0) then begin
      Achou  := false;
      Result := false;
      i      := OcorrenciasPagamentos.Count-1;
      while (i >= 0) and (not Achou) do begin
        with OcorrenciasPagamentos[i] do 
          if (Juliano(RegOcorrenciasPgtos.DtProc) <= Juliano(DataRef)) and
             (RegOcorrenciasPgtos.SeqPag = 0) then begin
            result :=  (RegOcorrenciasPgtos.DtPg.Dia > 0) and 
                       (juliano(RegOcorrenciasPgtos.DtPg) <= juliano(DataRef)) and
                      ((Juliano(RegOcorrenciasPgtos.DtProc) <= Juliano(DataRef)) and
                       (not (RegOcorrenciasPgtos.TipoPg in [8..9,74,66,95,51,108,110,111,114,115,117,121,195,200,253]))   and
                      ((RegOcorrenciasPgtos.TipoPg <> 19) or Scciconf.ConsideraTipoPgto19NoContabil));
            if Result and (Juliano(RegOcorrenciasPgtos.DtProc) = Juliano(DataRef)) then
              TemBaixaProcEmDataRef := true;
            Achou := true;
          end;
        dec(i);
      end;
    end
    else begin //c digo original 
      result :=  (DtPg.Dia > 0) and (juliano(DtPg) <= juliano(DataRef)) and
                ((Juliano(DtProcPg) <= Juliano(DataRef)) and
                 (not (TipoPg in [8..9,74,66,95,51,108,110,111,114,115,117,121,195,200,253]))   and
                ((TipoPg <> 19) or Scciconf.ConsideraTipoPgto19NoContabil)) or
                ((TipoPg in [8..9,74,66,95,{51,}108,110{,111},114,117,121]) and
                 (Juliano(DtProcPg) > Juliano(DataRef)));
      TemBaixaProcEmDataRef := Result and (Juliano(DtProcPg) = Juliano(DataRef));

      if Result and (TipoPg in PgtoComRedSdDev) and
        (Acessorios > Zero) then begin
        result :=  (DtPgSeg.Dia > 0) and (juliano(DtPgSeg) <= juliano(DataRef)) and
                  ((Juliano(DtProcSeg) <= Juliano(DataRef)) and
                   (not (TipoPgSeg in [8..9,74,66,95,51,108,110,111,114,115,117,121,195,200,253]))   and
                  ((TipoPgSeg <> 19) or Scciconf.ConsideraTipoPgto19NoContabil)) or
                  ((TipoPgSeg in [8..9,74,66,95,{51,}108,110{,111},114,117,121]) and
                   (Juliano(DtProcSeg) > Juliano(DataRef)));
        TemBaixaProcEmDataRef := Result and (Juliano(DtProcSeg) = Juliano(DataRef));
      end;
    end;
  end
  else
    result := false;
end;

function TParcela.EstaPagaCtb(DataRef:TData; IgnoraOcorrenciasPgtos : boolean = false;
                              Acessorios : real = 0):boolean;
var
  TemBaixaProcEmDataRef : boolean;
begin
  TemBaixaProcEmDataRef := false;
  Result := EstaPagaCtb(TemBaixaProcEmDataRef,DataRef,IgnoraOcorrenciasPgtos,Acessorios);
end;

function TParcela.EstaPaga0(DataRef:TData):boolean;
begin
  result := (DtPg.Dia > 0) and (juliano(DtPg) <= juliano(DataRef)) and
            (not (TipoPg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253]));
end;

function TParcela.EstaPaga(DataRef:TData; Acessorios : real = 0):boolean;
begin
  if EstaPaga0(DataRef) and (abs(Acessorios) > zero) then begin // se informou acessorios, tem que conferir se   uma antecipa  o e se pagou os acess rios
    if (TipoPg in PgtoComRedSdDev) then
      Result := SeguroEstaPago(DataRef)
    else
      Result := true;
  end  
  else
    result := EstaPaga0(DataRef);
end;

function TParcela.EstaPagaReal0:boolean;
begin
  result := (DtPg.Dia > 0) and (not (TipoPg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253]));
end;

function TParcela.EstaPagaReal(Acessorios : real = 0):boolean;
begin
  if EstaPagaReal0 and (Abs(acessorios) > zero) then begin // se informou acessorios, tem que conferir se   uma antecipa  o e se pagou os acess rios
    if (TipoPg in PgtoComRedSdDev) then
      Result := SeguroEstaPagoReal
    else
      Result := true;
  end  
  else
    result := EstaPagaReal0;
end;

function TParcela.SeguroEstaPagoReal:boolean; // originalmente era apenas o seguro, mas passamos a considerar como "acess rios" incluindo taxas tamb m.
begin
  result := (DtPgSeg.Dia > 0) and (not (TipoPgSeg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253]));
end;

function TParcela.SeguroEstaPago(DataRef : Tdata):boolean; // semelhante a TParcela.EstaPaga, mas para o seguro/acess rios
begin
  result := (DtPgSeg.Dia > 0) and (juliano(DtPgSeg) <= juliano(DataRef)) and
            (not (TipoPgSeg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253]));
