  result := CalculaCETRemanescente(Contrato, Dataref, RegValores, CalcComAMaisJ, MemCalcNode);
end;

function CalculaCETRemanescente(Contrato : TContrato; DataRef : TData; var RegValores : TpRelCET; CalcComAmaisJ : boolean = false; MemCalcNode : TpXmlNode = nil) : real;  overload;
type
  TArrParcelas = Array of Double;
  TArrDatas    = Array of TDateTime;
var
  UsaArqP : boolean;
  TxJuros : real;
  Dt : Tdata;
  ArrayParcelas : TArrParcelas;
  Datas         : TArrDatas;
  i,
  Qtd : integer;
  DtZero : tdata;
  DtUltLib : TData;
  stlist : Thashedstringlist;
  VencList : Tstringlist;
  obj    : tobjValorCalculoCet;
  Reg : TObjPrestCalculoCet;
  index : integer;
  Valor : real;
  JulianoStr : string;
  PrestacoesNode : TpXmlNode;
  p : TpXmlNode;
begin
{$IFDEF FPC}
  ArrayParcelas := default(TArrParcelas);
  Datas:= default(TArrDatas);
{$ENDIF}
  result := 0;
  fillchar(RegValores,sizeof(TpRelCET),0);
  dtzero.dia := 0;
  fillchar(dtzero,sizeof(TData),0);
  dtultlib.dia := 0;
  fillchar(dtultlib,sizeof(TData),0);
  dtzero.dia := 1;
  dtzero.mes := 1;
  dtzero.ano := 50; // Sol. 34081
  TxJuros := 0;
  if not (Contrato.MutDsk.cad.tipoctr in [33,34,35,36,47]) then begin
    stlist := Thashedstringlist.create;
    VencList := TStringlist.create;
    try 
      stList.sorted := true;
      VencList.sorted := true;
      VencList.Duplicates := DupAccept;
      if Contrato.MutDsk.Cad.Ctr > '' then begin
        SetLength(ArrayParcelas,MaxEvoAtr);
        Setlength(Datas,MaxEvoAtr);
        for i := 0 to MaxEvoAtr-1 do begin
          ArrayParcelas[i]:= 0;
          Datas[i]:= 0;
        end;
        try
          UsaArqP := Scciconf.UsaArqPrest;
          try
            Contrato.InicRpa;
            while Contrato.Rpa.Mac < mes_int(DataRef.Mesano) do
              Contrato.Evolui;
            Scciconf.UsaArqPrest := false;
            TxJuros := Contrato.Rpa.FinRpa.TxJuros;
            Valor := - Contrato.Rpa.ValRpa.SaldoDev;
            Reg := TObjPrestCalculoCet.create;
            int_mes(Contrato.RPA.Mac,Reg.Data.mesano);
            Reg.Data.Dia := Contrato.Rpa.FinRpa.Diavenc;
            Reg.Parcela := 0;
            Reg.Amaisj := 0;
            Reg.Amortizacao := 0;
            Reg.Juros := 0;
            Reg.Mip := 0;
            Reg.Dfi := 0;
            Reg.ValTxAdm := 0;
            Reg.Encargo := 0;
            Reg.SaldoDevedor := Contrato.Rpa.ValRpa.SaldoDev;
            Reg.Dias := 0;
            Reg.Valor := - Contrato.Rpa.ValRpa.SaldoDev;
            VencList.addObject(DataToAAAAMMDD(Reg.Data),Reg);
            RegValores.VlLiberado := Contrato.Rpa.valrpa.SaldoDev;
            if abs(Valor) > zero then begin
              index := stlist.indexof(intstr(juliano(Contrato.RPA.FinRPA.DtAssin)));
              if index >= 0 then begin
                obj := stlist.objects[index] as tobjValorCalculoCet;
                obj.valor := Obj.valor + Valor;
              end
              else begin
                obj := tobjValorCalculoCet.create;
                obj.valor := Valor;
                stlist.addobject(intstr(juliano(Reg.Data)),obj)
              end;
            end;
            MarcaContratoParaNaoReajustar(Contrato);
            Contrato.Evolui; // Para sair da data de assinatura
            Qtd := 0;
            while Ctr_Ativo(Contrato.RPA) and (Qtd < MaxEvoAtr) do begin
              Dt.dia := Contrato.RPA.FinRPA.DiaVenc;
              Int_Mes(Contrato.RPA.Mac,Dt.MesAno);
              Valor := 0;
              if Ctr_Ativo(Contrato.RPAF) and (Contrato.RPAF.FinRPA.NPC > 0) then begin// considera apenas a partir da primeira parcela encontrada
                if CalcComAMaisJ then begin
                  Valor := Contrato.RpaF.ValRpa.AMaisJ;
                  Reg := TObjPrestCalculoCet.create;
                  Reg.Data := Dt;
                  Reg.Parcela := Contrato.RPAF.FinRPA.NPC;
                  Reg.Amaisj := Contrato.RPAF.valRPA.Amaisj;
                  Reg.Amortizacao := Contrato.RPAF.valRPA.Amaisj-Contrato.RPAF.valRPA.Juro;
                  Reg.Juros := Contrato.RPAF.valRPA.Juro;
                  Reg.Mip := Contrato.RPAF.valRPA.SegFin;
                  Reg.Dfi := Contrato.RPAF.valRPA.SegImv;
                  Reg.ValTxAdm := Contrato.RPAF.valRPA.ValTxAdm;
                  Reg.Encargo := Contrato.RPAF.valRPA.TotPrest;
                  Reg.SaldoDevedor := Contrato.RPAF.valRPA.SaldoDev;
                  Reg.Dias := Juliano(Dt)-Juliano(Contrato.RPAF.FinRPA.DtAssin);
                  Reg.Valor := Contrato.RpaF.ValRpa.AMaisJ;
                  VencList.addObject(DataToAAAAMMDD(Dt),Reg);
                end
                else begin
                  Valor := Contrato.RpaF.ValRpa.TotPrest;
                  Reg := TObjPrestCalculoCet.create;
                  Reg.Data := Dt;
                  Reg.Parcela := Contrato.RPAF.FinRPA.NPC;
                  Reg.Amaisj := Contrato.RPAF.valRPA.Amaisj;
                  Reg.Amortizacao := Contrato.RPAF.valRPA.Amaisj-Contrato.RPAF.valRPA.Juro;
                  Reg.Juros := Contrato.RPAF.valRPA.Juro;
                  Reg.Mip := Contrato.RPAF.valRPA.SegFin;
                  Reg.Dfi := Contrato.RPAF.valRPA.SegImv;
                  Reg.ValTxAdm := Contrato.RPAF.valRPA.ValTxAdm;
                  Reg.Encargo := Contrato.RPAF.valRPA.TotPrest;
                  Reg.SaldoDevedor := Contrato.RPAF.valRPA.SaldoDev;
                  Reg.Dias := Juliano(Dt)-Juliano(Contrato.RPAF.FinRPA.DtAssin);
                  Reg.Valor := Contrato.RpaF.ValRpa.TotPrest;
                  VencList.addObject(DataToAAAAMMDD(Dt),Reg);
                end;
                RegValores.VlSegMip := RegValores.VlSegMip + Contrato.RPAF.ValRPA.SegFin ;
                RegValores.VlSegDfi := RegValores.VlSegDfi + Contrato.RPAF.ValRPA.SegImv ;
                RegValores.VlOutros := RegValores.VlOutros + Contrato.RPAF.ValRPA.ValTxAdm ;
              end;
              for i := 0 to Contrato.Series.count-1 do begin
                if Ctr_Ativo(Contrato.Series[i].RPAS) and
                   (Contrato.Series[i].fin.DtRenegGeradora.dia = 0) and {sol. 34081}
                   ((Contrato.Series[i].RPAS.FinRPA.NPC > 0) or  { s. 21058 }
                    (Contrato.Series[i].RPAS.MAC > Mes_Int(Contrato.Series[i].RPAS.FinRPA.DtAssin.MesAno))) and
                   (Contrato.Series[i].RPAS.ValRPA.TotPrest-Contrato.Series[i].RPAS.ValRPA.Desc > Zero) and
                   assigned(Contrato.Series[i].ParcelaDoMes) then begin// igual a atrlib.ParcSerieOk
                  if CalcComAMaisJ then begin
                    Valor := Valor + Contrato.Series[i].RPAS.ValRPA.AMaisJ;
                    Reg := TObjPrestCalculoCet.create;
                    Reg.Data := Dt;
                    Reg.Parcela := Contrato.Series[i].RPAS.FinRPA.NPC;
                    Reg.Amaisj := Contrato.Series[i].RPAS.valRPA.Amaisj;
                    Reg.Amortizacao := Contrato.Series[i].RPAS.valRPA.Amaisj-Contrato.Series[i].RPAS.valRPA.Juro;
                    Reg.Juros := Contrato.Series[i].RPAS.valRPA.Juro;
                    Reg.Mip := Contrato.Series[i].RPAS.valRPA.SegFin;
                    Reg.Dfi := Contrato.Series[i].RPAS.valRPA.SegImv;
                    Reg.ValTxAdm := Contrato.Series[i].RPAS.valRPA.ValTxAdm;
                    Reg.Encargo := Contrato.Series[i].RPAS.valRPA.TotPrest;
                    Reg.SaldoDevedor := Contrato.Series[i].RPAS.valRPA.SaldoDev;
                    Reg.Dias := Juliano(Dt)-Juliano(Contrato.Series[i].RPAS.FinRPA.DtAssin);
                    Reg.Valor := Contrato.Series[i].RPAS.ValRpa.Amaisj;
                    VencList.addObject(DataToAAAAMMDD(Dt),Reg);
                  end
                  else begin
                    Valor := Valor + Contrato.Series[i].RPAS.ValRPA.TotPrest;
                    Reg := TObjPrestCalculoCet.create;
                    Reg.Data := Dt;
                    Reg.Parcela := Contrato.Series[i].RPAS.FinRPA.NPC;
                    Reg.Amaisj := Contrato.Series[i].RPAS.valRPA.Amaisj;
                    Reg.Amortizacao := Contrato.Series[i].RPAS.valRPA.Amaisj-Contrato.Series[i].RPAS.valRPA.Juro;
                    Reg.Juros := Contrato.Series[i].RPAS.valRPA.Juro;
                    Reg.Mip := Contrato.Series[i].RPAS.valRPA.SegFin;
                    Reg.Dfi := Contrato.Series[i].RPAS.valRPA.SegImv;
                    Reg.ValTxAdm := Contrato.Series[i].RPAS.valRPA.ValTxAdm;
                    Reg.Encargo := Contrato.Series[i].RPAS.valRPA.TotPrest;
                    Reg.SaldoDevedor := Contrato.Series[i].RPAS.valRPA.SaldoDev;
                    Reg.Dias := Juliano(Dt)-Juliano(Contrato.Series[i].RPAS.FinRPA.DtAssin);
                    Reg.Valor := Contrato.Series[i].RPAS.ValRpa.TotPrest;
                    VencList.addObject(DataToAAAAMMDD(Dt),Reg);
                  end;
                  RegValores.VlSegMip := RegValores.VlSegMip + Contrato.Series[i].RPAS.ValRPA.SegFin ;
                  RegValores.VlSegDfi := RegValores.VlSegDfi + Contrato.Series[i].RPAs.ValRPA.SegImv ;
                  RegValores.VlOutros := RegValores.VlOutros + Contrato.Series[i].RPAS.ValRPA.ValTxAdm ;
                end;
              end;
              if abs(Valor) > zero then begin
                index := stlist.indexof(intstr(juliano(Dt)));
                if index >= 0 then begin
                  obj := stlist.objects[index] as tobjValorCalculoCet;
                  obj.valor := Obj.valor + Valor;
                end
                else begin
                  obj := tobjValorCalculoCet.create;
                  obj.valor := Valor;
                  stlist.addobject(intstr(juliano(Dt)),obj)
                end;
              end;
              inc(qtd);
              Contrato.evolui;
            end;
            RegValores.VlSegTot   := RegValores.VlSegDfi   + RegValores.VlSegMip;
            RegValores.VlDespesas := RegValores.VlTarifas  + RegValores.VlTributos + RegValores.VlSegTot + RegValores.VlOutros + RegValores.VlTie;
            RegValores.VlTotal    := RegValores.VlLiberado + RegValores.VlTributos + RegValores.VlTaxaIncorporadaFinanc;
            if RegValores.VlTotal > zero then begin
              RegValores.PeLiberado := (RegValores.VlLiberado / RegValores.VlTotal) * 100;
              RegValores.PeDespesas := (RegValores.VlDespesas / RegValores.VlTotal) * 100;
              RegValores.PeTarifas  := (RegValores.VlTarifas /  RegValores.VlTotal) * 100;
              RegValores.PeTributos := (RegValores.VlTributos / RegValores.VlTotal) * 100;
              RegValores.PeSegTot   := (RegValores.VlSegTot /   RegValores.VlTotal) * 100;
              RegValores.PeSegMip   := (RegValores.VlSegMip /   RegValores.VlTotal) * 100;
              RegValores.PeSegDfi   := (RegValores.VlSegDfi /   RegValores.VlTotal) * 100;
              RegValores.PeOutros   := (RegValores.VlOutros /   RegValores.VlTotal) * 100;
              RegValores.PeTie      := (RegValores.VlTie /      RegValores.VlTotal) * 100;
            end;
  
            Qtd := 0;
            for i := 0 to stlist.count-1 do begin
              inc(Qtd);
              obj := stlist.objects[i] as tobjValorCalculoCet;
              if Qtd > Length(ArrayParcelas) then begin
                setLength(ArrayParcelas,qtd);
                setLength(Datas,qtd);
              end;
              ArrayParcelas[Qtd-1] := Obj.Valor;
              julianostr := stlist[i];
              J_Data(valint(julianostr),dt);
              Datas[Qtd-1] := DataToDateTime(Dt);
            end;
            if Qtd > 0 then begin
              SetLength(ArrayParcelas,Qtd);
              SetLength(Datas,Qtd);
            end
            else begin
              SetLength(ArrayParcelas,0);
              Setlength(Datas,0);
            end;
          finally
            Scciconf.UsaArqPrest := UsaArqP;
          end;
        except
          on e : exception do begin
            SetLength(ArrayParcelas,0);
            Setlength(Datas,0);
          end;
        end;
        if Length(ArrayParcelas) > 1 then try
          if abs(TxJuros) < zero then
            TxJuros := 0.1
          else
            TxJuros := (TxJuros/100)+1;
//          GeraTxtCet(Datas,Arrayparcelas); // Somente para depura  o
          result := XTIR(ArrayParcelas,Datas,TxJuros);
        except
          result := 0;
        end
        else
          result := 0;
      end;
      if Assigned(MemCalcNode) then begin
        if CalcComAmaisJ then
          MemCalcNode.add('CEM').asfloat := result
        else
          MemCalcNode.add('CET').asfloat := result;
        PrestacoesNode := MemCalcNode.add('Prestacoes');
        for i := 0 to VencList.count-1 do begin
          p := PrestacoesNode.add('Prestacao');
          Reg := VencList.objects[i] as TObjPrestCalculoCet;
          p.add('Data').asTdata := Reg.Data;
          p.add('Parcela').asinteger := Reg.Parcela;
          p.add('Amaisj').asfloat := Reg.Amaisj;
          p.add('Amortizacao').asfloat := Reg.Amortizacao;
          p.add('Juros').asfloat := Reg.Juros;
          p.add('Mip').asfloat := Reg.Mip;
          p.add('Dfi').asfloat := Reg.Dfi;
          p.add('ValTxAdm').asfloat := Reg.ValTxAdm;
          p.add('Encargo').asfloat := Reg.Encargo;
          p.add('SaldoDevedor').asfloat := Reg.SaldoDevedor;
          p.add('Dias').asinteger := Reg.Dias;
          if abs(Reg.Tie) > zero then
            p.add('Tie').asfloat := Reg.Tie;
          if abs(Reg.ValIOF) > zero then
            p.add('ValIOF').asfloat := Reg.ValIOF;
          if abs(Reg.SegPrestamistaAVista) > zero then
            p.add('SegPrestamistaAVista').asfloat := Reg.SegPrestamistaAVista;
          p.add('Valor').asfloat := Reg.Valor;
        end;
      end;
    finally
      for i := 0 to stlist.count-1 do
        stlist.objects[i].free;
      for i := 0 to VencList.count-1 do
        VencList.objects[i].free;
      stlist.free;
      VencList.free;
    end;
  end;
end;    

procedure AtualizaCET(Ctr : tpCtr);
var
  Contrato : TContrato;
  DtZero : tdata;
  Gravou : boolean;
  c,
  p,
  Node : TpXmlNode;
  XmlLog,
  Xml : TpXml;
  cet,cem,cesh : real;
  pgeralog : boolean;
begin
  pgeralog := false;
  dtzero.dia := 1;
  dtzero.mes := 1;
  dtzero.ano := 50; // Sol. 34081

  if (Ctr > '') and (Ctr <> cCtrInexistente) then begin
    Contrato := TContrato.create;
    try
      Contrato.Le(Ctr,DtZero);
      if Contrato.MutDsk.Cad.Ctr > '' then begin
        Xml := TpXml.create;
        try
          XmlLog := TpXml.create;
  
          Xml.DocumentElement.nodename := 'RELANALITICOCUSTOSEIOF';
          Node := Xml.DocumentElement;
  
          cet := (Contrato.MutDsk.Cad4.CET);
          cem := (Contrato.MutDsk.Cad6.CEM);
          cesh := (Contrato.MutDsk.Cad6.CESH);
  
          Contrato.MutDsk.Cad4.CET := CalculaCET(Contrato,false{CalcComAmaisj},Node.add('CET'));
          Contrato.MutDsk.Cad6.CEM := CalculaCET(Contrato,true{CalcComAmaisJ},Node.Add('CEM'));
          Contrato.MutDsk.Cad6.CESH := CalculaCESHContrato(Contrato,Node.Add('CESH'));
  
          Grava_MutDsk(Contrato.MutDsk,Gravou);
          GravaRelAnaliticoCustos(Contrato.MutDsk.cad.ctr,Xml);
          p := xmllog.documentelement.addchild('CET');
          if abs(cet) <> abs(Contrato.MutDsk.Cad4.CET) then begin
            c := p.add('CAD4_CET');
            c.add('antes').asString := floattostrF(cet,ffFixed,5,6);
            c.add('depois').asString :=floattostrF(Contrato.MutDsk.Cad4.CET,ffFixed,5,6);
            pgeralog := true;
          end;
  
          if abs(cem) <> abs(Contrato.MutDsk.Cad6.Cem) then begin
            c := p.add('CAD6_CEM');
            c.add('antes').asString := floattostrF(cem,ffFixed,5,6);
            c.add('depois').asString :=floattostrF(Contrato.MutDsk.Cad6.CEM,ffFixed,5,6);
            pgeralog :=true;
          end;
  
          if abs(cesh) <> abs(Contrato.MutDsk.Cad6.CESH) then begin
            c := p.add('CAD6_CESH');
            c.add('antes').asString  := floattostrF(cesh,ffFixed,5,6);
            c.add('depois').asString := floattostrF(Contrato.MutDsk.Cad6.CESH,ffFixed,5,6);
            pgeralog := true;
          end;
  
         if   pgeralog  then
             uloglib.GeraLog(logaplic_AltCET,logseveridade_Aviso,Contrato.MutDsk.cad.Ctr,PegaUsuario,'','','',XmlLog);
  
  
        finally
          Xml.free;
        end;
      end;
    finally
      Contrato.free;
    end;
  end;
end;

procedure AtualizaSegVista(ctr : tpctr);
var
  Mutdsk : TpMutdsk;
  gravou : boolean;
  RegPadraoCtr : TpPadraoCtr;
  Contrato : TContrato;
begin
  // Sol. 67260
  // gravar o campo CADMUT.CAD_SEGVISTA com o valor do pr mio de seguro
  // da presta  o 0 (zero), sempre que o conte do da vari vel
  // PADRAOCTR.COBRARSEGSEMPREP0 for verdadeiro

  RegPadraoCtr.codpadrao := '';
  fillchar(RegPadraoCtr,sizeof(TpPadraoCtr),0);
  Mutdsk.cad.ctr := '';
  fillchar(Mutdsk,sizeof(TpMutdsk),0);
  if (Ctr > '') and (Ctr <> cCtrInexistente) then begin
    if Le_Mutdsk(ctr,Mutdsk) then begin
      Contrato := TContrato.create;
      try
        Contrato.Le(Mutdsk);
        if Contrato.MutdskC.Cad2.CodPadrao > '' then begin
          LePadraoCtr(Contrato.MutDskC.cad2.CodPadrao,Contrato.MutDsk.cad.CodEmpresa,RegPadraoCtr);
          if RegPadraoCtr.CobrarSegSempreP0 then begin
            Contrato.InicRPA;
            Contrato.Mutdsk.Cad.SegVista := Contrato.RPA.ValRPA.Seguro;
            Grava_mutdsk(Contrato.Mutdsk,gravou);
          end;
        end;
      finally
        Contrato.free;
      end;
    end;
  end;
end;

procedure MontaContratoParaIOF(TipoSerie : integer;
                               SaldoDev : real;
                               DataRef,
                               DataCarencia,
                               DataInicio : Tdata;
                               Prazo : integer;
                               TxJuros : real;
                               TpJuros : integer;
                               SistAmort : integer;
                               Contrato : TContrato;
                               JurosProRata : boolean;
                               JDataLiquid : integer;
                               In_Carencia_Amortizacao : boolean;
                               NuPrazoCarenciaAmort : integer;
                               In_Tipo_Juros_Carencia : integer);
var
  RegTipoSerie : TpTipoSerie;
  Mutdsk : TpMutdsk;
  Hist : TpHistEdit;
  ArrSeries : TpArrCadSerie;
  ChaveLog : TpChaveLogMem;
  DataLiquid : TData;
begin
  RegTipoSerie.TpSerie := 0;
  fillchar(RegTipoSerie,sizeof(RegTipoSerie),0);
  MutDsk.Cad.Ctr := '';
  fillchar(MutDsk,sizeof(TpMutdsk),0);
  Hist[0].Tam := 0;
  fillchar(Hist,sizeof(TpHistEdit),0);
  ArrSeries[0].Chave.Tam := 0;
  fillchar(ArrSeries,sizeof(TpArrCadSerie),0);


  if TipoSerie > -1 then begin
    Mutdsk.Cad2.TemSerie := true;
    ArrSeries[0].Chave.Tam := 1;
    LeTipoSerie(TipoSerie,RegTipoSerie);
    PreencheSerieComTipoSerie(RegTipoSerie,ArrSeries[1]);
    if arrseries[1].PerParcelas = 0 then
      arrseries[1].Perparcelas := 1;
  
    ArrSeries[1].compoesaldo := true;
  
    ArrSeries[1].ctr := cCtrInexistente;
    ArrSeries[1].codserie := MaxInt;
    ArrSeries[1].tiposerie := RegTipoSerie.TpSerie;
    ArrSeries[1].valor := SaldoDev;
    ArrSeries[1].prazo := Prazo;
    ArrSeries[1].Dataref := DataRef;
    ArrSeries[1].dtinicio := DataInicio;
    ArrSeries[1].TpJuros := TpJuros;
    ArrSeries[1].TxJuros := TxJuros;
    ArrSeries[1].SistAmort := SistAmort;
    ArrSeries[1].DtCarenciaDeJuros := DataCarencia;
  end
  else begin
    Mutdsk.financ.valfinanc := SaldoDev;
    Mutdsk.financ.prazo := Prazo;
    Mutdsk.financ.DtAssin := DataRef;
    Mutdsk.financ.DtInFin := DataInicio;
    MutDsk.financ.DiaVenc := DataInicio.dia;
    MutDsk.financ.TxJuros := TxJuros;
    MutDsk.financ.CodReaj := 31;
    MutDsk.financ.TTX := 16;
    MutDsk.Cad.CadFin.SdRata := 128;
    MutDsk.Cad6.PercFia := 0;
    MutDsk.financ.Plano := 110 + SistAmort;
    if JurosProRata then begin
      MutDsk.financ3.JurProRata := true;
      MutDsk.financ3.AmortizaSaldoComNPC0 := true;
    end;
    if In_Carencia_Amortizacao and (NuPrazoCarenciaAmort > 0) then begin
      MutDsk.Cad6.IniCarAmort := DataInicio.MesAno;
      IncMA(MutDsk.Cad6.IniCarAmort);
      MutDsk.Cad6.PrzCarAmort := NuPrazoCarenciaAmort;
      MutDsk.Cad6.IncJurCarAmort := In_Tipo_Juros_Carencia;
    end;
  end;
  Mutdsk.cad.ctr := cCtrInexistente;

  if JDataLiquid > 0 then begin
    ChaveLog := 0;
    J_Data(JDataLiquid,DataLiquid);
    IncluiLogMem(Hist,MutDsk.Cad.Ctr,1,DataH,'LAN',ChaveLog);
    IncluiDatMem(Hist,ChaveLog,DataLiquid.MesAno,47,DataLiquid.Dia);
    IncluiDatMem(Hist,ChaveLog,DataLiquid.MesAno,43,26);
  end;
  Contrato.lemem(MutDsk,Hist,ArrSeries);
end;


function ObtemPercIOFPorPrazo(TipoSerie : integer;
                              DataRef,
                              DataCarencia,
                              DataInicio : Tdata;
                              Prazo : integer;
                              TxJuros : real;
                              TpJuros : integer;
                              SistAmort : integer;
                              PercIOFJur : real = 0;
                              JurosProRata : boolean = false;
                              JDataLiquid : integer = 0;
                              In_Carencia_Amortizacao : boolean = false;
                              NuPrazoCarenciaAmort : integer = 0;
                              In_Tipo_Juros_Carencia : integer = 0;
                              EPJuridica : boolean = false;
                              InSimplesNacional : boolean = false;
                              SaldoDev : real = 100000;
                              DadosEvoIOF : TDadosEvoIOF = nil) : real; overload;
var
  IOF,
  IOFMes : real;
  Dias : integer;
  Amortizacao : real;
  Contrato : TContrato;
  DtVenc : TData;
  perciof : real;
  DataLiquid : TData;
  PercIOFOp : real;
  DadosEvoIOFItem : TDadosEvoIOFItem;
  RPAZero : TpRPA;
  IndDescapitalizacao : real;
begin
  IndDescapitalizacao := 1;
  if assigned(DadosEvoIOF) then
    DadosEvoIOF.clear;
    
  if (PercIOFJur > zero) or EPJuridica then begin
     if (PercIOFJur <= Zero) then
       PercIOF := ObtemAliquotaIOF(DataRef,'IOF_JURIDICA')
     else
       PercIOF := PercIOFJur;
  end
  else begin
     PercIOF := ObtemAliquotaIOF(DataRef,'IOF_FISICA')
  {
    if ScciConf.PerIOFPf > Zero then
      PercIOF := ScciConf.PerIOFPf
    else
      PercIOF := 0.0082;
   }
  end;
  if (PercIOFJur > Zero) or EPJuridica then begin
    if not InSimplesNacional then
      PercIOFOp := ObtemAliquotaIOF(DataRef,'IOF_OPERACAO_JURIDICA')
    else begin
      if SaldoDev <= ObtemValorMaximoIofJurSimples(DataRef,'IOF_OPERACAO_JURIDICA_SIMPLES') then
        PercIOFOp := ObtemAliquotaIOF(DataRef,'IOF_OPERACAO_JURIDICA_SIMPLES')
      else
        PercIOFOp := ObtemAliquotaIOF(DataRef,'IOF_OPERACAO_JURIDICA');
    end;
    if (PercIOF <= Zero) then
      PercIOFOp := ObtemAliquotaIOF(DataRef,'IOF_OPERACAO');
  end
  else
    PercIOFOp := ObtemAliquotaIOF(DataRef,'IOF_OPERACAO');

//  SaldoDev := 100000; passou a ser par metro default
  if Prazo = 0 then
    IOF := Arredonda(SaldoDev * ((365 * PercIOF/100)+(PercIOFOp/100)))
  else begin
    if PercIOFOp > zero then begin
      IOF := int(SaldoDev * PercIOFOp + 0.5)/100;
      if assigned(DadosEvoIOF) then begin
        DadosEvoIOFItem := DadosEvoIOF.add as TDadosEvoIOFItem;
        RPAZero.ctr := '';
        fillchar(RPAZero,sizeof(TpRPA),0);
        DadosEvoIOFItem.AtribuiRPA(RPAZero);
        DadosEvoIOFItem.VENCIMENTO := DataRef;
        DadosEvoIOFItem.VA_SALDO_DEVEDOR := SaldoDev;
        DadosEvoIOFItem.NU_DIAS_IOF := 0;
        DadosEvoIOFItem.ALIQUOTA_IOF := PercIOFOp;
        DadosEvoIOFItem.VA_IOF := Arredonda(IOF);
      end;
    end
    else
      IOF := 0;
    Contrato := TContrato.create;
    try
      MontaContratoParaIOF(TipoSerie,SaldoDev,DataRef,DataCarencia,DataInicio,
                           Prazo,TxJuros,TpJuros,SistAmort,Contrato,JurosProRata,JDataLiquid,
                           In_Carencia_Amortizacao,NuPrazoCarenciaAmort,In_Tipo_Juros_Carencia);
      Contrato.mutdsk.Financ.IndSegFin := -1;
      Contrato.mutdsk.Financ.IndSegImv := -1; // Otimiza  o para n o tabela de refer ncia para c lculo pelo SFH
      Contrato.InicRPA(true {N o Reajusta});
      while Contrato.Ativo do begin
        if Contrato.RPA.FinRPA.Npc = 1 then begin
          if (SaldoDev > Zero) and (Contrato.RPA.Temp.SalDevAnt > Zero) then
            IndDescapitalizacao := SaldoDev / Contrato.RPA.Temp.SalDevAnt;
        end
        else begin
          if (In_Carencia_Amortizacao and (Contrato.RPA.FinRPA.NPC = (NuPrazoCarenciaAmort+1))) then
            if (SaldoDev > Zero) and (Contrato.RPA.Temp.SalDevAnt > Zero) then
              IndDescapitalizacao := SaldoDev / Contrato.RPA.Temp.SalDevAnt;
        end;
        if Contrato.MutDsk.Cad2.TemSerie then begin
          if Contrato.Series[0].RPAS.Temp10.TemParcNoMes then begin
            DtVenc.dia := Contrato.Series[0].RPAS.FinRPA.DiaVenc;
            Int_mes(Contrato.Series[0].RPAS.Mac,DtVenc.MesAno);
            Dias := Juliano(DtVenc)-Juliano(Contrato.Series[0].RPAS.FinRPA.DtAssin);
            if dias > 365 then
              dias := 365;
            Amortizacao := (Contrato.Series[0].RPAS.ValRPA.Amaisj-
                           Contrato.Series[0].RPAS.ValRPA.Juro) * IndDescapitalizacao;
            if Amortizacao > zero then
              IOFmes := (Dias * Amortizacao * PercIOF)/ 100
            else
              IOFMes := 0;
            if assigned(DadosEvoIOF) and (Juliano(DtVenc) > Juliano(DataRef)) then begin
              DadosEvoIOFItem := DadosEvoIOF.add as TDadosEvoIOFItem;
              DadosEvoIOFItem.AtribuiRPA(Contrato.Series[0].RPAS);
              DadosEvoIOFItem.NU_DIAS_IOF := dias;
              DadosEvoIOFItem.ALIQUOTA_IOF := PercIOF;
              DadosEvoIOFItem.VA_IOF := Arredonda(IOFMes);
            end;
            IOF := IOF + IOFMes;
          end;
        end
        else begin
          Amortizacao := (Contrato.RPAf.ValRPA.Amaisj-
                         Contrato.Rpaf.ValRPA.Juro) * IndDescapitalizacao;
          DtVenc.dia := Contrato.Rpaf.FinRPA.DiaVenc;
          Int_mes(Contrato.Rpaf.Mac,DtVenc.MesAno);
          Dias := Juliano(DtVenc)-Juliano(Contrato.Rpaf.FinRPA.DtAssin);
          if dias > 365 then
            dias := 365;
          if Amortizacao > zero then
            IOFMes := (Dias * Amortizacao * PercIOF)/ 100
          else
            IOFMes := 0;
          if assigned(DadosEvoIOF) and (Juliano(DtVenc) > Juliano(DataRef)) then begin
            DadosEvoIOFItem := DadosEvoIOF.add as TDadosEvoIOFItem;
            DadosEvoIOFItem.AtribuiRPA(Contrato.RPAF);
            DadosEvoIOFItem.NU_DIAS_IOF := dias;
            DadosEvoIOFItem.ALIQUOTA_IOF := PercIOF;
            DadosEvoIOFItem.VA_IOF := Arredonda(IOFMes);
          end;
          IOF := IOF + IOFMes;
          if JDataLiquid > 0 then begin
            J_Data(JDataLiquid,DataLiquid);
            if Contrato.Rpa.Mac = Mes_Int(DataLiquid.MesAno) then begin
              Dias := Juliano(DataLiquid)-Juliano(Contrato.Rpaf.FinRPA.DtAssin);
              if dias > 365 then
                dias := 365;
              IOF := IOF + (Dias * (Contrato.Rpaf.Temp.SalDevAnt - Amortizacao) * PercIOF)/ 100;
              if assigned(DadosEvoIOF) then begin
                DadosEvoIOFItem := DadosEvoIOF.add as TDadosEvoIOFItem;
                DadosEvoIOFItem.AtribuiRPA(Contrato.RPAF);
                DadosEvoIOFItem.NU_PRESTACAO := 0;
                DadosEvoIOFItem.VENCIMENTO := DataLiquid;
                DadosEvoIOFItem.VA_AMAISJ_SEM_FIA := 0;
                DadosEvoIOFItem.VA_JUROS := 0;
                DadosEvoIOFItem.VA_SALDO_DEVEDOR := 0;
                DadosEvoIOFItem.VA_PRESTACAO := 0;
                DadosEvoIOFItem.NU_DIAS_IOF := dias;
                DadosEvoIOFItem.ALIQUOTA_IOF := PercIOF;
                DadosEvoIOFItem.VA_Amortizacao := Contrato.Rpaf.Temp.SalDevAnt - Amortizacao;
                DadosEvoIOFItem.VA_IOF := Arredonda((Dias * (Contrato.Rpaf.Temp.SalDevAnt - Amortizacao) * PercIOF)/ 100);
              end;
            end;
          end;
        end;
        Contrato.Evolui;
      end;
      if JDataLiquid > 0 then begin
        J_Data(JDataLiquid,DataLiquid);
        if Contrato.Rpa.Mac = Mes_Int(DataLiquid.MesAno) then begin
          Amortizacao := Contrato.RPAf.ValRPA.Amaisj-
                         Contrato.Rpaf.ValRPA.Juro;
          Dias := Juliano(DataLiquid)-Juliano(Contrato.Rpaf.FinRPA.DtAssin);
          if dias > 365 then
            dias := 365;
          IOF := IOF + (Dias * (Contrato.Rpaf.Temp.SalDevAnt - Amortizacao) * PercIOF) / 100;
          if assigned(DadosEvoIOF) then begin
            DadosEvoIOFItem := DadosEvoIOF.add as TDadosEvoIOFItem;
            DadosEvoIOFItem.AtribuiRPA(Contrato.RPAF);
            DadosEvoIOFItem.NU_PRESTACAO := 0;
            DadosEvoIOFItem.VENCIMENTO := DataLiquid;
            DadosEvoIOFItem.VA_AMAISJ_SEM_FIA := 0;
            DadosEvoIOFItem.VA_JUROS := 0;
            DadosEvoIOFItem.VA_SALDO_DEVEDOR := 0;
            DadosEvoIOFItem.VA_PRESTACAO := 0;
            DadosEvoIOFItem.NU_DIAS_IOF := dias;
            DadosEvoIOFItem.ALIQUOTA_IOF := PercIOF;
            DadosEvoIOFItem.VA_Amortizacao := Contrato.Rpaf.Temp.SalDevAnt - Amortizacao;
            DadosEvoIOFItem.VA_IOF := Arredonda((Dias * (Contrato.Rpaf.Temp.SalDevAnt - Amortizacao) * PercIOF)/ 100);
          end;
        end;
     end;
    finally
      Contrato.free;
    end;
  end;
  if Abs(SaldoDev) > Zero then
    result := IOF / SaldoDev
  else
    result := 0;
end;


function ObtemPercIOFPorPrazo(TipoSerie : integer;
                              DataRef,
                              DataInicio : Tdata;
                              Prazo : integer;
                              TxJuros : real;
                              TpJuros : integer;
                              SistAmort : integer;
                              PercIOFJur : real = 0;
                              JurosProRata : boolean = false;
                              JDataLiquid : integer = 0;
                              In_Carencia_Amortizacao : boolean = false;
                              NuPrazoCarenciaAmort : integer = 0;
                              In_Tipo_Juros_Carencia : integer = 0) : real; overload;
var
  DataCarencia : TData;
begin
  Datacarencia.dia := 0;  
  fillchar(DataCarencia,sizeof(TData),0);
  result := ObtemPercIOFPorPrazo(TipoSerie,DataRef,DataCarencia,DataInicio,
                                 Prazo,TxJuros,TpJuros,SistAmort,PercIOFJur,JurosProRata,JDataLiquid,
                                 In_Carencia_Amortizacao,NuPrazoCarenciaAmort,In_Tipo_Juros_Carencia);
end;

function ObtemIOFPorPrazo(TipoSerie : integer;
                          DataRef,
                          DataCarencia,
                          DataInicio : Tdata;
                          ValFinanc : real;
                          Prazo : integer;
                          TxJuros : real;
                          TpJuros : integer;
                          SistAmort : integer;
                          IOF_AVista : boolean;
                          PercIOFJur : real = 0;
                          JurosProRata : boolean = false;
                          JDataLiquid : integer = 0;
                          In_Carencia_Amortizacao : boolean = false;
                          NuPrazoCarenciaAmort : integer = 0;
                          In_Tipo_Juros_Carencia : integer = 0;
                          EPJuridica : boolean = false;
                          InSimplesNacional : boolean = false;
                          DadosEvoIOF : TDadosEvoIOF = nil) : real; overload;
begin
  if IOF_AVista then begin
    result := Arredonda(ValFinanc * ObtemPercIOFPorPrazo(TipoSerie,DataRef,DataCarencia,DataInicio,
                                                 Prazo,TxJuros,TpJuros,SistAmort,PercIOFJur,
                                                 JurosProRata,JDataLiquid,
                                                 In_Carencia_Amortizacao,NuPrazoCarenciaAmort,
                                                 In_Tipo_Juros_Carencia,EPJuridica,InSimplesNacional,ValFinanc,DadosEvoIOF));
  end
  else begin
    result := ValFinanc / (1 -ObtemPercIOFPorPrazo(TipoSerie,DataRef,DataCarencia,DataInicio,
                                                   Prazo,TxJuros,TpJuros,SistAmort,PercIOFJur,
                                                   JurosProRata,JDataLiquid,In_Carencia_Amortizacao,
                                                   NuPrazoCarenciaAmort,In_Tipo_Juros_Carencia,
                                                   EPJuridica,InSimplesNacional,ValFinanc,DadosEvoIOF));
    result := Arredonda(result - ValFinanc);
  end;
end;


function ObtemIOFPorPrazo(TipoSerie : integer;
                          DataRef,
                          DataInicio : Tdata;
                          ValFinanc : real;
                          Prazo : integer;
                          TxJuros : real;
                          TpJuros : integer;
                          SistAmort : integer;
                          IOF_AVista : boolean;
                          PercIOFJur : real = 0;
                          JurosProRata : boolean = false;
                          JDataLiquid : integer = 0;
                          In_Carencia_Amortizacao : boolean = false;
                          NuPrazoCarenciaAmort : integer = 0;
                          In_Tipo_Juros_Carencia : integer = 0;
                          EPJuridica : boolean = false;
                          DadosEvoIOF : TDadosEvoIOF = nil) : real;
var
  Datacarencia : TData;
begin
  Datacarencia.dia := 0;  
  Fillchar(DataCarencia,sizeof(Tdata),0);
  result := ObtemIOFPorPrazo(TipoSerie,DataRef,DataCarencia,DataInicio,
                             ValFinanc,Prazo,TxJuros,TpJuros,SistAmort,IOF_AVista,PercIOFJur,
                             JurosProRata,JDataLiquid,In_Carencia_Amortizacao,
                             NuPrazoCarenciaAmort,In_Tipo_Juros_Carencia,EPJuridica,
                             false{InSimplesNacional},DadosEvoIOF);

end;

procedure ZeraRPAEmDisco(Ctr : TpCtr; MARef : TMes_Ano);
var
  MACRef : smallint;
  Qry    : TsqlQuery;
begin
  if AbriuRPASql then begin
    MACRef := Mes_Int(MARef);
    Qry := TsqlQuery.create(niL);
    try
      Qry.SqlConnection := GetSqlConnection(PegaDirCor,'cadmut');
      Qry.sql.add('DELETE FROM RPA WHERE CO_BASE='+IntStr(PegacoBase(Qry.SqlConnection))+' AND MAC='+IntStr(MACRef)+' AND ');
      Qry.sql.add('CO_CONTRATO='+QuotedStr(CtrToSqlCtr(Ctr)));
      Qry.execSql;
    finally
      Qry.free;
    end;
  end;
end;

procedure FastRPA(    Contrato : TContrato;
                      NaoConsideraMesAnterior : boolean;
                      DataRef : TData;
                      DataHist : Tdata;
                      DataRPA : TData;
                      CriaRPA : boolean;
                  Var TotPrest : real);
var
  i : integer;
  MutMem : TpMutMem;
  RPA : TpRPA;
  RPAnt : TpRPA;
  MAHoje : integer;
  wArrComp : ^TpArrComp;
begin
  MutMem.Mutdsk.Cad.ctr := '';
  fillchar(mutMem,sizeof(TpMutMem),0);
  Rpa.Ctr := '';
  fillchar(RPA,sizeof(TpRPA),0);
  RPAnt.Ctr := '';
  fillchar(RPAnt,sizeof(TpRPA),0);

  TotPrest := 0;
  MAHoje := mes_int(DataRef.MesAno);
  if CriaRPA then
    ZeraRPAEmDisco(Contrato.Mutdsk.cad.Ctr,DataRef.MesAno);
  if NaoConsideraMesAnterior then
    Contrato.InicRPA
  else
    Contrato.ObtemRPA(MAHoje-1);
  while Contrato.RPA.MAC < MAHoje do Contrato.Evolui;
  for i := 0 to Contrato.Series.Count - 1 do begin
    RPA := Contrato.Series[i].RPAS;
    if Rpa.MAC<>MAHoje then begin  // SCAt 36068
      RPA.FinRPA.Status := 11; RPA.ValRPA.MacStatus := RPA.MAC;
      ZeraPrest(RPA); ZeraSaldos(RPA); RPA.MAC := MAHoje;
    end;
    if (RPA.Ctr > '') and (Rpa.Mac = MAHoje) then GravaRpaData(Rpa,DataRpa,CriaRPA);
  end;
  Rpa := Contrato.Rpa;
  Rpa.Temp8.CodSerie := 0;
  if Rpa.MAC<>MAHoje then begin   //SCAt 36068
    RPA.FinRPA.Status := 11; RPA.ValRPA.MacStatus := RPA.MAC;
    ZeraPrest(RPA); ZeraSaldos(RPA); RPA.MAC := MAHoje;
  end;
  if (Rpa.Ctr > '') and (Rpa.Mac = MAHoje) and Contrato.MutDsk.Cad2.TemSerie then
    GravaRpaData(Rpa,DataRpa,CriaRPA);
  if TemFinancDinamico(Contrato.MutDsk) or not Contrato.Mutdsk.cad2.TemSerie then begin
    if (Contrato.MutDsk.Financ.Status = 0) then begin
      RPA := Contrato.RPAF;
      RPA.Temp5.EvoCompleta := 1;
    end
    else begin
      MutMem.Mutdsk := Contrato.Mutdsk;
      MutMem.Hist[0].Tam := 0;
      Getmem(wArrComp,sizeof(TpArrComp));
      try
        wArrComp^ := Contrato.GetArrComp;
        Init_RPA(MutMem,RPA,wArrComp^,Contrato.ApolicesMistas,
                 Contrato.ContratosCorrelacionados,false{InibeLegLink}(*$IFDEF CONSOLE*),Contrato.GrupoImv(*$ENDIF*));
      finally
        freemem(wArrcomp);
      end;
      RPA.MAC := MAHoje;
      RPA.Temp5.EvoCompleta := 0;
    end;
    if Contrato.MutDsk.Cad2.TemSerie then Rpa.Temp8.CodSerie := -1;
    if (RPA.Ctr > '') and (RPA.Mac = MAHoje) then GravaRpaData(Rpa,DataRpa,CriaRPA);
  end;

  TotPrest := RPA.ValRPA.TotPrest;
end;

procedure GravaRPA(Contrato: TContrato;
                   RPA: TpRpa;
                   MutMem: TpMutMem;
                   MAHoje : integer;
                   DataRPA : TData;
                   CriaRPA : boolean;
                   var TotPrest: real);
var
  i : integer;
  wArrComp : ^TpArrComp;
begin
  for i := 0 to Contrato.Series.Count - 1 do begin
    RPA := Contrato.Series[i].RPAS;
    if Rpa.MAC<>MAHoje then begin  // SCAt 36068
      RPA.FinRPA.Status := 11; RPA.ValRPA.MacStatus := RPA.MAC;
      ZeraPrest(RPA); ZeraSaldos(RPA); RPA.MAC := MAHoje;
    end;
    if (RPA.Ctr > '') and (Rpa.Mac = MAHoje) then GravaRpaData(Rpa,DataRpa,CriaRPA);
  end;
  Rpa := Contrato.Rpa;
  Rpa.Temp8.CodSerie := 0;
  if Rpa.MAC<>MAHoje then begin   //SCAt 36068
    RPA.FinRPA.Status := 11; RPA.ValRPA.MacStatus := RPA.MAC;
    ZeraPrest(RPA); ZeraSaldos(RPA); RPA.MAC := MAHoje;
  end;
  if (Rpa.Ctr > '') and (Rpa.Mac = MAHoje) and MutMem.MutDsk.Cad2.TemSerie then
    GravaRpaData(Rpa,DataRpa,CriaRPA);
  if TemFinancDinamico(MutMem.MutDsk) or not MutMem.Mutdsk.cad2.TemSerie then begin
    if (MutMem.MutDsk.Financ.Status = 0) then begin
      RPA := Contrato.RPAF;
      RPA.Temp5.EvoCompleta := 1;
    end
    else begin
      MutMem.Hist[0].Tam := 0;
      Getmem(wArrComp,sizeof(TpArrComp));
      try
        wArrComp^ := Contrato.GetArrComp;
        Init_RPA(MutMem,RPA,wArrComp^,Contrato.ApolicesMistas,
                  Contrato.ContratosCorrelacionados,
                  false{InibeLegLink}(*$IFDEF CONSOLE*),Contrato.GrupoImv(*$ENDIF*));
      finally
        freemem(wArrcomp);
      end;
      RPA.MAC := MAHoje;
      RPA.Temp5.EvoCompleta := 0;
    end;
    if MutMem.MutDsk.Cad2.TemSerie then Rpa.Temp8.CodSerie := -1;
    if (RPA.Ctr > '') and (RPA.Mac = MAHoje) then GravaRpaData(Rpa,DataRpa,CriaRPA);
  end;
  MutMem.MutDsk := Contrato.MutDsk;
  TotPrest := RPA.ValRPA.TotPrest;
end;

procedure FastRPA(Var MutDsk : TpMutdsk;
                      NaoConsideraMesAnterior : boolean;
                      DataRef : TData;
                      DataHist : Tdata;
                      DataRPA : TData;
                      CriaRPA : boolean;
                  Var TotPrest : real;
                      ValFinancOrigComAgioeDesagio : boolean = false;
                      MAFinal: integer = 0);
var
//  LiberacoesPlanoEmp : TLiberacoesPlanoEmp;
//  LaudoVistoria : TLaudoVistoria;
//  IniRPA : boolean;
  Contrato : TContrato;
//  EvoCompleta : byte;
  i : integer;
  MutMem : TpMutMem;
  RPA : TpRPA;
  RPAnt : TpRPA;
//  ArqRPAnt : TArqRpaDsk;
//  MAAnt : TMes_Ano;
//  HEvo : TpHistEvo;
  MAHoje : integer;
  // wArrComp : ^TpArrComp;
  DtAux: TData;
begin
  MutMem.Mutdsk.Cad.ctr := '';
  fillchar(mutMem,sizeof(TpMutMem),0);
  Rpa.Ctr := '';
  fillchar(RPA,sizeof(TpRPA),0);
  RPAnt.Ctr := '';
  fillchar(RPAnt,sizeof(TpRPA),0);
//  HEvo[0].tam := 0;
//  fillchar(HEvo,sizeof(TpHistEvo),0);

  TotPrest := 0;
  MAHoje := mes_int(DataRef.MesAno);
  
  if CriaRPA then
    ZeraRPAEmDisco(Mutdsk.cad.Ctr,DataRef.MesAno);
  
  MutMem.MutDsk := Mutdsk;
//  if MutMem.MutDsk.Cad2.TemSerie or
//     MutMem.MutDsk.Cad6.TemVendedores or
//     TemFinancDinamico(MutMem.MutDsk) then begin
    Contrato := TContrato.Create;
    try
      Contrato.ValFinancOrigComAgioeDesagio := ValFinancOrigComAgioeDesagio;
      Contrato.Le( MutMem.MutDsk );
      if NaoConsideraMesAnterior then
        Contrato.InicRPA
      else
        Contrato.ObtemRPA(MAHoje-1);
      if MAFinal > 0 then begin
        while Contrato.RPA.Mac < MAFinal do begin
          Contrato.Evolui;
          if Contrato.RPA.Mac >= MAHoje then begin
            DtAux := DataRpa;
            int_mes(Contrato.RPA.Mac, DtAux.mesano);
            if CriaRPA then
              ZeraRPAEmDisco(Mutdsk.cad.Ctr,DtAux.MesAno);
            GravaRPA(Contrato, RPA, MutMem, Contrato.RPA.Mac, DtAux, CriaRPA, TotPrest);
          end;
        end;
      end
