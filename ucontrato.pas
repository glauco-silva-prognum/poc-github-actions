function LogDeTermino(    Serie : TSerie;
                      Var FichaEdit : TpFichaEdit;
                      Var DtEvento : Tdata;
                          TrataTermDaPropriaSerie : boolean = true) : boolean;
var
  PtrAux         : TpPtrFicha;
begin
  result := false;
  fillchar(DtEvento,sizeof(TData),0);
  PtrAux := FichaEdit.PtrFicha;
  while (PtrAux <> nil) do begin
    if ((PtrAux^.Ficha.CodSerie = Serie.Fin.CodSerie) and TrataTermDaPropriaSerie) or
       (PtrAux^.Ficha.CodSerie <> Serie.Fin.CodSerie) then begin

      if (not PtrAux^.Ficha.MarcaDat) and
        ((PtrAux^.Ficha.CodSerie = Serie.Fin.CodSerie) or
         ((FichaEdit.Log.CodMov in CodMovTratadoPorSerieSet) and
          (PtrAux^.Ficha.CodSerie <> -1) and
          (Juliano(FichaEdit.Log.Data) >= Juliano(Serie.Fin.DataRef))) or
         (PtrAux^.Ficha.Campo = 235)) then begin
         if PtrAux^.Ficha.Campo = 43 then begin
           if (PtrAux^.Ficha.ValByte <> 98) and
              ((PtrAux^.Ficha.ValByte in OpcoesDeTerminoSet) or
               ((PtrAux^.Ficha.ValByte = 71) and (Serie.Fin.CodClassificacao <> serie_acordo))) then begin
             result := true;
             DtEvento.MesAno := PtrAux^.Ficha.MesAno;
           end;
         end
         else if PtrAux^.Ficha.Campo = 47 then
           DtEvento.Dia := PtrAux^.Ficha.ValByte;
      end; (* if *)
    end;
    PtrAux := PtrAux^.Prox;
  end; (* while *)
  if DtEvento.dia = 0 then
    if Serie.Fin.DiaVenc > 0 then
      DtEvento.dia := Serie.Fin.DiaVenc
    else
      DtEvento.dia := Serie.Fin.DtInicio.dia;
end;

procedure TSeries.MarcaTerminosAposPrimeiroTermino(var TempHistMem : TpHistEdit;
                                                       CodSerie : longint);
var
  I : byte;
  DtEvento,
  DtPrimeiroTermino : tdata;
  wSerie : TSerie;
  indice : integer;
begin
  DtEvento.dia := 0; DtEvento.mes := 0; DtEvento.ano := 0;
  DtPrimeiroTermino.dia := 0; DtPrimeiroTermino.mes := 0; DtPrimeiroTermino.ano := 0;
  indice := Indexof(CodSerie);
  // Se achou a s rie
  if indice > -1 then begin
    wSerie := GetSerie(indice);
    fillchar(DtPrimeiroTermino,sizeof(Tdata),0);

    // encontra primeiro t rmino
    for I := 1 to TempHistMem[0].Tam do
      if (Juliano(TempHistMem[I].Log.Data) <= Juliano(DataH)) and
         (not TempHistMem[I].Log.MarcaLog) then begin
        if LogDeTermino(wSerie,TempHistMem[i],DtEvento) then begin
          if (DtPrimeiroTermino.dia = 0) or
             (Juliano(DtEvento) < Juliano(DtPrimeiroTermino)) then
            DtPrimeiroTermino := DtEvento;
        end;
      end;

    // Marca t rminos posteriores ao primeiro t rmino
    if DtPrimeiroTermino.dia > 0 then
      for I := 1 to TempHistMem[0].Tam do
        if (Juliano(TempHistMem[I].Log.Data) <= Juliano(DataH)) and
           (not TempHistMem[I].Log.MarcaLog) then
          if LogDeTermino(wSerie,TempHistMem[I],DtEvento,false) then
            if Juliano(DtEvento) > Juliano(DtPrimeiroTermino) then
              TempHistMem[i].Log.MarcaLog := true;
  end;
end;

procedure TSeries.ProcessaHistSerie(const HistMem   : TpHistEdit;
                                    var   HEvoSerie : TpHistEvo;
                                          CodSerie  : longint);
var
  PtrAux         : TpPtrFicha;
  I              : Longint;
  MaxHistMemCopy : Smallint;
  TempHistMem    : TpHistEdit;
begin
  HEvoSerie[0].Tam := 0;
  TempHistMem := HistMem;
  MarcaTerminosAposPrimeiroTermino(TempHistMem,CodSerie);
  for I := 1 to TempHistMem[0].Tam do
//  Solic. 86450  if (Juliano(TempHistMem[I].Log.Data) <= Juliano(DataH)) and
    if (not TempHistMem[I].Log.MarcaLog) then begin
      PtrAux := TempHistMem[I].PtrFicha;
      MaxHistMemCopy := MaxHistMem;
      while (PtrAux <> nil) and (HEvoSerie[0].Tam < MaxHistMemCopy) do begin
        if ((not PtrAux^.Ficha.MarcaDat) or
            (TempHistMem[i].Log.CodMov in [42,45])) and
           (PtrAux^.Ficha.CodSerie <> -1) and
          ((PtrAux^.Ficha.CodSerie = CodSerie) or
           ((PtrAux^.Ficha.CodSerie = 0) and // 99318 - s  considerar o codmov se o codserie for zero no dat. N o quero for ar um dat de outra s rie a ser considerado.
            (TempHistMem[i].Log.CodMov in CodMovTratadoPorSerieSet)) or 
           (PtrAux^.Ficha.Campo in [42,47,151,235,223,221,238]) or
           (PtrAux^.Ficha.Campo = 286)) then begin
          // Sol. 072391 o log 45 renegocia  o foi inclu do somente 
          // para preencher as vari veis CoEvento e DtEvento
          // Mas n o deve ser processados. Ent o estamos marcando o dat
          // Sol. 72070 o log 42 incorpora  o foi inclu do usando a mesma
          // l gica do hist rico 45
          inc(HEvoSerie[0].Tam);
          HEvoSerie[HEvoSerie[0].Tam].Ficha := PtrAux^.Ficha;
          // Scat 75351 retirou o 42 Incorpora  o e passou a tratar o hist rico
          // Mas se o hist rico da s rie for diferente, deve inativar o hist rico
          // Neste caso ele s  deve entrar para marcar o Rpas.Temp12.CoEvento
          if (TempHistMem[i].Log.CodMov in [45]) or
             ((TempHistMem[i].Log.CodMov = 42) and (PtrAux^.Ficha.CodSerie <> CodSerie)) then  
            HEvoSerie[HEvoSerie[0].Tam].Ficha.MarcaDat := true;
          if CodMovTratadoAntesNaAssin(TempHistMem[i].Log.CodMov) then
            HEvoSerie[HEvoSerie[0].Tam].Ficha.ConsideraNaAssinatura := true; 
        end; (* if *)
        PtrAux := PtrAux^.Prox;
      end; (* while *)
    end; (* if e for *)
end;

