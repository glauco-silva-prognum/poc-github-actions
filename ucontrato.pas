       ((FDataRefHist.Dia = 0) or
        (Series[i].RPAS.MAC <= Mes_Int(FDataRefHist.MesAno))) then 
        DtIniCondAdversa := MontaDtIniCondAdversa(Series[i].RPAS,DtIniCondAdversa,FDataRefHist);

    end;

    Temp8.TemSerieAtiva := false;
    TemSerieComStatusZero := false;
    if not temFinancDinamico(MutDsk) then begin
      FcvsCobre := false;
      FinRPA.ValFinanc := 0;
      fillchar(DtAssin,sizeof(TData),0); // DtAssin e DtInFin do consolidado s  devem considerar o financ. din mico
      fillchar(Rpa.Temp8.DtAssinOrig,sizeof(TData),0); // DtAssin e DtInFin do consolidado s  devem considerar o financ. din mico
      fillchar(DtInFin,sizeof(Tdata),0); // se ele existir, sol. 32907
    end
    else
      Temp12.ValFinancOrig := RPAF.Temp12.ValFinancOrig;
    if not TemFinancDinamico(Mutdsk) or not Ctr_Ativo(RPAF) then
      CodErro := 0;
    if (CodErro<>0) and (TxPst <= Zero) then TxPst := 1.0;
    if TxSD <= Zero then TxSD := 1.0;
    for i := 0 to Series.Count -1 do 
    if Series[i].SerieValida(FDataRefHist) then with Series[i] do begin
      if not TemFinancDinamico(MutDsk) then begin
        MAC := RPAS.MAC;
        if (RPAS.FinRPA.ValAval>Zero) and (Temp5.MacAval <= RPAS.Temp5.MacAval) then begin
          FinRPA.ValAval   := RPAS.FinRPA.ValAval;
          Temp5.MACAVal    := RPAS.Temp5.MACAval;
          Temp12.ValAvalCorr := RPAS.Temp12.ValAvalCorr;
          Temp12.DiaReavaliacao := RPAS.Temp12.DiaReavaliacao;
        end;

        if (MutDsk.Cad.TipoCtr = 48) then begin
          if (Series[i].Fin.Status = 0) and
             (RPAF.Temp12.ValFinancOrig <= Zero) and
             (Series[i].Fin.CompoeSaldo) and
             ((Series[i].Fin.CodClassificacao in Tipo48ClassificacaoOk) or
              (Series[i].Fin.CodClassificacao = 23)) and
             ((Series[i].RPAS.FinRPA.Status=0) or 
              (Series[i].RPAS.ValRPA.MACStatus = RPAF.Mac) or
              ((Series[i].RPAS.FinRPA.Status=30) and SerieRenegEstaAtiva(Series[i].Fin.Co_Serie_Reneg,RPAF.MAC))) then
            Temp12.ValFinancOrig := Temp12.ValFinancOrig + RPAS.Temp12.ValFinancOrig
          else
            RPAS.Temp12.ValFinancOrig := 0;  { zerando as s ries n o utilizadas }
        end
        else begin
         if (Series[i].Fin.CompoeSaldo) and
            (Series[i].Fin.CodClassificacao in Tipo48ClassificacaoOk) and
            (Series[i].Fin.Status = 0) and
            (RPAF.Temp12.ValFinancOrig <= Zero) then
           Temp12.ValFinancOrig := Temp12.ValFinancOrig + RPAS.Temp12.ValFinancOrig
         else
           RPAS.Temp12.ValFinancOrig := 0;  { zerando as s ries n o utilizadas }
        end;


(*        if (RpaS.FinRpa.ValFinanc > zero) and
           (Series[i].Fin.Status = 0) and
           (Series[i].Fin.CompoeSaldo) and
           (((Mutdsk.Cad.TipoCtr <> 48) and
             (Series[i].Fin.CodClassificacao in ClassificacaoOk) and
             (Juliano(Series[i].fin.DataRef) = MenorDataFinanc)) or
            ((Mutdsk.Cad.TipoCtr = 48) and
             ((Series[i].Fin.CodClassificacao in ClassificacaoOk) or
              (Series[i].Fin.CodClassificacao = 23)))) then 
          FinRPA.ValFinanc := FinRPA.ValFinanc + RPAS.FinRPA.ValFinanc;
*)
        if (RPAS.FinRPA.ValFinanc>Zero) and (Fin.CompoeSaldo) and (not (RPAS.FinRPA.Status in [30{Ren},4{T.Outros}])) then
          FinRPA.ValFinanc := FinRPA.ValFinanc + RPAS.FinRPA.ValFinanc;

      end
      else
        RPAS.Temp12.ValFinancOrig := 0;  { zerando as s ries n o utilizadas }
      
      Temp2.FezOPC := Temp2.FezOPC or RPAS.Temp2.FezOPC;
      Temp3.FezOpc2 := Temp3.FezOpc2 or RPAS.Temp3.FezOpc2;
      Temp7.FezOpc3 := Temp7.FezOpc3 or RPAS.Temp7.FezOpc3;
      Temp7.FezOpc4 := Temp7.FezOpc4 or RPAS.Temp7.FezOpc4;
      Temp12.Recup_Judicial_Extra := Temp12.Recup_Judicial_Extra or RpaS.Temp12.Recup_Judicial_Extra;
      if (Temp12.DtEvento.dia = 0) or (Juliano(RPAS.Temp12.DtEvento) > Juliano(temp12.DtEvento)) then begin
        Temp12.DtEvento := RPAS.Temp12.DtEvento;
        Temp12.CoEvento := RPAS.Temp12.CoEvento;
      end;
      if not Temp12.Reestruturada then
        Temp12.Reestruturada := RPAS.Temp12.Reestruturada;
      // no consolidado s  fica verdadeiro, se TODAS as series forem
      Temp12.MantemValorDFI := Temp12.MantemValorDFI and RPAS.Temp12.MantemValorDFI;
      Temp12.MantemValorMIP := Temp12.MantemValorMIP and RPAS.Temp12.MantemValorMIP;

{      if not Temp12.COVID19 then
        Temp12.COVID19 := RPAS.Temp12.COVID19;
}     
      if Temp12.CondAdversa = 0 then
        Temp12.CondAdversa := RPAS.Temp12.CondAdversa;
      FinRPA.DonoCred := RPAS.FinRPA.DonoCred;
      if RPAS.Temp12.PreFixado then 
        Temp12.Prefixado := RPAS.Temp12.PreFixado;
      if (RPAF.FinRPA.LCobr = 0) or
         ((RPAS.FinRPA.LCobr > 0) and
          (RPAS.Mac >= RPAS.Temp12.MacPrestIniCessao) and
          (RPAS.Mac <= RPAS.Temp12.MacPrestFimCessao)) then // respeitar a cess o se houver, antes do cadmut
        FinRPA.LCobr := RPAS.FinRPA.LCobr; //SCAt 51302 + 51878 priorizar sempre o do cadmut
      if (Temp11.CodRisco = 0) or (RPAS.Temp11.CodRisco > Temp11.CodRisco) then
        Temp11.CodRisco := RPAS.Temp11.CodRisco;
      if ExOpc = 0 then ExOpc := RPAS.FinRpa.ExOpc;
      if ExAmInc = 0 then ExAmInc := RPAS.FinRpa.ExAmInc;
      if Temp3.ExSub = 0 then Temp3.ExSub := RPAS.Temp3.ExSub;
      if Temp5.Carteira=0 then begin
        Temp5.Carteira := RPAS.Temp5.Carteira;
        Temp6.EdoSFH   := RPAS.Temp6.EdoSFH;
      end;
      if Temp11.MATermDescSegMIP = 0 then 
