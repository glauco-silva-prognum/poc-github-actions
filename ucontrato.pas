function TDadosAtrasoEvo.TotalGeral : real;
begin
  result := TotPrest    - TotFGTS  + TotCorr  +
            TotMora     + TotDifer - TotDesc  - TotDescpagamento+
            TotHonor    + TotMulta + TotAcordo+ 
            TotSerie    +{ TotPoup +}TotDesp  +
            TotTaxaBanco - TotValorPagoAntecipado + TotResiduoCobrado + 
            TotIOFComp;
  if NPrest > 0 then
    result := result + Int(ValorTaxa*QtdeRecibos*100+0.5)/100;
end;

procedure TDadosAtrasoEvo.RecalculaPorValor(ValorDefPeloUsuario : real);
var
  i : SmallInt;
begin
  for i := 0 to count-1 do begin
    if not getPrestacao(i).Esconde then begin
      AjusteUltPrest := ValorDefPeloUsuario - (getPrestacao(i).ValTit + ValorTaxa);
      if Abs(AjusteUltPrest) > Zero then begin
        if AjusteUltPrest > Zero then
          AjusteUltPrest :=  Int(AjusteUltPrest*100+0.5)/100
        else
          AjusteUltPrest := -Int(Abs(AjusteUltPrest)*100+0.5)/100;

        getPrestacao(i).Diferenca := getPrestacao(i).Diferenca + AjusteUltPrest;
        getPrestacao(i).DifCalculada := getPrestacao(i).Difcalculada + AjusteUltPrest;
        getPrestacao(i).AJCompensavel := AjusteUltPrest;
        getPrestacao(i).ValTit := getPrestacao(i).ValTit + AjusteUltPrest;
      end;
    end
    else AjusteUltPrest := 0.0;
    if NPrest < PrstComPend then
      PrstComPend := 0;
    TotalizaDados;
  end;
end;

function TDadosAtrasoEvo.TemAtrasoParaMesAno(MAC : smallint) : boolean;
var
  TemAtraso  : boolean;
  i          : smallint;
begin
  TemAtraso  := false;
  i          := 0;
  while (i < count) and (not TemAtraso) do begin
    TemAtraso := TemAtraso or (GetPrestacao(i).MACPrst = MAC);
    inc(i);
  end;
  TemAtrasoParaMesAno := TemAtraso;
end;

