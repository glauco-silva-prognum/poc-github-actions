function TContrato.MacMinimoInicial(var MenorDataAssin : Tdata):Integer;

var
  i : integer;
begin
  { Todos os rpas precisam come ar em um mesmo mac, e ser  o memor mac da data de assinatura }
  { Para as s ries cuja a primeira presta  o ven a no mesmo mes da assinatura dever o chamar a evolui. }
  Result := 9999;
  MenorDataAssin.Dia := 0;
  fillchar(MenorDataAssin,sizeof(TData),0);
  if TemFinancDinamico(MutDsk) and (MutDsk.Financ.Status <> 98) then begin
    if RpaF.Mac < Result then 
      Result := RpaF.Mac;
    MenorDataAssin := MutDsk.Financ.DtAssin;
  end;
  for i := 0 to FSeries.Count-1 do begin
    if mes_int(FSeries.Serie[i].Fin.DataRef.MesAno) < Result then
      Result := mes_int(FSeries.Serie[i].Fin.DataRef.MesAno);
    if ((MenorDataAssin.Dia = 0) or 
        DataEMenor(FSeries.Serie[i].Fin.DataRef,MenorDataAssin)) and
        (FSeries.Serie[i].Fin.Status <> 98) then
      MenorDtAssin := FSeries.Serie[i].Fin.DataRef;
  end;
  if TemFinancDinamico(MutDsk) and (MutDsk.Financ.Status <> 98) then begin // O sistema n o suporta s ries com data de referencia anterior   assinatura.
    if Result < RpaF.Mac then Result := RpaF.Mac;
    MenorDataAssin := MutDsk.Financ.DtAssin;
  end;
end;

function TContrato.TemCA : boolean;
begin
  Result := false;
  if (scciconf.DtAssinParaCustoAmortizado.Dia > 0) and
     (MutDsk.Cad.TipoCtr <> 41{98550}) then begin
    if MenorDtAssin.Dia = 0 then begin
      if self.RPA.FinRPA.DtAssin.Dia > 0 then
        MenorDtAssin := self.RPA.FinRPA.DtAssin
      else
        MacMinimoInicial(MenorDtAssin);
    end;
    Result := (juliano(MenorDtAssin) >= juliano(scciconf.DtAssinParaCustoAmortizado));
  end;
end;

procedure TContrato.IniciaValoresVendedores(var aRpa:TpRpa);
var
  i: integer;
  ValFinanc: Double;
  Dt1, Dt2 : TData;
  MACAux   : integer;
  JurosFGTS,
  CorrFGTS,
  NJurosPoup : Double;
begin
  aRpa.Temp12.SaldoVendedores        := 0;
  aRpa.Temp12.CorrecaoVendedores     := 0;
  aRpa.Temp12.JurosVendedores        := 0;
  aRpa.Temp12.LiberacaoVendedores    := 0;
  aRpa.Temp12.DiaLiberacaoVendedores := 0;
  aRpa.Temp12.DiaLiberacaoFGTSConst  := 0;
  aRpa.Temp12.SaldoFgtsVendedores    := 0;
  aRpa.Temp12.CorrecaoFgtsVendedores := 0;
  aRpa.Temp12.JurosFgtsVendedores    := 0;
  aRpa.Temp12.LiberacaoFGTSVendedores:= 0;
  aRpa.Temp12.LibParcialVend         := 0;
  aRpa.Temp12.LibParcialFGTSVend     := 0;
  aRpa.Temp12.DtFGTSEntrada.DtStr    := #0#0#0;
  FInibeCorSdVendedor := false;
  i := 1;
  while (not FInibeCorSdVendedor) and (i <= ArrComp[0].Tam) do
  begin
    FInibeCorSdVendedor := FInibeCorSdVendedor or ((ArrComp[i].Cad.CompVend > 0) and
                                                   (ArrComp[i].Cad.InibeCorSdVendedor));
    i := i + 1;
  end;
  FInibeCorSdVendedor := FInibeCorSdVendedor or
                         ((aRpa.Temp7.TipoCtr = 40) and (scciconf.EvoluirSaldoVendedoresSemCorrJurParaCtrEmprestimo));
  // Verificar se tem vendedores com percentual de venda preenchido
  FTemVendedores := false;
  i := 1;
  while (not TemVendedores) and (i <= ArrComp[0].Tam) do
  begin
    FTemVendedores := FTemVendedores or ((ArrComp[i].Cad.CompVend > 0) and
                                       (ArrComp[i].Cad.PercPartImovel >0));
    i := i + 1;
  end;
  FTemFgtsApoioAConstrucao := false;
  if (MutDsk.Cad.TipoCtr = 49) and (MutDsk.Cad6.ValFGTSEntrada > Zero) then
    FTemFgtsApoioAConstrucao := true;
  if (FTemVendedores) or (FTemFgtsApoioAConstrucao) then
  begin
    // Soma os valores de Financiamento das s ries que comp e saldo e
    // Tem a data de refer ncia igual a data de assinatura
    if (FTemVendedores) then begin
      ValFinanc := MutDsk.Financ.ValFinanc;
      for i := 0 to Series.Count-1 do
      begin
        if Series[i].Fin.CompoeSaldo and
           (Juliano(MutDsk.Financ.DtAssin) = Juliano(Series[i].Fin.DataRef)) then
          ValFinanc := ValFinanc + Series[i].Fin.Valor;
      end;
      if MutDsk.Financ.PA = 40 {EGI} then 
        aRpa.Temp12.SaldoVendedores := ValFinanc
      else
        aRpa.Temp12.SaldoVendedores := ValFinanc -
                                       MutDsk.Cad6.ValInterveniente -
                                       Mutdsk.Cad6.TaxaIncorporadaFinanc -
                                       MutDsk.Cad6.SaldoRefin+
                                       MutDsk.Cad6.VaBonusFundingFgts;
      aRpa.temp12.SaldoPrincVend         := aRpa.Temp12.SaldoVendedores;
    end;

    aRpa.Temp12.DtFGTSEntrada          := MutDsk.Cad6.DtFGTSEntrada;
    aRpa.Temp12.SaldoFgtsVendedores    := MutDsk.Cad6.ValFgtsEntrada - MutDsk.Cad6.ValFGTSInterveniente;
    aRpa.Temp12.SaldoFGTSPrincVend     := aRpa.Temp12.SaldoFgtsVendedores;
    if not TemFinancDinamico(MutDsk) then
    begin
      if MutDsk.Financ.DtAssin.Dia > 0  then 
        aRpa.FinRpa.DtAssin := MutDsk.Financ.DtAssin
      else
        aRpa.FinRpa.DtAssin := MenorDtAssin;
      if (MutDsk.Cad.TipoCtr = 42) and
         (Mes_Int(aRpa.Temp12.DtFGTSEntrada.MesAno) > 0) and
         (Mes_Int(aRpa.FinRpa.DtAssin.MesAno) = 0) and
//         ((Mes_Int(aRpa.FinRpa.DtAssin.MesAno) = 0) or
//         (juliano(aRpa.Temp12.DtFGTSEntrada) < juliano(aRpa.FinRpa.DtAssin))) and
         (aRpa.Temp12.SaldoFgtsVendedores > Zero) then
        aRpa.MAC := Mes_Int(aRpa.Temp12.DtFGTSEntrada.MesAno)
      else
        aRpa.MAC := Mes_Int(aRpa.FinRPA.DtAssin.MesAno);
    end;
    if (aRpa.Temp12.DtFGTSEntrada.Dia > 0) and
       (Mes_Int(aRpa.Temp12.DtFGTSEntrada.MesAno) < aRpa.MAC) then begin
      MACAux := Mes_Int(aRpa.Temp12.DtFGTSEntrada.MesAno);
      if aRpa.Temp12.DtFGTSEntrada.Dia >= aRpa.FinRpa.DtAssin.Dia then
        inc(MACAux);
      while MACAux < aRpa.MAC do begin
        Int_Mes(MACAux,Dt1.MesAno); Dt1.Dia := aRpa.Temp12.DtFGTSEntrada.Dia;
        Dt2 := Dt1;
        DecMA(Dt1.MesAno);
        if juliano(Dt1) < juliano(aRpa.Temp12.DtFGTSEntrada) then
          Dt1 := aRpa.Temp12.DtFGTSEntrada;
        if juliano(Dt1) <> juliano(Dt2) then begin
          CorrFGTS := arredonda(aRpa.Temp12.SaldoFGTSVendedores * (IndiceDiario(AjustaData293031ParaDia1(dt1),AjustaData293031ParaDia1(dt2),0)-1));
          aRpa.Temp12.CorrecaoFGTSVendedores := aRpa.Temp12.CorrecaoFGTSVendedores + CorrFGTS;
          aRpa.Temp12.SaldoFGTSVendedores := aRpa.Temp12.SaldoFGTSVendedores + CorrFGTS;
          aRpa.Temp12.SaldoFGTSPrincVend := aRpa.Temp12.SaldoFGTSVendedores;
          if (not RegCarteira.SdVendSemCorrJur) and (not FInibeCorSdVendedor) then begin
            if FTemFgtsApoioAConstrucao then
              NJurosPoup := NovosJurosPoupFgts(Dt1)
            else
              NJurosPoup := NovosJurosPoup(Dt1);
            if Scciconf.EvoluirSaldoVendedoresComJurosSimples then
              JurosFGTS := arredonda(aRpa.Temp12.SaldoFGTSPrincVend * NJurosPoup)
            else
              JurosFGTS := arredonda(aRpa.Temp12.SaldoFGTSVendedores * NJurosPoup);
  
            aRpa.Temp12.JurosFGTSVendedores := aRpa.Temp12.JurosFGTSVendedores + JurosFGTS;
  
            aRpa.Temp12.SaldoFGTSVendedores := aRpa.Temp12.SaldoFGTSVendedores + JurosFGTS;
            aRpa.Temp12.SaldoFGTSPrincVend := aRpa.Temp12.SaldoFGTSVendedores;
          end;
        end;
        inc(MACAux);
      end;
    end;
  end;
end;                                    

procedure TContrato.IniciaValoresDespesasComercializacaoADiferir(var aRpa:TpRpa);
var
  TotDesp,
  PercDiferimento : real;
begin
  if not TemFinancDinamico(MutDsk) then begin
    if MutDsk.Financ.DtAssin.Dia > 0 then 
      aRpa.FinRPA.DtAssin := MutDsk.Financ.DtAssin
    else
      aRpa.FinRPA.DtAssin := MenorDtAssin;
    aRpa.MAC            := Mes_Int(aRpa.FinRPA.DtAssin.MesAno);
  end;
  if (aRpa.FinRpa.DtAssin.ano <= 114) or Scciconf.Difere100PorCentoDasDespesasDeComissao then
    PercDiferimento := 100.00
  else if aRpa.FinRpa.DtAssin.ano = 115 then 
    PercDiferimento := 66.67
  else if aRpa.FinRpa.DtAssin.ano = 116 then 
    PercDiferimento := 33.34
  else PercDiferimento := 0;
  TotDesp := DespesasComercializacao.somaValorADiferir;
  aRpa.temp12.SaldoDiferidoComissao := arredonda(TotDesp*(PercDiferimento/100));
  aRpa.Temp12.ValApropComissao := TotDesp-aRpa.temp12.saldoDiferidoComissao;  
end;

procedure TContrato.IniciaValoresReceitasComercializacaoADiferir(var aRpa:TpRpa);
var
  TabValAberto : boolean;
  Qry : TSqlQuery;
begin
  if ReceitasComercializacao.Count > 0 then begin
    if Scciconf.TabelaVPTaxaAdm = 0 then
      FTaxaDescaptalizacaoTaxaAdmFundingFgts := MetaSelicCache.Le(MutDsk.Financ.DtAssin)
    else begin
      TabValAberto := AbriuTabVal;
      if not TabValAberto then
        AbreTabVal;
      FTaxaDescaptalizacaoTaxaAdmFundingFgts := LeCmTabPercMes(ScciConf.TabelaVPTaxaAdm,Mes_Int(MutDsk.Financ.DtAssin.MesAno));
      if not TabValAberto then
        FechaTabVal;
    end;
    if Abs(FTaxaDescaptalizacaoTaxaAdmFundingFgts) < Zero then
      FTaxaDescaptalizacaoTaxaAdmFundingFgts := 1;

    Qry := TSqlQuery.create(nil);
    try
      Qry.SqlConnection := GetSqlConnection(PegaDirTab);
      Qry.Sql.add('SELECT PE_LIMITE FROM FGTS_PERC_LIMITE ');
      Qry.Sql.add('WHERE DT_INICIO_VALIDADE <= :DtAssin ');
      Qry.Sql.add('AND DT_FIM_VALIDADE >= :DtAssin');
      Qry.parambyname('DtAssin').AsDateTime := DataToDateTime(MutDsk.Financ.DtAssin);
      Qry.open;
      if not Qry.Eof then begin
        if ((FTaxaDescaptalizacaoTaxaAdmFundingFgts - Qry.fieldbyname('PE_LIMITE').asfloat) > Zero) then
          FTaxaDescaptalizacaoTaxaAdmFundingFgts := Qry.fieldbyname('PE_LIMITE').asfloat;
      end;
      Qry.close;
    finally
      Qry.free;
    end;
    
    aRpa.temp12.SaldoDifJurosFGTS := ReceitasComercializacao.SomaDifJurosAdministracao;
    aRpa.temp12.SaldoDescTaxaFGTS := ReceitasComercializacao.SomaDescTaxaFGTS;
    FTaxaAdmFundingFgtsMensal := CalcAmaisj(1,MutDsk.Financ.Prazo,
      aRpa.temp12.SaldoDescTaxaFGTS, FTaxaDescaptalizacaoTaxaAdmFundingFgts/1200);
    if not TemFinancDinamico(MutDsk) then begin
      if MutDsk.Financ.DtAssin.Dia > 0 then 
        aRpa.FinRPA.DtAssin := MutDsk.Financ.DtAssin
      else
        aRpa.FinRPA.DtAssin := MenorDtAssin;
      aRpa.MAC            := Mes_Int(aRpa.FinRPA.DtAssin.MesAno);
    end;
  end;
end;

