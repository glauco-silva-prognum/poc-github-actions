          Temp11.LiberaJurNaInd := RPAS.Temp11.LiberaJurNaInd;
        end;
        if StripStr(Temp11.CodApoliceDFI) = '' then
          Temp11.CodApoliceDFI := RPAS.Temp11.CodApoliceDFI;
      end;
      if RPAS.Temp11.IdadeIniGrupoApolice > 0 then
        Temp11.IdadeIniGrupoApolice := RPAS.Temp11.IdadeIniGrupoApolice;
      if Temp11.MacIniSeguro = 0 then
