procedure TValoresPorMac.AjustaRPA_2(MacIni,MacFim : smallint);
begin
{ Valores do ValRPA que precisam ser atualizados por esta rotina
  Esta rotina   utilizada no c lculo de atraso da ucontrato.
  Equivalentes ao TpValores:
                       SaldoDev,   AmaisJ,
                       SegFin,     SegImv,
                       SegCre,     Seguro,
                       FCVS,       ValTxAdm,
                       RARD,       FGTS,
                       Residuo,    CotaFGTS,
                       TotPrest,   Juro,
                       TetoFGTS,   Intermediaria,
                       ValorAIFGTS,TotAmAcum,
                       Desc,       Honorarios,
                       Despesas,   Diferenca,
                       Recorr ,    TxAcumDis  : real;
}
  AjustaMoeda2(MacIni,MacFim,SaldoDev);
  AjustaMoeda2(MacIni,MacFim,CorrSaldo);
  AjustaMoeda2(MacIni,MacFim,AmaisJ);
  AjustaMoeda2(MacIni,MacFim,SegFin);
  AjustaMoeda2(MacIni,MacFim,SegImv);
  AjustaMoeda2(MacIni,MacFim,SegCre);
  AjustaMoeda2(MacIni,MacFim,Seguro);
  AjustaMoeda2(MacIni,MacFim,FCVS);
  AjustaMoeda2(MacIni,MacFim,ValTxAdm);
  AjustaMoeda2(MacIni,MacFim,RARD);
  AjustaMoeda2(MacIni,MacFim,FGTS);
  AjustaMoeda2(MacIni,MacFim,Residuo);
  AjustaMoeda2(MacIni,MacFim,CotaFGTS);
  AjustaMoeda2(MacIni,MacFim,TotPrest);
  AjustaMoeda2(MacIni,MacFim,Juro);
//  AjustaMoeda2(MacIni,MacFim,TetoFGTS);
  AjustaMoeda2(MacIni,MacFim,Intermediaria);
//  AjustaMoeda2(MacIni,MacFim,ValorAIFGTS);
//  AjustaMoeda2(MacIni,MacFim,TotAmAcum);
  AjustaMoeda2(MacIni,MacFim,Desc);
  AjustaMoeda2(MacIni,MacFim,Honorarios);
  AjustaMoeda2(MacIni,MacFim,Despesas);
  AjustaMoeda2(MacIni,MacFim,Diferenca);
//  AjustaMoeda2(MacIni,MacFim,Recorr);
//  AjustaMoeda2(MacIni,MacFim,TxAcumDis);
  SegFin := Seguro - SegImv - SegCre;
  AmaisJ := TotPrest-(Seguro+ValTxAdm+FCVS+Intermediaria-FGTS);
  AjustaMoeda2(MacIni,MacFim,AmortNegMes);
  AjustaMoeda2(MacIni,MacFim,SaldoAmortNeg);
  AjustaMoeda2(MacIni,MacFim,CorrSaldoAmortNeg);
end;

procedure TValoresPorMac.AtualizaTotPrest;
begin
  if Plano div 10 = HIP then
    TotPrest := Arredonda(AmaisJ + Seguro +ValTxAdm-FGTS+Intermediaria - ResiduoMes)
  else
    TotPrest := Arredonda(AmaisJ + Seguro + ValTxAdm + FCVS+Intermediaria-FGTS - ResiduoMes);
end;

function TValoresPorMac.TemOpcao(n:SmallInt) : boolean;
begin
  result := sccilib.TemOpcao(FezOpc,FezOpc2,FezOpc3,FezOpc4,n);
end;

function TValoresPorMac.TemCessaoNaData(Data : TData): boolean;
var
  DtCessao : TData;
begin
  result := false;
  if (Donocred > 0) and (ValCed > zero) and (not CessaoComAdministracao) then begin
    DtCessao.Dia := DiaCessao;
    int_mes(MacDono,DtCessao.MesAno);
    result := juliano(Data) >= juliano(DtCessao);
  end;
end;

function TValoresPorMac.TemQuitAnteriorARef(DataRef : Tdata): boolean;
var
  DtEvento : TData;
begin
  result := false;
  if Status = 1 then begin
    int_mes(MacStatus,DtEvento.mesano);
    DtEvento.dia := dialiq;
    if DtEvento.dia = 0 then
      DtEvento.dia := diavenc;
    result := Juliano(DtEvento) < Juliano(DataRef);
  end;
end;

function TValoresPorMac.TemTermAnteriorARef(DataRef : Tdata): boolean;
var
  DtEvento : TData;
begin
  result := false;
  if Status in [2..5,7,9,10,94] then begin
    int_mes(MacStatus,DtEvento.mesano);
    DtEvento.dia := dialiq;
    if DtEvento.dia = 0 then
      DtEvento.dia := diavenc;
    result := Juliano(DtEvento) < Juliano(DataRef);
  end;
end;

function TValoresPormac.PrestReman : integer;
var
  PZ     : SmallInt;
  DiaAux : byte;
begin
  if ((ExOpc=17) or (ExOpc=116)) and (NovoPrazo<>PrazoAnt) and (NovoPrazo > 0) then begin
    if ((scciconf.IniPstReneg) or (IniPrst=1)) then
      result := NovoPrazo
    else begin
      if (DiaLiq < DiaVenc) then
        result := NovoPrazo - NPC + 1
      else result := NovoPrazo - NPC;
    end;
  end
  else begin
    if NPC = 0 then result := Prazo - OldNPC
    else if NPC = 1 then result := Prazo
    else begin
      if DiaAmInc > 0 then DiaAux := DiaAmInc else DiaAux := DiaLiq;
      if (DiaAux >= byte(DiaVenc)) then begin
        PZ := Prazo - NPC;
        if (ExOpc <> 18) and (ExAmInc <> 18) then result := PZ - NPAI
        else result := PZ;
      end
      else result := Prazo - NPC + 1;
    end;
  end;
  if result < 0 then result := 0;
end;

function TValoresPorMac.CtrSusp : boolean;
begin
  result := CTR_SUSPENSO(CodSusp,DtInFin);
end;

procedure TValoresPorMac.IdentificaParcela(Var ParcSerieAntec : boolean;
                                           Var TipoParc,
                                               NumParcSerie : integer;
                                           Var TemPgParcial : boolean);
begin
  // Mesma l gica do TSerie.IdentificaParcela
  if assigned(ParcelaDoMes) and
    (ParcelaDoMes.TipoPg in PgtoComRedSdDev) and
    (ParcelaDoMes.DtPg.Dia > 0) then
    ParcSerieAntec:= true;
  if assigned(ParcelaDoMes) and TemParcNoMes then begin
    if ParcSerieAntec then
      TipoParc     := 7
    else
      TipoParc     := 6;
    NumParcSerie := TParcelaSerie(ParcelaDoMes).Seq;
  end
  else if (abs(amaisj)<=0) and (Seguro+ValTxAdm > 0) then begin 
    // 91858 - somente parcela de acess rios deve ter o tipoparc 7
    //         estava setando 7 incorretamente para financ. din mico, sem antecipa  o
    //         erro verificado na emiss o consolidada
    TipoParc     := 7;
    NumParcSerie := mac;
  end
  else begin
    TipoParc := 0;
    NumParcSerie := 0;
  end;
  
  TemPgParcial := assigned(ParcelaDomes) and
                  ParcelaDomes.TemPgParcial;
end;

function TValoresPorMac.EParcelaDeSeguro : boolean;
Var 
  ParcSerieAntec : boolean;
  TipoParc,
  NumParcSerie : integer;
  TemPgParcial : boolean;
begin
  ParcSerieAntec := false;
  TipoParc := 0;
  NumParcSerie := 0;
  TemPgParcial := false;

  IdentificaParcela(ParcSerieAntec,TipoParc,
                    NumParcSerie,TemPgParcial);  

  result := TipoParc = 7;
end;

