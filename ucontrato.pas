function TSerie.EstaPagaRpaS(DataRef:TData):boolean;
begin
  Result := false;
  if assigned(FParcelaDoMes) then begin
    if (FParcelaDoMes.DtPg.Dia > 0) and
       (Juliano(FParcelaDoMes.DtPg) <= juliano(DataRef)) and
       (not (FParcelaDoMes.TipoPg in [8..9,66,74,95,51,108,110,111,114,115,117,121,200,253])) then begin
      if (FParcelaDoMes.TipoPg in PgtoComRedSdDev) and (RpaS.ValRPA.Seguro > Zero) then
        Result := (FParcelaDoMes.DtPgSeg.Dia > 0) and
                  (not (FParcelaDoMes.TipoPgSeg in [8..9,66,74,108,110,114,117,95,121,200,253])) and
                  (Juliano(FParcelaDoMes.DtPgSeg) <= juliano(DataRef))
      else
        Result := true;
    end;
  end;

end;

