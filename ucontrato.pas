function TSerieFinanciamentoDinamico.NumPrstAtraso4(    DtRef : Tdata;
                                                        pStatus,
                                                        pMacStatus,
                                                        pMAC,
                                                        pDiaLiq,
                                                        pDiaVenc,
                                                        pDiaVenc1aPrest : integer;
                                                        pDtInFin : TData;
                                                        pDesconsideraPrstNoDiaSin : boolean;
                                                        pUF : str3;
                                                        pCodMun : smallint) : smallint;
var
  Mac,
  resultado,
//  Indice,
  DiaVenc   : SmallInt;
  DtInFin,
  DtFim,
  DtIsen,
  DtUltVenc : Tdata;
  Parcela : TParcela;
begin
  DtIsen.Dia := 0; DtIsen.Mes := 0; DtIsen.ano := 0;
  resultado := 0;
  if (not(Contrato.MutDsk.Financ.Status in StatusTermino)) and
     (not(Contrato.MutDsk.Cad.TipoCtr in [1,2])) then begin

    { Determinando inicio do financiamento }
    if ((Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1) < Mes_Int(Contrato.MutDsk.Financ.DtAssin.MesAno)) then begin
      DtInFin := Contrato.MutDsk.Financ.DtAssin;
      DecMA(DtInFin.MesAno);
    end
    else DtInFin := Contrato.MutDsk.Financ.DtInFin;

    DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),Contrato.MutDsk.Financ.DtInFin.Dia);

    //LeDtPgto(MutDsk.Cad.Ctr,DtInFin);  vai usar a leitura dos pagamentos locais

    { Determinando ultimo mes }
    DtFim := DtRef;
    if not CTR_ATV(pStatus,pMacStatus,
                   pMAC,pDiaLiq,
                   pDiaVenc,
                   pDtInFin,
                   pDesconsideraPrstNoDiaSin) then begin
      if pDiaLiq > 0 then
        DtFim.dia := pDialiq
      else DtFim.Dia := pDiaVenc;
      int_Mes(pMacStatus,DtFim.MesAno);

      (* A condicao a baixo e' necessaria porque no caso de termino de
         prazo, o dialiq do mes do termino e' prenchido com o diavenc,
         e no caso do termino ser em fevereiro, com o contrato vencendo
         no dia 30, a evolucao ajusta tando o dialiq, quanto o dia venc
         do rpa de fevereiro para 28 ( ou 29 ). Entretanto no rparef, que
         pode ser de outro mes, estara' com o diavenc 30. Neste caso
         para a rotina ctr_ativo, que espera um rpa do mes do termino,
         funcionar adequadamente para termino de prazo, o diavenc esta'
         sendo passado como o dia do termino. ( No exemplo dia 28).

         Para compatibilizar com a evolucao, no caso do dialiq ser zero,
         este sera' mantido, para que esta rotina reproduza o mesmo erro
         da evolucao. O erro ocorre quando foi feito um historico de
         tpz em conversao sem o dialiq. Nesta situacao a evolucao nao
         preenche o dialiq, e a funcao ctrativo considera o contrato
         como inativo no mes do termino. Este comportamento nao e' o
         esperado, uma vez que os contratos estao ativos no mes do seu
         termino por prazo. *)
      if (pMacStatus = Mes_Int(pDtInfin.MesAno)+1) and
         (pDiaVenc1aPrest in [1..31]) then
        DiaVenc := pDiaVenc1aPrest
      else
        DiaVenc := pDtInFin.Dia;
      if (pStatus = 8) and (pDiaLiq > 0) then
        DiaVenc := pDiaLiq;
      if not CTR_ATV(pStatus,pMacStatus,
                     pMACStatus,pDiaLiq,
                     DiaVenc,DtInFin,
                     pDesconsideraPrstNoDiaSin) then
        DecMA(DtFim.MesAno);
    end;

    { tratamento da isencao de mora }
    DtUltVenc := DtFim;
    if (Mes_int(DtInFin.MesAno) + 1 = Mes_Int(DtFim.MesAno)) and
       (Contrato.MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then
      DtUltVenc.dia := Dia_Venc(mes_int(DtUltVenc.mesano),Contrato.MutDsk.Financ3.DiaVenc1aPrest)
    else
      DtUltVenc.dia := Dia_Venc(mes_int(DtUltVenc.mesano),DtInFin.Dia);
    DtIsencaoMora(DtUltVenc,DtIsen,Contrato.MutDsk.Cad.DiaIsencao);
    if DiasDeAtrasoEntreDatas(DtIsen,DtRef,pUF,pCodMun) <= 0 then DecMA(DtFim.MesAno);
    DecMA(DtIsen.MesAno);
    if (Mes_int(DtInFin.MesAno) + 1 = Mes_Int(DtFim.MesAno)) and
       (Contrato.MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then
      DtIsen.dia := Dia_Venc(mes_int(DtIsen.mesano),Contrato.MutDsk.Financ3.DiaVenc1aPrest)
    else
      DtIsen.dia := Dia_Venc(mes_int(DtIsen.mesano),DtInFin.Dia);

    if DiasDeAtrasoEntreDatas(DtIsen,DtRef,pUF,pCodMun) <= 0 then decMA(DtFim.MesAno);
    { testando pagamento de prestacoes }
    for Mac := Mes_int(DtInFin.MesAno)+1 to Mes_int(DtFim.MesAno) do begin
      Parcela := Parcelas.ObtemParcelaPorMac(Mac);
      if not assigned(parcela) or not Parcela.EstaPaga(DtRef) then
        inc(Resultado);
    end;
  end;
  result := resultado;
end;

