end;

procedure TSerie.InicRPAS(ValMac:Integer; 
                          const MutDsk:TpMutDsk; const HEvoSerie : TpHistEvo;
                          NaoReajusta : boolean = false);
var
  MAPrimrepac{,nmeses,macinijur }: smallint;
  ValTaxaGestao: Double;
  DataRefParaReaj : Tdata;
  LegLinkItem : TLegLinkItem;
  RegApolice,
  RegApoliceDFI : TpApolice;
  DescApolice,
  DescApoliceDFI : ansistring;
  DtTermino : Tdata;
  LegLinkItemCoberturaMip : TLegLinkItem;
  DtAssinContrato : TData;
begin
  LegLinkItem   := nil;
  LegLinkItemCoberturaMip := nil;
