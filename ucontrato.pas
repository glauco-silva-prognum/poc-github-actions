procedure TSerie.ListaPrstAtrasoEvo(    DtRef : TData;
                                        DtAtr : Tdata;
                                    var ArrAtr : TArrayOfDatas;
                                        DesconsideraSeguroEmAtr : boolean = false;
                                        ConsideraAgenda : boolean = false);
var
  Reg : TValoresPorMac;
  i : integer;
  DtVenc : Tdata;
begin
  setLength(ArrAtr,0);
  i := mes_int(Fin.DataRef.MesAno);
  while (i <= Mes_int(DtRef.mesano)) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      Int_Mes(Reg.MAC,DtVenc.MesAno);
      if Reg.CtrAtivo then
        if assigned(Reg.ParcelaDoMes) and
           (Reg.TemParcNoMes or 
            ((not DesconsideraSeguroEmAtr) and (Reg.MAC > Mes_Int(Fin.Dataref.MesAno)))) and
           (((not (Fin.FinancBancario or (Fin.CodClassificacao = serie_Chaves))) and
             (Reg.TotPrest-Reg.Desc > Zero)) or
            ((Reg.NPC = 0) and
             (Reg.MAC > Mes_Int(Reg.DtAssin.MesAno)) and
             (Reg.TotPrest-Reg.Desc > Zero)) or
            ESerieFinBancChavesDevida(Reg.DtHabit,DtAtr)) then
            if EstaEmAtrasoAtualS(Reg,DtAtr) and
               (not Reg.ParcelaDoMes.EstaPagaReal) and
               (not ConsideraAgenda or not Contrato.PrestAgendada(Reg,DtRef)) then begin
              setLength(ArrAtr,length(ArrAtr)+1);
              int_mes(Reg.Mac,DtVenc.MesAno);
              DtVenc.dia := Reg.diavenc;
              ArrAtr[length(ArrAtr)-1] := DtVenc;
            end;
    end;
    inc(i);
  end;
end;

function TSerie.ObtemSaldoEventosAmIncAntesVenc(DataRef : TData): real;
var
  ValoresParaDataRef : TValoresPorMac;  
  DtEvento : TData;
  i : integer;
  JurosAmortAux : real;
begin
  // semelhante a nctb.TrataSaldosEventosAmInc - sol. 94342
  result := 0;
  DtEvento.dia := 0;
  fillchar(DtEvento,sizeof(Tdata),0);
  ValoresParaDataRef := ObtemValoresPorMac(mes_Int(DataRef.MesAno));
  if DataRef.dia < byte(ValoresParaDataRef.diaVenc) then begin // se o dia for igual ou posterior ao vencimento n o preciso calcular nada
    if (ValoresParaDataRef.Status <> 0) and (ValoresParaDataRef.MACStatus > 0) and
      ((ValoresParaDataRef.MACStatus < Mes_Int(DataRef.MesAno)) or 
      ((ValoresParaDataRef.MACStatus = Mes_Int(DataRef.MesAno)) and 
      (byte(ValoresParaDataRef.DiaLiq) < DataRef.Dia))) then begin
      Int_Mes(ValoresParaDataRef.MACStatus,DataRef.MesAno);
      if ValoresParaDataRef.DiaLiq > 0 then 
        DataRef.Dia := ValoresParaDataRef.DiaLiq
      else
        DataRef.Dia := ValoresParaDataRef.DiaVenc;
    end;
    Int_Mes(ValoresParaDataRef.MAC,DtEvento.MesAno);
    for i := 0 to ValoresParaDataRef.ListaEventosAmInc.Count-1 do begin
      DtEvento.Dia := ValoresParaDataRef.ListaEventosAmInc[i].DiaEvento;
      if ((ValoresParaDataRef.ListaEventosAmInc[i].ExAmInc in [18,103,105,114]))
                                 and
        (not ValoresParaDataRef.ListaEventosAmInc[i].MarcaDat) 
                                 and
       (
         (Juliano(DtEvento) <= juliano(DataRef)) or
        ((Mes_Int(DtEvento.MesAno) = ValoresParaDataRef.MACStatus) and 
         (ValoresParaDataRef.ListaEventosAmInc[i].ExAmInc in [103,105,114]) and //Amex
         (ValoresParaDataRef.Status = 8))
       )
                                 and
       ((Juliano(DtEvento) > juliano(ValoresParaDataRef.DtAssin)) or
        (ValoresParaDataRef.Status <> 20) or (ValoresParaDataRef.TipoCtr <> 45))                                 
                                 then begin
        if ValoresParaDataRef.ListaEventosAmInc[i].ExAmInc in [18,102,104,106,108]  then begin
          result := result + ValoresParaDataRef.ListaEventosAmInc[i].ValorAmInc;
        end
        else if ValoresParaDataRef.ListaEventosAmInc[i].ExAmInc in [21,103,105,114,121] then begin
          if ValoresParaDataRef.ListaEventosAmInc[i].ExAmInc in [103,105,114,121] then begin
            JurosAmortAux := ValoresParaDataRef.ListaEventosAmInc[i].JurosAmort;
            if {((not SCCIConf.CalculaProRataJurosSobreTotalNaAmExtra) or
                (SAtual.CodSerie > 0) sempre   s rie) and}
                (ValoresParaDataRef.ListaEventosAmInc[i].ValorAmInc      < Zero) and 
                (Abs(ValoresParaDataRef.ListaEventosAmInc[i].JurosAmort) > Zero) and
                (ValoresParaDataRef.ListaEventosAmInc[i].JurosAmort      < Zero)  then
              JurosAmortAux := Abs(ValoresParaDataRef.ListaEventosAmInc[i].JurosAmort);
            result := Arredonda(result + (ValoresParaDataRef.ListaEventosAmInc[i].ValorAmInc + ValoresParaDataRef.ListaEventosAmInc[i].CMProrataContabil + JurosAmortAux));
          end
          else begin
            result := Arredonda(result - (ValoresParaDataRef.ListaEventosAmInc[i].ValorAmInc - 
                                          ValoresParaDataRef.ListaEventosAmInc[i].CMProrataContabil));
          end;
        end;
      end;
    end;  
  end;
end;

