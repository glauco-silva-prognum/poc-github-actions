          GridSituacaoContrato.Add('DATA').AsString := data_str2(MutDsk.Cad.DtSitCobJ);
        end;
      if (Cad.SitCobJ > 0) then begin
        indice := Sit.add(AbvSitCj(Cad.SitCobj));
        sitcompleto := DescSitCj(Cad.SitCobj);
        GridSituacaoContrato := dados.Add('GRIDSITCTR');
        GridSituacaoContrato.Add('COD').AsString := IntToStr(MutDsk.Cad.SitCobJ);
        GridSituacaoContrato.Add('ABREV').AsString := Sit[indice];
        GridSituacaoContrato.Add('DESCR').AsString := Compstr(sitcompleto);
        GridSituacaoContrato.Add('DATA').AsString := data_str2(MutDsk.Cad.DtSitCobJ);
      end;
      if (Cad.SitCobJ2 > 0) then begin
        indice := Sit.add(AbvSitCj(Cad.SitCobj2));
        sitcompleto := DescSitCj(Cad.SitCobj2);
        GridSituacaoContrato := dados.Add('GRIDSITCTR');
        GridSituacaoContrato.Add('COD').AsString := IntToStr(MutDsk.Cad.SitCobJ2);
        GridSituacaoContrato.Add('ABREV').AsString := Sit[indice];
        GridSituacaoContrato.Add('DESCR').AsString := CompStr(sitcompleto);
        GridSituacaoContrato.Add('DATA').AsString := data_str2(MutDsk.Cad.DtSitCobJ2);
      end;

      Situacoes := TSitEspCtr.create;
      try
        Situacoes.LeSituacoes(Mutdsk.Cad.Ctr);
        for i := 0 to Situacoes.count-1 do
          if (Situacoes[i].SitEsp > 0) and sitlib.DataOk(Situacoes[i].DtExpSitEsp,DataH) then begin
            CodClienteSitEsp := CodClienteSit(Situacoes[i].SitEsp);
            if (CodClienteSitesp = 0) then  CodClienteSitEsp := Situacoes[i].SitEsp;
            indice := sit.add(AbvSit(Situacoes[i].SitEsp));
            SitCompleto := DescSit(Situacoes[i].SitEsp);
            GridSituacaoContrato := dados.Add('GRIDSITCTR');
            GridSituacaoContrato.Add('COD').AsString := intStr(CodClienteSitEsp);
            GridSituacaoContrato.Add('ABREV').AsString := Sit[indice];
            GridSituacaoContrato.Add('DESCR').AsString := Compstr(SitCompleto);
            GridSituacaoContrato.Add('DATA').AsString := data_str2(Situacoes[i].DtSitEsp);
          end;
      finally
        Situacoes.free;
      end;
    end;
  finally
    Sit.free;
  end;
end;

procedure ObtemStatusAdimp(Ctr: TpCtr; DadosXml: TpXmlNode);
var
  Qry: TSqlQuery;
  DiasAtraso: Integer;
  StatusAdimp: string;
begin
  StatusAdimp := 'N/A';
  DiasAtraso := 0;
  Qry := TSqlQuery.Create(nil);
  try
    Qry.SqlConnection := GetSqlConnection(PegaDirTab);
    Qry.Sql.Add('SELECT max(NU_DIAS_ATRASO) as DIAS from POSICAO_ATRASO ');
    Qry.Sql.Add('WHERE CO_CONTRATO=:CTR and DT_POSICAO_ATRASO=:DATA group by CO_CONTRATO');
    Qry.ParamByName('CTR').AsString := Ctr;
    Qry.ParamByName('DATA').asDateTime := DataToDateTime(DataH);
    Qry.Open;
    if not Qry.IsEmpty then begin
      DiasAtraso := Qry.FieldByName('DIAS').AsInteger;
      if DiasAtraso > 0 then
        StatusAdimp := 'Inadimplente'
      else
        StatusAdimp := 'Adimplente';
    end
    else begin
      StatusAdimp := 'N/A';
      DiasAtraso := 0;
    end;
  finally
    Qry.Free;
  end;
  DadosXml.AddOrGet('DISPLAY_STATUS_ADIMP').AsString := StatusAdimp;
  DadosXml.AddOrGet('DISPLAY_STATUS_ADIMP_DIAS').AsInteger := DiasAtraso;
end;

function RetornaPlanoStr(pl, PA, TipoCtr : integer; SuprimirPA40: Boolean = false) : string;
var
  PlanoStr : string;
  TipoDeCtr : SmallInt;
  Reg : TpPlanoConf;
begin
  PlanoStr := '';
  Reg.Abv := '';
  fillchar(Reg,sizeof(Reg),0);
  if (PA > 0) and (TipoCtr <> 33) then
    TipodeCtr := PA
  else
    TipoDeCtr := TipoCtr;
  case TipoDeCtr of
    01: PlanoStr := 'FinEmCst';
    02: PlanoStr := 'Comodato';
    03: PlanoStr := 'C.de Uso';
    08: PlanoStr := 'RefQuit70%';
    09: PlanoStr := 'RefQuit30%';
    10: PlanoStr := 'RefQuit ';
    11: PlanoStr := 'Fut. Aq.';
    13: PlanoStr := 'T.Pos.T.';
    14: PlanoStr := 'RefTpz  ';
    19: PlanoStr := 'FamiliaP';
    20: PlanoStr := 'FamiliaE';
    21: PlanoStr := 'ConjRed.';
    22: PlanoStr := 'V.Rurais';
    23: PlanoStr := 'Mutir o ';
    24: PlanoStr := 'Acordo  ';
    27: PlanoStr := 'Desfav. ';
    28: PlanoStr := 'PR SOL';
    29: PlanoStr := 'PHSP';
    30: PlanoStr := 'PSP' + '/'+SistAmort5[(pl mod 10)];
    31: PlanoStr := 'Ctrl.Taxas';
    33: if TipoCtr = 33 then
          PlanoStr := 'Plano Emp'
        else
          PlanoStr := 'D.Ressarc';
    34: PlanoStr := 'Cred.Assoc.';
    35: if TipoCtr = 35 then
          PlanoStr := 'C.CredInd'
        else
          PlanoStr := 'PROFI   ';
    36: if TipoCtr = 36 then
          PlanoStr := 'ProCotista'
        else
          PlanoStr := 'PROMO   ';
    37: PlanoStr := 'RD460/RES';
    38: PlanoStr := 'CSS POSSE'; { Obs.: o 39 est  livre, era o antigo prefixado }
    //50: PlanoStr := 'CCDRU   '; Scat 87301
    51: PlanoStr := 'PRU     ';
    65: PlanoStr := 'Plano A';
    83: PlanoStr := 'CFLote  ';
    84: PlanoStr := 'PlE     ';
    85: PlanoStr := 'MFeliz1R';
    86: PlanoStr := 'CUB     ';
    91: PlanoStr := 'Poup.FMH';
    92: PlanoStr := 'P1000/CCT';
    93: PlanoStr := 'SPL';
    94: PlanoStr := 'FUNCEF';
    95: PlanoStr := 'JUCA';
    100: PlanoStr := 'AMAR';
    else if (PA=40) and (not SuprimirPA40) then PlanoStr := DescrPA(PA) //93781
    else if (pl mod 10) = Alug  then PlanoStr := 'Aluguel'
    else if ScciConf.DescrevePCSComoNovoPES and (pl div 10 = PCS) then
      planoStr := 'NOVO PES'
    else if pl > 10 then begin
      PlanoStr := Plano[(pl div 10)];
      if trim(PlanoStr)<= '' then begin
        AbrePlanoConf;
        if LePlanoConf(pl,Reg) then
          PlanoStr := Reg.Abv;
        FechaPlanoConf;
      end;
      if trim(SistAmort5[(pl mod 10)]) > '' then
        PlanoStr := PlanoStr+'/'+SistAmort5[(pl mod 10)];
    end;
  end;
  result := PlanoStr;
end;

