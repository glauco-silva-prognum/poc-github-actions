procedure DeterminaInicio(Contrato : TContrato; Var DtInicio : Tdata);
var
  i : integer;
begin
  DtInicio := Contrato.MutDsk.Financ.DtInFin;
  incMa(DtInicio.MesAno);
  if DtInicio.dia > Dias_Mes(mes_int(DtInicio.mesano)) then
    DtInicio.dia := Dias_Mes(mes_int(DtInicio.mesano));
  for i := 0 to Contrato.Series.count - 1 do begin
    if Contrato.Series[i].Fin.CompoeSaldo or Contrato.Series[i].Fin.CompoeEntrada then begin
      if ((DtInicio.dia = 0) or
          ((juliano(Contrato.Series[i].Fin.DtInicio) > 0) and
           (Juliano(Contrato.Series[i].Fin.DtInicio) < Juliano(DtInicio)))) and
         (Contrato.Series[i].RPAS.FinRPA.Status <> 30) then
        DtInicio := Contrato.Series[i].Fin.DtInicio;
    end;
  end;
end;

function CalculaPrazoEmMeses(Contrato : TContrato; TerminosAntec : boolean = false; ConsiderarPrazoOrig : boolean = false): integer;
var
  Dt1aPrest,
  DtTerminoContratual,
  DtTerminoContratualSerie : TData;
  i : integer;
begin
  Dt1aPrest.Dia := 0;
  fillchar(Dt1aPrest,sizeof(TData),0);
  DtTerminoContratual.Dia := 0;
  fillchar(DtTerminoContratual,sizeof(TData),0);
  DtTerminoContratualSerie.Dia := 0;
  fillchar(DtTerminoContratualSerie,sizeof(TData),0);
  DeterminaInicio(Contrato,Dt1aPrest);
  if TemFinancDinamico(Contrato.MutDsk) then
    DeterminaTermino(Contrato.RPAF,DtTerminoContratual,ConsiderarPrazoOrig)
  else
    fillchar(DtTerminoContratual,sizeof(Tdata),0);
  for i := 0 to Contrato.Series.count - 1 do begin
    DeterminaTermino(Contrato.Series[i].RPAS,DtTerminoContratualSerie,TerminosAntec,ConsiderarPrazoOrig);
    if ((DtTerminoContratual.dia = 0) or
        (Juliano(DtTerminoContratualSerie) > Juliano(DtTerminoContratual))) and
       (Contrato.Series[i].RPAS.FinRPA.Status <> 30){Sol. 33387} then
      DtTerminoContratual := DtTerminoContratualSerie;
  end;
  if Mes_int(DtTerminoContratual.mesAno)>=Mes_int(Dt1aPrest.mesano) then
    result := Mes_int(DtTerminoContratual.mesAno)-Mes_int(Dt1aPrest.mesano)+1
  else result := 0;
end;

function CalculaPrazoEmMeses(RPA : TpRPA; TerminosAntec : boolean = false; ConsiderarPrazoOrig : boolean = false): integer;
var
  Dt1aPrest,
  DtTerminoContratual : TData;
begin
  Dt1aPrest.Dia := 0;
  fillchar(Dt1aPrest,sizeof(TData),0);
  DtTerminoContratual.Dia := 0;
  fillchar(DtTerminoContratual,sizeof(TData),0);

  Dt1aPrest := Rpa.FinRPA.DtInFin;
  incMa(Dt1aPrest.MesAno);
  if Dt1aPrest.dia > Dias_Mes(mes_int(Dt1aPrest.mesano)) then
    Dt1aPrest.dia := Dias_Mes(mes_int(Dt1aPrest.mesano));

  DeterminaTermino(RPA,DtTerminoContratual,TerminosAntec,ConsiderarPrazoOrig);

  if Mes_int(DtTerminoContratual.mesAno)>=Mes_int(Dt1aPrest.mesano) then
    result := Mes_int(DtTerminoContratual.mesAno)-Mes_int(Dt1aPrest.mesano)+1
  else result := 0;
end;

