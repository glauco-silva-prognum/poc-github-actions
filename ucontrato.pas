function FIndRata( dt1, dt2 : TData; CodTabelaGenerica:smallint; 
                   defas:byte;var IndInvalido : boolean; var dtIndInvalido : Tdata;
                   ProRataDC : boolean; 
                   UsaD2: boolean = false; // Se Scciconf.AnvpDtAssin estiver false, este par metro n o tem efeito e ser  considerado sempre true
                   ProRataMisto : boolean = false ):real;
var
  dt3:TData; UsaSerieD2 : boolean;
  repetido : boolean;
begin
  repetido := false;
  result := 0;
  
  {
    sol. 43804
    como a chamada da FIndRata ocorre para todas as parcelas e com mesmos par metros
    Svv sugeriu sempre verificar se a execu  o   exatamente a mesma da anterior e se for
    n o fazer de novo, como forma de otimiza  o, aproveitando o  ltimo resultado obtido
  }
  
  if juliano(dt1) = juliano(FIndRataReg.dt1) then
    if juliano(dt2) = juliano(FIndRataReg.dt2) then
      if codtabelagenerica = FIndRataReg.CodTabelaGenerica then
        if defas = FIndRataReg.defas then
          if proratadc = FIndRataReg.proratadc then
            if usad2 = FIndRataReg.usad2 then
              if proratamisto = FIndRataReg.proratamisto then begin
                result := FIndRataReg.resultado;
                IndInvalido := FIndRataReg.IndInvalido;
                DtIndInvalido := FIndRataReg.DtIndInvalido;
                repetido := true;
              end;

  if not repetido then begin
  //SCat 21402 - Esta rotina foi refeita para ficar compat vel com a calculadora
    dt3.dia := 0;
    fillchar(dt3,4,0); dt3.dummy := 3;
    dt3 := dt1; dt3.dia := dt2.dia;
    if dt3.dia < dt1.dia then INCMA(dt3.mesano);

  // A fun  o deve retornar apenas o indice pro-rata do primeiro mes
  // Para isto   criada dt3 que deve ser sempre a primeira data subsequente a dt1
  // Mas com dia igual ao de dt2.

    // Para as tabelas mensais a utiliza  o do flag D2 est 
    // associado a vari vel na aba das s ries se utiliza o indice do m s
    // para o primeiro pro-rata.
    // Para as tabelas diarias ou mistas, o flag da s rie n o   utilizado
    // E o comportamento depende da vari vel de configura  o
    // Usa s rie do dia da assinatura.
    // O flag UsaSerieD2 no caso de tabelas mensais determina que
    // o pro-rata   calculado com o indice do m s anterior para o m s de referencia
    if (CodTabelaGenerica>0) and (CodTabelaGenerica<>100) and
       IndiceMensal(CodTabelaGenerica) then
      UsaSerieD2 := UsaD2 // Scat 42633
    else
      UsaSerieD2 := (not Scciconf.AnvpDtAssin);
    if ((CodTabelaGenerica>0) and (CodTabelaGenerica<>100)) then begin
       if ProRataMisto then  // SCAt 52910
         result := CalcRataAss(Dt1,CodTabelaGenerica,defas,IndInvalido,DtIndInvalido)
       else
         result := IndiceTabGenerica(Dt1,Dt3,CodTabelaGenerica,false,UsaSerieD2,defas,IndInvalido,DtIndInvalido);
    end
    else begin
      int_mes(mes_int(dt1.mesAno)-defas,dt1.mesano); //SCAt 43747
      int_mes(mes_int(dt3.mesAno)-defas,dt3.mesano);
      if UsaSerieD2 then
        result := indicecmd( dt1,dt3,dt3,false,ProRataDC)
      else
        result := indicecmd( dt1,dt3,dt1,false,ProRataDC);
    end;

    FIndRataReg.dt1 := dt1;
    FIndRataReg.dt2 := dt2;
    FIndRataReg.CodTabelaGenerica := codtabelagenerica;
    FIndRataReg.defas := defas;
    FIndRataReg.proratadc := proratadc;
    FIndRataReg.usad2 := usad2;
    FIndRataReg.proratamisto := proratamisto;
    FIndRataReg.resultado := result;
    FIndRataReg.IndInvalido := IndInvalido;
    FIndRataReg.DtIndInvalido := DtIndInvalido;
  end;
end;

function detinddataadata( CodTabelaGenerica:smallint;defas:byte;
                          dt1,dt2: TData; TxProj : Real; 
                          TemProrata:boolean;
                          var IndInvalido : boolean;
                          var DtIndInvalido : tdata;
                              ProRataDC : boolean = false;
                              perfin:integer=1;
                              UsaIndiceMesPrimeiroProRata:Boolean=false;
                              proratamisto:Boolean=false;
                              CalcMes:Boolean=false;
                              LegLink : TLegLinkItem = nil) : real;
var dtprorata:TData; indrata,ni1,ni2 : real; difmeses,defu : integer; UltimoDiaMes : boolean;
begin
  dt1.Dummy := 3; dt2.dummy := 3;
  dtprorata := dt1; dtprorata.dia := dt2.dia;
  if (dtprorata.dia < dt1.dia) or ProrataMisto then INCMA(dtprorata.mesano);
  UltimoDiaMes :=  (Dt1.Dia>=DIAS_MES(mes_int(Dt1.MesAno))) and
                   (Dt2.Dia>=DIAS_MES(mes_int(Dt1.MesAno)));
  if CodTabelaGenerica<=0 then Result:=1.0
  else begin
    difmeses := (mes_int(Dt2.mesano) - mes_int(Dt1.mesano));
    if (TemProRata and (Dt1.Dia <> Dt2.Dia) and (not UltimoDiaMes) and
       ((Mes_Int(Dt2.MesAno)<>Mes_Int(Dt1.MesAno)) or (perfin=1))) or
       ProRataMisto then begin
      if DifMeses = 0 then 
        if ProrataMisto then begin
          IndRata := FIndRata( Dt1, dtprorata, CodTabelaGenerica, succ(defas),IndInvalido,DtIndInvalido,ProRataDC,
                           UsaIndiceMesPrimeiroProRata,false);
        end
        else IndRata := FIndRata( Dt1, dtprorata, CodTabelaGenerica, defas,IndInvalido,DtIndInvalido,ProRataDC,
                           UsaIndiceMesPrimeiroProRata,false)
      else IndRata := FIndRata( Dt1, dtprorata, CodTabelaGenerica, defas,IndInvalido,DtIndInvalido,ProRataDC,
                           UsaIndiceMesPrimeiroProRata,ProRataMisto);
    end
    else begin IndRata := 1.0; dtprorata.mesano := dt1.mesano; end;
    if  (difmeses > 1) or 
        ( (difmeses=1) and (dt2.dia >= dt1.dia) ) or
        (not TemProRata) then begin
      if ProRataMisto then defu := succ(defas) else defu := defas;
      if ProRataMisto and CalcMes then
        Result := CalcRataAss(dt1,CodTabelaGenerica,defas,IndInvalido,DtIndInvalido)
      else begin
        Result := ObtemIndDefas(CodTabelaGenerica,defu,dtprorata,IndInvalido,DtIndInvalido);
        ni1 := result;
        if Result>0.0 then begin
          if (Juliano(Dt2)>=Juliano(dtprorata)) then begin
            ni2 := ObtemIndDefas(CodTabelaGenerica,defu,Dt2,IndInvalido,DtIndInvalido);
            Result := ni2/ni1;
            if assigned(leglink) then begin
              LegLink.valores[' ndice para '+data_str2(dtprorata)] := formatfloat('0.000000000000',ni1);
              LegLink.valores[' ndice para '+data_str2(Dt2)] := formatfloat('0.000000000000',ni2);
            end;
          end
          else Result := 1.0;
          Result := Result*IndRata;
          if assigned(leglink) then
            LegLink.valores[' ndice pro rata'] := formatfloat('0.000000000000',IndRata);
        end
        else Result := TxProj;
      end
    end
    else Result := IndRata;
    if ProRataMisto and (difmeses > 0) then Result:=Result*CalcRataVenc(Dt2,CodTabelaGenerica,defas,IndInvalido,DtIndInvalido);
    if (Result <=Zero) or IndInvalido then Result := TxProj;
    if Result <=Zero then Result := 1.0;
    Result := int(Result*100000000+0.5)/100000000;
  end;
end;

procedure ObtemDadosPendCtr(    Contrato : TContrato;
                                RegLCobr : TpTabLCobr;
                            var DadosPend: TpTotPend;
                                DtVenc,
                                DataRef  : TData;
                                ValPrest : real;
                                IgnoraDtTetoPend,
                                GravaPendEmi : boolean;
                                IgnoraPendenciaManual : boolean = false);
var
  Dt,
  DtIniPend : TData;
  UPF       : real;
begin
  DtIniPend.dia := 0; DtIniPend.Mes := 0; DtIniPend.Ano := 0;
  Contrato.RetornaDtTetoPend(DtIniPend);
  if IgnoraDtTetoPend then begin
     DtIniPend.dia := 01;
     DtIniPend.mes := 12;
     DtIniPend.Ano := 199;
  end;
  fillchar(DadosPend,sizeof(TpTotPend),0);
  if not IgnoraPendenciaManual then 
    DadosPend.PendMan := ObtemPendManual(Contrato.MutDsk,0,Mes_Int(DtVenc.MesAno),
                                         Mes_Int(DtVenc.MesAno),DataRef,ValPrest);
  int_mes(mes_int(DataRef.MesAno)-RegLCobr.DefasagemCobAcFinanc,Dt.MesAno);
  if DataRef.dia > Dias_mes(mes_int(Dt.MesAno)) then Dt.Dia := Dias_mes(mes_int(Dt.MesAno))
  else Dt.Dia := DataRef.Dia;
  if juliano(DtVenc) >= juliano(DtIniPend) then begin
    DadosPend.PendCalc := Contrato.CalculaAcertoFinPadrao(DataRef,DtInipend,Dt,DataRef,Nil,false{com200},false{semliminar},GravaPendEmi{grava});
  end;
  {
    109585
    Estava pedindo uma TR para calcular o valor desprez vel da pend ncia, sem sequer ter um valor de pend ncia.
    Assim, gerava uma cr tica de falta de  ndice in til. Ajustei para s  pedir o  ndice se realmente for  til.
  }
  if abs(DadosPend.PendCalc) > zero then
    UPF := Obtem_Moeda_RefD(Dataref,true{98652 - Deve considerar ConsideraUltVariacao, por ser atraso})
  else
    UPF := 0;
  if UPF < Zero then UPF := 1;
  if (abs(DadosPend.PendCalc/UPF) < ScciConf.PendDesprezivel) then DadosPend.PendCalc := 0;
end;

procedure IncluiDadosPendCtr(    Contrato : TContrato;
                                 RegLCobr    : TpTabLCobr;
                             var DadosPendCtr: TpArrPendCtr;
                                 DtVenc,
                                 DataRef     : TData;
                                 ValPrest    : real;
                                 IgnoraDtTetoPend,
                                 GravaPendEmi : boolean;
                                 IgnoraPendenciaManual : boolean = false);
begin
  if DadosPendCtr[0].Tam < MaxPendCtr then
    inc(DadosPendCtr[0].Tam);
  ObtemDadosPendCtr(Contrato,RegLCobr,DadosPendCtr[DadosPendCtr[0].Tam].DadosPend,DtVenc,DataRef,ValPrest,IgnoraDtTetoPend,GravaPendEmi,IgnoraPendenciaManual);
  DadosPendCtr[DadosPendCtr[0].Tam].Ctr := Contrato.MutDsk.Cad.Ctr;
end;

