  Reg : TValoresPorMac;
begin
  RParc.tipo:= 0;
  fillchar(RParc,sizeof(TpParcelas),0);
  if Parcelas.count > 0 then
    RParc := Acordo.Parcelas[0].Dados;
  if (RParc.Tipo = 1) and (RParc.Codigo = Acordo.Dados.Codigo) and
     (RParc.Seq = 1) then
    Dt1oVenc := RParc.DtVenc
  else fillchar(Dt1ovenc,Sizeof(Tdata),0);
  try
    if (Juliano(Dt1oVenc) > 0) and
       (Juliano(Dt1oVenc) < Juliano(Acordo.Dados.DataAcordo)) then
      Reg := ObtemValoresPorMac(Mes_int(Dt1oVenc.MesAno))
    else
      Reg := ObtemValoresPorMac(Mes_int(Acordo.Dados.DataAcordo.MesAno));
    result := Reg.TxPstAcum;
  except
    result := 1;
  end;
end;

function TSerieFinanciamentoDinamico.CorrParcAcValor(    Acordo   : TAcordosItem;
                                                         Valor,
                                                         TxPstAcum : real;
                                                         DataCorr  : TData) : real;
var
  Ind,
  Corr, M,
  IndPst  : real;
  DtAssin : TData;
  UF : str3;
  CodMun : smallint;
begin
  M := 0;
  UF := '';
  CodMun := 0;
  Corr := 0;
  if (Juliano(Acordo.Dados.DataAcordo) < Juliano(DataCorr)) and
     (Acordo.Dados.TipoAcordo <> TipoAcPrstEst) and
     (Acordo.Dados.TipoAcordo <> TipoAcNorSemReaj) then begin
    DtAssin.dia := 0;
    fillchar(DtAssin,sizeof(TData),0);
    if Acordo.Dados.TipoAcordo = TipoAcLeiMun8973 then begin
      Corr := (IndiceURM(Acordo.Dados.DataAcordo,DataCorr)-1) * Valor;
      AjustaMoeda2(Mes_Int(Acordo.Dados.DataAcordo.MesAno),
                   Mes_Int(DataCorr.MesAno),Corr);
    end
    else
    if scciconf.ReajParcAcordoPrest or
       (Acordo.Dados.TipoAcordo = TipoAcPrest20    ) or
       (Acordo.Dados.TipoAcordo = TipoAcNorReajPrst) then begin
      IndPst := IndPstEvoluido(Acordo);
      if IndPst > Zero then ind := TxPstAcum/IndPst else ind := 1.0;
      if ind <> 1.0 then Corr := Valor * (ind-1);
      AjustaMoeda2(Mes_Int(Acordo.Dados.DataAcordo.MesAno),Mes_Int(DataCorr.MesAno),Corr);
      if Corr > Zero then Corr := Int(Corr*100+0.5)/100 else Corr := 0;
    end
    else begin
      Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
      Corr := CorrecaoMJSemIsencao(Acordo.Dados.DataAcordo,DataCorr,UF,CodMun,Valor,0,0,M,DtAssin,0{CodTG},0{CoBase},0{DefReaj},true{CalculoDeAtraso});
    end;
  end;
  Result := Corr;
end;

procedure TSerieFinanciamentoDinamico.ListaPrstAtrasoEvo(    DtRef : TData;
                                                             DtAtr : Tdata;
                                                         var ArrAtr : TArrayOfDatas;
                                                             DesconsideraSeguroEmAtr : boolean = false;
                                                             ConsideraAgenda : boolean = false;
                                                             ConsideraPrstSoDeAcessorios : boolean = false;
                                                             ConsideraValoresPrest : boolean = false);
var
  Reg : TValoresPorMac;
  i : integer;
  DtVenc : Tdata;
begin
  setLength(ArrAtr,0);
  i := mes_int(Contrato.MutDsk.Financ.DtAssin.MesAno);
  while (i <= mes_int(DtRef.mesano)) and (i < FValoresPorMacList.count) do begin
    if assigned(FValoresPorMacList[i]) then begin
      Reg := TValoresPorMac(FValoresPorMacList[i]);
      if Reg.CtrAtivo and (Reg.TotPrest-Reg.Desc > zero) then begin
        if (Reg.MAC > Mes_Int(Reg.DtInFin.MesAno)) and
           PrstEmAtrasoReal(Reg,DtAtr,true{ConsideraIsencao},
                            false{ConsideraVencida},ConsideraPrstSoDeAcessorios) and
           (not ConsideraAgenda or not Contrato.PrestAgendada(Reg,DtRef)) and
           (not ConsideraValoresPrest or (Reg.TotPrest-Reg.Desc > Zero)) then begin
          setLength(ArrAtr,length(ArrAtr)+1);
          int_mes(Reg.Mac,DtVenc.MesAno);
          DtVenc.dia := Reg.diavenc;
          ArrAtr[length(ArrAtr)-1] := DtVenc;
        end;
      end;
    end;
    inc(i);
  end;
end;

procedure TSerieFinanciamentoDinamico.CalculaDadosPrestSeguro(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                              var MutDsk : TpMutDsk;
                                                              var RegCarteira : TpCarteira;
                                                                  Reg : TValoresPorMac;
                                                                  Prest : TPrestacaoAtrasoEvo;
                                                              var DtVencOrig,
                                                                  DataRef : TData);
var
  JMoratorios,
  DescJMoratorios,
  DescJurosContr,
  DescMora,
  Valor,
  VMora,
  DifAbat      : real;
  MoraCap,
  JmoraCorrido,
  SalvaNaoCorrigeAts : boolean;
  UF : str3;
  CodMun : smallint;
  CodTabG,
  CodTabGPreChv : smallint;
begin
  SalvaNaoCorrigeAts := ScciConf.NaoCorrigeAts;
  VMora := 0;
  UF := '';
  CodMun := 0;
  Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
  DescJurosContr := 0;
  DescMora := 0;
  PreencheDadosPrestSeguro(CalculoAtrasoParametros,Contrato,Reg,Prest,
                           RegCarteira,false,false,false,DtVencOrig,
                           -CodMaxParaSegDeFinanc,0,DataRef);
  DtVencOrig.Dia := Reg.DiaVenc;
  if Reg.PA = 81 then
    Prest.PercMulta := 2.0
  else
    Prest.PercMulta := MutDsk.Cad.PercMulta;

  if PrstEmAtrasoAtual(Reg.Mac,Reg.DiaVenc,DataRef,RetornaLCobrValoresPorMac(Mutdsk,Reg)) then begin

    if Mutdsk.Cad6.CodReajAtraso > 0 then begin
      CodTabG := Mutdsk.Cad6.CodReajAtraso;
      CodTabGPreChv := 0;
    end
    else begin
      CodTabG := Reg.CodTabGCorr;
      CodTabGPreChv := Reg.CodTabGPreChvCorr;
      if Scciconf.NaoAtualizaAtrasoDeSeriesSemIndexador and
        (Reg.CodReaj = 31) then ScciConf.NaoCorrigeAts := true;
    end;
    
    Prest.Correcao := CorrecaoJMJCChaves(MutDsk,UF,CodMun,Reg.Seguro,
                                         DtVencOrig,Prest.DtVencRec,
                                         Reg.IndJuros,
                                         Reg.TMora,VMora,
                                         Prest.JurosContr,
                                         CodTabGPreChv,
                                         CodTabG,
                                         sfhlib.SfhDiasAtrasoCorridos{false},RegCarteira.NaoCobraJurosContr,
                                         Reg.DefReajPreChvCorr,Reg.DefReajCorr{0},
                                         true{CalculaAtraso},
                                         reg.txjuros,
                                         reg.CO_JUROS_FLUTUANTE,
                                         reg.PERCACRESJURFLUT);
    Prest.Mora := VMora;
    if CalculoAtrasoParametros.EhQuitacaoDeDebito and ScciConf.CalcAtrasoComMoraSimplesEdiasCorridosParaQuitDeDebito then begin
      MoraCap := ScciConf.MoraCapitaliz;
      ScciConf.MoraCapitaliz := false;
      JMoraCorrido := ScciConf.JurosDeMoraEContratuaisPorDiasCorridos;
      ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := true;
      try
        CorrecaoJMJCChaves(MutDsk,UF,CodMun,Reg.Seguro,
                           DtVencOrig,Prest.DtVencRec,
                           Reg.IndJuros,
                           Reg.TMora,DescMora,
                           DescJurosContr,
                           CodTabGPreChv,
                           CodTabG,
                           sfhlib.SfhDiasAtrasoCorridos{false},
                           RegCarteira.NaoCobraJurosContr,
                           Reg.DefReajPreChvCorr,
                           Reg.DefReajCorr{0},
                           true{CalculoDeAtraso},
                           reg.txjuros,
                           reg.CO_JUROS_FLUTUANTE,
                           reg.PERCACRESJURFLUT);
      finally
        ScciConf.MoraCapitaliz := MoraCap;
        ScciConf.JurosDeMoraEContratuaisPorDiasCorridos := jMoraCorrido;
      end;
    end;
    if (Prest.TMoraPrst in [202,207,209,211,213..215,43,52,55..56,60..62,70..71,81..82,217..219,222..223]) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
      Prest.IsenMora.IsenMulta := true;

    if (Prest.TMoraPrst in [41,43..44,217,56,100,199,202,215]) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
      Prest.Mora := 0;
      DescMora := 0;
      Prest.JurosContr := 0;
      DescJurosContr := 0;
    end
    else if (Prest.TMoraPrst in [81..84]) and
            (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
      Prest.Mora := Prest.JurosContr;
      DescMora := DescJurosContr;
    end
    else if (Prest.TMoraPrst in [68..71]) and
            (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
      Prest.Mora       := Arredonda(Prest.Mora - Prest.JurosContr);
      DescMora          := Arredonda(DescMora - DescJurosContr);
      Prest.JurosContr := 0;
      DescJurosContr := 0;
    end;
    if (Prest.TMoraPrst in [100,202,205,42..44,59..60,69..70,81,84,219,221,223]) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then
      Prest.Correcao := 0;

    if (Prest.TMoraPrst in [58..61,220..223]) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
      Prest.Mora := int((Prest.Mora * 0.2)*100+0.5)/100;
      DescMora := int((DescMora * 0.2)*100+0.5)/100;
    end;
    if (not Prest.IsenMora.IsenMulta) then begin
      if (Contrato.DiasDeAtrasoEntreDatas(DtVencOrig(*Prest.IsenMora.DataIsen*),DataRef) > 0) then begin
        Valor := Prest.Seguro;
        if (Reg.TMora <> 101) then
          Valor := Valor + Prest.Correcao;
        if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
          Valor := Valor + Prest.Mora;
        if (Reg.TMora in [38..40]) then
          Prest.Multa := ValorMulta(DtVencOrig,Prest.DtVencRec,UF,CodMun,
                                    Prest.PercMulta,Valor,
                                    MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                    Mutdsk.cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
        else
          Prest.Multa := ValorMulta(DtVencOrig,Prest.DtVencRec,UF,CodMun,
                                    Prest.PercMulta,Valor,
                                    MutDsk.Cad.DiaIsencao,MutDsk.Cad3.MultaContratualProRata,
                                    Mutdsk.cad6.DtIniCobMulta);
      end;
    end;
    Prest.PercDescHonorarios := Prest.IsenMora.PercDescHonorarios/100;
    Prest.CorrecaoTot := Prest.Correcao;
    Prest.MoraTot := Prest.Mora;
    Prest.JurosContrTot := Prest.JurosContr;
    Prest.MultaTot := Prest.Multa;
    if ((Prest.IsenMora.PercDescMora > zero) or
        (Prest.IsenMora.PercDescCorr > zero) or
        (Prest.IsenMora.PercDescMulta > zero) or
        (Prest.IsenMora.PercDescjremuneratorios > zero)) and
       (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
{      Prest.PercDescMora := Prest.IsenMora.PercDescMora;
      Prest.PercDescCorr := Prest.IsenMora.PercDescCorr;
      Prest.PercDescMulta:= Prest.IsenMora.PercDescMulta;
      Prest.PercDescjremuneratorios := Prest.IsenMora.PercDescjremuneratorios;}
      if (Prest.IsenMora.PercDescCorr > zero) then begin
        Prest.DescIsenCorrecao := Prest.Correcao;
        Prest.Correcao := int((Prest.Correcao -(Prest.Correcao * (Prest.IsenMora.PercDescCorr/100)))*100+0.5)/100;
        Prest.DescIsenCorrecao := Prest.DescIsenCorrecao - Prest.Correcao;
      end;
      if (Prest.IsenMora.PercDescMulta > zero) and
         (Contrato.DiasDeAtrasoEntreDatas(Prest.IsenMora.DataIsen,DataRef) <= 0) then begin
        Prest.DescIsenMulta := Prest.Multa;
        Prest.Multa := int((Prest.Multa -(Prest.Multa * (Prest.IsenMora.PercDescMulta/100)))*100+0.5)/100;
        Prest.DescIsenMulta := Prest.DescIsenMulta - Prest.Multa;
      end;
      JMoratorios    := Prest.Mora - Prest.JurosContr;
      DescJMoratorios:= DescMora - DescJurosContr;
      if (Prest.IsenMora.PercDescJremuneratorios > zero) then begin
        Prest.DescIsenJurosContr := Prest.JurosContr;
        Prest.JurosContr := int((Prest.Juroscontr -(Prest.JurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
        Prest.DescIsenJurosContr := Prest.DescIsenJurosContr - Prest.JurosContr;
        DescJurosContr := int((DescJuroscontr -(DescJurosContr * (Prest.IsenMora.PercDescJremuneratorios/100)))*100+0.5)/100;
      end;
      if (Prest.IsenMora.PercDescMora > zero) then begin
        Prest.DescIsenJMoratorios := JMoratorios;
        JMoratorios := int((JMoratorios - (JMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
        Prest.DescIsenJMoratorios := Prest.DescIsenJMoratorios - JMoratorios;
        DescJMoratorios := int((DescJMoratorios - (DescJMoratorios*(Prest.IsenMora.PercDescMora/100)))*100+0.5)/100;
      end;
      if (Prest.IsenMora.PercDescJremuneratorios > zero) or (Prest.IsenMora.PercDescMora > Zero) then begin
        Prest.Mora := JMoratorios+Prest.JurosContr;
        DescMora := DescJMoratorios+DescJurosContr;
      end;
    end;
  end;
  if (DescMora  > zero) then
    if (Prest.mora-DescMora > zero) then
      Prest.DescPagamento := Prest.Mora - DescMora
    else begin
      Prest.Mora := DescMora;
      DescMora := 0;
    end;
  Prest.EncMes := Prest.Seguro   +
                  Prest.Mora     + Prest.Correcao  +
                  Prest.Multa ;
  DifAbat := 0;
  if Prest.Diferenca > Zero then Prest.OutRec := Prest.Diferenca
  else DifAbat := Prest.Diferenca * -1;
  if (ValInt(scciconf.nserie) <> nsLetra) and
     (not (ValInt(Scciconf.NSerie) in [5..8])) then
    Prest.OutAbat := DifAbat + Prest.Desc
  else Prest.OutAbat := DifAbat;
  if Prest.DescPagamento > zero then Prest.OutAbat := Prest.outAbat + Prest.DescPagamento;
  Prest.ValTit       := Prest.EncMes - Prest.OutAbat +
                        Prest.OutRec + Prest.TaxaBanco;
  ScciConf.NaoCorrigeAts := SalvaNaoCorrigeAts;
end;

procedure TSerieFinanciamentoDinamico.CalculaDetalhesPrestFGTS(RegMes : TValoresPorMac;
                                                               Prest : TPrestacaoAtrasoEvo);
var
  NCRest : integer;
begin
  Prest.CotaFGTS := RegMes.CotaFGTS;
  Prest.FGTS := RegMes.FGTS;
  if Prest.FGTS >= zero then begin
    NCRest := RegMes.NCotasFGTS - (RegMes.Mac - RegMes.PstInFG + 1);
    if NCRest < 0 then
      NCRest := 0;
    if NCRest > 0 then
      Prest.FGTSMes := RegMes.CotaFGTS * Le_OtnFGTS(RegMes.Mac)
    else
      Prest.FGTSMes := 0;
    Prest.RGNM := 0;
    Prest.RUNM := 0;
    if abs(Prest.FGTSMes - RegMes.FGTS) > Zero then
      if Prest.FGTSMes > RegMes.FGTS then
        Prest.RGNM := Prest.FGTSMes - RegMes.FGTS
      else
        Prest.RUNM := RegMes.FGTS - Prest.FGTSMes;
    Prest.NCota := RegMes.Mac - RegMes.PstInFG + 1;
    Prest.SldDispFGTS := ((RegMes.CotaFGTS * NCRest + RegMes.Residuo) * Le_OtnFGTS(RegMes.Mac));
  end;
end;

procedure TSerieFinanciamentoDinamico.CalculaDadosPrest(    CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                        var MutDsk : TpMutDsk;
                                                            Reg,
                                                            RegConsRef : TValoresPorMac;
                                                            Dados : TDadosAtrasoevo;
                                                            Prest : TPrestacaoAtrasoEvo;
                                                        var DtVencOrig,
                                                            DtIniPend,
                                                            DataRef : TData);
var
  RegAux,
  RegSemAjuste : TValoresPorMac;
  Desc,
  DescAux,
  Perc,
  valor : real;
  DtVenc : TData;
  DtIsMora : TData;
  DtVencCarencia: TData;
  DiasDeAtraso : boolean;
  NMeses : integer;
  DifEmi : real;
  TMora : integer;
//DiasCarenciaMora,sol. 51401
  DiasCarenciaMulta,
  DiasCarenciaCorr : smallint;
  CodTabGCorr,
  CodTabGPreChvCorr : integer;
  DefReajPreChvCorr,
  DefReajCorr : byte;
  AmaisJParcialVencPrst,
  JC,
  MDesp,
  JMoratorios,
  JMoratoriosAmaisj,
  DifAbat : real;
  MoraAc,
  CorrAc : real;
  Acordo : TAcordosItem;
  RParcela : TpParcelas;
  UF : str3;
  CodMun : smallint;
  Moracap,
  JMoraCorrido : boolean;
  valorPrest,
  DescMora,
  DescMoraAmaisj,
  DescJurosContr,
  DescJurosContrAmaisj,
  DescJMoratorios,
  DescJMoratoriosAmaisj : real;
  SalvaNaoCorrigeAts : boolean;
  RegPgtoParcial     : TpValPgtoParcial;
  CorrecaoSeguro,
  JMoratoriosSeg,
  MoraSeguro,
  MultaSeguro,
  JurosContrSeguro,
  ValorSeguro   : real;
  PosicaoAtraso : TDadosPosicaoAtrasoItem;
  ValorAmaisj : real;
  TemPgParcialAux : boolean;
  NumParcSerieAux : integer;
begin
  AmaisJParcialVencPrst  := 0;
  RegPgtoParcial.CodParc := 0; fillchar(RegPgtoParcial,sizeof(RegPgtoParcial),0);
  SalvaNaoCorrigeAts := ScciConf.NaoCorrigeAts;
  if CalculoAtrasoParametros.UsaPosicaoAtraso then
    PosicaoAtraso := Contrato.DadosPosicaoAtraso.ObtemPrest(0,Reg.Mac)
  else
    PosicaoAtraso := nil;
  RParcela.Acrescimos := 0;
  fillchar(RParcela,sizeof(RParcela),0);
  Acordo := nil;
  MDesp := 0;
  JC := 0;

  DtIsMora.dia := 0; DtIsMora.mes := 0; DtIsMora.ano := 0;
  UF := '';
  CodMun := 0;
  CorrecaoSeguro   := 0;
  MoraSeguro       := 0;
  MultaSeguro      := 0;
  JurosContrSeguro := 0;

  DescMora := 0;
  DescMoraAmaisj := 0;
  DescJurosContr := 0;
  DescJurosContrAmaisj := 0;
  Desc := Reg.Desc;
  DtVencOrig.Dia := Reg.DiaVenc;
  if Reg.TipoDesc in [5,9] then CalculoAtrasoParametros.ConcedeDesc := true;
  if (Scciconf.EmiteDescSobreAmaisJSoParaAdimp or (Reg.TipoDesc in [5,9])) and
     (Reg.PercDesc > Zero) and (Reg.Desc > Zero) then begin
    if Reg.TipoDesc in [1,5,9] then Prest.DescSoParaAdimp := true;
    if CalculoAtrasoParametros.ConcedeDesc then begin
      if Reg.TipoDesc = 9 then begin
        DtVenc := DtVencOrig;
        DtIsencaoMoraValoresPorMac(Contrato.Mutdsk,Reg,DtVenc,DtIsMora,MutDsk.Cad.DiaIsencao);
        DiasDeAtraso := (Contrato.DiasDeAtrasoEntreDatas(DtIsMora,DataRef) > 0);
        if DiasDeAtraso then SfhDiasAtrasoCorridos := false
        else if (juliano(DtIsMora) > juliano(Prest.IsenMora.DataIsen)) and
                 SfhDiasAtrasoCorridos then begin
          Prest.IsenMora.DataIsen     := DtIsMora;
          Prest.IsenMora.IsenMora     := true;
          Prest.IsenMora.IsenCorrecao := true;
          Prest.IsenMora.IsenMulta    := true;
        end;
      end else DiasDeAtraso := (Contrato.DiasDeAtrasoEntreDatas(Prest.DtVencAtu,DataRef) > 0);
     if DiasDeAtraso and
       ((Reg.TipoDesc <> 5) or (not Prest.IsenMora.IsenMulta)) then
       CalculoAtrasoParametros.ConcedeDesc := false;
    end;
    if (not CalculoAtrasoParametros.ConcedeDesc) then
      Desc := 0;
  end;
  if (ValInt(Scciconf.NSerie) in [5..8]) and (Desc > Zero) then begin
    if NumPrstAtraso4(DataRef,Reg) > 0 then Desc := 0;
  end;
  if (Reg.TipoDesc = 8) and (Desc > Zero) and
     (not CalculoAtrasoParametros.InibePerdaDescCessaoDePosse) then begin
    NMeses := NMesesAtraso(Prest.DtVencAtu,DataRef,MutDsk.Cad.DiaIsencao);
    Desc := Desc * (1 - NMeses/24);
    Desc := Int(Desc*100+0.5)/100;
  end;
  Prest.TotPrestOrig := Reg.TotPrest;
  RegAux := TValoresPorMac.create;
  RegSemAjuste := TValoresPorMac.create;
  try
    RegAux.Assign(Reg);
    if Dados.SeparaSeguro then begin
      RegAux.Seguro   := 0;
      RegAux.SegCre   := 0;
      RegAux.SegFin   := 0;
      RegAux.SegImv   := 0;
      RegAux.DescSeg   := 0;
      RegAux.AtualizaTotPrest;
    end;
    RegSemAjuste.assign(RegAux);
    RegAux.AjustaRPA_2(RegAux.Mac,mes_int(DataRef.MesAno));
    AjustaMoeda2(RegAux.mac,mes_int(DataRef.MesAno),RegAux.Reduzente);
    DescAux := Desc;
    AjustaMoeda2(RegAux.mac,mes_int(CalculoAtrasoParametros.DataRef.MesAno),DescAux);
    Prest.DtVencRec := DataRef;
