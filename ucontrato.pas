function TSerieReneg.TemVincendas      : boolean;
begin
  result := (FParcelas.count > 0) or (SaldoParaQuitacao > zero);
end;

function TSerieReneg.SelecaoVincendas : integer;
var
  i,
  Qtd,Sel : integer;
begin
  Qtd := 0;
  Sel := 0;
  for i := 0 to FParcelas.count - 1 do begin
    inc(Qtd);
    if FParcelas[i].Seleciona then
      inc(Sel);
  end;
  if Qtd = 0 then
    result := cSelecaoTodas
  else if Qtd = Sel then
    result := cSelecaoTodas
  else if Sel > 0 then
    result := cSelecaoAlgumas
  else
    result := cSelecaoNenhuma;
end;

procedure TSerieReneg.FazSelecaoVincendas(selecao : integer);
var
  i : integer;
begin
  for i := 0 to FParcelas.count - 1 do
    FParcelas[i].Seleciona := selecao = cSelecaoTodas;
end;

