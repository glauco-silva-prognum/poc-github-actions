function TDadosAtrasoEvo.UltPrest : integer;
begin
  result := count-1;
  while (result >= 0) and Prestacao[result].Esconde do dec(result);
end;

function TDadosAtrasoEvo.UltPrestPend : integer;
var
  i : SmallInt;
begin
  result := UltPrest;
  i := result-1;
  while (i >= 0) and (Prestacao[i].MacPrst = Prestacao[result].MacPrst) do begin
    if (not Prestacao[i].Esconde) and
       ((Prestacao[i].TotPrest - Prestacao[i].Desc) > (Prestacao[result].TotPrest-Prestacao[result].Desc)) then
        result := i;
    dec(i);
  end;
end;

function TDadosAtrasoEvo.NumPrestSelecionada : integer;
var
  i : integer;
begin
  result := 0;
  for i := 0 to count-1 do
    if not Prestacao[i].esconde then inc(result);
end;

