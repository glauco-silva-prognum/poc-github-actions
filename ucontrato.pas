function ParcelaDeFinBancChavesDevida(Contrato : Tcontrato; 
                                      DtVencParc,DtHabit,DataRef: TData;
                                      CarenciaPelaDtInicio : boolean) : boolean;
var
  DtCarencia,
  DtVenc   : TData;
  Carencia : Integer;
begin
  Carencia := TemCarenciaAtrasoFinBancChaves(Contrato.Mutdsk,Contrato.Empreendimento);
  if Carencia > 0 then begin
    if CarenciaPelaDtInicio then 
      DtCarencia := DtVencParc
    else
      DtCarencia := DtHabit;
    if Juliano(DtCarencia) > 0 then begin
      J_Data(Juliano(DtCarencia)+Carencia,DtVenc);
      Result := (Contrato.DiasDeAtrasoEntreDatas(DtVenc,DataRef) > 0);
    end
    else
      Result := false;
  end else Result := (Contrato.DiasDeAtrasoEntreDatas(DtVencParc,DataRef) > 0);
end;

function SerieEstaEmFaseDeCarenciaFinBancChaves(Const Mutdsk : TpMutdsk; Const RegEmpr : TpTabEmp;
                                                Var RegSerie : TpSeries; DtHabit, dataref : tdata) : boolean;
var
  DtCarencia,
  DtVenc : TData;
  Carencia : integer;
begin
  result := false;
  if RegSerie.FinancBancario or (RegSerie.CodClassificacao = serie_chaves) then begin
    Carencia := TemCarenciaAtrasoFinBancChaves(Mutdsk,RegEmpr);
    if Carencia > 0 then begin
      if CalcCarenciaFinBancChavesPelaDtInicio(RegSerie,RegEmpr) then 
        DtCarencia := RegSerie.DtInicio
      else
        DtCarencia := DtHabit;
      if Juliano(DtCarencia) > 0 then begin
        J_Data(Juliano(DtCarencia)+Carencia,DtVenc);
        Result := (sfhlib.DiasDeAtrasoEntreDatas(DtVenc,DataRef) <= 0);
      end
      else
        Result := true;
    end;
  end;
end;

procedure MarcaErroRPAS( var RPA:TpRPA; nerro:SmallInt; CodTabelaGenerica : smallint; DtIndice : Tdata);
begin
  if (RPA.CodErro=0) or (nErro = 2) then begin
    if (RPA.CodErro <> nErro) // se n o   o mesmo tipo, respeita o coderro
        or (RPA.Temp11.ErroMACIndice = 0) // Se n o tinha data ainda
        or ((Juliano(DtIndice) > 0) and
            ((Mes_int(DtIndice.MesAno) < RPA.Temp11.ErroMACIndice) or
             ((Mes_int(DtIndice.MesAno) = RPA.Temp11.ErroMACIndice) and
              (DtIndice.Dia < RPA.Temp11.ErroDiaIndice)))) // Mantenho sempre o  ndice mais antigo com problemas
    then begin
      RPA.Temp11.ErroCodigoIndice := CodTabelaGenerica;
      RPA.Temp11.ErroMACIndice    := mes_int(DtIndice.MesAno);
      RPA.Temp11.ErroDiaIndice    := DtIndice.dia;
    end;
    RPA.CodErro := nerro;
  end;
end;

