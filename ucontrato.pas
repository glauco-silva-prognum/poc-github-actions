      if Temp5.TpSRoga=0 then Temp5.TpSRoga := RPAS.Temp5.TpSRoga;
      if Temp11.MacSubrogacao=0 then Temp11.MacSubRogacao := RPAS.Temp11.MacSubrogacao;
      if Temp11.DiaSubrogacao=0 then Temp11.DiaSubRogacao := RPAS.Temp11.DiaSubrogacao;
      if Temp11.MATermDescSegDFI = 0 then 
