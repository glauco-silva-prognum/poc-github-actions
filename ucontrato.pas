    ValAvalCorrSalvo:= RPA.Temp12.ValAvalCorr;
    ValReavalSalvo  := RPA.Temp12.ValReavaliacao;
    ValJustoSalvo   := RPA.Temp12.ValorJusto;
    ValPEJurosTJEOProp := RPA.Temp12.PE_Juros_Contratuais;
