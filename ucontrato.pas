procedure TGrupoDeContratos.LeGrupo(ctr : tpctr);
var
  Grupo : ^TpArrayGrupo;
  PaiGrupo : integer;
  i : integer;
  Item : TGrupoDeContratosItem;
  Mutdsk : TpMutdsk;
begin
  MutDsk.Cad.Ctr := '';
  fillchar(MutDsk,sizeof(MutDsk),0);
  Clear;
  PaiGrupo := GrupoDoCtr(Ctr);
  if PaiGrupo = 0 then begin
    if Le_Mutdsk(ctr,Mutdsk) then begin
      Item := self.add as TGrupoDeContratosItem;
      Item.OwnsContrato := true;
      Item.Contrato := TContrato.create;
      Item.Contrato.Le(Mutdsk);
      Item.Contrato.Grupo := self;
      FPrincipal := Item;
    end;
  end
  else begin
    getMem(Grupo,sizeof(TpArrayGrupo));
    try
      LeArrGrupo(PaiGrupo,Grupo^);
      ExcluiDoGrupo(Grupo^,IntStr2(PaiGrupo,tamctr));
      IncluiNoGrupo(Grupo^,IntStr2(PaiGrupo,tamctr));
      for i := 1 to Grupo^[0].Tam do begin
        if Le_Mutdsk(Grupo^[i].ctr,Mutdsk) then begin
          Item := self.add as TGrupoDeContratosItem;
          Item.OwnsContrato := true;
          Item.Contrato := TContrato.create;
          Item.Contrato.Le(Mutdsk);
          Item.Contrato.Grupo := self;
          if IntStr2(PaiGrupo,TamCtr) = Item.Contrato.Mutdsk.Cad.ctr then
            FPrincipal := Item;
        end;
      end;
    finally
      freeMem(Grupo,sizeof(TpArrayGrupo));
    end;
  end;
end;

procedure TGrupoDeContratos.LeGrupo(Contrato : TContrato);
var
  Grupo : ^TpArrayGrupo;
  PaiGrupo : integer;
  i : integer;
  Item : TGrupoDeContratosItem;
  Mutdsk : TpMutdsk;
begin
  MutDsk.Cad.Ctr := '';
  fillchar(MutDsk,sizeof(MutDsk),0);
  Clear;
  PaiGrupo := GrupoDoCtr(Contrato.MutDsk.Cad.Ctr);
  if PaiGrupo = 0 then begin
    Item := self.add as TGrupoDeContratosItem;
    Item.OwnsContrato := false;
    Item.Contrato := Contrato;
    FPrincipal := Item;
  end
  else begin
    getMem(Grupo,sizeof(TpArrayGrupo));
    try
      LeArrGrupo(PaiGrupo,Grupo^);
      ExcluiDoGrupo(Grupo^,IntStr2(PaiGrupo,tamctr));
      IncluiNoGrupo(Grupo^,IntStr2(PaiGrupo,tamctr));
      for i := 1 to Grupo^[0].Tam do begin
        if Grupo^[i].ctr = Contrato.Mutdsk.cad.Ctr then begin
          Item := self.add as TGrupoDeContratosItem;
          Item.OwnsContrato := false;
          Item.Contrato := Contrato;
        end
        else begin
          if Le_Mutdsk(Grupo^[i].ctr,Mutdsk) then begin
            Item := self.add as TGrupoDeContratosItem;
            Item.OwnsContrato := true;
            Item.Contrato := TContrato.create;
            Item.Contrato.Le(Mutdsk);
          end
          else
            Item := nil;
        end;
        if assigned(Item) then begin
          Item.Contrato.Grupo := self;
          if IntStr2(PaiGrupo,TamCtr) = Item.Contrato.Mutdsk.Cad.ctr then
            FPrincipal := Item;
        end;
      end;
    finally
      freeMem(Grupo,sizeof(TpArrayGrupo));
    end;
  end;
end;


procedure TGrupoDeContratos.AjustaPrePrzAtraso(PrestAcumulada,Prest : TPrestacaoAtrasoEvo);
begin
  if PrestAcumulada.CodSerie = 0 then
    if (PrestAcumulada.Ctr <> FPrincipal.Contrato.Mutdsk.cad.Ctr) or not PrestAcumulada.SerieAtiva then
      if (PrestAcumulada.Prazo-PrestAcumulada.Npc) < (Prest.Prazo-Prest.Npc) then begin
        PrestAcumulada.Prazo := Prest.Prazo;
        PrestAcumulada.Npc := Prest.Npc;
      end;
end;

procedure TGrupoDeContratos.CalculaAtrasoMembroGrupo(Item : TGrupoDeContratosItem;
                                                     CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                                     Dados : TDadosAtrasoEvo;
                                                     Var ArrMac : TSparseObjectArray;
                                                     Recalculo : boolean);
var
  j : integer;
  Prest : TPrestacaoAtrasoEvo;
  ArrCodSerie : TSparseObjectArray;
begin
  // Calcular o atraso individual SEM considerar taxas
  // agrupar taxas no final
  if Recalculo then
    Item.Contrato.RecalculaDadosAtraso(CalculoAtrasoParametros,Item.DadosAtrasoEvo, false{pCalculaTaxas})
  else
    Item.Contrato.CalculaAtraso(CalculoAtrasoParametros,Item.DadosAtrasoEvo, false{pCalculaTaxas});

  if ((Dados.MACErro2 > Item.DadosAtrasoEvo.MACErro2) or (Dados.MACErro2 = 0)) then
    Dados.MACErro2 := Item.DadosAtrasoEvo.MACErro2;
  for j := 0 to Item.DadosAtrasoEvo.count-1 do begin
    if ArrMac.HasItem(Item.DadosAtrasoEvo[j].MacPrst) then
      ArrCodSerie := ArrMac[Item.DadosAtrasoEvo[j].MacPrst] as TSparseObjectArray
    else begin
      ArrCodSerie := TSparseObjectArray.create;
      ArrMac[Item.DadosAtrasoEvo[j].MacPrst] := ArrCodSerie;
    end;
    if ArrCodSerie.HasItem(Item.DadosAtrasoEvo[j].CodSerie) then begin
      Prest := ArrCodSerie[Item.DadosAtrasoEvo[j].CodSerie] as TPrestacaoAtrasoEvo;
      Prest.Acumula(Item.DadosAtrasoEvo[j]);
      if ScciConf.DemonstraSeparadoCtrsAgrupadosBoleto then // se n o vai separar, n o pode contar como uma presta  o extra
        inc(Prest.QtdParcsAgrupadas);
      AjustaPrePrzAtraso(Prest,Item.DadosAtrasoEvo[j]);
    end
    else begin
      Prest := TPrestacaoAtrasoEvo.create;
      Prest.Ctr := Principal.Contrato.Mutdsk.Cad.Ctr;
      Dados.Add(Prest);
      ArrCodSerie[Item.DadosAtrasoEvo[j].CodSerie] := Prest;
      Prest.assign(Item.DadosAtrasoEvo[j]);
    end;
  end;
end;

procedure TGrupoDeContratos.CalculaTaxasAgrupadas(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados : TDadosAtrasoEvo);
var
  i : integer;
  ValorTaxaAux : real;
begin
  Dados.ValorTaxa := 0;
  Dados.Iptu := 0;
  Dados.Taxas.clear;

  if (SisTaxasDiversas(Scciconf.SistemaDeTaxas)) then begin
    for i := 0 to Count-1 do begin
      GrupoDecontratosItems[i].Contrato.CalculaTaxasAtraso(CalculoAtrasoParametros,
                                                           GrupoDecontratosItems[i].DadosAtrasoEvo,
                                                           GrupoDecontratosItems[i]=Principal{CalculaTaxaEmissao});
      Dados.Taxas.AddTaxas(GrupoDecontratosItems[i].DadosAtrasoEvo.Taxas);
      Dados.Iptu := Dados.Iptu + GrupoDecontratosItems[i].DadosAtrasoEvo.Iptu;
    end;

    for i := 0 to Dados.Taxas.count-1 do
      Dados.ValorTaxa := Dados.ValorTaxa + Dados.Taxas[i].Dados.ValorCorrigido;
  end
  else if (Scciconf.SistemaDeTaxas = SisTaxaPorRecibo) and not CalculoAtrasoParametros.IgnoraTaxas then begin
    for i := 0 to Count-1 do begin
      ValorTaxaAux := 0;
      GrupoDecontratosItems[i].DadosAtrasoEvo.ValorTaxa := 0;
      GrupoDecontratosItems[i].DadosAtrasoEvo.Iptu := 0;
      GrupoDecontratosItems[i].Contrato.CalculaValorTaxaAtraso(CalculoAtrasoParametros,
                                                               ValorTaxaAux,
                                                               GrupoDecontratosItems[i].DadosAtrasoEvo.Iptu);
      Dados.Iptu := Dados.Iptu + GrupoDecontratosItems[i].DadosAtrasoEvo.Iptu;
      if GrupoDecontratosItems[i].Contrato.Mutdsk.Cad.Ctr = Principal.Contrato.Mutdsk.Cad.ctr then
        Dados.ValorTaxa := ValorTaxaAux; // considerar o valor da taxa de emiss o como sendo a do contrato principal
    end;
  end;
end;

procedure TGrupoDeContratos.CalculaAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados : TDadosAtrasoEvo; Recalculo : boolean = false);
var
  i : integer;
  Achou : boolean;
  Obj : TObject;
  ArrMac : TSparseObjectArray;
  Total : real;
  TempPodeCobrarTaxaBancaria : boolean;
  RegConsRef : TValoresPorMac;
begin
  Obj := nil;
  Dados.Clear;
  ArrMac := TSparseObjectArray.create;
  try
    Dados.ValorTaxa := 0;
    Dados.Iptu := 0;
    Dados.ValorTaxaBanco := 0;
    // Para calculo agrupado n o deve ser calculado a taxa banc ria para cada contrato
    TempPodeCobrarTaxaBancaria := CalculoAtrasoParametros.PodeCobrarTaxaBancaria;
    CalculoAtrasoParametros.PodeCobrarTaxaBancaria := false;
    try
      // dados que n o s o somados devem apresentar detalhes do contrato principal
      CalculaAtrasoMembroGrupo(Principal,CalculoAtrasoParametros,
                               Dados,ArrMac,Recalculo);
      Dados.PendCtr := Principal.DadosAtrasoEvo.PendCtr;

      // soma os demais dados de contratos agrupados
      for i := 0 to Count-1 do
        if GrupoDecontratosItems[i] <> Principal then
          CalculaAtrasoMembroGrupo(GrupoDecontratosItems[i],
                                   CalculoAtrasoParametros,
                                   Dados,ArrMac,Recalculo);
                                   
    finally
      CalculoAtrasoParametros.PodeCobrarTaxaBancaria := TempPodeCobrarTaxaBancaria;
    end;
    Dados.PodeIsentarCobrancaTaxa := Principal.DadosAtrasoEvo.PodeIsentarCobrancaTaxa;
    Dados.PodeCobrarHonorarios    := Principal.DadosAtrasoEvo.PodeCobrarHonorarios;
    Dados.PodeFazerIncorporacao := Principal.DadosAtrasoEvo.PodeFazerIncorporacao;
    Dados.SelecionaPrestApenasPorFaixa := Principal.DadosAtrasoEvo.SelecionaPrestApenasPorFaixa;
    Dados.GeraUmReciboComPrstComJanela := CalculoAtrasoParametros.GeraUmReciboComPrstComJanela;
    Dados.DiaVenc := Principal.DadosAtrasoEvo.DiaVenc;
    Dados.Agrupado := count > 1;
    Dados.OrdenaPorVencimentoECodSerie;
    if (count > 1) and (Dados.MacErro2 > 0) then begin
      i := 0;
      while i < Dados.Count do begin
        if Dados.Prestacao[i].MacPrst >= Dados.MacErro2 then
          Dados.Delete(i)
        else
          inc(i);
      end;
    end;

    Total := 0;
    for i := 0 to Dados.Count-1 do
      if not Dados[i].Esconde then
        Total := Total + Dados[i].ValTit;

    if abs(Total) > 0 then begin
      if not CalculoAtrasoParametros.IgnoraTaxas then begin
        // 99250 - preciso inibir o c lculo das taxas para atender o requisito da sol,
        //         no entanto, apenas o c lculo para um contrato n o agrupado respeitava 
        //         qualquer par metro para inibir as taxas. Por isso, estou colocando 
        //         nesta rotina de agrupado o teste para o par metro que j  existia
        //         ignoraTaxas 
        TrataIsencaoTaxaEmissao(CalculoAtrasoParametros,Dados);
        CalculaTaxasAgrupadas(CalculoAtrasoParametros,Dados);
      end;  
      RegConsRef := Principal.Contrato.ObtemValoresPorMac(Mes_int(CalculoAtrasoParametros.DataRef.MesAno));
      LeLCobrValoresPorMac(Principal.Contrato.MutDsk,RegConsRef,Dados.RegLCobr);
      Dados.RegLcobrContrato := Dados.RegLCobr;
      if (Dados.ReglCobr.Lcobr2avia > 0) and not CalculoAtrasoParametros.DebitoCC then
        LeLcobr2aVia(Dados.RegLCobr.Lcobr,Dados.RegLCobr);
      Dados.ValorTaxaBanco := DefineValorTaxaBanco(Principal.Contrato.Mutdsk,Dados.RegLCobr);
      if CalculoAtrasoParametros.RespeitaNumMaxParcPorRecConsLcobr then
        Dados.NumMaxParcPorRecCons := Dados.RegLcobr.NumMaxParcPorRecCons;
      if CalculoAtrasoParametros.DeveCobrarTaxaBancaria then
        Dados.CalculaTaxaBanco;
    end;
    Dados.TotalizaDados;
  finally
    achou := ArrMac.findFirst(i,Obj);
    while achou do begin
      Obj.free;
      achou := ArrMac.findNext(i,Obj);
    end;
    ArrMac.free;
  end;
end;

procedure TGrupoDeContratos.CalculaAtrasoParaAtivo(CalculoAtrasoParametros : TCalculoAtrasoParametros; Dados : TDadosAtrasoEvo);
var
  RegRef : TValoresPorMac;
  i : integer;
begin
  // criado para no sig poder testar apenas o t rmino do contrato
  // mantendo a l gica da CalculaAtraso
  Dados.Clear;
  Dados.status := CalculoAtrasoStatus_Ok;
  for i := 0 to count-1 do
    GrupoDeContratosItems[i].Contrato.EvoluiParaCalculoAtraso(CalculoAtrasoParametros);
  try
    for i := 0 to count-1 do begin
      RegRef := GrupoDeContratosItems[i].Contrato.ObtemValoresPorMac(mes_int(CalculoAtrasoParametros.DataRef.MesAno));
      GrupoDeContratosItems[i].Contrato.TestaTerminoParaCalcAtraso(RegRef.Mac,
                                                                   CalculoatrasoParametros.CalcAtrParaInativos,
                                                                  ((CalculoAtrasoParametros.TipoExec in [TipoExec_2avia,TipoExec_Atraso]) and ScciConf.EmiteBoletoAtrasoCtrReneg) or
                                                                   CalculoAtrasoParametros.DevidasParaAviso,true{TestaGrupo});
    end;
  except
    on e : exception do begin
      Dados.msg := e.message;
      Dados.status := CalculoAtrasoStatus_Erro;
    end;
  end;
  if Dados.status <> CalculoAtrasoStatus_Erro then
    CalculaAtraso(CalculoAtrasoParametros,Dados);
end;

procedure TGrupoDeContratos.CalculaDadosAtraso(CalculoAtrasoParametros : TCalculoAtrasoParametros;
                                               Dados : TDadosAtrasoEvo;
                                               LstAvisos : TStringlist = nil);
var
  i : integer;
begin
  Dados.Clear;
  for i := 0 to count-1 do begin
    GrupoDeContratosItems[i].DadosAtrasoEvo.clear;
    GrupoDeContratosItems[i].Contrato.EvoluiParaCalculoAtraso(CalculoAtrasoParametros);
  end;
  Dados.Status := Principal.Contrato.PodeCalcularAtraso(CalculoAtrasoParametros,Dados.Suspendeu,Dados.Msg,
                                                        LstAvisos,true{TestaGrupo});
  if Dados.status <> CalculoAtrasoStatus_Erro then begin
    CalculaAtraso(CalculoAtrasoParametros,Dados);
    Principal.Contrato.VerificaResultadoCalculoAtraso(CalculoAtrasoParametros,Dados,true{testaGrupo});
  end;
end;

procedure TGrupoDeContratos.RecalculaDadosAtraso(CalculoAtrasoparametros : TCalculoAtrasoParametros;
                                                 Dados : TDadosAtrasoEvo);
var
  i,j : integer;
  ArrMac,
  ArrCodSerie : TSparseObjectArray;
  Achou : boolean;
  Obj : TObject;
  Prest : TPrestacaoAtrasoEvo;
begin
  Obj := nil;
  ArrCodSerie := TSparseObjectArray.create;
  try
    for i := 0 to Dados.Count-1 do begin
      if ArrCodSerie.HasItem(Dados[i].CodSerie) then
        ArrMac := ArrCodSerie[Dados[i].CodSerie] as TSparseObjectArray
      else begin
        ArrMac := TSparseObjectArray.create;
        ArrCodSerie[Dados[i].CodSerie] := ArrMac;
      end;
      if not ArrMac.HasItem(Dados[i].MacPrst) then
        ArrMac[Dados[i].MacPrst] := Dados[i];
    end;
    for i := 0 to Count-1 do
      for j := 0 to GrupoDeContratosItems[i].DadosAtrasoEvo.count-1 do begin
        GrupoDeContratosItems[i].DadosAtrasoEvo[j].Esconde := true;
        fillchar(GrupoDeContratosItems[i].DadosAtrasoEvo[j].IsenMora,sizeof(TpIsenMora),0);
        if ArrCodSerie.hasItem(GrupoDeContratosItems[i].DadosAtrasoEvo[j].CodSerie) then begin
          ArrMac := ArrCodSerie[GrupoDeContratosItems[i].DadosAtrasoEvo[j].CodSerie] as TSparseObjectArray;
          if ArrMac.HasItem(GrupoDeContratosItems[i].DadosAtrasoEvo[j].MacPrst) then begin
            Prest := ArrMac[GrupoDeContratosItems[i].DadosAtrasoEvo[j].MacPrst] as TPrestacaoAtrasoEvo;
            GrupoDeContratosItems[i].DadosAtrasoEvo[j].Esconde := Prest.esconde;
            GrupoDeContratosItems[i].DadosAtrasoEvo[j].IsenMora := Prest.IsenMora;
          end;
        end;
      end;
    Dados.clear;
  finally
    achou := ArrCodSerie.findFirst(i,Obj);
    while achou do begin
      Obj.free;
      achou := ArrCodSerie.findNext(i,Obj);
    end;
    ArrCodSerie.free;
  end;
  CalculaAtraso(CalculoAtrasoParametros,Dados,true{Recalculo});
end;

function TGrupoDeContratos.NumPrstAtrasoEvo( DtRef : TData;
                                             DtAtr : Tdata;
                                             DesconsideraSeguroEmAtr : boolean = false;
                                             ConsideraAgenda : boolean = false) : integer;
var
  c,s : integer;
  ArrAtr : TArrayOfDatas;
  LstMac : THashedStringlist;
  i : integer;
begin
{$IFDEF FPC} ArrAtr := default(TArrayOfDatas); {$ENDIF}
  result := 0;
  SetLength(ArrAtr,0);
  if DtAtr.dia = 0 then
    DtAtr := DtRef;

  LstMac := THashedStringlist.create;
  try
    LstMac.sorted := true;
    LstMac.duplicates := dupignore;
    for c := 0 to Count-1 do begin
      for s := 0 to GrupoDecontratosItems[c].Contrato.Series.count-1 do begin
        GrupoDecontratosItems[c].Contrato.Series[s].ListaPrstAtrasoEvo(DtRef,DtAtr,ArrAtr,
                                                                       DesconsideraSeguroEmAtr,
                                                                       ConsideraAgenda);
        result := result + Length(ArrAtr);
      end;

      GrupoDecontratosItems[c].Contrato.SerieF.ListaPrstAtrasoEvo(DtRef,DtAtr,ArrAtr,
                                                                  DesconsideraSeguroEmAtr,
                                                                  ConsideraAgenda);
      for i := 0 to length(ArrAtr)-1 do
        LstMac.add(inttostr(mes_int(ArrAtr[i].MesAno)));
    end;
    result := result + LstMac.count;
  finally
    LstMac.free;
  end;
end;

