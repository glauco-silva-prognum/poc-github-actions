  DoSelecaoChanged;
end;

constructor TSelecaoContratos.create;
begin
  reset;
end;

procedure TContratos.PesquisaNomeContratoComLike(comlike : boolean);
begin
  FPesquisaComLike := comlike;
end;
          
procedure TContratos.MontaQuery;
begin
//  FQry.Prepared := false; // A query nao tem parametros.
  Fqry.sql.beginupdate;
  try
    Fqry.sql.clear;
    FQry.sql.add('SELECT');
    FMutdskCampos.GeraSelectStrings(FQry.Sql);
    FQry.sql.add('FROM CADMUT WHERE');
    FQry.sql.add('CO_BASE ='+inttostr(FCoBase));
    if FSelecaoContratos.PorSitCobj then begin
      if FSelecaoContratos.Sitcobj > -1 then
        Fqry.sql.add('AND CAD_SITCOBJ='+intstr(FSelecaoContratos.Sitcobj));
    end
    else if FSelecaoContratos.Cpf > '' then
      Fqry.sql.add('AND CAD_CPF='+quotedstr(FSelecaoContratos.Cpf))
    else if FSelecaoContratos.Email > '' then 
      Fqry.sql.add('AND UPPER(CAD_EMAIL) like '+quotedstr(UpStr('%'+FSelecaoContratos.Email+'%')))
    else if FSelecaoContratos.CtrEstrangeiro > '' then
      Fqry.sql.add('AND CAD5_CODCTRESTRANGEIRO='+quotedstr(FSelecaoContratos.CtrEstrangeiro))
    else if FSelecaoContratos.CtrAntSec > '' then
      Fqry.sql.add('AND CADSEC_CTRANTSEC='+quotedstr(FSelecaoContratos.CtrAntSec))
    else if FSelecaoContratos.CtrVelho > '' then begin
      if FSelecaoContratos.CtrVelhoFim > '' then begin
        Fqry.sql.add('AND CAD_CTRVELHO>='+quotedStr(FSelecaoContratos.CtrVelho));
        Fqry.sql.add(' AND CAD_CTRVELHO<='+quotedStr(FSelecaoContratos.CtrVelhoFim));
      end
      else 
        Fqry.sql.add('AND CAD_CTRVELHO='+quotedStr(FSelecaoContratos.CtrVelho))
    end
    else if FSelecaoContratos.CtrSistemaantigoIni > '' then begin
      if FSelecaoContratos.CtrSistemaAntigoFim > '' then begin
        Fqry.sql.add('AND CAD5_CTRSISTEMAANTIGO>='+quotedStr(FSelecaoContratos.CtrSistemaAntigoIni));
        Fqry.sql.add(' AND CAD5_CTRSISTEMAANTIGO<='+quotedStr(FSelecaoContratos.CtrSistemaAntigoFim));
      end
      else 
        Fqry.sql.add('AND CAD5_CTRSISTEMAANTIGO='+quotedStr(FSelecaoContratos.CtrSistemaAntigoIni))
    end
    else if FSelecaoContratos.MAtricula > '' then begin
      if FSelecaoContratos.MAtriculaFim > '' then begin
        Fqry.sql.add('AND CAD5_MATRICULAFUNCIONARIO>='+quotedStr(FSelecaoContratos.Matricula));
        Fqry.sql.add(' AND CAD5_MATRICULAFUNCIONARIO<='+quotedStr(FSelecaoContratos.matriculaFim));
      end
      else 
        Fqry.sql.add('AND CAD5_MATRICULAFUNCIONARIO='+quotedStr(FSelecaoContratos.matricula));
    end    
    else if FSelecaoContratos.NomeIni > '' then begin
      if FPesquisaComLike then  begin
          if FSelecaoContratos.NomeIniExclusivo > '' then begin
              Fqry.sql.add('AND ((UPPER(CAD_NOME) like '+quotedStr(UpStr(FSelecaoContratos.nomeIni)+'%'));
              Fqry.sql.add('AND CAD_NOME >= '+quotedStr(FSelecaoContratos.nomeIni)+')');
              Fqry.sql.add('OR (UPPER(CAD_NOMESOCIAL) like '+quotedStr(UpStr(FSelecaoContratos.nomeIni)+'%'));
              Fqry.sql.add('AND CAD_NOMESOCIAL >= '+quotedStr(FSelecaoContratos.nomeIni)+'))');
          end
          else begin
              Fqry.sql.add('AND (UPPER(CAD_NOME) like '+quotedStr(UpStr(FSelecaoContratos.nomeIni)+'%'));
              Fqry.sql.add('OR UPPER(CAD_NOMESOCIAL) like '+quotedStr(UpStr(FSelecaoContratos.nomeIni)+'%')+')');
          end;
      end 
      else begin
        Fqry.sql.add('AND (CAD_NOME >= '+quotedStr(FSelecaoContratos.nomeIni));
        Fqry.sql.add('OR CAD_NOMESOCIAL >= '+quotedStr(FSelecaoContratos.nomeIni)+')');
      end;
    end
    else if FSelecaoContratos.NomeIniExclusivo > '' then
      FQry.sql.add('AND (CAD_NOME > '+quotedStr(FSelecaoContratos.nomeIniExclusivo)+
                        'OR CAD_NOMESOCIAL > '+quotedStr(FSelecaoContratos.nomeIniExclusivo)+')')
    else if FSelecaoContratos.Chaveimv.Empreend > -1 then begin
      Fqry.sql.add('AND CHAVEIMV_EMPREEND='+intstr(FSelecaoContratos.ChaveImv.Empreend));
      if FSelecaoContratos.Chaveimv.Codimv > '' then
        Fqry.sql.add('AND CHAVEIMV_CODIMV='+QuotedStr(FSelecaoContratos.ChaveImv.CodImv));
    end
    else if FSelecaoContratos.ContrMut > '' then begin
      if FSelecaoContratos.ContrMutFim > '' then begin
        Fqry.sql.add('AND CAD_CONTRMUT>='+quotedStr(FSelecaoContratos.ContrMut));
        Fqry.sql.add(' AND CAD_CONTRMUT<='+quotedStr(FSelecaoContratos.ContrMutFim));
      end
      else
        Fqry.sql.add('AND CAD_CONTRMUT='+quotedstr(FSelecaoContratos.ContrMut));
    end
    else if FselecaoContratos.Gestor > 0 then  begin
      FQry.sql.add('AND FINANC3_GESTOR='+IntStr(FSelecaoContratos.gestor))
    end
    else if FSelecaoContratos.Operacao > '' then
      FQry.sql.add('AND CADSEC_OPERACAO='+quotedstr(FSelecaoContratos.Operacao))
    else if FSelecaoContratos.CodCRI > '' then
      FQry.sql.add('AND CADSEC_CODCRI='+quotedstr(FSelecaoContratos.CodCRI))
    else if FSelecaoContratos.NumAverbCCI > '' then
      FQry.sql.add('AND CADSEC_NUMAVERBCCI='+quotedstr(FSelecaoContratos.NumAverbCCI))
    else if FSelecaoContratos.CerCefhab > -1 then
      FQry.sql.add('AND CAD_CERCEFHAB='+intstr(FSelecaoContratos.CerCefHab))
   else if FSelecaoContratos.ChaveEmpNome.Empreend > -1 then begin
      Fqry.sql.add('AND CHAVEIMV_EMPREEND='+intstr(FSelecaoContratos.ChaveEmpNome.Empreend));
      if FSelecaoContratos.ChaveEmpNome.NomeIni > '' then
        Fqry.sql.add('AND (CAD_NOME >= '+quotedStr(FSelecaoContratos.ChaveEmpNome.NomeIni)+
                          'OR CAD_NOMESOCIAL >= '+quotedStr(FSelecaoContratos.ChaveEmpNome.NomeIni)+')')
      else if FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo > '' then begin
        FQry.sql.add('AND (CAD_NOME > '+quotedStr(FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo)+
                          'OR CAD_NOMESOCIAL > '+quotedStr(FSelecaoContratos.ChaveEmpNome.NomeIniExclusivo)+')');
      end;
    end
    else if FSelecaoContratos.Empresa > -3 then
      FQry.sql.add('AND CAD_CODEMPRESA='+intstr(FSelecaoContratos.Empresa))
    else if FSelecaoContratos.ChaveEmpresaNome.Empresa > -3 then begin
      Fqry.sql.add('AND CAD_CODEMPRESA='+intstr(FSelecaoContratos.ChaveEmpresaNome.Empresa));
      if FSelecaoContratos.ChaveEmpresaNome.NomeIni > '' then
        Fqry.sql.add('AND (CAD_NOME > '+quotedStr(FSelecaoContratos.ChaveEmpresaNome.NomeIni)+
                          'OR CAD_NOMESOCIAL > '+quotedStr(FSelecaoContratos.ChaveEmpresaNome.NomeIni)+')');
    end;

    if FSelecaoContratos.FCtrIniExclusivo > '' then
      FQry.sql.add('AND CO_CONTRATO>'+quotedstr(CtrToSqlCtr(FSelecaoContratos.FCtrIniExclusivo)));
    if FCtrIni > '' then
      FQry.sql.add('AND CO_CONTRATO>='+quotedstr(CtrToSqlCtr(FCtrIni)));
    if FCtrFim > '' then
    FQry.sql.add('AND CO_CONTRATO<='+quotedStr(CtrToSqlCtr(FCtrFim)));
    FQry.sql.add('ORDER BY '+FOrdem);

  finally
    FQry.sql.endUpdate;
  end;
end;

procedure TContratos.TrataOnSelecaoChanged(Sender : TObject);
begin
  Fecha;
  if FSelecaocontratos.PorSitCobj then begin
    AtivaIndice(7);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Cpf > '' then begin
    AtivaIndice(3);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CtrVelho > '' then begin
    AtivaIndice(4);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Matricula > '' then begin
    AtivaIndice(13);
    FCtrini := '';
    FCtrFim := '';
  end  else if (FSelecaoContratos.NomeIni > '') or (FSelecaoContratos.NomeIniExclusivo > '') then begin
    AtivaIndice(2);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Chaveimv.Empreend > -1 then begin
    AtivaIndice(6);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CtrAntSec > '' then begin
    AtivaIndice(9);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.ContrMut > '' then begin
    AtivaIndice(11);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CtrEstrangeiro > '' then begin
    AtivaIndice(12);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Operacao > '' then begin
    AtivaIndice(14);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CtrSistemaantigoini > '' then begin
    AtivaIndice(15);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CodCRI > '' then begin
    AtivaIndice(8);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.NumAverbCCI > '' then begin
    AtivaIndice(18);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.CerCefHab > -1 then begin
    AtivaIndice(19);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Gestor > 0 then begin
    AtivaIndice(5);
    FCtrIni := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.ChaveEmpNome.Empreend > -1 then begin
    AtivaIndice(16);
    FCtrIni := '';
    FctrFim := '';
  end
  else if FSelecaoContratos.Empresa > -3 then begin
    AtivaIndice(20);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.ChaveEmpresaNome.Empresa > -3 then begin
    AtivaIndice(21);
    FCtrini := '';
    FCtrFim := '';
  end
  else if FSelecaoContratos.Email > '' then begin
    AtivaIndice(24);
    FCtrini := '';
    FCtrFim := '';
  end;
  MontaQuery;
end;

