procedure TSerie.CalculaEncargos(    Reg : TValoresPorMac;
                                 var MutDsk : TpMutDsk;
                                     DataRef : TData;
                                 var Correcao,
                                     JMora,
                                     JContr,
                                     Multa,
                                     CorrMoraMultaSeg :Double;
                                 var CorrecaoAmaisj,
                                     JMoraAmaisj,
                                     JContrAmaisj,
                                     MultaAmaisj : real;
                                     NaoCobraJC: boolean;
                                     ComIsencao : boolean = false;
                                     AtrasoContabil : boolean = false;
                                     IgnoraPendenciaManual : boolean = false;
                                     SomenteTipoPgParcial : boolean = false;
                                     SomenteSeguro : boolean = false);
var
  DifEmi,
  ValorAux          : real;
  DataVenc          : TData;
  CodTabGPreChvCorr,
  CodTabGCorr       : smallint;
  TmoraAux : byte;
  ValAux,
  ValorPagoAntecipado : real;
  CorrecaoSeguro,
  JMoraSeguro,
  JContrSeguro,
  MultaSeguro : real;
  UF : str3;
  CodMun : smallint;
  DataRefReajSerie,
  DtIndInvalido : Tdata;
  SalvaNaoCorrigeAts : boolean;
  IndiceInvalido : boolean;
begin
  SalvaNaoCorrigeAts := ScciConf.NaoCorrigeAts;
  ValAux := 0;
  JContrSeguro := 0;
  JMoraSeguro := 0;
  MultaSeguro := 0;
  CorrecaoSeguro := 0;
  UF := '';
  CodMun := 0;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
{ Sol 24882
  Calcular:
  At  a dtvenc da parcela: nada
  At  a condi  o de atraso: corr/juros contratuais
  A partir da condi  o de atraso: corr/mora/juros contratuais/multa
}

  if assigned(self) and not EmCarenciaCobAtraso(Reg,DataRef)(*and
   ((Fin.codclassificacao <> serie_Inibe1aVia) or
    ((RpaS.FinRPA.NPC = 0) and
     (RpaS.MAC > Mes_Int(RPAS.FinRPA.DtAssin.MesAno)) and
     (RpaS.ValRPA.TotPrest-RPAS.ValRPA.Desc > Zero)) or
     ESerieFinancBancarioDevida(Fin,RpaS.Temp10.DtHabit,DataRef)) *)then begin
    {
      Mudan a de crit rio. N o usar mais valorpagoantecipado, pois este s  vem preenchido se a parcela n o estiver com
      tipopg pago. Utilizar a nova vari vel RPAS.Temp11.VUtilPgParcialAntec que informa quanto realmente foi antecipado
      at  o vencimento da parcela.
      Sol. 27982
    }
    if Fin.CodReajAtraso > 0 then begin
      CodTabGPreChvCorr := 0;
      CodTabGCorr       := Fin.CodReajAtraso;
    end
    else begin
      CodTabGPreChvCorr := Reg.CodTabGPreChvCorr;
      CodTabGCorr       := Reg.CodTabGCorr;
    end;
  
    if Scciconf.NaoAtualizaAtrasoDeSeriesSemIndexador and
      (CodTabGPreChvCorr = 0) and (CodTabGCorr = 0) then 
      ScciConf.NaoCorrigeAts := true;
  
    fillchar(DtIndInvalido,sizeof(Tdata),0);
    IndiceInvalido := false;
    DataRefReajSerie := Fin.DataRefReaj;
    if ((Abs(Reg.AmaisJ) <= Zero) and (Reg.Seguro > Zero)) or
        (not Reg.TemParcNoMes) or SomenteSeguro then
      ValorPagoAntecipado := 0
    else
//      ValorPagoAntecipado := Reg.VUtilPgParcialAntec;                                  
    ValorPagoAntecipado := int(PagamentosParciais.ObtemSaldoAteDataref(Reg.Mac,Dataref,Reg.IndJuros,ValAux,AtrasoContabil,SomenteTipoPgParcial) * Reg.TxPstacum *100+0.5)/100;
    if (AtrasoContabil and (not Scciconf.ConsideraPendEmiNaAtualizacaoDoAtrasoCtb)) then
      DifEmi := 0
    else
      DifEmi := Contrato.Pendencias.ValorPendEmi(Reg.MAC,Fin.CodSerie);
    DataVenc.Dia := Reg.DiaVenc;
    int_mes(Reg.MAC,DataVenc.MesAno);
    Correcao := 0;
    Jmora    := 0; { Juros morat rios + Juros remunerat rios }
    JContr   := 0; { Juros Remunerat rios }
    multa    := 0;
    CorrMoraMultaSeg := 0;
    CorrecaoAmaisj := 0;
    JmoraAmaisj := 0;
    JContrAmaisj := 0;
    multaAmaisj := 0;
    if EstaEmFaseDeCarenciaFinBancChaves(Dataref) then begin // Sol. 27946+28414
      TMoraAux := 0;
      NaoCobraJC := false;
    end
    else
      TmoraAux := Reg.TMora;
    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    if AtrasoContabil then begin
      if ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb then
        Reg.TotPrest := Arredonda(Reg.TotPrest-Reg.ValTxAdm);
      if ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb then begin
        Reg.TotPrest := Arredonda(Reg.TotPrest-Reg.Seguro-Reg.DescSeg);
        Reg.Desc     := Arredonda(Reg.Desc - Reg.DescSeg);
        if Reg.Desc < Zero then Reg.Desc := 0;
      end;
      if (ValorPagoAntecipado > zero) and (Reg.AmaisJ > zero) and
         (ValorPagoAntecipado - Reg.AmaisJ > zero) then
        ValorPagoAntecipado := Reg.AmaisJ;
    end;
    if  EstaEmCondicaoDeAtrasoRPAS(Reg,DataRef) then begin
      {
        107585
        A DefineValorPrestAtraso estava recebendo valores incorretos vindo do RPA.
        Alterei para que todos os valores viessem do Reg(ValoresPorMac).
      }
      Correcao := CorrecaoJMJCChaves( MutDsk,UF,Codmun,
                                      DefineValorPrestAtraso(Reg.Totprest+Reg.ResiduoCobrado-ValorPagoAntecipado-Reg.Desc+DifEmi,
                                                             Reg.Seguro,Reg.ValTxAdm,AtrasoContabil),      
                                    DataVenc,
                                    DataRef,
                                    Reg.IndJuros,
                                    TmoraAux,JMora,JContr,
                                    CodTabGPreChvCorr,
                                    CodTabGCorr,
                                    ComIsencao{false},NaoCobraJC,
                                    Reg.DefReajPreChvCorr,Reg.DefReajCorr{Fin.DefReaj},
                                    Fin.DataRef,Fin.TxJurosNoAtraso,
                                    DataRefReajSerie,
                                   ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                    true {CalculoDeAtraso});
      CorrecaoAmaisj := CorrecaoJMJCChaves( MutDsk,UF,Codmun,
                                            Reg.Amaisj-ValorPagoAntecipado,
                                            DataVenc,
                                            DataRef,
                                            Reg.IndJuros,
                                            TmoraAux,JMoraAmaisj,JContrAmaisj,
                                            CodTabGPreChvCorr,
                                            CodTabGCorr,
                                            ComIsencao{false},NaoCobraJC,
                                            Reg.DefReajPreChvCorr,Reg.DefReajCorr{Fin.DefReaj},
                                            Fin.DataRef,Fin.TxJurosNoAtraso,
                                            DataRefReajSerie,
                                           ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                            true {CalculoDeAtraso});
    end
    else begin
      Correcao := CorrecaoJMJCChaves( MutDsk,Fin.DataRef,UF,CodMun,
                                    Reg.Totprest+Reg.ResiduoCobrado-ValorPagoAntecipado-Reg.Desc+
                                    DifEmi,
                                    DataVenc,
                                    DataRef,
                                    Reg.IndJuros,
                                    TmoraAux,JMora,JContr,
                                    CodTabGPreChvCorr,
                                    CodTabGCorr,
                                    ComIsencao{false},NaoCobraJC,
                                    DtIndInvalido,IndiceInvalido,
                                    Reg.DefReajPreChvCorr,
                                    Reg.DefReajCorr{Fin.DefReaj},
                                    DataRefReajSerie,
                                  ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                   true {CalculoDeAtraso});
      CorrecaoAmaisj := CorrecaoJMJCChaves( MutDsk,Fin.DataRef,UF,CodMun,
                                            Reg.Amaisj-ValorPagoAntecipado,
                                            DataVenc,
                                            DataRef,
                                            Reg.IndJuros,
                                            TmoraAux,JMoraAmaisj,JContrAmaisj,
                                            CodTabGPreChvCorr,
                                            CodTabGCorr,
                                            ComIsencao{false},NaoCobraJC,
                                            DtIndInvalido,IndiceInvalido,
                                            Reg.DefReajPreChvCorr,
                                            Reg.DefReajCorr{Fin.DefReaj},
                                            DataRefReajSerie,
                                          ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                            true {CalculoDeAtraso});
    end;
    CorrecaoSeguro := CorrecaoJMJCChaves( MutDsk,Fin.DataRef,UF,CodMun,
                                          Reg.Seguro-Reg.Desc,
                                          DataVenc,
                                          DataRef,
                                          Reg.IndJuros,
                                          TMoraAux,JMoraSeguro,JContrSeguro,
                                          CodTabGPreChvCorr,
                                          CodTabGCorr,
                                          ComIsencao{false},NaoCobraJC,
                                          DtIndInvalido,IndiceInvalido,
                                          Reg.DefReajPreChvCorr,
                                          Reg.DefReajCorr{Fin.DefReaj},
                                          DataRefReajSerie,
                                        ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                          true {CalculoDeAtraso});

    if not EstaEmCondicaoDeAtrasoRPAS(Reg,DataRef) then begin
      JMora := JContr;
      JMoraSeguro := JContrSeguro;
      JMoraAmaisj := JContrAmaisj;
    end;
    if Scciconf.CobraMultaNoAtrasoDeSeries and EstaEmCondicaoDeAtrasoRPAS(Reg,DataRef) then begin
      ValorAux := Reg.TotPrest+Reg.ResiduoCobrado-ValorPagoAntecipado-Reg.Desc +
                  DifEmi;
      if ScciConf.NaoPenalizaAcessoriosNoAtraso then begin // 101894
        if AtrasoContabil then begin
          if not ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb then
            ValorAux := arredonda(ValorAux - Reg.ValTxAdm);
          if not ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb then
            ValorAux := arredonda(ValorAux - Reg.Seguro - Reg.DescSeg);
        end
        else 
          ValorAux := arredonda(ValorAux - (Reg.Seguro-Reg.DescSeg) - Reg.ValTxADm);
        if ValorAux < 0 then
          ValorAux := 0;
      end;  
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (Reg.TMora <> 101) then
        ValorAux := ValorAux + Correcao;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + JMora;
      if (Reg.TMora in [38..40]) then 
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta)
      else
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);

      ValorAux := Reg.Seguro-Reg.Desc;
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (MutDsk.Financ.TMora <> 101) then
        ValorAux := ValorAux + CorrecaoSeguro;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + JMoraSeguro;
      if (Reg.TMora in [38..40]) then 
        MultaSeguro := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
      else
        MultaSeguro := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);

      ValorAux := Reg.Amaisj-ValorPagoAntecipado;
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (Reg.TMora <> 101) then
        ValorAux := ValorAux + CorrecaoAmaisj;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + JMoraAmaisj;
      if (Reg.TMora in [38..40]) then 
        MultaAmaisj := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
      else
        MultaAmaisj := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
    end else begin
      Multa := 0;
      MultaSeguro := 0;
      MultaAmaisj := 0;
    end;
    CorrMoraMultaSeg := CorrecaoSeguro + JMoraSeguro + MultaSeguro;
  end
  else begin
    correcao := 0;
    Jmora    := 0; { Juros morat rios + Juros remunerat rios }
    JContr   := 0; { Juros Remunerat rios }
    multa    := 0;
    CorrMoraMultaSeg := 0;
    correcaoAmaisj := 0;
    JmoraAmaisj    := 0;
    JContrAmaisj   := 0;
    multaAmaisj    := 0;
  end;
  ScciConf.NaoCorrigeAts := SalvaNaoCorrigeAts;
  if SomenteSeguro then begin
    correcao := correcaoSeguro;
    Jmora    := JMoraSeguro;
    JContr   := JContrSeguro;
    multa    := MultaSeguro;
  end;
end;

