      // voltar as antecipa  es
      //RPAS.Valrpa.saldodev := RPAS.Valrpa.saldodev - Rpas.Temp12.PagAntecNoVenc - Rpas.Temp12.PagAntecPosVenc;
    end;  
  end;

  if ( Rpas.Temp12.PagAntecAntesVenc +  Rpas.Temp12.PagAntecNoVenc +  Rpas.Temp12.PagAntecPosVenc) > 0 then
  begin
    // Se estiver na primeira presta  o, tem que amortizar o saldo swap
    // Depois isto   feito somando o valor no amaisjswap
    if rpas.mac = mes_int(rpas.finrpa.dtassin.MesAno)  then
    begin
      rpas.temp12.VlrAmortSwap := FValorAntecNoVencSwap +  FValorAntecAntesVencSwap + FValorAntecPosVencSwap;
      rpas.sec.SaldodevSwap := rpas.sec.SaldodevSwap - FValorAntecNoVencSwap - FValorAntecAntesVencSwap - FValorAntecPosVencSwap;
    end;
    AmortizaSaldosSecuritizados( Rpas.Temp12.PagAntecAntesVenc, Rpas.Temp12.PagAntecNoVenc, Rpas.Temp12.PagAntecPosVenc);
{    if (RPAS.ValRPA.SaldoDev >= 0.999) and   // SCAt 24432
         (RPAS.FinRPA.Prazo=0) and (RPAS.Temp.PrazoAnt<>0) then
        RPAS.FinRPA.Prazo := 1; desfazendo conforme sol. 43702}
  end;

  if ( Rpas.Temp12.PagAntecAntesVenc +  Rpas.Temp12.PagAntecNoVenc +  Rpas.Temp12.PagAntecPosVenc) > 0 then // Scat 26176
  // Se o prazo terminou devido a prgamentos antecipados n o deixa res duo no saldo devedor
  // o saldo dever  ser amortizado integralmente. Esta situa  o   quando n o existem mais
  // parcelas a verncer. Todas j  foram quitadas.
  begin
(***** Renata - Desisti da tentativa de jogar o resto do saldo como valor da ultima para a sol.38494
    FValorAntecDaUltima := RPAS.VALRPA.SALDODEV;
****)
    if ((RPAS.FINRPA.PRAZO - RPAS.FINRPA.NPC)<=0) then
    begin
      if (not RPAS.Temp10.TemParcNoMes or  FParcelaDoMesTevePagamentoAntecipado) then
      begin
        if  Rpas.Temp12.PagAntecPosVEnc > 0 then begin
           Rpas.Temp12.PagAntecPosVenc :=  Rpas.Temp12.PagAntecPosVenc + RPAS.VALRPA.SALDODEV;
           if not AmortizouSaldo then 
             Rpas.Temp12.PagAntecPosVenc := Rpas.Temp12.PagAntecPosVenc + RPAS.ValRPA.Juro;
        end
        else if  Rpas.Temp12.PagAntecNoVenc > 0 then begin
           Rpas.Temp12.PagAntecNoVenc :=  Rpas.Temp12.PagAntecNoVenc + RPAS.VALRPA.SALDODEV;
           if not AmortizouSaldo then
             Rpas.Temp12.PagAntecNoVenc := Rpas.Temp12.PagAntecNoVenc  + RPAS.ValRPA.Juro;
        end
        else begin
           Rpas.Temp12.PagAntecAntesVenc := R2( Rpas.Temp12.PagAntecAntesVenc + RPAS.VALRPA.SALDODEV -
                                    RPAS.Temp.CorrSaldo);
          RPAS.Temp.CorrSaldo := 0;
          RPAS.Temp11.CorrSaldoMes := 0;
        end;
        RPAS.VALRPA.SALDODEV := 0;
        RPAS.VALRPA.AMAISJ := 0;
        RPAS.VALRPA.JURO := 0;
      end
      else begin  { Sol 48084 - A s rie foi totalmente amortizada no ou p s vencto, mas a prest. do m s n o foi antecipada }
        if AmortizouSaldo then // Preciso conferir se o saldo j  est  amortizado ou n o, para chegar no residuo
          ResiduoSd := RPAS.ValRPA.SaldoDev
        else
          ResiduoSd := RPAS.ValRPA.SaldoDev - (RPAS.ValRPA.Amaisj-RPAS.ValRPA.Juro);
        if  Rpas.Temp12.PagAntecPosVEnc > 0 then
           Rpas.Temp12.PagAntecPosVenc :=  Rpas.Temp12.PagAntecPosVenc + ResiduoSd
        else if  Rpas.Temp12.PagAntecNoVenc > 0 then
           Rpas.Temp12.PagAntecNoVenc :=  Rpas.Temp12.PagAntecNoVenc + ResiduoSd;
        RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev - ResiduoSd;
      end;
    end;
  end;
  RPAS.FinRPA.ValorAI := R2(RPAS.FinRPA.ValorAI +  Rpas.Temp12.PagAntecAntesVenc +  Rpas.Temp12.PagAntecNoVenc +  Rpas.Temp12.PagAntecPosVenc);
end;

procedure TSerie.TrataEventoAmortizacao_AntesVenc(Evento : TEventoAmInc);
var
  IndAmInc: Double;
  legLinkItem: TlegLinkItem;
  Dt1,
  Dt2: TData;
  IndiceDeCorrecaoProRata: Double;
begin
  LegLinkItem := nil;
  with Evento do
  begin
    if (ExAmInc in [103,105,114]) and
        (DiaEvento < integer(Rpas.FinRpa.DiaVenc)) then { Amortiza  o }
    begin
      // Amortiza  es positivas e incorpora  es negativas
      // Mantendo o mesmo crit rio de financiamento din mico
      ValorAmInc := -ValorAmInc;
      SaldoDevAntes := RpaS.ValRpa.SaldoDev;
      if not Contrato.FInibeLegLink then 
        leglinkItem := LegLink.Add(fin.codserie,'<br><br><b>Amortiza  o antes do vencimento</b><br>');
      if assigned(legLinkItem) then
      begin
        leglinkItem.Valores['Dia Evento'] := intstr(DiaEvento);
        leglinkItem.Valores['Valor da Amortiza  o'] := strgrana(-valorAmInc);
        if ComProRataJur then
          leglinkItem.Valores['Com <i>pro rata</i> de juros'] := 'Sim'
        else
          leglinkItem.Valores['Com <i>pro rata</i> de juros'] := 'N o';
      end;
      
      DiaVenc := Rpas.FinRpa.DiaVenc;
      int_mes(RPAS.MAC,Dt2.Mesano);
      Dt2.Dia := byte(DiaEvento);
      Dt1:=Dt2;
      decma(Dt1.MesAno);
      Dt1.Dia := Dia_Venc(mes_int(Dt1.MesAno),Rpas.Finrpa.DtInFin.Dia); // DiaInFinAnt;Solic 70633  //DiaVencAnt Solic.64543
      if (Juliano(Dt1) < Juliano(RpaS.FinRpa.DtAssin)) then
        Dt1 := RpaS.FinRpa.DtAssin;

      // Calcula juros pro-rata
      if not ComProRataJur then
        JurosAmort := 0
      else if fin.jurosSimples then
        JurosAmort := -arredonda(-ValorAMInc * Rpas.FinRpa.IndJuros*NoDiasProrataJuros(Dt1,Dt2)/NoDiasMesProRataJuros(Dt1))
      else
        JurosAmort := -arredonda(-ValorAMInc * (1/(pot(1+Rpas.FinRpa.IndJuros,NoDiasProrataJuros(Dt1,Dt2)/NoDiasMesProRataJuros(Dt1)))-1));
      if abs(HJurosAmort) > Zero then JurosAmort := -HJurosAmort;

      // Calcula corre  o pro-rata
      if (IncSCorr=0) then
        IndiceDeCorrecaoProRata := CalcIndiceCorrecaoProRata(Dt1,Dt2,Rpas,legLinkItem,true)-1
      else
        IndiceDeCorrecaoProRata := 0;
      IndCorEv := IndiceDeCorrecaoProRata;

      // ValorAiNoVencto   negativa por convens o

      ValorAINoVencto := arredonda2((ValorAMInc+JurosAmort) / (1+IndiceDeCorrecaoProrata));

      CMProrataContabil := -ValorAMInc-JurosAmort+ValorAINoVencto;

      JurosAmort := -JurosAmort; // Para que ela fique positiva
      if assigned(legLinkItem) and 
        ((jurosAmort > 0) or (Abs(CMProrataContabil) > Zero)) then
      begin
        leglinkItem.Valores['Data inicial prorata'] := data_str2(dt1);
        leglinkItem.Valores['Data final prorata'] := data_str2(dt2);
        leglinkItem.Valores['Dias para c lculo de juros'] := inttostr(DiasCorridos360(Dt1,Dt2));
        leglinkItem.Valores['Juros <i>pro rata</i> sobre a amortiza  o'] := strgrana(JurosAmort);
        leglinkItem.Valores['Corre  o <i>pro rata</i> sobre a amortiza  o'] := strgrana(CMProrataContabil);
        leglinkItem.Valores['Valor a amortizar no vencimento'] := strgrana(-ValorAINoVencto);
      end;

      // Calcula a amortiza  o
      if NPAI = 0 then // Evolu  o de s ries n o suporta amortiza  o no prazo
      begin            // Mas se tiver esta vari vel fornecida n o altera a presta  o
        if Abs(rpas.valrpa.SaldoDev) > Zero then
          IndAmInc := 1+ValorAINoVencto/(rpas.valrpa.SaldoDev)
        else
          IndAmInc := 0;
        rpas.Temp10.IndRedPrest := 1-((1-rpas.Temp10.IndRedPrest) * IndAmInc);
      end;

      RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + ValorAINoVencto;
      NovoSaldoNoEvento := RPAS.ValRPA.SaldoDev;

      if assigned(legLinkItem) then
      begin
        leglinkItem.Valores[' ndice de redu  o da presta  o'] := formatfloat('0.00000000',rpas.Temp10.IndRedPrest);
        leglinkItem.Valores['Valor Amortizado'] := strgrana(abs(ValorAINoVencto));
        leglinkItem.Valores['Saldo Amortizado'] := strgrana(RPAS.ValRPA.SaldoDev);
      end;

    end;
  end;  
end;

procedure TSerie.TrataEventoAmortizacao_No_E_Apos_Venc(Evento : TEventoAmInc);
var
  IndAmInc: Double;
  legLinkItem: TlegLinkItem;
  Dt1,
  Dt2: TData;
  IndiceDeCorrecaoProRata: Double;
begin
  LegLinkItem := nil;
  with Evento do
  begin
    if (ExAmInc in [103,105,114,121]) and
        (DiaEvento >= integer(Rpas.FinRpa.DiaVenc)) then { Amortiza  o }
    begin
      // Amortiza  es positivas e incorpora  es negativas
      // Mantendo o mesmo crit rio de financiamento din mico
      ValorAmInc := -ValorAmInc;

      SaldoDevAntes := RpaS.ValRpa.SaldoDev;
      if not Contrato.FInibeLegLink then begin
        if DiaEvento = integer(Rpas.FinRpa.DiaVenc) then
          leglinkItem := LegLink.Add(fin.codserie,'<br><br><b>Amortiza  o no vencimento</b><br>')
        else
          leglinkItem := LegLink.Add(fin.codserie,'<br><br><b>Amortiza  o depois do vencimento</b><br>');
      end;
      if assigned(legLinkItem) then
      begin
        leglinkItem.Valores['<b>Dia Evento</b>'] := intstr(DiaEvento);
        leglinkItem.Valores['Valor da Amortiza  o'] := strgrana(-valorAmInc);
        if ComProRataJur then
          leglinkItem.Valores['Com <i>pro rata</i> de juros'] := 'Sim'
        else
          leglinkItem.Valores['Com <i>pro rata</i> de juros'] := 'N o';
      end;

      // Calcula juros pro-rata
      DiaVenc := Rpas.FinRpa.DiaVenc;
      int_mes(RPAS.MAC,Dt2.Mesano);
      Dt2.Dia := byte(DiaEvento);
      Dt1:=Dt2;
      Dt1.Dia := Dia_Venc(mes_int(Dt1.MesAno),Rpas.Finrpa.DtInFin.Dia); // DiaInFinAnt;Solic 70633  //DiaVencAnt Solic.64543
      if (Juliano(Dt1) < Juliano(RpaS.FinRpa.DtAssin)) then
        Dt1 := RpaS.FinRpa.DtAssin;

      if not ComProRataJur then
        JurosAmort := 0
      else if fin.jurosSimples then
        JurosAmort := -arredonda(-ValorAMInc * Rpas.FinRpa.IndJuros*NoDiasProrataJuros(Dt1,Dt2)/NoDiasMesProRataJuros(Dt1))
      else
        JurosAmort := -arredonda(-ValorAMInc * (1/(pot(1+Rpas.FinRpa.IndJuros,NoDiasProrataJuros(Dt1,Dt2)/NoDiasMesProRataJuros(Dt1)))-1));
      if abs(HJurosAmort) > Zero then JurosAmort := -HJurosAmort;

      // Calcula corre  o pro-rata
      if (IncSCorr=0) then
        IndiceDeCorrecaoProRata := CalcIndiceCorrecaoProRata(Dt1,Dt2,Rpas,legLinkItem,false)-1
      else
        IndiceDeCorrecaoProRata := 0;
      IndCorEv := IndiceDeCorrecaoProRata;
      // ValorAmInc e ValorAiNoVencto s o negativas
      ValorAINoVencto := arredonda2((ValorAMInc+JurosAmort) / (1+IndiceDeCorrecaoProrata));

      CMProrataContabil := -ValorAMInc-JurosAmort+ValorAINoVencto;
      JurosAmort := -JurosAmort; // Para que ela fique positiva
      if assigned(legLinkItem) and 
        ((jurosAmort > 0) or (Abs(CMProrataContabil) > Zero)) then
      begin
        leglinkItem.Valores['Data inicial prorata'] := data_str2(dt1);
        leglinkItem.Valores['Data final prorata'] := data_str2(dt2);
        leglinkItem.Valores['Dias para c lculo de juros'] := inttostr(DiasCorridos360(Dt1,Dt2));
        leglinkItem.Valores['Juros <i>pro rata</i> sobre a amortiza  o'] := strgrana(JurosAmort);
        leglinkItem.Valores['Corre  o <i>pro rata</i> sobre a amortiza  o'] := strgrana(CMProrataContabil);
        leglinkItem.Valores['Valor a amortizar no vencimento'] := strgrana(-ValorAINoVencto);
      end;
      
      // Calcula a amortiza  o
      if NPAI = 0 then // Evolu  o de s ries n o suporta amortiza  o no prazo
      begin            // Mas se tiver esta vari vel fornecida n o altera a presta  o
        if Abs(rpas.valrpa.SaldoDev) > Zero then begin
          IndAmInc := 1+ValorAINoVencto/(rpas.valrpa.SaldoDev);
        end  
        else
          IndAmInc := 0;
        rpas.Temp10.IndRedPrest := 1-((1-rpas.Temp10.IndRedPrest) * IndAmInc);
      end;
      RPAS.ValRPA.SaldoDev := RPAS.ValRPA.SaldoDev + ValorAINoVencto;
      NovoSaldoNoEvento := RPAS.ValRPA.SaldoDev;

      if assigned(legLinkItem) then
      begin
        leglinkItem.Valores[' ndice de redu  o da presta  o'] := formatfloat('0.00000000',rpas.Temp10.IndRedPrest);
        leglinkItem.Valores['Saldo Amortizado desprorateado'] := formatfloat('0.00000000',RPAS.ValRPA.SaldoDev);
      end;
    end;
  end;
end;

procedure TSerie.TrataEventoPagAntecipado(Evento : TEventoAmInc; pTemAmortAntecMesmoDia : boolean);
begin
  if (Fin.FinanciaResiduo or ((Rpas.FinRpa.Plano mod 10)=SACR)) or pTemAmortAntecMesmoDia then
    CalculaAntecipacaoPeloValorPago(Evento,Evento.ParcelaObj as TParcelaSerie,
                                    Rpas.Temp12.PagAntecAntesVenc,
                                    Rpas.Temp12.PagAntecNoVenc,
                                    Rpas.Temp12.PagAntecPosVenc,
                                    FValorAntecDaUltima,FUltDiaPgAntec)
  else
    CalculaAntecipacaoPeloValorPresente(Evento,Evento.ParcelaObj as TParcelaSerie,
                                        Rpas.Temp12.PagAntecAntesVenc,
                                        Rpas.Temp12.PagAntecNoVenc,
                                        Rpas.Temp12.PagAntecPosVenc,
                                        FValorAntecDaUltima,FUltDiaPgAntec);
end;

function TSerie.TemAntecAmortNoMesmoDia : boolean;
var
  i : integer;
begin
  result := false;
  i := 1;
  while (i < FListaEventosAmInc.Count) and not result do begin
    result := result or 
              ((FListaEventosAmInc[i].DiaEvento=FListaEventosAmInc[i-1].DiaEvento) and
               (FListaEventosAmInc[i].ExAmInc in [103,105,114]) and // s  devo considerar eventos de amortiza  o
               (FListaEventosAmInc[i].TipoEvento<>FListaEventosAmInc[i-1].TipoEvento));
    inc(i);
  end;
end;

procedure TSerie.Calc_Eventos_AtesVenc;
var
  i: integer;
  lTemAntecAmortNoMesmoDia : boolean;
begin
  lTemAntecAmortNoMesmoDia := TemAntecAmortNoMesmoDia();
  for i := 0 to FListaEventosAmInc.Count-1 do
    if FListaEventosAmInc[i].DiaEvento < integer(Rpas.FinRpa.DiaVenc) then begin
      if FListaEventosAmInc[i].TipoEvento = tipoevento_amortizacao then
        TrataEventoAmortizacao_AntesVenc(FListaEventosAmInc[i])
      else if FListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado then
        TrataEventoPagAntecipado(FListaEventosAmInc[i], lTemAntecAmortNoMesmoDia);
    end;
end;

procedure TSerie.GeraResumoDeAntecipacoes;
var
  LegLinkItem : TLegLinkItem;
begin
  LegLinkItem := nil;
  if (Rpas.Temp12.PagAntecAntesVenc > zero) or
     (Rpas.Temp12.PagAntecNoVenc > zero) or
     (Rpas.Temp12.PagAntecPosVenc > zero) then begin
    if not Contrato.FInibeLegLink then 
      leglinkItem := LegLink.Add(CodSerie,'<br><b>Soma dos valores de antecipa  o de parcelas no m s</b><br>');
    if assigned(LegLinkItem) then
    begin
      leglinkItem.valores['AntecipacaoAntesVencimento'] := strgrana(Rpas.Temp12.PagAntecAntesVenc);
      leglinkItem.valores['AntecipacaoNoVencimento'] := strgrana(Rpas.Temp12.PagAntecNoVenc);
      leglinkItem.valores['AntecipacaoAposVencimento'] := strgrana(Rpas.Temp12.PagAntecPosVenc);
    end;
  end;  

  if (Rpas.Temp12.PagAntecAntesVenc + Rpas.Temp12.PagAntecNoVenc + Rpas.Temp12.PagAntecPosVenc) <> (FValorAntecAntesVencSwap+FValorAntecNoVencSwap+FValorAntecPosVencSwap) then 
  begin
    if not Contrato.FInibeLegLink then 
      leglinkItem := LegLink.Add(CodSerie,'<br><b>Soma dos valores de antecipa  o de parcelas no m s swap</b><br>');
    if assigned(LegLinkItem) then
    begin
      leglinkItem.valores['AntecipacaoAntesVencimento'] := strgrana(FValorAntecAntesVencSwap);
      leglinkItem.valores['AntecipacaoNoVencimento'] := strgrana(FValorAntecNoVencSwap);
      leglinkItem.valores['AntecipacaoAposVencimento'] := strgrana(FValorAntecPosVencSwap);
      leglinkItem.valores['PercColateral'] := formatfloat('0.000000',rpas.sec.PercColateral);
      leglinkItem.valores['AntecipacaoAntesVencimentoAdq'] := strgrana(FValorAntecAntesVencSwap* (1-rpas.sec.PercColateral));
      leglinkItem.valores['AntecipacaoNoVencimentoAdq'] := strgrana(FValorAntecNoVencSwap* (1-rpas.sec.PercColateral));
      leglinkItem.valores['AntecipacaoAposVencimentoAdq'] := strgrana(FValorAntecPosVencSwap*(1-rpas.sec.PercColateral));
    end; 
  end;
end;

procedure  TSerie.Calc_Eventos_No_E_Apos_Venc;
var
  i: integer;
  lTemAntecAmortNoMesmoDia : boolean;
begin
  lTemAntecAmortNoMesmoDia := TemAntecAmortNoMesmoDia();
  for i := 0 to FListaEventosAmInc.Count-1 do
    if FListaEventosAmInc[i].DiaEvento >= integer(Rpas.FinRpa.DiaVenc) then begin
      if FListaEventosAmInc[i].TipoEvento = tipoevento_amortizacao then
        TrataEventoAmortizacao_No_E_Apos_Venc(FListaEventosAmInc[i])
      else if FListaEventosAmInc[i].TipoEvento = tipoevento_PagAntecipado then  
        TrataEventoPagAntecipado(FListaEventosAmInc[i],lTemAntecAmortNoMesmoDia);
    end;
  Rpas.Temp12.PagAntecAntesVenc := R2(Rpas.Temp12.PagAntecAntesVenc);
  Rpas.Temp12.PagAntecNoVenc    := R2(Rpas.Temp12.PagAntecNoVenc);
  Rpas.Temp12.PagAntecPosVenc   := R2(Rpas.Temp12.PagAntecPosVenc);
  FValorAntecDaUltima  := R2(FValorAntecDaUltima);
  GeraResumoDeAntecipacoes;  
//  AmortizouposVenc := true;  Inibi! N o pode setar sempre como fiz.
//  Antes era setado apenas na CalculaValoresAntecipacoesPeloValorPago, quando h  pagamentos
//  no dia.
end;

