               (Fin.CodReajpreChaves>0) then 
             begin // SCAt 35211 // J  houve entrega das chaves
               FinRPA.TxSD := Temp9.IndAteChaves * 
                      detinddataadata(Temp7.CodTabelaGenerica,defas,DtEntHab, DtVenc, 1.0,
                      Fin.CorrProRata,IndInvalido,DtIndInvalido,false,finrpa.persaldev,fin.CorrProRataIniPelaVarDataRef,Temp12.CmProRataMesAnt,true)/Temp3.IndSaldoAcum;
         
             end
             else begin
               FinRPA.TxSD := detinddataadata(Temp7.CodTabelaGenerica,defas,DataRefParaReaj, DtVenc, 1.0,
                                            Fin.CorrProRata,IndInvalido,DtIndInvalido,false,finrpa.persaldev,
                                            fin.CorrProRataIniPelaVarDataRef,Temp12.CmProRataMesAnt,true)/Temp3.IndSaldoAcum;
             end;
           end;
         end;
       end; //case
       if IndInvalido then begin
          MarcaErroRPAS(RPAS,1,Temp7.CodTabelaGenerica,DtIndInvalido);
          FinRPA.TxSD := 1.0;
       end;
       DetTxSDAmortNeg(RPAs,FDataUltimoReajuste,DtVenc);
     end; // if 

     if (Fin.CodReaj=-1) and assigned(Contrato) then begin
       AtribuiReajContrato(RPAS);
       FinRpa.TxSD := Contrato.RPAF.FinRPA.TxSD;
       if not Contrato.FInibeLegLink then 
         LegLinkItem := LegLink.Add(CodSerie,'<b> ndice de corre  o da s rie ajustado ao contrato</b>');
       if assigned(LegLinkItem)  then begin
         LegLinkItem.valores[' ndice de corre  o do contrato'] := formatfloat('0.000000000000',Contrato.RPAF.FinRPA.TxSD);
       end;
     end;

     CalculaJurosProgressivos;

     if IndInvalido then MarcaErroRPAS(RPAS,1,Temp7.CodTabelaGenerica,DtIndInvalido);

     if (Temp10.NaoReajusta) or 
       (((FinRPA.Plano mod 10)=SACR) and (MAC<=succ(mes_int(FinRPA.DtInfin.MesAno)))) then
       Temp11.TxSDMes := 1.0
     else
       Temp11.TxSDMes := detinddataadata(Temp7.CodTabelaGenerica,defas, DtVencmenos1mes,
                                       DtVenc, 1.0, Fin.CorrProRata, IndInvalido,DtIndInvalido,false,finrpa.persaldev,
                                       fin.CorrProRataIniPelaVarDataRef,Temp12.CmProRataMesAnt,true);

     FIndSaldoAcumAnt := Temp3.IndSaldoAcum;
     FTxSdSwapAcumAnt := FTxSdSwapAcum;
     Temp.SaldevAnt := Valrpa.Saldodev; // atribuir antes de calcular amortiza  es e antecipa  es
     CalculaAntecipacoes;
     FListaEventosAmInc.Sort; // reordenar com antecipa  es
     Calc_Eventos_AtesVenc;
     if MAC>=mes_int(Fin.MAPrimReaj) then
       DeterminaTxSdSwap(Dt1Swap,DtVenc)
     else
       rpas.sec.TxSDSwap := 1;

     if scciconf.NPCCLIENTEINCREMENTAACADAMES and
        CTR_ATIVO(RPAS) then begin
        if RPAS.Mac > mes_int(RPAS.FinRPA.DtAssin.mesano) then
          inc(Temp11.NPCCliente);
        if assigned(FParcelaDoMes) and (FParcelaDoMes.NPCClienteEmi > 0) then
          Temp11.NPCCliente := ParcelaDoMes.NPCClienteEmi; // Priorizar o NPCCliente da tabela parcelas
        if Temp7.Periodicidade = 0 then
          lPeriodicidade := 1
        else
          lPeriodicidade := Temp7.Periodicidade;
        Temp11.PrazoCliente:= (FinRPA.Prazo-1)*lPeriodicidade+
                              (mes_int(RPAS.FinRPA.DtInFin.mesano)+1-mes_int(RPAS.FinRPA.DtAssin.mesano))+
                              Fin.NPCCliente;
     end;

     // Determina A+J
     if assigned(FParcelaDoMes) and RPAS.Temp10.TemParcNoMes and CTR_ATIVO(RPAS) then begin
        inc(FinRPA.NPC);

        if not scciconf.NPCCLIENTEINCREMENTAACADAMES then begin
          if FinRpa.NPC = 1 then Temp11.NPCCliente := Fin.NPCCliente
          else inc(Temp11.NPCCliente);
          if assigned(FParcelaDoMes) and (FParcelaDoMes.NPCClienteEmi > 0) then
            Temp11.NPCCliente := ParcelaDoMes.NPCClienteEmi; // Priorizar o NPCCliente da tabela parcelas
          Temp11.PrazoCliente:= FinRPA.Prazo + Temp11.NPCCliente-Finrpa.NPC;
        end;
        DefineAmaisJParcela(FParcelaDoMes as TParcelaSerie);
        if (Temp12.CmProRataMesAnt) and (abs(FinRPA.TxSD-1.0)>Zero) and
           (FinRPA.PerSaldev <> 1) and (not Fin.CobraResiduo) { Sol. 057972 } then begin
          FinRPA.TxSD := FinRPA.TxFull;
          Temp11.TxSDMes := FinRPA.TxFull;
        end;
        if not FUsandoAmaisJPeloValorEmitido then
          if assigned(FParceladomes) then begin
            if FParceladoMes.TipoPg in PgtoComRedSdDev then ValRPA.Amaisj:=0
            else begin
              ValRPA.AmaisJ := (1-Temp10.IndRedPrest)*Temp5.AmaisJIntegral;
            end;  
          end
          else ValRpa.AmaisJ := 0;
     end
     else begin
        if (MAC = mes_int(FinRPa.DtInFin.MesAno)+1) and CTR_ATIVO(RPAS) then begin
          inc(FinRpa.NPC); { Isto   para corrigir uma situa  o de inconsist ncia nos dados de uma s rie que n o possui a primeira parcela 
                      Causa problema no caso da primeira presta  o vencer no mesmo mes da assinatura. Incrementando o mac retira a 
                      possibilidade de loop. No futuro esta situa  o poder  gerar uma exception }
        end;
//          raise EEvolucaoError.Create('Dados da s rie inconsistentes: Falta parcela do primeiro vencimento da s rie ');
        if (not FDesconsideraParcela) or (FinRPA.NPC=0) then 
        begin
          RpaS.ValRpa.AmaisJ := 0;
          if (Fin.PerParcelasSwap <> 0) and (fin.PerParcelasSwap <> 1) then
            Rpas.Sec.AmaisJSwap := 0;
        end;
        

        if (Temp12.CmProRataMesAnt) and (abs(FinRPA.TxSD-1.0)>Zero) and
           (FinRPA.PerSaldev <> 1) and (not Fin.CobraResiduo) {Sol. 057972} then begin
          FinRPA.TxSD := FinRPA.TxFull;
          Temp11.TxSDMes := FinRPA.TxFull;
        end;
     end;
     
     if (Fin.RecalculaPrestacao) or ((FinRPA.Plano mod 10)=SACR) then 
       Temp10.IndRedPrest := 0.0;
     Temp3.IndSaldoAcum := Temp3.IndSaldoAcum*FinRPA.TxSD;
     FTxSdSwapAcum := FTxSdSwapAcum * Sec.TxSdSwap;
     if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples
         and ( Temp7.Periodicidade >= 1 ) then 
         { Se for scp com juros simples precisa calcular o reajuste da RDRD todo m s }
     begin
        ValRpa.RARD      := ValRpa.RARD*FinRpa.TxSd;
        if (Rpas.Temp11.planoswap =  0) then
        begin
          Rpas.Temp12.RaRdSwap := R2((Rpas.Sec.TxSDSwap) * Rpas.Temp12.RaRdSwap);
        end;
     end;
     DtEntHab := RPAS.Temp9.DtEntregaChaves; // SCAt 29363
     if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then DtEntHab := RPAS.Temp10.DtHabit;
      if (MAC <= Mes_int(DtEntHab.MesAno)) then begin
         Temp9.IndAteChaves := Temp3.IndSaldoAcum; //RPAS.Temp5.TxPstAcum;
         Temp.MAUA := MAC;
      end;
//     Temp.SaldevAnt := Valrpa.Saldodev; atribuir antes de tratar amortiza  es e antecipa  es
//     CalculaAntecipacoes; // Precisa ser chamada antes da corre  o do saldo / Precisa ser chamada antes de tratar as amortiza  es
//     FazAntecipacoesAntesVenc;
     if Temp6.AmSaldoAntCorr then Temp.CorrSaldo := 0 // SCAt 27613
     else begin
      Temp.CorrSaldo := R2((FinRPA.TxSD-1) * ValRPA.Saldodev);
    end;
//      Temp.SaldevAnt := Valrpa.Saldodev;  atribuir antes de calcular antecipa  es, pois depois o saldo pode ter sido zerado
     ValRPA.SaldoDev := ValRPA.SaldoDev + Temp.CorrSaldo;
     if (Fin.SistAmort=7) {SCP} and (FinRPA.Perfin<>1) and Temp12.JurSCPAnuais and
        (FinRPA.MReaj=integer(MACMA.Mes)) and (ValRPA.Amaisj>Zero) then begin
        ValRPA.SaldoDev := int(ValRPA.Amaisj*(FinRPA.Prazo-FinRPA.NPC)*100+0.5)/100;
        Temp.CorrSaldo := int(Temp.SaldevAnt*(FinRPA.TxSD-1)*100+0.5)/100;
        if (Juliano(Fin.DtCarenciaDeJuros) > Juliano(DtVenc)) then
          ValRpa.Juro := 0.00
        else
          ValRPA.Juro := ValRPA.Amaisj+(ValRPA.SaldoDev-Temp.SalDevAnt);
        AmortizouSaldo := true;
     end;

     Temp12.SaldoPrincipal := Temp12.SaldoPrincipal*FinRPA.TxSD;
     Temp.ValTmp2 := Temp.ValTmp2 * FinRPA.TxSD;
//      Temp11.MAUASD := MAC;
     Temp11.SldDevCorr := int(Temp11.SldDevCorr * FinRPA.TxSD*100+0.5)/100;
      //SCAt 21249
     Temp12.CorrSaldoMesAntAcum := Temp11.CorrSaldoMesAcum;
     CalcCorrSaldoMes(Rpas,Fin);
//      TrataMoeda( RPAS ); Antecipada pelo scat 39994
     if Fin.CompoeSaldo then
        Temp11.SegFinparaSeg := int( FinRPA.IndSegFin * ValRPA.SaldoDev * 100 + 0.5)/100;
     if CalculaTaxasNoMes then begin
       CalculaTaxapSeries;
     end
     else ValRpa.ValtxAdm := 0;
     if  assigned(FParceladoMes) and 
        ((abs(FParceladoMes.TaxaEmi) > Zero) or (FParcelaDoMes.Flag = 102)) and
        (not FDesconsideraParcela) and
        (abs(ValRPA.ValTxAdm-FParceladoMes.TaxaEmi) >= 0.01) then 
       ValRPA.ValTxAdm  := FParceladoMes.TaxaEmi;
     if (Fin.Status = 98) and (Mes_Int(Fin.DtExclusao.MesAno) <= RPAS.MAC) and
        Ctr_Ativo(RPAS)  then begin
       if (Contrato.FDataRefHist.Dia = 0) or
          DataEMenorOuIgual(Fin.DtExclusao,Contrato.FDataRefHist) then 
         TerminaCtrPorExclusao;
     end;
     // Calcula AmaisJ Agio Scat 73434
     if (Rpas.Sec.SaldoAgio>0) and (Mes_Int(Rpas.Finrpa.DtInFin.MesAno)+1 = Rpas.mac) then // Scat 73434
       CalcAmaisJAgio;
     // copiado da uevolui3, TEvolui3.CALC_OPCAO
     // antes n o setava as fezopcn e por isso n o podia usar a TemOpcao
     // para s ries.
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, FinRPA.ExOpc );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, FinRPA.ExAmInc );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, Temp7.ExInc );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, Temp3.ExSub );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, Temp7.ExOpcSeg );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FezOpc3, Temp7.FezOpc4, Temp7.ExOpcMudCateg );
     MarcaFezOPC( Temp2.FezOpc, Temp3.FezOpc2,Temp7.FEzOpc3, Temp7.FezOpc4, Temp7.ExOpcLim );
     CalcOpc( RPAS,fin.CodClassificacao,DiaLiqTmp, DataRefCtb); 
     //FazAntecipacoesNoEPosVenc; Renomiei para FazAjustesAntecipacoes e 
     //                           movi para depois da Calc_Eventos_No_E_Apos_Venc
     CalcSaldoPagamentoAntecipadoParcial;
     if Sec.PercColateral>=Zero then 
        Sec.AmaisjColateral := Sec.PercColateral * RPAS.ValRPA.AmaisJ;
  end;

  if not Ctr_Ativo(RPAS) then begin
    CmTabErr := TempCmTabErr;
    CmTabErrData := TempCmTabErrData;
  end;

  if abs(RPAS.ValRPA.Juro) < Zero then begin
    CalcJuro(DiaVencAnt);
  end;  
  if not AmortizouSaldo then begin
    RPAS.ValRPA.SaldoDev := arredonda(RPAS.ValRPA.SaldoDev - (RPAS.ValRPA.Amaisj-RPAS.ValRPA.Juro));
    AmortizouSaldo := true;
  end;
  Calc_Eventos_No_E_Apos_Venc;  // antiga Calc_multiplas_Aminc_No_E_Apos_Venc;
  FazAjustesAntecipacoes;
  if AmortizouSaldo then begin // A terminactr espera o saldo n o amortizado, ent o tiro a amortiza  o antes de chamar a PosCalcOpc
    RPAS.ValRPA.SaldoDev := arredonda(RPAS.ValRPA.SaldoDev + (RPAS.ValRPA.Amaisj-RPAS.ValRPA.Juro));
    AmortizouSaldo := false;
  end;
  PosCalcOpc( RPAS,fin.CodClassificacao,DiaLiqTmp, DataRefCtb,MacDoDiaLiqTmp);
end;

function VAAntecipacoes:double;
var i,mafim   : integer;
    parcatual : real;
begin
  Result := 0;
  mafim := mes_int(RPAS.FinRPA.DtInFin.MesAno)+1+Fin.PerParcelas*(RPAS.FinRPA.Prazo-1);
  with Parcelas do
  for i := 0 to Count-1 do
    if { est  paga,  o tipo de pag   80 ou 243, e o pg foi anterior ou igual ao MAC
         e o venc   posterior ao MAC,limitado ao prazo remanesc.  }
       (Parcela[i].DtPg.Dia > 0) and (Parcela[i].DtPg.Dia <= 31) and
       (Mes_int(Parcela[i].DtPg.MesAno) <= RPAS.Mac) and
       (Parcela[i].MAC > RPAS.MAC) and
       (Parcela[i].MAC < mafim) and
       (Parcela[i].TipoPg in PgtoComRedSdDev) then begin
      { Soma o pagamento no dia }
        parcatual := Parcela[i].ValorPresenteOrig(RPAS.MAC,RPAS.FinRPA.IndJuros);
        ajustamoeda2(mes_int(Fin.DataRef.MesAno), RPAS.MAC, parcatual);
        Result := Result + parcatual;
    end;
    Result := Result * RPAS.Temp5.TxPstAcum;
end;

procedure DeterminaDefasagemEJuros(Var Defasagem,J : double);
var
  MesAnoRef : TMes_Ano;
  DtInicio,
  DataRefJuros : Tdata;
  Dia2 : Integer;
  IndJurosAoMes : real;
begin
  DtInicio := Fin.DtInicio;
  if Fin.DiaVenc > 0 then
    DtInicio.Dia := Fin.DiaVenc;
  if DtInicio.dia > Dias_Mes(Mes_int(DtInicio.MesANo)) then
    DtInicio.dia := Dias_Mes(Mes_Int(DtInicio.MesAno));

  J := CalculaJuros(Fin.TpJuros,RPAS.FinRPA.TxJuros,Fin.PerParcelas);
  if (Fin.DtCarenciaDeJuros.Dia > 0) and
     (Juliano(Fin.DtCarenciaDeJuros) > Juliano(Fin.DataRef)) then
    DataRefJuros := Fin.DtCarenciaDeJuros
  else
    DataRefJuros := Fin.DataRef;
  MesAnoRef := DataRefJuros.MesAno;
  Defasagem := Mes_Int(DtInicio.MesAno) - Mes_Int(MesAnoRef) - Fin.PerParcelas;
  if Fin.JurProRata then // Dever  ser considerado a diferen a de dias na defasagem
  begin
    Dia2 := DIA_VENC(mes_int(DataRefJuros.MesAno),DtInicio.Dia);
    Defasagem := Defasagem + (Dia2 - DataRefJuros.Dia) / 30;
  end
  else if Fin.IncluiFracaoDoMes then // Se n o tem juros pro-rata ent o verifica se cobra um per odo para fra  o do m s
  begin
    if DataRefJuros.Dia < DtInicio.Dia then Defasagem := Defasagem + 1;
  end;

  IndJurosAoMes := pot(1 + J/100, 1.0 / Fin.PerParcelas ) -1 ;

  if Fin.CobraJurosNaCarencia then begin
    Defasagem := 0;
    J := IndJurosAoMes*100;
  end;
end;

procedure CalculaResiduo(Parcela:TParcelaSerie);
var  DataBasepReajuste : TData;
     np : integer;
     AmortizacaoResiduo, JurosparaoPeriodo, SaldoparaRecalculo : Double;
     Defasagem,J : double;
     MACMA:TMes_Ano;
     DataRefParaReaj : Tdata;
     ConstanteDeArredondamento : Double;
begin
  J := 0;
  Defasagem := 0;
  DataRefParaReaj := fin.DataRefReaj;
  if DataRefParaReaj.dia = 0 then
    DataRefParaReaj := Fin.DataRef;
  with RPAS do begin
      // Corrige o saldo anterior do res duo
      Temp9.CorrecaoResiduo := int(Temp9.ResiduoAcum * (FinRpa.TxFull -1) *100+0.5)/100;
      Temp9.ResiduoAcum := Temp9.ResiduoAcum + Temp9.CorrecaoResiduo;
      if Fin.FinanciaResiduo or Fin.SaldoResiduoComJuros then 
        Temp9.JurosResiduo := int(Temp9.ResiduoAcum * FinRpa.TxJuros /12 + 0.5) /100
      else
        Temp9.JurosResiduo := 0;
      Temp9.ResiduoAcum := Temp9.ResiduoAcum + Temp9.ResiduoMes;
      if (Fin.CobraResiduo or ((FinRPA.Plano mod 10)=SACR)) then begin
        int_mes(MAC,MACMA);
        DataBasepReajuste := DataRefParaReaj;
        if byte(FinRPA.MReaj) <> DataBasepReajuste.Mes then begin
           DataBasepReajuste.Mes := FinRPA.MReaj;
           while Juliano(DataBasepReajuste)>Juliano(DataRefParaReaj) do
             int_mes(mes_int(DataBasepReajuste.MesAno)-FinRPA.PerFin, DataBasepReajuste.MesAno);
        end;
        np := (MAC-(mes_int(DataBasepReajuste.MesAno)));
        if (Fin.RecalculaPrestacao or ((FinRPA.Plano mod 10)=SACR))
           and (assigned(Parcela) and (Parcela.ValorEmitido<=Zero))
           then if FinRPA.NPC=1 then FinRPA.TxPst := Temp5.TxPstAcum  // SCAt 27315
                else FinRPA.TxPst := 1.0;
        if np<0 then np := 0;
        if (((FinRPA.NPC>1) and (byte(FinRPA.Mreaj)=MACMA.Mes)) or (FinRPA.NPC=FinRPA.Prazo)
            or ((FinRPA.NPC=1) and fin.REPACTUA_SACRE_JUROS_0 and (fin.amaisjini < Zero))) and
         ( ( ((np div FinRPA.PerFin)*FinRPA.PerFin + mes_int(DataBasepReajuste.MesAno)) = MAC ) or
             ( FinRPA.Prazo=FinRPA.NPC) or // Scat 22521
             ( Mac - Temp11.MacRecalc > 12) ) then begin
          if not FParcelaDoMesTevePagamentoAntecipado then 
            Temp11.MAcRecalc := Mac;

          if ( (Fin.RecalculaPrestacao or ((FinRPA.Plano mod 10)=SACR)) and 
             ( (MAC>succ(mes_int(FinRPA.DtInFin.MesAno))) or
               ((MAC=succ(mes_int(FinRPA.DtInFin.MesAno))) and fin.REPACTUA_SACRE_JUROS_0))
              ) and
             (FDesconsideraParcela or (not assigned(Parcela)) or
             ((Parcela.ValorEmitido <= Zero) and not FParcelaDoMesTevePagamentoAntecipado)) then begin

              if CodErro = 1 then CodErro := 2; // Se n o tem indice para o saldo -> n o tem indice para presta  o
              JurosparaoPeriodo := pot( 1 + FinRPA.IndJuros, Fin.PerParcelas  ) - 1;
              SaldoparaRecalculo := ValRPA.Saldodev + VAAntecipacoes();
              if (FinRPA.ExOPC=35) or (FinRPA.ExAmInc=35) or (FinRPA.ExOpc=21) or (FinRPA.ExAmInc=21) then
                SaldoparaRecalculo := SaldoparaRecalculo + FinRPA.ValorAI; //SCAt 70295
              
              ConstanteDeArredondamento := 0;

              if ((FinRPA.Plano mod 10)=SACR) and fin.REPACTUA_SACRE_JUROS_0 then
              begin
                JurosParaoPeriodo := 0;
                // Neste caso o recalculo   feito com o saldo antes da corre  o
                SaldoParaRecalculo := SaldoParaRecalculo - Rpas.Temp.CorrSaldo;
                ConstanteDeArredondamento := 0.5;
              end;
              if not assigned(Parcela) then begin
                AmaisJAnt := int( CalcAmaisJ( FinRPA.Plano,FinRPA.Prazo-FinRPA.NPC+1,SaldoparaRecalculo,JurosParaoPeriodo)*100)/100;
                FinRPA.TxPst := 1.0;
              end
              else begin
//                if ((RPAS.Coderro=0) or (RPAS.Temp11.ErroMacIndice>MAC-12)) then  Retirado pelo scat 39221
                ValRPA.AmaisJ := int( CalcAmaisJ( FinRPA.Plano,FinRPA.Prazo-FinRPA.NPC+1,SaldoparaRecalculo,JurosParaoPeriodo)*100+ConstanteDeArredondamento)/100;
                DeterminaDefasagemEJuros(Defasagem,J);
                ValRPA.RARD := CalculaRazao(SaldoParaRecalculo,J,
                                            Fin.PerParcelas,FinRPA.Prazo-FinRPA.NPC+1,
                                            FinRPA.Plano mod 10,Defasagem,Fin.JurosSimples);
                if RPAS.MAC >= 1070 then
                  RPAS.ValRPA.RARD := RPAS.ValRPA.RARD * 1000 ;
                ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
                If (ValRPA.AmaisJ>Zero) and (AmaisJAnt > Zero) then begin
                  FinRPA.TxPst := (ValRPA.AmaisJ-ValRPA.Recorr) / AmaisjAnt;
                  Temp5.TxPstAcum := Temp5.TxPstAcum * FinRPA.TxPst; //SCAT 23284
                end
                else FinRPA.TxPst := 1.0;
              end;
          end
          else if Fin.financiaResiduo then begin
            if Rpas.FinRpa.Prazo-Rpas.FinRpa.NPC+1 > 0 then 
              Temp9.ResiduoCobrado := Payment(FinRpa.TxJuros/1200,Rpas.FinRpa.Prazo-Rpas.FinRpa.NPC+1,-Temp9.ResiduoAcum-Temp9.JurosResiduo,0,ptStartOfPeriod);
          end
          else if fin.Residuo12meses then
            Temp9.ResiduoCobrado := int(Temp9.ResiduoAcum/12*100+0.5)/100
          else
          begin
            // Este teste precisa ser mudado na vers o seguinte para uma nova
            // vari vel a ser criada na s rie
            if Temp12.CmProratamesant then // Scat 53775
            begin
              Temp9.ResiduoCobrado :=  Temp9.ResiduoAcum -  Temp9.ResiduoMes;
            end
            else
            begin
              Temp9.ResiduoCobrado := Temp9.ResiduoAcum;
            end;
          end;
        end else
          if not Fin.FinanciaResiduo then
            if Fin.Residuo12meses then
            begin 
              if Temp9.ResiduoCobrado > Temp9.ResiduoAcum then
                Temp9.ResiduoCobrado := Temp9.ResiduoAcum
            end
            else
              Temp9.ResiduoCobrado := 0;
      end;
      if FDesconsideraParcela then begin
        FinRpa.TxPst := FinRpa.TxSD;
        ValRpa.Amaisj := int( FinRpa.TxPst *ValRpa.Amaisj*100+0.5)/100;
        ValRPA.RARD := ValRPA.RARD*FinRpa.TxPst;
        ValRPA.Recorr := DeterminaRecorr(FinRPA.Plano, MAC, ValRPA.RARD);
      end; 
      if assigned(Parcela) and (Parcela.ResiduoCobradoEmi > Zero) and (not FDesconsideraParcela) and
         ScciConf.UsaArqPrest then Temp9.ResiduoCobrado := Parcela.ResiduoCobradoEmi;
      AmortizacaoResiduo := Temp9.ResiduoCobrado - Temp9.JurosResiduo;
      if Fin.FinanciaResiduo and (Temp9.ResiduoAcum>Zero) and
         (AmortizacaoResiduo > Temp9.ResiduoAcum) then begin
          AmortizacaoResiduo := Temp9.ResiduoAcum;
          Temp9.ResiduoCobrado :=AmortizacaoResiduo + Temp9.JurosResiduo;
      end;
      Temp9.ResiduoAcum := Temp9.ResiduoAcum - AmortizacaoResiduo;
  end;
end;


