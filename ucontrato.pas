procedure TDadosAtrasoEvo.CalculaTaxaBanco;
var
  PosIni,i: SmallInt;
  Inicia  : boolean;
  ListaEmissao : Tstringlist;
  QtdParcelasBoleto : integer;
  ValtitTotalDoRecibo : real;
  TeveEmissaoAnterior   : boolean;
begin
  for i := 0 to count-1 do begin
    Prestacao[i].Valtit := Prestacao[i].ValTit - Prestacao[i].TaxaBanco;
    Prestacao[i].TaxaBanco := 0;
  end;
  if ValorTaxaBanco > zero then begin
    ListaEmissao := Tstringlist.create;
    try
      QtdParcelasBoleto := 0;
      ValtitTotalDoRecibo := 0;
      PosIni := 0;
      Inicia := true;
      TeveEmissaoAnterior := false;
      MontaListaDeEmissao(ListaEmissao,false);
      for i := 0 to ListaEmissao.count - 1 do
        with TPrestacaoAtrasoEvo(ListaEmissao.objects[i]) do begin
          if Inicia then begin
            PosIni := i;
            Inicia := false;
            QtdParcelasBoleto := 0;
            ValtitTotalDoRecibo := 0;
            TeveEmissaoAnterior := false;
          end;
          if (ScciConf.SistemaDeTaxas = SisTaxasCondicionadas) then
            if TestaEmissaoAnterior(Ctr,MacPrst,CodSerie) then TeveEmissaoAnterior := true;
          inc(QtdParcelasBoleto,TPrestacaoAtrasoEvo(ListaEmissao.objects[i]).QtdParcsAgrupadas + 1);
          ValtitTotalDoRecibo := ValtitTotalDoRecibo + TPrestacaoAtrasoEvo(ListaEmissao.objects[i]).ValTit;
          if (i = (ListaEmissao.count - 1))  or
             ((not GeraUmReciboComPrstComJanela) and
              (MACPrst + 1 <> TPrestacaoAtrasoEvo(ListaEmissao.objects[i+1]).MACPrst) and
              (TpPrestMemPtr(ListaEmissao.objects[i+1])^.Tit.MACPrst <> MACPrst)) or
              Scciconf.EmiteRecPorSerie or
             ((NumMaxParcPorRecCons > 0) and
              ((QtdParcelasBoleto + TPrestacaoAtrasoEvo(ListaEmissao.objects[i+1]).QtdParcsAgrupadas + 1) > NumMaxParcPorRecCons)) then begin
             if (ScciConf.SistemaDeTaxas<>SisTaxasCondicionadas) then
               TeveEmissaoAnterior := true;
             if (Abs(ValtitTotalDoRecibo) > Zero) and TeveEmissaoAnterior then begin
               TPrestacaoAtrasoEvo(ListaEmissao.objects[PosIni]).TaxaBanco := ValorTaxaBanco;
               TPrestacaoAtrasoEvo(ListaEmissao.objects[PosIni]).ValTit := TPrestacaoAtrasoEvo(ListaEmissao.objects[PosIni]).ValTit + ValorTaxaBanco;
             end;
             Inicia := true;
          end;
        end;
    finally
      ListaEmissao.free;
    end;
  end;
  TotalizaDados;
end;

