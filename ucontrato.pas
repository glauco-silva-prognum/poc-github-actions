function GetCodSerieParaTaxaNaoIncorp(Contrato : Tcontrato) : longint;
var
  MaiorPrazo, i     : integer;
  DtAssinMaisAntiga : TData;
begin
  Result := -1;
  if assigned(Contrato) and (Contrato.MutDsk.Cad.Ctr > '') then begin
    if TemFinancDinamico(Contrato.MutDsk) then 
      Result := 0
    else if Contrato.Series.Count = 1 then
      Result := Contrato.Series[0].Fin.CodSerie
    else begin
      DtAssinMaisAntiga.Dia := 0;
      fillchar(DtAssinMaisAntiga,sizeof(DtAssinMaisAntiga),0);
      MaiorPrazo := 0;
      for i := 0 to Contrato.Series.Count-1 do 
        if (Contrato.Series[i].Fin.CompoeSaldo or Contrato.Series[i].Fin.CompoeEntrada) 
                                   and
           (Contrato.Series[i].Fin.Status = 0) and
           (Contrato.Series[i].Fin.Valor-Contrato.Mutdsk.Cad6.TaxaNaoIncorporadaFinanc > zero) and
          ((DtAssinMaisAntiga.Dia = 0) or 
           (juliano(Contrato.Series[i].Fin.DataRef) <= juliano(DtAssinMaisAntiga))
          ) then begin
          if juliano(Contrato.Series[i].Fin.DataRef) = juliano(DtAssinMaisAntiga) then begin
            if Contrato.Series[i].Fin.Prazo > MaiorPrazo then
               Result := Contrato.Series[i].Fin.CodSerie;
          end
          else Result := Contrato.Series[i].Fin.CodSerie;
          if Contrato.Series[i].Fin.Prazo > MaiorPrazo then
            MaiorPrazo := Contrato.Series[i].Fin.Prazo;
          DtAssinMaisAntiga := Contrato.Series[i].Fin.DataRef;
        end; //if
      if DtAssinMaisAntiga.Dia = 0 then begin
        for i := 0 to Contrato.Series.Count-1 do 
          if (Contrato.Series[i].Fin.Status = 0) and
             (Contrato.Series[i].Fin.Valor-Contrato.Mutdsk.Cad6.TaxaNaoIncorporadaFinanc > zero) and
             ((DtAssinMaisAntiga.Dia = 0) or 
              (juliano(Contrato.Series[i].Fin.DataRef) <= juliano(DtAssinMaisAntiga))
             )  then begin
            if juliano(Contrato.Series[i].Fin.DataRef) = juliano(DtAssinMaisAntiga) then begin
              if Contrato.Series[i].Fin.Prazo > MaiorPrazo then
                 Result := Contrato.Series[i].Fin.CodSerie;
            end
            else Result := Contrato.Series[i].Fin.CodSerie;
            if Contrato.Series[i].Fin.Prazo > MaiorPrazo then
              MaiorPrazo := Contrato.Series[i].Fin.Prazo;
            DtAssinMaisAntiga := Contrato.Series[i].Fin.DataRef;
          end; //if
      end;
    end;
  end;
end;

