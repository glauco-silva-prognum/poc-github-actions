function TSerie.GetIndJurosCA : real;
var
  PeriodParcelas : byte;
begin
  if Self.Fin.PerParcelas > 0 then 
    PeriodParcelas := Self.Fin.PerParcelas
  else
    PeriodParcelas := 1;
  if Self.Fin.JurosSimples then
    Result := CalculaJuros(1{Fin.TpJuros},Self.RPAS.Temp12.TxJurosCA,PeriodParcelas,Self.Fin.JurosSimples)/100/PeriodParcelas
  else
    Result := pot((1+CalculaJuros(1{Fin.TpJuros},Self.RpaS.Temp12.TxJurosCA,PeriodParcelas,Self.Fin.JurosSimples)/100),1.0/PeriodParcelas)-1;
end;

function TSerie.SerieTodaPaga(SomentePrincipal : boolean = false; MACRef : smallint = 0) : boolean;
var
  i         : integer;
  TodasPagas: boolean;
begin
  Result := false;
  if Parcelas.Count > 0 then begin
    TodasPagas := true;
    for i := 0 to Parcelas.Count-1 do 
      if SomentePrincipal then begin
        if (Parcelas[i].Seq > 0) and ((MACRef = 0) or (Parcelas[i].MAC <= MACRef)) then 
          TodasPagas := TodasPagas and Parcelas[i].EstaPagaReal;
      end
      else if (MACRef = 0) or (Parcelas[i].MAC <= MACRef) then
        TodasPagas := TodasPagas and (Parcelas[i].EstaPagaReal or 
                                    ((Parcelas[i].Seq = 0) and (Parcelas[i].DtPgSeg.dia > 0) and
                                     (not Parcelas[i].TipoPgSeg in [8..9,66,74,95,108,110,114,117,121,200,253])));
    Result := TodasPagas;
  end;
end;


