            wParcela.TipoParc := TpParc_Series;
            wParcela.DiaVenc  := Dia_Venc(wParcela.Mac,Mutdsk.Financ.DtInFin.Dia);
            wParcela.Co_Forma_Pag := InfoPagamentosObj.Co_Forma_Pag;
            wParcela.Co_LiqForm := InfoPagamentosObj.Co_LiqForm;
            wParcela.Nu_TarjaChq1 := InfoPagamentosObj.Nu_TarjaChq1;
            wParcela.Nu_TarjaChq2 := InfoPagamentosObj.Nu_TarjaChq2;
            wParcela.Nu_TarjaChq3 := InfoPagamentosObj.Nu_TarjaChq3;
            wParcela.Nu_CompChq := InfoPagamentosObj.Nu_CompChq;
            wParcela.Va_Cheque := InfoPagamentosObj.Va_Cheque;
            wParcela.Co_PagCartao := InfoPagamentosObj.Co_PagCartao;
            wParcela.Nu_Cartao := InfoPagamentosObj.Nu_Cartao;
            wParcela.No_IdentCliente := InfoPagamentosObj.No_IdentCliente;
            wParcela.Co_SegCartao := InfoPagamentosObj.Co_SegCartao;
            wParcela.Nu_AgenReceb := InfoPagamentosObj.Nu_AgenReceb;
            wParcela.ContaCorrReceb := InfoPagamentosObj.ContaCorrReceb;
            wParcela.ContaCorrDVReceb := InfoPagamentosObj.ContaCorrDVReceb;
            if (DataRef.Dia > 0) and
               (juliano(RegValPgto.DtPg) > juliano(DataRef)) then begin
              fillchar(wParcela.DtPg,sizeof(wParcela.DtPg),0);
              fillchar(wParcela.DtProcPg,sizeof(wParcela.DtProcPg),0);
              wParcela.ValorPago := 0;
              wParcela.TipoPg    := 0;
            end;
          end;
          gQryLerParcelasFinanciamentoDinamico.next;
        end;
      finally
        gQryLerParcelasFinanciamentoDinamico.close;
        DBRegistroPagamentos.free;
        InfoPagamentosObj.free;
      end;
    end;
  end;

  if count > 0 then begin
  {
    Ordenar por Mac e Contrato.
    Quando o contrato lido   um azinho,
    dar prioridade para os pagamentos com azinho,
    mas aproveitar os sem(l gica da pglib.lepginterna)
    Contrato azinho e mesmo mac vem na frente.
    Por otimiza  o, s o lidos todos os contratos azinhos na faixa ( P.CO_CONTRATO>=:ctr and P.CO_CONTRATO<=:ctrcomazinho )
    Tenho que eliminar nesta l gica.
  }
    {$IFDEF FPC}Sort(@ProcSortPorMacECtr);{$ENDIF}

    wParcelaAnt := GetParcela(0);
    FIndicePorMac[wParcelaAnt.Mac] := wParcelaAnt;
    
    i := 1;
    while i < count do begin
      wParcela := GetParcela(i);
      if (wParcela.mac = wParcelaAnt.mac) or
         ((length(wParcela.CO_CONTRATO) > Tamctr) and
          (wParcela.CO_CONTRATO <> Mutdsk.Cad.Ctr)) then // como azinho vem primeiro, e   prioridade, excluo sempre o segundo mac repetido
        Delete(i)
      else begin
        FIndicePorMac[wParcela.Mac] := wParcela;
        wParcelaAnt := wParcela;
        inc(i);
      end;
    end;
  end;
end; 70836*)

procedure TParcelasFinanciamentoDinamico.SetaPagamentoMem(Mac : integer;
                                                          DtPg,DtProcPg : Tdata;
                                                          TipoPg : integer;
                                                          ValorPago : real);
// For ar pagamentos em mem ria
// n o me preocupo com todos os detalhes do pagamento
var
  wParcela : Tparcela;
begin
  if FIndicePorMac.HasItem(Mac) then
    wParcela := FIndicePorMac[Mac] as Tparcela
  else begin
    wParcela := self.add as TParcela;
    FIndicePorMac[Mac] := wParcela;
  end;
  
  if assigned(wParcela) then begin
    wParcela.Mac  := Mac;
    wParcela.DtPg := DtPg;
    wParcela.DtProcPg := DtProcPg;
    wParcela.TipoPg := TipoPg;
    wParcela.ValorPago := ValorPago;
  end;
end;

procedure TParcelasFinanciamentoDinamico.Le(MutDsk:TpMutDsk; DataRef : TData);
var
  DtFim : Tdata;
  MutPgArr : ^TpMutPgArr;
  i,
  Tam : integer;
  wParcela : TParcela;
  InfoPagamentosObj : TInfoPagamentosObj;
  DtIni : TData;
begin
  Self.Clear;
  if TemFinancDinamico(MutDsk) then begin
    GetMem(MutPgArr,sizeof(TpMutPgArr));
    InfoPagamentosObj := TInfoPagamentosObj.create;
    try
{
107074      
  No caso de um contrato PA 40, a MutDsk.Financ.dtinfin pode estar vazia, pois a primeira
  presta  o s  acontece depois da primeira libera  o. At  l , esta rotina n o vai conseguir
  ler qualquer pagamento, podendo gerar erros como o visto na 107074.
  Para sanar este problema, resolvi usar a dtassin, pois mantenho o crit rio de ler apenas pagamentos
  que existem durante a exist ncia do contrato. No caso de um contrato normal(n o PA 40) sem dtinfin,
  vou assumir que   um erro de cadastro e deixar ler errado os pagamentos, assim eu isolo a altera  o.

106898
  Nesta sol. pede-se para mostrar o pagamento do seguro registrado na presta  o zero, no entanto,
  a presta  o zero n o era lida na LePg, por passar a dtini como DtInFin.
  Assim, estou for ando a DtIni para DtAssin(o que j  foi feito para 107074 de qualquer forma).  
}
      {DtIni := MutDsk.Financ.DtInFin;
      if not Testa_Data(DtIni) and (Mutdsk.Financ.PA=40) then 106898}
        DtIni := Mutdsk.Financ.DtAssin;
      DtFim := DtIni;
      IncMa(DtFim.MesAno,MaxDtPgto+1);

      tam := LePg(MutDsk.Cad.Ctr,DtIni,DtFim,MutPgArr^,true);
      for i := 1 to Tam do
        if (DataRef.Dia = 0) or MutPgArr^[i].TemPgParcial or
           (juliano(MutPgArr^[i].DataPg) <= juliano(DataRef)) then begin
          wParcela      := self.add as TParcela;
          FIndicePorMac[MutPgArr^[i].Mac] := wParcela;
          wParcela.Mac  := MutPgArr^[i].Mac;
          wParcela.DtPg := MutPgArr^[i].DataPg;
//          wParcela.DataEmi := MutPgArr^[i].DataEmi;
          int_Mes(MutPgArr^[i].MAProc,wParcela.DtProcPg.MesAno);
          if MutPgArr^[i].DiaProc > 0 then
            wParcela.DtProcPg.Dia := MutPgArr^[i].DiaProc
          else if Mes_Int(wParcela.DtPg.MesAno) = Mes_Int(wParcela.DtProcPg.MesAno) then
            wParcela.DtProcPg.Dia := wParcela.DtPg.Dia
          else
            wParcela.DtProcPg.Dia := 01;
          wParcela.PercDescMora := MutPgArr^[i].PercDescMora;
          wParcela.PercDescCorr := MutPgArr^[i].PercDescCorr;
          wParcela.PercDescMulta := MutPgArr^[i].PercDescMulta;
          wParcela.PercDescJremuneratorios := MutPgArr^[i].PercDescJRemuneratorios;
          wParcela.DescontoPagamento := MutPgArr^[i].Desconto;
          wParcela.ValorHonorarios := MutPgArr^[i].ValorHonorarios;
          wParcela.PercDescHonorarios := MutPgArr^[i].PercDescHonorarios;
          wParcela.PercHonorarios := MutPgArr^[i].PercHonorarios;
          wParcela.ValIOFComplem  := MutPgArr^[i].ValIOFComplem;
          wParcela.DifEmitida     := MutPgArr^[i].DifEmitida;
          wParcela.TipoPg := MutPgArr^[i].Flag;
          wParcela.ValorPago := MutPgArr^[i].ValorPg;
          wParcela.Banco := MutPgArr^[i].Banco;
          wParcela.DataRefCalc := MutPgArr^[i].DataRefCalc;
          wParcela.DataValidadeTit := MutPgArr^[i].DataValidadeTit;
          wParcela.Motivo := MutPgArr^[i].Motivo;
          wParcela.Caixa  := MutPgArr^[i].Caixa;
          wParcela.Agencia := MutPgArr^[i].Agencia;
          wParcela.NossoNum := MutPgArr^[i].NossoNum;
          wParcela.CorrecaoPgto := MutPgArr^[i].Correcao;
          wParcela.MoraPgto := MutPgArr^[i].Mora;
          wParcela.JRemuneratoriosPgto := MutPgArr^[i].JRemuneratorios;
          wParcela.MultaPgto := MutPgArr^[i].Multa;
          wParcela.TipoDesc := MutpgArr^[i].TipoDesc;
          wParcela.ResiduoCobrado := MutPgArr^[i].ResiduoCobrado;
          wParcela.DescSeg := MutPgArr^[i].DescSeg;
          wParcela.DescPagamento := MutPgArr^[i].DescPagamento;
          wParcela.TipoRecebimento := MutPgArr^[i].Tiporecebimento;
          wParcela.VA_DESC_ANTEC_USU := MutPgArr^[i].VA_DESC_ANTEC_USU;
          LeInfoPagamentosCache(Mutdsk.cad.Ctr,MutPgArr^[i].NossoNum,InfoPagamentosObj);
          wParcela.Co_Forma_Pag := InfoPagamentosObj.Co_Forma_Pag;
          wParcela.Co_LiqForm := InfoPagamentosObj.Co_LiqForm;
          wParcela.Nu_TarjaChq1 := InfoPagamentosObj.Nu_TarjaChq1;
          wParcela.Nu_TarjaChq2 := InfoPagamentosObj.Nu_TarjaChq2;
          wParcela.Nu_TarjaChq3 := InfoPagamentosObj.Nu_TarjaChq3;
          wParcela.Nu_CompChq := InfoPagamentosObj.Nu_CompChq;
          wParcela.Va_Cheque := InfoPagamentosObj.Va_Cheque;
          wParcela.Co_PagCartao := InfoPagamentosObj.Co_PagCartao;
          wParcela.Nu_Cartao := InfoPagamentosObj.Nu_Cartao;
          wParcela.No_IdentCliente := InfoPagamentosObj.No_IdentCliente;
          wParcela.Co_SegCartao := InfoPagamentosObj.Co_SegCartao;
          wParcela.Nu_AgenReceb := InfoPagamentosObj.Nu_AgenReceb;
          wParcela.ContaCorrReceb := InfoPagamentosObj.ContaCorrReceb;
          wParcela.ContaCorrDVReceb := InfoPagamentosObj.ContaCorrDVReceb;
          wParcela.LCobr  := MutPgArr^[i].LCobr;
          wParcela.TemPgParcial := MutPgArr^[i].TemPgParcial;
          wParcela.LeDetalhesPagAcessorios(MutPgArr^[i]); // 91805
          wParcela.TipoParc := TpParc_Series;
          wParcela.DiaVenc  := Dia_Venc(wParcela.Mac,Mutdsk.Financ.DtInFin.Dia);
          if (DataRef.Dia > 0) and
             (juliano(MutPgArr^[i].DataPg) > juliano(DataRef)) then begin
            fillchar(wParcela.DtPg,sizeof(wParcela.DtPg),0);
            fillchar(wParcela.DtProcPg,sizeof(wParcela.DtProcPg),0);
            wParcela.ValorPago := 0;
            wParcela.TipoPg    := 0;
          end;
        end;
    finally
      FreeMem(MutPgArr);
      InfoPagamentosObj.free;
    end;
  end;
end;

