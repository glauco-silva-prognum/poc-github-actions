    result := FOwner as TContrato
  else
    result := nil;
end;

{TDadosAgendaPagamento}
constructor TDadosAgendaPagamento.create(Owner:TObject);
begin
  inherited create;
  FItems := TObjectList.create;
  Fitems.OwnsObjects := false;
  FArrCodSerie := TSparseObjectArray.create;
  FOwner := Owner;
  FLeu := false;
  FQryLeAgendamentos := TSqlQuery.Create(nil);
  FQryLeAgendamentos.SqlConnection := GetSqlConnection(PegaDirTab);
  FQryLeAgendamentos.Sql.beginUpdate;
  try
    FQryLeAgendamentos.Sql.Add('SELECT CO_SERIE,NU_TP_PARCELA,NU_PARCELA,DT_AGENDAMENTO,');
    FQryLeAgendamentos.Sql.Add('PERCDESCMORA,PERCDESCJREMUNERATORIOS,PERCDESCCORR,PERCDESCMULTA,');
    FQryLeAgendamentos.Sql.Add('IN_EMITIDO,DT_INC_AGENDAMENTO,CO_USUARIO_INC,NU_MAC,CO_TIPO_AGENDAMENTO,VA_PGTO_PARCIAL FROM AGENDA_PAGAMENTO ');
    FQryLeAgendamentos.Sql.Add('WHERE NU_CONTRATO = :CTR');
  finally
    FQryLeAgendamentos.Sql.EndUpdate;
    FQryLeAgendamentos.Params[0].DataType := ftString;
  end;
  
  FQryLeAgendamentosPorDtAgendamento := TSqlQuery.Create(nil);
  FQryLeAgendamentosPorDtAgendamento.SqlConnection := GetSqlConnection(PegaDirTab);
  FQryLeAgendamentosPorDtAgendamento.Sql.beginUpdate;
  try
    FQryLeAgendamentosPorDtAgendamento.Sql.Add('SELECT CO_SERIE,NU_TP_PARCELA,NU_PARCELA,DT_AGENDAMENTO,');
    FQryLeAgendamentosPorDtAgendamento.Sql.Add('PERCDESCMORA,PERCDESCJREMUNERATORIOS,PERCDESCCORR,PERCDESCMULTA,');
    FQryLeAgendamentosPorDtAgendamento.Sql.Add('IN_EMITIDO,DT_INC_AGENDAMENTO,CO_USUARIO_INC,NU_MAC,CO_TIPO_AGENDAMENTO,VA_PGTO_PARCIAL FROM AGENDA_PAGAMENTO ');
    FQryLeAgendamentosPorDtAgendamento.Sql.Add('WHERE NU_CONTRATO = :CTR');
    FQryLeAgendamentosPorDtAgendamento.Sql.Add('ORDER BY DT_AGENDAMENTO');
  finally
    FQryLeAgendamentosPorDtAgendamento.Sql.EndUpdate;
    FQryLeAgendamentosPorDtAgendamento.Params[0].DataType := ftString;
  end;

  FQryExcluiAgendamento := TSqlQuery.Create(nil);
  FQryExcluiAgendamento.SqlConnection := GetSqlConnection(PegaDirTab);
  FQryExcluiAgendamento.Sql.beginUpdate;
  try
    FQryExcluiAgendamento.Sql.Add ('DELETE FROM AGENDA_PAGAMENTO ');
    FQryExcluiAgendamento.Sql.Add('WHERE NU_CONTRATO = :CTR AND ');
    FQryExcluiAgendamento.Sql.Add('      CO_SERIE  = :CODSERIE AND ');
    FQryExcluiAgendamento.Sql.Add('      NU_TP_PARCELA  = :TIPOPARC AND ');
    FQryExcluiAgendamento.Sql.Add('      NU_PARCELA  = :NUMPARC AND ');
    FQryExcluiAgendamento.Sql.Add('      NU_MAC  = :NUMAC');
  finally
    FQryExcluiAgendamento.Sql.EndUpdate;
    FQryExcluiAgendamento.Params[0].DataType := ftString;
    FQryExcluiAgendamento.Params[1].DataType := ftinteger;
    FQryExcluiAgendamento.Params[2].DataType := ftinteger;
    FQryExcluiAgendamento.Params[3].DataType := ftinteger;
    FQryExcluiAgendamento.Params[4].DataType := ftinteger;
  end;
end;

procedure TDadosAgendaPagamento.clear;
  procedure ClearMac(ArrMac : TSparseObjectArray);
  var
    Obj : Tobject;
    achou : boolean;
    i : integer;
  begin
    Obj := nil;
    i := 0;
    achou := ArrMac.findFirst(I,Obj);
    while achou do begin
      Obj.free;
      achou := ArrMac.findNext(I,Obj);
    end;
    ArrMac.Clear;
  end;
  procedure ClearNumParc(ArrNumParc : TSparseObjectArray);
  var
    ArrMac : Tobject;
    achou : boolean;
    i : integer;
  begin
    ArrMac := nil;
    i := 0;
    achou := ArrNumParc.findFirst(I,ArrMac);
    while achou do begin
      ClearMac(ArrMac as TSparseObjectArray);
      ArrMac.free;
      achou := ArrNumParc.findNext(I,ArrMac);
    end;
    ArrNumParc.Clear;
  end;

  procedure ClearTipo(ArrTipo : TSparseObjectArray);
  var
    ArrNumParc : Tobject;
    achou : boolean;
    i : integer;
  begin
    ArrNumParc := nil;
    i := 0;
    achou := ArrTipo.findFirst(I,ArrNumParc);
    while achou do begin
      ClearNumParc(ArrNumParc as TSparseObjectArray);
      ArrNumParc.free;
      achou := ArrTipo.findNext(I,ArrNumParc);
    end;
    ArrTipo.Clear;
  end;
var
  i: integer;
  ArrTipo : TObject;
  achou: boolean;
begin
  ArrTipo := nil;
  i := 0;
  achou := FArrCodSerie.findFirst(I,ArrTipo);
  while achou do begin
    ClearTipo(ArrTipo as TSparseObjectArray);
    ArrTipo.free;
    achou := FArrCodSerie.findNext(I,ArrTipo);
  end;
  FArrCodSerie.Clear;
  FItems.clear;
  FLeu := false;
end;

