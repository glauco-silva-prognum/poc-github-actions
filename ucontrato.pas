function FuncOrdenaAcertoPorVencimentoECodSerie(Item1,Item2 : pointer) : integer;
var
  Prest1,
  Prest2 : TItemAcertoEvo;
begin
  Prest1 := TItemAcertoEvo(item1);
  Prest2 := TItemAcertoEvo(item2);
  if Juliano(Prest1.Dtvenc) < Juliano(Prest2.DtVenc) then
    result := -1
  else if Juliano(prest1.DtVenc) > Juliano(Prest2.DtVenc) then
    result := 1
  else if Prest1.Codserie < prest2.CodSerie then
    result := -1
  else if prest1.CodSerie > prest2.CodSerie then
    result := 1
  else
    result := 0;
end;

