function TDadosAtrasoEvo.RetornaPrstComPend(Index : smallint) : smallint;
var
  i  : smallint;
begin
  if Index > 0 then begin
    if Index > Count-1 then Index := Count-1;
    i := Index;
    while (i > 0) and Prestacao[i].Esconde do dec(i);
    while (i > 0) and (not Prestacao[i-1].Esconde) and
          (Prestacao[i-1].MacPrst = Prestacao[Index].MacPrst) do dec(i);
    Result := i;
  end else Result := 0;
end;

function FuncOrdenaPorVencimentoECodSerie(Item1,Item2 : pointer) : integer;
var
  Prest1,
  Prest2 : TPrestacaoAtrasoEvo;
begin
  Prest1 := TPrestacaoAtrasoEvo(item1);
  Prest2 := TPrestacaoAtrasoEvo(item2);
  if Mes_int(Prest1.Dtvenc.mesano) < Mes_int(Prest2.DtVenc.mesano) then
    result := -1
  else if Mes_int(prest1.DtVenc.mesano) > mes_int(Prest2.DtVenc.mesano) then
    result := 1
  else if Prest1.Codserie < prest2.CodSerie then
    result := -1
  else if prest1.CodSerie > prest2.CodSerie then
    result := 1
  else
    result := 0;
end;

procedure TDadosAtrasoEvo.MontaIndicePorCodSerieEMac;
var
  i : integer;
  ArrPorMac : TSparseObjectArray;
begin
  FIndicePorCodSerie.clear;
  for i := 0 to count-1 do begin
    if FIndicePorCodSerie.HasItem(GetPrestacao(i).CodSerie) then
      ArrPorMac := FIndicePorCodSerie[GetPrestacao(i).CodSerie] as TSparseObjectArray
    else begin
      ArrPorMac := TSparseObjectArray.create;
      FIndicePorCodSerie[GetPrestacao(i).CodSerie] := ArrPorMac;
    end;
    ArrPormac[GetPrestacao(i).MacPrst] := GetItem(i);
  end;
end;

procedure TDadosAtrasoEvo.OrdenaPorVencimentoECodSerie;
begin
  sort({$IFDEF FPC}@{$ENDIF}FuncOrdenaPorVencimentoECodSerie);
  MontaIndicePorCodSerieEMac;
end;

