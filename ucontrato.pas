function TSeries.SerieMaiorPrazoCriadaNaReneg(DtReneg : TData) : integer;
var
  MaiorPrazo : integer;
  i : integer;
  idxMaiorPrazo : integer;
begin
  //   - criadas pela reneg feita na DtReneg
  //   - maior prazo
  //   - priorizar a mensal, se os prazos forem iguais
  idxMaiorPrazo := -1;
  MaiorPrazo := 0;
  if DtReneg.Dia > 0 then
    for i := 0 to count-1 do
      if (juliano(Dtreneg) = Juliano(GetSerie(i).Fin.DtRenegGeradora)) and
         (GetSerie(i).Fin.Status <> 98) then
        if (idxMaiorPrazo < 0) or
           (MaiorPrazo = 0) or
           (GetSerie(i).Fin.Prazo >= MaiorPrazo) then
          if (idxMaiorPrazo < 0) or (GetSerie(i).Fin.PerParcelas=1) then begin
            MaiorPrazo := GetSerie(i).Fin.Prazo;
            idxMaiorPrazo := i;
          end;
          
  if idxMaiorPrazo >= 0 then
    result := GetSerie(idxMaiorPrazo).Fin.codserie
  else
    result := -1;
end;

function TSeries.TemSerieRenegAntesVenc(DataRef : Tdata) : boolean;
var
  i, j : integer;
  DtTermino : Tdata;
begin
  { sol. 76450
    b.2) Alterar a evolu  o de s ries para calcular seguro de MIP e DFI (SEGFINEMI e SEGIMVEMI)
         na data de refer ncia da S rie (data de assinatura) sempre que:
         - existir uma s rie terminada por renegocia  o no mesmo m s da dataref desta nova s rie
         - e este termino por renegocia  o ter dia menor que o do vencimento desta s rie terminada.
         - Ter este comportamento para renegocia  es efetuadas a partir da data informada no novo campo da configura  o geral.
         N o aplicar esse requisito se o novo campo do item b.1 estiver em branco.
  }
  result := false;

  if scciconf.DtInicioSegSerieRenegAntesVenc.dia > 0 then
    for i := 0 to count-1 do
      if (GetSerie(i).RPAS.finrpa.status = 30) and
         (GetSerie(i).RPAS.valrpa.macstatus = mes_int(DataRef.mesano)) and
         (GetSerie(i).RPAS.FinRPA.DiaLiq < GetSerie(i).RPAS.FinRPA.DiaVenc) then begin
        DtTermino.dia := GetSerie(i).RPAS.FinRPA.DiaLiq;
        int_mes(GetSerie(i).RPAS.valrpa.macstatus,DtTermino.mesano);
        if Juliano(DtTermino) > juliano(scciconf.DtInicioSegSerieRenegAntesVenc) then begin
          //scat 82676
          for j := 0 to count-1 do begin
            if (juliano(GetSerie(j).Fin.DataRef) = juliano(DtTermino)) then begin
              if Mes_Int(GetSerie(j).Fin.DtInicio.MesAno) > Mes_Int(GetSerie(j).Fin.DataRef.MesAno) then begin
                result := true;
                break;
              end
              else begin
                result := false;
                break;
              end;
            end;
          end;
        end;
      end;
end;

