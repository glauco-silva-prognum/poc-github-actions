end;

function TSerie.MACUltParcelaAntecipada(MACRef : smallint) : smallint;
  var
    i            : integer;
    TodasPagas   : boolean;
    MACDtPg      : smallint;
    DtPgMaisAtual: TData;
  begin
    MACDtPg    := 0;
    TodasPagas := true;
    for i := 0 to Parcelas.Count-1 do
      if Parcelas[i].ParcExisteNoMes and (Parcelas[i].MAC > MACRef) then
        TodasPagas := TodasPagas and Parcelas[i].EstaPagaReal;
    if TodasPagas then begin
      DtPgMaisAtual.dia := 0; DtPgMaisAtual.mes := 0; DtPgMaisAtual.ano := 0;
      fillchar(DtPgMaisAtual,sizeof(TData),0);
      for i := 0 to Parcelas.Count-1 do begin
        if (Parcelas[i].TipoPg in PgtoComRedSdDev) and
           (juliano(Parcelas[i].DtPg) >= juliano(DtPgMaisAtual)) then begin
          DtPgMaisAtual := Parcelas[i].DtPg;
          MACDtPg       := Parcelas[i].MAC;
        end;
      end;                     
    end;
    Result := MACDtPg;
end;


function GetTxPst(Serie         : TSerie;
                  ValoresPorMAC : TValoresPorMAC;
                  DtVenc,DataRef: TData) : real;
var
  TxPstTabErrData    : TData;
  TxPst              : real;
  TxPstTabErr        : integer;
  MACCorrSaldo       : smallint;
  PerSalDevLc        : byte;
begin
  TxPst  := 1.0;
  if assigned(ValoresPorMAC) then begin
    TxPstTabErr         := 0;
    TxPstTabErrData.Dia := 0; fillchar(TxPstTabErrData,sizeof(TxPstTabErrData),0);
    if ValoresPorMAC.MAUASD > 0 then
      MACCorrSaldo := ValoresPorMAC.MAUASD
    else
      MACCorrSaldo := ValoresPorMAC.MAUA;
  
    if Serie.Fin.CobraResiduo then  //qdo Serie.cobraResiduo t  marcada, mesmo Per.Reaj.Saldo sendo = 1,
      PerSalDevLc := 1              //mas se o reajuste da presta  o for diferente de 1, PerSalDev vem <> 1
    else
      PerSalDevLc := ValoresPorMAC.PerSalDev;
  
     if Serie.Fin.Indice_Obtido_Dia_Util or (Serie.fin.PERC_APLICACAO_IND_CORR <> 0)
       and (Serie.fin.PERC_APLICACAO_IND_CORR <> 100) then // scat 65260
      CalculaTxPstDataRefPercentual(DataRef,
                        ValoresPorMAC.CodTabelaGenerica,
                        Serie.Fin.defreaj,
                        Serie.Rpas.Temp11.MauaSD,
                        Serie.Rpas.Temp12.DiaMauaSD,
                        Serie.Fin.PERC_APLICACAO_IND_CORR, 
                        TxPst,
                        TxPstTabErr,
                        TxPstTabErrData)
    else 
      CalculaTxPstDataRef(Serie.Fin.CodSerie,
                          DataRef,
                          Serie.Fin.DataRefReaj,
                          Serie.Fin.DataRef,  //DtAssin
                          ValoresPorMAC.DtEntregaChaves,
                          DtVenc,
                          ValoresPorMAC.DiaVencOrig,
                          ValoresPorMAC.MAC,
                          Serie.Fin.PerReaj,
                          Serie.Fin.defreaj,
                          Serie.Fin.defreajprechv,
                          Serie.Fin.Codreajprechaves,
                          ValoresPorMAC.CodTabelaGenerica,
                          ValoresPorMAC.IndSaldoAcum,
                          ValoresPorMAC.CorrSaldoMesAntAcum,
                          ValoresPorMAC.CorrSaldoMesAcum,
                          ValoresPorMAC.SalDevAnt,
                          ValoresPorMAC.SaldoDev,
                          PerSalDevLc,
                          Serie.Fin.CorrProRata,
                          MACCorrSaldo,
                          Serie.Fin.CorrProRataIniPelaVarDataRef,
                          Serie.Fin.CmproRatamesAnt,
                          TxPst,
                          TxPstTabErr,
                          TxPstTabErrData);
  end;
  result := TxPst;
end;

procedure TSerie.ObtemValorParcelaAntecipada(    ValoresDoMes : TValoresPorMac;
                                             var MutDsk    : TpMutDsk;
                                                 Parcela   : TParcelaSerie;
                                                 DtRef     : Tdata;
                                                 NaoCobraJC: boolean;
                                             Var Valor, Desconto : real);

  function CalculaSaldoUltParcelaAntecipada2(var MutDsk     : TpMutDsk; 
                                                 MACDaUltima: smallint;
                                                 NaoCobraJC : boolean;
                                                 DtCarenciaDeJuros,
                                                 DtRef      : TData) : real;
  var
    ValoresPorMac : TValoresPorMac;
    DtAux,
    DtVencJuros,
    DtVencOrig,
    DtVencCorr,
    DtVencComCarencia,
    DtVenc        : Tdata;
    corr,
    Mora,
    JurosContr    : real;
    ParcelaMACRef,
    ParcMAC       : TParcela;
    CorrP,
    PagoNoMes     : real;
    IndC          : real;
    IndInvalido   : boolean;
    DtIndInvalido : TData;
    UF : str3;
    MACRef,
    MACCorSaldo,
    CodMun        : smallint;
    SaldoPgParcialAntecParaDataRef : real;
  begin
    Mora       := 0;
    JurosContr := 0;
    IndInvalido:= false;
    UF := '';
    CodMun := 0;
    DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
    result := 0;
    PagoNoMes := 0;
    SaldoPgParcialAntecParaDataRef := 0;
    DtVenc.MesAno := DtRef.MesAno;
    if ValoresDoMes.DiaVencOrig in [1..31] then
      DtVenc.Dia := ValoresDoMes.DiaVencOrig
    else DtVenc.dia := ValoresDoMes.diaVenc;
    if Juliano(DtVenc) < Juliano(Fin.DataRef) then
      DtVenc := Fin.DataRef;
    DtVencOrig := DtVenc;
    DtVencJuros:= DtVenc;
    DtVenc.Dia := Dia_Venc(Mes_Int(DtVenc.MesAno),DtVenc.Dia);
    if DtRef.dia < DtVenc.dia then begin
      result := ValoresDoMes.SalDevAnt;  //ValoresdoMes.ValorAntecAntesVenc;
      MACRef := Mes_Int(DtRef.MesAno);
      if (Mes_Int(Parcela.DtPg.MesAno) < MACRef) and
         (Mes_Int(Parcela.DtPg.MesAno) = ValoresDoMes.MAC) then begin
        if (Parcela.DtPg.Dia >= byte(ValoresDoMes.DiaVenc)) then
          Result  := Arredonda(ValoresDoMes.SalDevAnt*ValoresDoMes.TxSd);
        SaldoPgParcialAntecParaDataRef := SaldoPgParcialAntec(DtRef,true);
      end
      else
        SaldoPgParcialAntecParaDataRef := SaldoPgParcialAntec(DtRef);
      ParcMAC := Parcelas.ObtemParcelaPorMac(mes_int(DtVenc.MesAno));
      if assigned(ParcMAC) and ParcMAC.EstaPagaReal and
        (not (ParcMAC.TipoPg in PgtoComRedSdDev)) then begin
        PagoNoMes := ValoresDoMes.Amaisj;
        PagoNoMes := CalculaEncargoAtualizado(PagoNoMes,DtVenc,
                                              DtRef,ValoresDoMes.IndJuros,
                                              Fin.JurProRata or
                                              ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                              Fin.IncluiFracaoDoMes,false{JurosSimples},
                                              (Fin.TpJuros = 6),
                                              DiaVencOrig,
                                              (Fin.TpJuros = 7));
        if Juliano(ParcMAC.DtPg) <> Juliano(DtRef) then begin
          IndC := detinddataadata(ValoresDoMes.CodTabelaGenerica,Fin.DefReaj, DtRef,DtVenc,1.0,
                                  Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                                  fin.CorrProRataIniPelaVarDataRef,Fin.CmProRataMesAnt,false{CalcMes});
          if abs(IndC) > 0 then
            PagoNoMes := Arredonda(PagoNoMes / (IndC));
        end;
      end;
      decMa(dtVenc.MesANo);
      if Self.DiaVencOrig > 0 then DtVenc.Dia := Self.DiaVencOrig
      else if DtVenc.Dia <> Fin.DtInicio.Dia then begin
        ValoresPorMac := ObtemValoresPorMac(Mes_Int(DtVenc.MesAno));
        if assigned(ValoresPorMAC) then 
           DtVenc.Dia := ValoresPorMAC.DiaVenc
        else
          DtVenc.Dia := Fin.DtInicio.Dia;
      end;
      DtVenc.Dia := Dia_Venc(Mes_Int(DtVenc.MesAno),DtVenc.Dia);
      if Juliano(DtVenc) < Juliano(Fin.DataRef) then
        DtVenc := Fin.Dataref;
      decMA(DtVencJuros.MesAno);
      if juliano(DtVencJuros) < juliano(Fin.DataRef) then
        DtVencJuros := Fin.DataRef;
    end
    else begin
      Result := ValoresdoMes.ValorAntecNoVenc + ValoresdoMes.ValorAntecPosVenc;
      if Abs(ValoresDoMes.VUtilPgParcialAntec) > zero then begin
        ParcelaMACRef := Parcelas.ObtemParcelaPorMac(ValoresDoMes.MAC);
        if (not assigned(ParcelaMACRef)) or
           (not ParcelaMACRef.EstapagaReal) or
           (juliano(ParcelaMACRef.DtPg) > juliano(DtRef)) then
          Result := Result - ValoresDoMes.VUtilPgParcialAntec;
      end;
    end;

    if (Fin.PerReaj = 0) {or (not Fin.CorrProRata) Sol. 056470 } then corr := 0
    else begin
      DtAux      := DtRef;
      if not Fin.CorrProRata then DtAux.dia := DtVenc.dia;
      Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
      if (ValoresDoMes.PerSalDev >= 6) and (not Fin.CobraResiduo) then begin
//        if (ValoresDoMes.MAUASD < Mes_Int(DtRef.MesAno)) and
//           DataEMaiorOuIgual(DtRef,DtVencOrig) then begin
//          Corr := ValoresDoMes.CorrSaldoMesAcum;
//          Result:= Result + Corr;
//        end
//        else begin
          if ValoresDoMes.MAUASD > 0 then
            MACCorSaldo := ValoresDoMes.MAUASD
          else
            MACCorSaldo := ValoresDoMes.MAUA;
          if MACCorSaldo = Mes_Int(DtRef.MesAno) then begin
            if DtRef.Dia < byte(ValoresDoMes.DiaVenc) then 
              MACCorSaldo := MACCorSaldo - ValoresDoMes.PerSalDev
          end
          else if (MACCorSaldo = 0) and 
                 ((Mes_Int(DtRef.MesAno)-ValoresDoMes.PerSalDev) <= 
                  Mes_Int(Fin.DataRef.MesAno)) then
                 MACCorSaldo := Mes_Int(Fin.DataRef.MesAno);
          if Mes_Int(Fin.DataRef.MesAno) >= MACCorSaldo then
            DtVencCorr := Fin.DataRef
          else if (MACCorSaldo > 0) and (MACCorSaldo <= Mes_Int(DtRef.Mesano)) then begin
            Int_Mes(MACCorSaldo,DtVencCorr.MesAno);
            if ValoresDoMes.DiaVencOrig in [1..31] then 
              DtVencCorr.Dia := Dia_Venc(MACCorSaldo,ValoresDoMes.DiaVencOrig)
            else
              DtVencCorr.Dia := Dia_Venc(MACCorSaldo,ValoresDoMes.DiaVenc);
          end;
          if (fin.DataRefReaj.Dia > 0) and 
             (juliano(DtVencCorr) < juliano(fin.DataRefReaj)) then
            DtVencCorr := fin.DataRefReaj;
          if juliano(DtVencCorr) < juliano(DtVenc) then begin
            corr := (detinddataadata(ValoresDoMes.CodTabelaGenerica,Fin.DefReaj, DtVencCorr,DtVenc,1.0,
                               Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                               Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,false)-1) * result;
            Result:= Result + Corr;
          end;
//        end;
      end;
      Corr := 0;
      if not DatasSaoIguais(DtAux,DtVenc) then begin
        DtVencCorr := DtVenc;
        if (Fin.DataRefReaj.Dia > 0) and
           (juliano(DtVencCorr) < juliano(fin.DataRefReaj)) then
          DtVencCorr := fin.DataRefReaj;
        if ((Fin.SistAmort = 7) and (Fin.JurosSimples) and (Fin.TpJuros = 6)) or
            Fin.CmProRataMesAnt then
          corr := (detinddataadata(ValoresDoMes.CodTabelaGenerica,Fin.DefReaj, DtVencCorr,DtAux{DtRef},1.0,
                  Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                  Fin.CorrProRataIniPelaVarDataref,Fin.CmProRataMesAnt,true)-1) * result
        else
          Corr  := CorrecaoJMJCChaves(MutDsk,UF,CodMun,Result,DtVencCorr,DtAux{DtRef},ValoresDoMes.IndJuros,
                                     0,Mora,JurosContr,ValoresDoMes.CodTabGPreChvCorr,
                                     ValoresDoMes.CodTabGCorr,false,
                                     NaoCobraJC,ValoresDoMes.DefReajPreChvCorr,
                                     ValoresDoMes.DefReajCorr{Fin.DefReaj});
      end;
    end;
    AjustaMoeda2 (mes_int(DtVenc.mesano), mes_int(DtRef.mesano), result);
    result := result + Corr;
    JurosContr := 0;
    if Fin.JurProRata and (not DatasSaoIguais(DtVenc,DtRef)) then begin
{---- esse c digo abaixo, apenas copiei da calculaSaldoParaQuitacao para --
 ---- ficar compat vel com o c lculo da antec. de s ries      -----------}
      if ((DtCarenciaDeJuros.dia > 0) and  
          (Juliano(DtRef) > Juliano(DtCarenciaDeJuros))) or
         ((DtCarenciaDeJuros.dia <= 0) and
         ((mes_int(Fin.DtInicio.mesano) - mes_int(fin.Dataref.mesano) <= 1) or  (* se n o tem carencia *)
         ((juliano(DtRef) >= juliano(Fin.DtInicio)) or (* se quit. depois da carencia *) 
          (not ScciConf.DispensaJurosProRataNaCarencia)))) then begin (* n o dispensa juros na carencia *)
        if (DtCarenciaDeJuros.dia > 0) and 
           (Juliano(DtVencJuros) < Juliano(DtCarenciaDeJuros)) then
          DtVencComCarencia := DtCarenciaDeJuros
        else
          DtVencComCarencia := DtVencJuros;

        if Fin.TpJuros = 6 then  //ajusto o dia de vencimento para o mes/ano
          DtVencComCarencia.Dia := Dia_Venc(Mes_Int(DtVencComCarencia.MesAno),DtVencComCarencia.Dia)
        else
          if DtVencComCarencia.Dia > 30 then
            DtVencComCarencia.Dia := 30;
        if (Fin.SistAmort = 7) and (Fin.JurosSimples) and (Fin.TpJuros = 6) then begin
          ValoresPorMac := ObtemValoresPorMac(Mes_Int(DtVencJuros.MesAno));
          corrp := (detinddataadata(ValoresDoMes.CodTabelaGenerica,Fin.DefReaj,DtVencJuros,DtAux,1.0,
                    Fin.CorrProRata,IndInvalido,DtIndInvalido,false,1,
                    Fin.CorrProRataIniPelaVarDataref,
                    Fin.CmProRataMesAnt,true)-1) * ValoresPorMac.SaldoPrincipal;

          JurosContr := CalcJurosProRata(ValoresPorMac.SaldoPrincipal+Corrp,
                                       ValoresDoMes.IndJuros,
                                       DtVencComCarencia,DtRef,
                                       Fin.JurosSimples,
                                       Fin.TpJuros = 6 {ProRataJurosDiasCorridos});
        end
        else
          JurosContr := CalcJurosProRata(Result,ValoresDoMes.IndJuros,
                                         DtVencComCarencia,DtRef,
                                         Fin.JurosSimples,(Fin.TpJuros = 6){ProRataJurosDiasCorridos});
      end;
      Result := Result + JurosContr;
    end;
    if Abs(SaldoPgParcialAntecParaDataRef) > Zero then
      result := result - SaldoPgParcialAntecParaDataRef;
    result := result - pagonomes;
  end;
   
  
  function GetIndSaldoAcum(ValoresMACRef : TValoresPorMAC; DataRef : TData) : real;
  var 
    DataPg : TData;
  begin
//fiz essa rotina na tentativa in til de chegar ao mesmo  ndice (txpst) da antecipacao
    Result := ValoresMACRef.IndSaldoAcum;

    if assigned(Parcela) then 
      DataPg := Parcela.DtPg
    else 
      DataPg := DataRef;

    if (Mes_Int(DataPg.MesAno) < Mes_Int(DataRef.MesAno)) and
       (ValoresMACRef.MAUASD > 0) and (ValoresMACRef.MAUASD < ValoresMACRef.MAC) and
       (ValoresMACRef.MACStatus < ValoresMACRef.MAC) and
       (DataRef.Dia >= byte(ValoresMACRef.DiaVenc)) and
       (ValoresMACRef.PerSalDev = 1) and (ValoresMACRef.TxSd = 1.0) then begin
      Result := Result * ValoresMACRef.TxSdMes;
    end;
  end;
     

  function Arredonda(Valor : real) : real;
  begin
    if Abs(Valor) > Zero then begin
      if Valor > Zero then
        Result := Int(Valor*100+0.5)/100
      else
        Result := -Int(Abs(Valor)*100+0.5)/100;
    end else Result := 0;
  end;

var
  DtCarenciaLocal,
  DtVenc        : TData;
//Dt1, DtEntHab      : TData;
  TxPst,
  ValorPagoAntecipadoAtu,
  ValorNaDataRefSerie,
  ValorSemDesc  : real;
//  defas,
  MacPrstRef    : integer;
  DataRef       : TData;
  ValoresPorMac : TValoresPorMac;
  MACDaUltima   : smallint;
  DescConc      : real;
begin
  DescConc:= 0;
  DataRef := DtRef;
  if Fin.RecalculaPrestacao then begin
    if abs(ValoresDoMes.TxPstAcum) > Zero then
      ValorNaDataRefSerie := ValoresDoMes.Amaisj / ValoresDoMes.TxPstAcum - Parcela.AmaisJPagoAteUltimoPagamento
    else
      ValorNaDataRefSerie := ValoresDoMes.Amaisj - Parcela.AmaisJPagoAteUltimoPagamento;
  end
  else
    ValorNaDataRefSerie := Parcela.Valor - Parcela.AmaisJPagoAteUltimoPagamento;
  AjustaMoeda2(mes_int(Fin.DataRef.MesAno),Mes_int(DtRef.MesAno),ValornaDatarefSerie);
  ValorPagoAntecipadoAtu := Parcela.ValorPagoAntecipado;
  AjustaMoeda2(mes_int(Fin.DataRef.MesAno),Mes_int(DtRef.MesAno),ValorPagoAntecipadoAtu);
  if (Fin.Prazo = 1) or (Fin.TaxaOportunidade > Zero) then
    ValPagParcSerieDtPg(Parcela,DescConc,false{SoDescConcedido}) //preciso do desconto de juros descapitalizados 
  else
    ValPagParcSerieDtPg(Parcela,DescConc,true{SoDescConcedido});
  DtVenc:= DtRef;
  DtVenc.dia := Dia_Venc(Mes_Int(DtVenc.MesAno),ValoresDoMes.DtInFin.dia);
  MacPrstRef :=  Mes_Int(DataRef.MesAno);
  if DataRef.Dia < DtVenc.Dia then dec(MacPrstRef);
  ValoresPorMac := ObtemValoresPorMAC(MacPrstRef);   

  TxPst := GetTxPst(Self,ValoresPorMAC,DtVenc,DtRef);

  Int_Mes(Parcela.Mac,DtVenc.MesAno);
  DtVenc.dia := ValoresDoMes.DtInFin.dia;

(*-------------------- retirado pelo scat 082458 -------------------------
  int_mes(MacPrstRef,Dt1.MesAno);
  Dt1.Dia := DtVenc.Dia;
  if juliano(Dt1) < juliano(Fin.DataRef) then Dt1 := Fin.DataRef;
  defas := Fin.defreaj;
  DtEntHab := ValoresDoMes.DtEntregaChaves; // SCAt 29363
  if ScciConf.ConsideraDataHabitnatrocadoindPreParaPos then DtEntHab := ValoresDoMes.DtHabit;
  if not ((Juliano(DtEntHab)>0) and
     (Juliano(DtEntHab)>Juliano(DataRef)) and  // SCAt 21613
     (Juliano(dtvenc)>Juliano(DtEntHab))) then
    if Fin.codreajprechaves > 0 then defas := Fin.defreajprechv;
  if Fin.CorrProRata then 
    TxPst := ValoresPorMAC.IndSaldoAcum * detIndProRata(ValoresPorMac.CodTabelaGenerica,Defas,Dt1,DataRef,1.0)
  else
    TxPst := ValoresPorMAC.IndSaldoAcum;
-------------------------------------------------------------------------*)

  ValorSemDesc := (ValorNaDataRefSerie * TxPst * (1-ValoresDoMes.IndRedPrest)) -
                  (ValorPagoAntecipadoAtu * TxPst);

  if Fin.Prazo = 1 then begin
    ValorSemDesc := CalculaVaEncargo(ValorSemDesc,
                                     DtVenc,DtRef,
                                     TxPst,
                                     ValoresPorMAC.IndJuros,
                                     ValoresPorMAc.IndRedPrest,
                                     ValoresPorMAC.RARD,
                                     Fin.TaxaOportunidade);

(*-Alterado pela sol. 057029 para que o acerto financeiro fique sempre------
   de acordo com as altera  es efetuadas na rotina TSerie.CalculaVaEncargo,que 
   estava abandonada, ficando desatualizada. Deixei o c digo antigo pois esta
   altera  o   perigosa e n o foram feitos testes suficientes para garantir
   que ficou mais correto agora!                                      
    if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then { Scat 41461 }
      ValorSemDesc := CalculaValorAtualEncargoJurosSimplesSCP(ValorSemDesc,DtVenc,DataRef,ValoresPorMAC.RaRd)-DescConc
    else
      ValorSemDesc := CalculaEncargoAtualizado(ValorSemDesc,DtVenc,DataRef,ValoresPorMAC.IndJuros,
                                        Fin.JurProRata or ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                        Fin.IncluiFracaoDoMes,false{JurosSimples},
                                        (Fin.TpJuros = 6),
                                        DiaVencOrig,
                                        (Fin.TpJuros = 7))-DescPag;
-----------------------------------------------------------------------*)
  end;
  if ValorSemDesc < zero then ValorSemDesc := 0;
  ValorSemDesc := Arredonda(ValorSemDesc);

  MACDaUltima := MACUltParcelaAntecipada(MacPrstRef);
  if Fin.DtCarenciaDeJuros.dia > 0 then begin
    DtCarenciaLocal := Fin.DtCarenciaDeJuros;
    if not Fin.JurProRata then DtCarenciaLocal.Dia := DtVenc.Dia;
    if Juliano(DtCarenciaLocal) > Juliano(DtRef) then 
      DataRef := DtCarenciaLocal;
  end;

  if Parcela.MAC = MACDaUltima then begin
    Valor := CalculaSaldoUltParcelaAntecipada2(MutDsk,MACDaUltima,NaoCobraJC,Fin.DtCarenciaDeJuros,DtRef) - DescConc;
    Valor := Arredonda(Valor - Arredonda(TotDevido*TxPst));    
    if assigned(Parcela) and ((Abs(Valor-Parcela.ValorPagoNoUltimoPagamento{Parcela.ValorPago}) <= 0.10) or
       (Mes_Int(Parcela.DtPg.MesAno) < Mes_Int(DtRef.MesAno))) then
      Valor := Parcela.ValorPagoNoUltimoPagamento;  {Parcela.ValorPago}

    TotDevido := 0;
  end
  else begin
    Valor := CalculaVaEncargo(ValorSemDesc,DtVenc,DtRef,TxPst,
                              ValoresPorMAC.IndJuros,
                              ValoresPorMAc.IndRedPrest,
                              ValoresPorMAC.RARD,
                              Fin.TaxaOportunidade)-DescConc;
(*-Alterado pela sol. 057029 para que o acerto financeiro fique sempre------
   de acordo com as altera  es efetuadas na rotina TSerie.CalculaVaEncargo,que 
   estava abandonada, ficando desatualizada. Deixei o c digo antigo pois esta
   altera  o   perigosa e n o foram feitos testes suficientes para garantir
   que ficou mais correto agora!                                      

    if (Fin.SistAmort = 7) {SCP} and Fin.JurosSimples then { Scat 41461 }
      Valor := CalculaValorAtualEncargoJurosSimplesSCP(ValorSemDesc,DtVenc,DataRef,ValoresPorMAC.RaRd)-DescPag
    else
      Valor := CalculaEncargoAtualizado(ValorSemDesc,DtVenc,DataRef,ValoresPorMAC.IndJuros,
                                        Fin.JurProRata or ScciConf.ForcaCobJurosProrataNaQuitSerie,
                                        Fin.IncluiFracaoDoMes,false{JurosSimples},
                                        (Fin.TpJuros = 6),
                                         DiaVencOrig,
                                        (Fin.TpJuros = 7))-DescPag;
------------------------------------------------------------------------*)  
      if TxPst > Zero then 
        TotDevido := TotDevido + (Valor + DescConc)/TxPst;
  end;
  Desconto := ValorSemDesc - Valor;
end;


procedure TSerie.ObtemValorParcelaAntecipadaNoMes(var MutDsk    : TpMutDsk;
                                                      Parcela   : TParcelaSerie;
                                                      DtRef     : Tdata;
                                                      NaoCobraJC: boolean;
                                                  Var Valor, Desconto : real);
begin
  ObtemValorParcelaAntecipada(TValoresPorMac(FValoresPorMacList[RPAS.Mac]),MutDsk,Parcela,DtRef,NaoCobraJC,Valor,Desconto);
end;

function TSerie.PodeExcluir : boolean;
var
  i : integer;
begin
  result := true;
  for i := 0 to Parcelas.count - 1 do
{
  N o excluir fisicamente uma s rie se ela:
     Estiver paga
     Tiver pagamento parcial
     Estiver emitido
     Tiver serguro pago
}
    if Parcelas[i].EstaPagaReal or
       (Parcelas[i].tipopg in [51,111,115]) or
       (Parcelas[i].MacEmitido > 0) or
       ((Parcelas[i].DtPgSeg.dia > 0) and
        not (Parcelas[i].TipoPgSeg in [8..9,66,74,95,108,110,114,117,121,200,253])) then begin
      result := false;
      break;
    end;
end;

function TSerie.CalculaTaxasNoMes(DesconsideraComporAlgo : boolean = false):Boolean;
begin
  Result := (DesconsideraComporAlgo or Fin.CompoeSaldo or Fin.CompoeEntrada or (Fin.TxAdm > zero)) and
            (not Fin.IgnoraCalcTxAdm) and
            (Fin.TxAdm > -1) and
            (mes_Int(Fin.DtInicio.MesAno)> 0) and
            (RPAS.MAC >= Mes_Int(RPAS.FinRPA.DtAssin.mesano)) and
            (RPAS.MAC >= Mes_Int(RPAS.FinRPA.DtInFin.mesano)+1) and
            Ctr_Ativo(RPAS) and
            ((not ScciConf.ZeraValTxAdmMesSemParc) or RPAS.Temp10.TemParcNoMes);


end;

function TSerie.CalculaSeguroNoMes : boolean;
var
  DtMAC : Tdata;
begin
  result := ((RPAS.FinRPA.IndSegFin > Zero) or
             (RPAS.Temp12.GrupoApoliceMista > 0) or
             (RPAS.Temp11.GrupoApolice > 0) or
             (StripStr(RPAS.Temp10.CodApolice) > '')) and
            (Fin.CompoeSaldo or Fin.CompoeEntrada) and
            (RPAS.MAC >= RPAS.Temp11.MacIniSeguro) and
            (((mes_int(Fin.DtInicio.MesAno)>0) and
             (Fin.Valor>Zero)) or (RPAS.FInRPA.Status>0)) and
            Ctr_ativo(RPAS) and
            (RPAS.Temp5.MACSuspSeg = 0);

  DtMAC.Dia := RPAS.FinRPA.DiaVenc;
  int_mes(RPAS.Mac,DtMAC.MesAno);
  result := result and
            (Juliano(DtMAC) >= Juliano(RPAS.Temp10.DtAssinPropSeguro));

  // SCAt 21537
  result := result and
            ((RPAS.MAC>mes_int(RPAS.FinRPA.DtAssin.MesAno)) or (RPAS.FinRPA.NPC>0) or
             not RPAS.Temp6.SegRecalcSaldo) or
             ((RPAS.MAC=mes_int(RPAS.FinRPA.DtAssin.MesAno)) and
              (Contrato.Series.TemSerieRenegAntesVenc(Fin.DataRef)));

  // S  entra no c lculo no per odo que existe
  result := result and
            (RPAS.MAC >= Mes_Int(RPAS.FinRPA.DtAssin.mesano));

  // N o gerar cobran a de seguro, para s ries cuja data de vencimento e de refer ncia sejam iguais,
  // prazo de financiamento igual a "1" e c digo de classifica  o igual a "Entrada"
  // sol. 45267
  if (Juliano(Fin.DtInicio) = Juliano(Fin.DataRef)) and
     (Fin.Prazo=1) and
     (Fin.CodClassificacao=serie_Entrada) then
    result := false;

  // Sol. 25337, N o h  seguro se a parcela vence na assinatura.
  // Sol. 28677, Alterado para n o ter seguro na parcela que vence na assinatura se o prazo for 1
  // Sol. 34610, Ter a op  o de cobrar seguro para s ries que come am no mes/ano de assinatura
  if not ScciConf.CobraSegSerieVencAssin then
    if (RPAS.MAC = Mes_Int(RPAS.FinRPA.DtAssin.mesano)) and
       (Mes_Int(RPAS.FinRPA.DtInFin.mesano)+1 = Mes_Int(RPAS.FinRPA.DtAssin.mesano)) and
       (byte(RPAS.FinRPA.DiaVenc) <= RPAS.FinRPA.DtAssin.Dia) and
       (Rpas.FinRpa.Prazo = 1) then
      result := false;
end;

function TSerie.CalculaSeguroDFINoMes(IgnoraValAVal : boolean = false; TemSegImvDefault : boolean = false) : boolean;
var
  DtMAC : Tdata;
begin
  result := (RPAS.Temp11.GrupoApolice = 0) and
            ((StripStr(RPAS.Temp11.CodApoliceDFI) > '') or
             ((RPAS.FinRpa.indSegImv > zero) or TemSegImvDefault))and
            ((RPAS.FinRPA.ValAVal > zero) or IgnoraValaVal) and
            (Fin.CompoeSaldo or Fin.CompoeEntrada) and
            (((mes_int(Fin.DtInicio.MesAno)>0) and
             (Fin.Valor>Zero)) or (RPAS.FInRPA.Status>0)) and
            Ctr_ativo(RPAS) and
            (RPAS.Temp5.MACSuspSeg = 0);

  DtMAC.Dia := RPAS.FinRPA.DiaVenc;
  int_mes(RPAS.Mac,DtMAC.MesAno);
  result := result and
            (Juliano(DtMAC) >= Juliano(RPAS.Temp10.DtAssinPropSeguro));

  // SCAt 21537
  result := result and
            ((RPAS.MAC>mes_int(RPAS.FinRPA.DtAssin.MesAno)) or (RPAS.FinRPA.NPC>0) or
             not RPAS.Temp6.SegRecalcSaldo);

  // S  entra no c lculo no per odo que existe
  result := result and
            (RPAS.MAC >= Mes_Int(RPAS.FinRPA.DtAssin.mesano));

  // N o gerar cobran a de seguro, para s ries cuja data de vencimento e de refer ncia sejam iguais,
  // prazo de financiamento igual a "1" e c digo de classifica  o igual a "Entrada"
  // sol. 45267
  if (Juliano(Fin.DtInicio) = Juliano(Fin.DataRef)) and
     (Fin.Prazo=1) and
     (Fin.CodClassificacao=serie_Entrada) then
    result := false;

  // Sol. 25337, N o h  seguro se a parcela vence na assinatura.
  // Sol. 28677, Alterado para n o ter seguro na parcela que vence na assinatura se o prazo for 1
  // Sol. 34610, Ter a op  o de cobrar seguro para s ries que come am no mes/ano de assinatura
  if not ScciConf.CobraSegSerieVencAssin then
    if (RPAS.MAC = Mes_Int(RPAS.FinRPA.DtAssin.mesano)) and
       (Mes_Int(RPAS.FinRPA.DtInFin.mesano)+1 = Mes_Int(RPAS.FinRPA.DtAssin.mesano)) and
       (byte(RPAS.FinRPA.DiaVenc) <= RPAS.FinRPA.DtAssin.Dia) and
       (Rpas.FinRpa.Prazo = 1) then
      result := false;
  if RPAS.FinRpa.IndSegImv < 0 then
    result := false;
end;

function TSerie.EstaEmFaseDeCarenciaFinBancChaves(dataref : tdata) : boolean;
var
  DtCarencia,
  DtVenc : TData;
  Carencia : integer;
begin
  result := false;
  if Fin.FinancBancario or (Fin.CodClassificacao = serie_chaves) then begin
    Carencia := TemCarenciaAtrasoFinBancChaves;
    if Carencia > 0 then begin
      if CalcCarenciaFinBancChavesPelaDtInicio(Fin,Contrato.Empreendimento) then
        DtCarencia := Fin.DtInicio
      else
        DtCarencia := RpaS.Temp10.DtHabit;
      if Juliano(DtCarencia) > 0 then begin
        J_Data(Juliano(DtCarencia)+Carencia,DtVenc);
        Result := (Contrato.DiasDeAtrasoEntreDatas(DtVenc,DataRef) <= 0);
      end
      else
        Result := true;
    end;
  end;
end;

function TSerie.EmCarenciaCobAtraso(dataref : Tdata) : boolean;
var
  DataVenc : Tdata;
begin
  result := false;
  if Fin.DataCarEncargos.dia > 0 then begin
    DataVenc.Dia := RpaS.FinRpa.DiaVenc;
    int_mes(RpaS.MAC,DataVenc.MesAno);
    if Juliano(Fin.DataCarEncargos) > Juliano(DataVenc) then
      DataVenc := Fin.DataCarEncargos;
    result := Juliano(dataref) <= juliano(DataVenc);
  end;
end;

function TSerie.EmCarenciaCobAtraso(Reg : TValoresPorMac; dataref : Tdata) : boolean;
var
  DataVenc : Tdata;
begin
  result := false;
  if Fin.DataCarEncargos.dia > 0 then begin
    DataVenc.Dia := Reg.DiaVenc;
    int_mes(Reg.MAC,DataVenc.MesAno);
    if Juliano(Fin.DataCarEncargos) > Juliano(DataVenc) then
      DataVenc := Fin.DataCarEncargos;
    result := Juliano(dataref) <= juliano(DataVenc);
  end;
end;

function DefineValorPrestAtraso(ValPrst,Seguro,ValTxAdm : real;AtrasoContabil : boolean = false) : real;
begin
  {
    101894 - se for atrasocontabil, na calculaencargos(abaixo) o valprest sofre a  o das configura  es
             ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb e ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb,
             ent o n o sei se a scciconf.NaoPenalizaAcessoriosNoAtraso deveria ser obedecida.
             Por enquanto, vou ignorar a scciconf.NaoPenalizaAcessoriosNoAtraso, quando o atrasocontabil for setado.
  }
  if scciconf.NaoPenalizaAcessoriosNoAtraso then begin
    if AtrasoContabil then begin
      if not ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb then 
        ValPrst := arredonda(ValPrst - ValTxAdm);
      if not ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb then
        ValPrst := arredonda(ValPrst - Seguro);
      Result := ValPrst;
    end
    else 
      result := arredonda(ValPrst-Seguro-ValTxAdm);
    if result < 0 then
      result := 0;
  end  
  else
    result := ValPrst;  
end;

procedure TSerie.CalculaEncargos(var MutDsk   : TpMutDsk;
                                     DataRef:TData;
                                 var Correcao,
                                     JMora,
                                     JContr,
                                     Multa,
                                     CorrMoraMultaSeg : Double;
                                 var CorrecaoAmaisj,
                                     JMoraAmaisj,
                                     JContrAmaisj,
                                     MultaAmaisj : real;
                                     NaoCobraJC: boolean;
                                     ComIsencao : boolean;
                                     AtrasoContabil : boolean = false;
                                     IgnoraPendenciaManual : boolean = false;
                                     SomenteTipoPgParcial : boolean = false;
                                     SomenteSeguro : boolean = false);
var 
  DifEmi,
  ValorAux          : real;
  DataVenc          : TData;
  CodTabGPreChvCorr,
  CodTabGCorr       : smallint;
  ValAux,
  ValorPagoAntecipado : real;
  RPABkp              : TpRpa;
  CorrecaoSeguro,
  JMoraSeguro,
  JContrSeguro,
  MultaSeguro : real;
  TmoraAux : byte;
  UF : str3;
  CodMun : smallint;
  DataRefReajSerie,
  DtIndInvalido : Tdata;
  SalvaNaoCorrigeAts,
  IndiceInvalido : boolean;
begin
  SalvaNaoCorrigeAts := ScciConf.NaoCorrigeAts;
  JMoraSeguro := 0;
  JContrSeguro := 0;
  correcaoSeguro := 0;
  MultaSeguro := 0;

  UF := '';
  CodMun := 0;
  ValAux := 0;
  DtIndInvalido.Dia := 0; DtIndInvalido.Mes := 0; DtIndInvalido.ano := 0;
{ Sol 24882
  Calcular:
  At  a dtvenc da parcela: nada
  At  a condi  o de atraso: corr/juros contratuais
  A partir da condi  o de atraso: corr/mora/juros contratuais/multa
}
  if assigned(self) and not EmCarenciaCobAtraso(dataref)(*and
   ((Fin.codclassificacao <> serie_Inibe1aVia) or
    ((RpaS.FinRPA.NPC = 0) and
     (RpaS.MAC > Mes_Int(RPAS.FinRPA.DtAssin.MesAno)) and
     (RpaS.ValRPA.TotPrest-RPAS.ValRPA.Desc > Zero)) or
     ESerieFinancBancarioDevida(Fin,RpaS.Temp10.DtHabit,DataRef)) *)then begin
    {
      Mudan a de crit rio. N o usar mais valorpagoantecipado, pois este s  vem preenchido se a parcela n o estiver com
      tipopg pago. Utilizar a nova vari vel RPAS.Temp11.VUtilPgParcialAntec que informa quanto realmente foi antecipado
      at  o vencimento da parcela.
      Sol. 27982
    }
    fillchar(DtIndInvalido,sizeof(Tdata),0);
    IndiceInvalido := false;
    DataRefReajSerie := Fin.DataRefReaj;
    if ((Abs(RPAS.ValRPA.AmaisJ) <= Zero) and (RPAS.ValRPA.Seguro > Zero)) or
        (not RPAS.Temp10.TemParcNoMes) or SomenteSeguro then
      ValorPagoAntecipado := 0
    else
      ValorPagoAntecipado := int(PagamentosParciais.ObtemSaldoAteDataref(RPAS.MAC,Dataref,RPAS.FinRPA.IndJuros,ValAux,AtrasoContabil,SomenteTipoPgParcial) * RPAS.Temp5.TxPstAcum*100+0.5)/100;
//      ValorPagoAntecipado := RPAS.Temp11.VUtilPgParcialAntec;
    if (AtrasoContabil and (not Scciconf.ConsideraPendEmiNaAtualizacaoDoAtrasoCtb)) then
      DifEmi := 0
    else 
      DifEmi := Contrato.Pendencias.ValorPendEmi(RPAS.MAC,RPAS.Temp8.CodSerie);

    DataVenc.Dia := RpaS.FinRpa.DiaVenc;
    int_mes(RpaS.MAC,DataVenc.MesAno);
    if Fin.CodReajAtraso > 0 then begin
      CodTabGPreChvCorr := 0;
      CodTabGCorr       := Fin.CodReajAtraso;
    end
    else begin
      CodTabGPreChvCorr := RPAS.Temp10.CodTabGPreChvCorr;
      CodTabGCorr       := RPAS.Temp10.CodTabGCorr;
    end;
    if Scciconf.NaoAtualizaAtrasoDeSeriesSemIndexador and
      (CodTabGPreChvCorr = 0) and (CodTabGCorr = 0) then 
      ScciConf.NaoCorrigeAts := true;

    Correcao := 0;
    Jmora    := 0; { Juros morat rios + Juros remunerat rios }
    JContr   := 0; { Juros Remunerat rios }
    multa    := 0;
    CorrMoraMultaSeg := 0;
    CorrecaoAmaisj := 0;
    JMoraAmaisj := 0;
    JContrAmaisj := 0;
    MultaAmaisj := 0;
    if EstaEmFaseDeCarenciaFinBancChaves(Dataref) then begin // Sol. 27946+28414
      TMoraAux := 0;
      NaoCobraJC := false;
    end
    else
      TmoraAux := RPAS.FinRPA.TMora;
    Contrato.ObtemMunicipioParaCobranca(UF,CodMun);
    RPABkp := RpaS;
    if AtrasoContabil then begin
      if ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb then 
        RpaS.ValRPA.TotPrest := Arredonda(RpaS.ValRPA.TotPrest-RpaS.ValRPA.ValTxAdm);
      if ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb then begin
        RpaS.ValRPA.TotPrest := Arredonda(RpaS.ValRPA.TotPrest-RpaS.ValRPA.Seguro-RpaS.Temp7.DescSeg);
        RpaS.ValRPA.Desc     := Arredonda(RpaS.ValRPA.Desc - RpaS.Temp7.DescSeg);
        if RpaS.ValRPA.Desc < Zero then RpaS.ValRPA.Desc := 0;
      end;
      if (ValorPagoAntecipado > zero) and (RpaS.ValRpa.Amaisj > zero) and
         (ValorPagoAntecipado - RpaS.ValRpa.Amaisj > zero) then
        ValorPagoAntecipado := RpaS.ValRpa.Amaisj;
    end;
    if  EstaEmCondicaoDeAtrasoRPAS(DataRef) then begin
      Correcao := CorrecaoJMJCChaves( MutDsk, UF, CodMun,
                                      DefineValorPrestAtraso(RpaS.ValRpa.TotPrest+RPAS.Temp9.ResiduoCobrado-
                                                             ValorPagoAntecipado-Rpas.ValRpa.Desc+DifEmi,
                                                             Rpas.ValRPA.Seguro,Rpas.valrpa.ValTxAdm,AtrasoContabil),
                                      DataVenc,
                                      DataRef,
                                      RPAS.FinRPA.IndJuros,
                                      TmoraAux,JMora,JContr,
                                      CodTabGPreChvCorr,
                                      CodTabGCorr,
                                      ComIsencao{false},NaoCobraJC,
                                      RPAS.Temp12.DefReajPreChvCorr,RPAS.Temp12.DefReajCorr{Fin.DefReaj},
                                      Fin.DataRef,Fin.TxJurosNoAtraso,
                                      DataRefReajSerie,
                                     ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                     true{CalculoDeAtraso});
      CorrecaoAmaisj := CorrecaoJMJCChaves( MutDsk, UF, CodMun,
                                            RpaS.ValRpa.Amaisj-ValorPagoAntecipado,
                                            DataVenc,
                                            DataRef,
                                            RPAS.FinRPA.IndJuros,
                                            TmoraAux,JMoraAmaisj,JContrAmaisj,
                                            CodTabGPreChvCorr,
                                            CodTabGCorr,
                                            ComIsencao{false},NaoCobraJC,
                                            RPAS.Temp12.DefReajPreChvCorr,RPAS.Temp12.DefReajCorr{Fin.DefReaj},
                                            Fin.DataRef,Fin.TxJurosNoAtraso,
                                            DataRefReajSerie,
                                           ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                            true{CalculoDeAtraso});
    end
    else begin
      Correcao := CorrecaoJMJCChaves( MutDsk,UF,CodMun,
                                      RpaS.ValRpa.TotPrest+RPAS.Temp9.ResiduoCobrado-
                                      ValorPagoAntecipado-Rpas.ValRpa.Desc+
                                      DifEmi,
                                      DataVenc,
                                      DataRef,
                                      RPAS.FinRPA.IndJuros,
                                      TmoraAux,JMora,JContr,
                                      CodTabGPreChvCorr,
                                      CodTabGCorr,
                                      ComIsencao{false},NaoCobraJC,
                                      DtIndInvalido,IndiceInvalido,
                                      RPAS.Temp12.DefReajPreChvCorr,
                                      RPAS.Temp12.DefReajCorr{Fin.DefReaj},
                                      DataRefReajSerie,
                                     ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                     true{CalculoDeAtraso});
      CorrecaoAmaisj := CorrecaoJMJCChaves( MutDsk,UF,CodMun,
                                            RpaS.ValRpa.Amaisj-ValorPagoAntecipado,
                                            DataVenc,
                                            DataRef,
                                            RPAS.FinRPA.IndJuros,
                                            TmoraAux,JMoraAmaisj,JContrAmaisj,
                                            CodTabGPreChvCorr,
                                            CodTabGCorr,
                                            ComIsencao{false},NaoCobraJC,
                                            DtIndInvalido,IndiceInvalido,
                                            RPAS.Temp12.DefReajPreChvCorr,
                                            RPAS.Temp12.DefReajCorr{Fin.DefReaj},
                                            DataRefReajSerie,
                                           ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                           true{CalculoDeAtraso});
    end;
    if not Scciconf.NaoPenalizaAcessoriosNoAtraso then // 101894
      CorrecaoSeguro := CorrecaoJMJCChaves( MutDsk,UF,CodMun,
                                            RpaS.ValRpa.Seguro-Rpas.ValRpa.Desc,
                                            DataVenc,
                                            DataRef,
                                            RPAS.FinRPA.IndJuros,
                                            TMoraAux,JMoraSeguro,JContrSeguro,
                                            CodTabGPreChvCorr,
                                            CodTabGCorr,
                                            ComIsencao{false},NaoCobraJC,
                                            DtIndInvalido,IndiceInvalido,
                                            RPAS.Temp12.DefReajPreChvCorr,
                                            RPAS.Temp12.DefReajCorr{Fin.DefReaj},
                                            DataRefReajSerie,
                                          ((Fin.CodClassificacao = serie_Chaves) or Fin.FinancBancario),
                                          true{CalculoDeAtraso});

    if not EstaEmCondicaoDeAtrasoRPAS(DataRef) then begin
      JMora := JContr;
      JMoraSeguro := JContrSeguro;
      JmoraAmaisj := JContrAmaisj;
    end;
    if Scciconf.CobraMultaNoAtrasoDeSeries and EstaEmCondicaoDeAtrasoRPAS(DataRef) then begin
      ValorAux := RPAS.ValRPA.TotPrest+RPAS.Temp9.ResiduoCobrado-ValorPagoAntecipado-Rpas.ValRpa.Desc+
                  DifEmi;
      if ScciConf.NaoPenalizaAcessoriosNoAtraso then begin // 101894
        if AtrasoContabil then begin
          if not ScciConf.DesconsideraTaxaNosEncargosEmAbertoCtb then
            ValorAux := arredonda(ValorAux - RPAS.ValRPA.ValTxAdm);

          if not ScciConf.DesconsideraSeguroNosEncargosEmAbertoCtb then
            ValorAux := arredonda(ValorAux - (RPAS.ValRPA.Seguro-RPAS.Temp7.DescSeg));
        end
        else 
          ValorAux := arredonda(ValorAux - (RPAS.ValRPA.Seguro-RPAS.Temp7.DescSeg) - RPAS.ValRPA.ValTxADm);
        if ValorAux < 0 then
          ValorAux := 0;
      end;  
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (RPAS.FinRPA.TMora <> 101) then
        ValorAux := ValorAux + Correcao;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + JMora;
      if (RPAS.FinRPA.TMora in [38..40]) then 
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
      else
        Multa := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
      if not ScciConf.NaoPenalizaAcessoriosNoAtraso then begin // 101894
        ValorAux := RPAS.ValRPA.Seguro-Rpas.ValRpa.Desc;
        AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
        if (RPAS.FinRPA.TMora <> 101) then
          ValorAux := ValorAux + CorrecaoSeguro;
        if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
          ValorAux := ValorAux + JMoraSeguro;
        if (RPAS.FinRPA.TMora in [38..40]) then 
          MultaSeguro := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
        else
          MultaSeguro := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
      end;    

      // multa sobre o Amaisj
      ValorAux := RPAS.ValRPA.Amaisj-ValorPagoAntecipado;
      AjustaMoeda2(Mes_Int(DataVenc.MesAno),Mes_Int(DataRef.MesAno),ValorAux);
      if (RPAS.FinRPA.TMora <> 101) then
        ValorAux := ValorAux + CorrecaoAmaisj;
      if not(Scciconf.MultaSemMora or MutDsk.Cad6.MultaNaoIncideSobreMora) then 
        ValorAux := ValorAux + JMoraAmaisj;
      if (RPAS.FinRPA.TMora in [38..40]) then 
        MultaAmaisj := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta,1{TipoAjuste=Truncar})
      else
        MultaAmaisj := ValorMulta(DataVenc,DataRef,UF,CodMun,MutDsk.Cad.PercMulta,ValorAux,MutDsk.Cad.DiaIsencao,MutDsk.cad3.MultaContratualProRata,Mutdsk.Cad6.DtIniCobMulta);
    end else begin
      Multa := 0;
      MultaSeguro := 0;
      MultaAmaisj := 0;
    end;
    CorrMoraMultaSeg := CorrecaoSeguro + JMoraSeguro + MultaSeguro;
    if AtrasoContabil then RpaS := RPABkp;
  end
  else begin
    correcao := 0;
    Jmora    := 0; { Juros morat rios + Juros remunerat rios }
    JContr   := 0; { Juros Remunerat rios }
    multa    := 0;
    CorrMoraMultaSeg := 0;
    correcaoAmaisj := 0;
    JmoraAmaisj    := 0;
    JContrAmaisj   := 0;
    multaAmaisj    := 0;
  end;
  ScciConf.NaoCorrigeAts := SalvaNaoCorrigeAts;
  if SomenteSeguro then begin
    correcao := correcaoSeguro;
    Jmora    := JMoraSeguro;
    JContr   := JContrSeguro;
    multa    := MultaSeguro;
  end;
end;

procedure TSerie.CalculaCorrecaoMoraMultaRpaS(var MutDsk   : TpMutDsk;
                                                  DataRef:TData;
                                              var Correcao,
                                                  JMora,
                                                  JContr,
                                                  Multa,
                                                  CorrMoraMultaSeg : Double;
