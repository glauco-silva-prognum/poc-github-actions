function TSerieFinanciamentoDinamico.PrestacaoCedida(Reg : TValorespormac): boolean;
begin
  result := false;
  if (Reg.DonoCred > 0) and (Reg.ValCed > zero) and (not Reg.CessaoComAdministracao) then begin
    result := (Reg.Mac >= Reg.MacPrestIniCessao) and (Reg.Mac <= Reg.MacPrestFimCessao);
  end;
end;

function TSerieFinanciamentoDinamico.PrstPagaPend(Data: TData;  Mac: SmallInt;
                                                  IgnoraTipoDePagamento : boolean = false): boolean;
var
  Parcela : TParcela;
begin
  // Mesma l gica da rotina PrstPagaPend da pendlib, mas lendo pagamentos em mem ria
  Parcela := FParcelas.ObtemParcelaPorMac(mac);
  if assigned(Parcela) then
    result := (  (Parcela.DtPg.Dia <> 0) and
                ((Juliano(Parcela.DtPg) <= Juliano(Data)) or
                 (Parcela.DtPg.Dia = 99)) and
               ( (not (Parcela.TipoPg in NotGerPend)) 
                           or
                 (IgnoraTipoDePagamento and
                 (not (Parcela.TipoPg in NotPg)))
               )
              )            or
              ((Parcela.DtPg.Dia = 0) and
               (Parcela.TipoPg in [200,253]))
  else
    result := false;
end;

procedure TSerieFinanciamentoDinamico.ExpandeValoresPorMacAteRef(MacRef : smallint; Status : integer);
var
  i : integer;
begin
  if FValoresPormacList.count <= MacRef then
    FValoresPorMacList.count := MacRef+1;
  for i := 0 to FValoresPorMacList.count-1 do begin
    if not assigned(FValoresPorMacList[i]) then
      FValoresPorMacList[i] := TValoresPorMac.create;
    TValoresPorMac(FValoresPorMacList[i]).CtrAtivo := false;
    TValoresPorMac(FValoresPorMacList[i]).status := status;
  end;
end;

function TSerieFinanciamentoDinamico.PrstPaga(DtRef : Tdata; Mac : integer; ConsideraPrstSoDeAcessorios : boolean = false) : boolean;
var
  DtInFin : TData;
  Parcela : TParcela;
  Valores : TValoresPorMac;
  PrestPaga : boolean;
  SeguroEstaPago : boolean;
  PrestacaoEstaPaga : boolean;
  PrestacaoPagaAntecipada : boolean;
begin
  // Se setar a "ConsideraPrstSoDeAcessorios", vai considerar se sobrou acessorios devido a uma antecipa  o
  // e estes acessorios est o em aberto(Imitar a l gica da TSerie.EstaPagaRpaS).  
  // ATEN  O:   utilizada a evolu  o no tcontrato, para verificar o valor dos acessorios!
  //          ent o   preciso estar evoluido pelo menos at  o mac pedido.

  {
    106876
    No caso de presta  es de carencia, n o vai haver um pagamento antecipado anterior e os acess rios
    devem ser testados de qualquer forma.
  }

  if Contrato.MutDsk.Financ.Status in StatusTermino then Result := true
  else begin
    if (juliano(Contrato.MutDsk.Financ.DtInFin) < juliano(Contrato.Mutdsk.Financ.DtAssin)) and
       ((Mes_Int(Contrato.MutDsk.Financ.DtInFin.MesAno)+1) < Mes_Int(Contrato.MutDsk.Financ.DtAssin.MesAno)) then begin
      DtInFin := Contrato.MutDsk.Financ.DtAssin;
      DecMA(DtInFin.MesAno);
    end else DtInFin := Contrato.MutDsk.Financ.DtInFin;
    DtInFin.Dia := Dia_Venc(Mes_Int(DtInFin.MesAno),Contrato.MutDsk.Financ.DtInFin.Dia);

    if (Mes_Int(DtInFin.MesAno)+1 = MAC) and
       (Contrato.MutDsk.Financ3.DiaVenc1aPrest in [1..31]) then
      DtInFin.Dia := Dia_Venc(MAC,Contrato.MutDsk.Financ3.DiaVenc1aPrest);

    if Mac <= Mes_Int(DtInFin.MesAno) then
      result := true
    else begin
      Parcela := Parcelas.ObtemParcelaPorMac(Mac);
      if assigned(parcela) then begin
        {
          106876
          Quero separar o teste da presta  o, do teste do acess rio.
          Por isso, eu n o vou mais considerar o acess rio apenas quando houver uma antecipa  o.
        }
        PrestPaga := Parcela.EstaPaga(DtRef);

        if PrestPaga or (ConsideraPrstSoDeAcessorios and Parcela.SeguroEstaPago(DtRef)) then begin
          try
            Valores := Contrato.SerieF.ObtemValoresPorMac(Mac);
          except
            on e : exception do begin
              raise exception.create('Erro ao obter a presta  o, na PrstPagaRPA.');
            end;
          end;  
{
    106876
    CORRE  O
    S  conferia se o acess rio foi pago, se o pagamento da presta  o fosse de antecipa  o(PgtoComRedSdDev).
    Agora estou conferindo para qualquer tipo de pagamento da presta  o.
    No caso de "012-Quita  o por Implantacao", passou a considerar o acess rio como em aberto,
    mas o cliente pagou exatamente o valor do acess rio, na implanta  o.
    Ex:
    EVOLU  O
    Data	      TipoParcela	            Pre/Prz	Presta  o	Valorpago 	Tipopagamento	DataPagamento	AmaisJ	Seguro	  Taxas
    20/Dez/2023	Financiamento Din mico	001/168	 128,72	  0,00	      &nbsp;	      &nbsp;	      0,00	  103,72	  25,00
    PAGAMENTOS
    Data	      Prest/Prz	S rie	            C digoS rie	DataPG.	    ValorPago	TipoPagamento	                  Observa  es
    20/Dez/2023	001/168	  Financ. Din mico	0	          20/Dez/2023	 128,72	  012-Quita  o por Implantacao  	Quita  o por Implantacao  

    Como solu  o, estou voltando ao requisito anterior: se a presta  o est  registrada como paga, considero que 
    os acess rios foram pagos, mesmo que no m s s  tenha acess rios.
}
          if {(Parcela.TipoPg in PgtoComRedSdDev) and} 
              Assigned(Valores) and 
              (Valores.TotalAcessorios > Zero) and 
              (Valores.Amaisj-Valores.Desc <= zero) then begin
{
  109971
    Para uma presta  o paga antecipadamente, estava retornando como true, sinalizando o que decidi na 106876 (acima) "se a presta  o est  
    registrada como paga, considero que os acess rios foram pagos, mesmo que no m s s  tenha acess rios", o que n o   verdade no caso de 
    antecipa  o, pois a presta  o antecipada, tem ainda acess rios a pagar(situa  o da 109971).
    Ent o estou alterando de novo esta l gica e fazendo isso com vari veis mais claras.
    Em geral, a presta  o est  paga se registrada como tal, tendo ou n o acess rios.
    Caso tenha sido uma antecipada, s  considero a presta  o paga, se os acess rios foram pagos especificamente.
}              
            SeguroEstaPago := ((Parcela.DtPgSeg.Dia > 0) and
                        (not (Parcela.TipoPgSeg in [8..9,66,74,108,110,114,117,95,121,200,253])) and
                        (Juliano(Parcela.DtPgSeg) <= juliano(DtRef)));
            PrestacaoEstaPaga := (PrestPaga and (Juliano(Parcela.DtPg) <= juliano(DtRef)));
            PrestacaoPagaAntecipada := Parcela.TipoPg in PgtoComRedSdDev;
            Result := PrestacaoEstaPaga;
{
  111312
  Quando a presta  o da car ncia(amaisj=0) tem acess rios(seguo+taxa>0) e tem pagamento normal,
  preciso considerar que os acess rios foram pagos, apesar do tipo de pagamento n o ser 
  compat vel, ou o usu rio ir  reclamar que a presta  o foi paga e o sistema n o acata o pagamento.
}            
            if PrestacaoPagaAntecipada or (Valores.AmaisJ <= zero) then
              result := SeguroEstaPago or PrestacaoEstaPaga;
          end            
          else // se for uma presta  o normal n o quero considerar tipopg65(acess rios) como pagamento de presta  o.
            Result := PrestPaga and (Parcela.TipoPg<>65);
        end
        else 
          result := PrestPaga;
      end  
      else
        result := false;
    end;
  end;
end;

